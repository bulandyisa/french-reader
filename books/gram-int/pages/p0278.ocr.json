5, 116, 117, 118]}, {"id": 22, "text": "70.", "words": [119]}, {"id": 23, "text": "Je suggère que nous un verre avant quitter.", "words": [120, 121, 122, 123, 124, 125, 126, 127]}, {"id": 24, "text": "m'a posé beaucoup questions et j'ai dit tout je savais.", "words": [128, 129, 130, 131, 132, 133, 134, 135, 136, 137]}, {"id": 25, "text": "72.", "words": [138]}, {"id": 26, "text": "Au cas où vous un problème, n'hésitez pas m'appeler.", "words": [139, 140, 141, 142, 143, 144, 145, 146, 147]}, {"id": 27, "text": "73.", "words": [148]}, {"id": 28, "text": "Je peur quand ma mère tombée dans l'escalier !", "words": [149, 150, 151, 152, 153, 154, 155, 156, 157]}, {"id": 29, "text": "74.", "words": [158]}, {"id": 30, "text": "Lily s'est mariée un an et elle un bébé il y a un mois.", "words": [159, 160, 161, 162, 163, 164, 165, 166, 167, 168, 169, 170, 171, 172]}, {"id": 31, "text": "75.S'il demain, nous à la piscine.", "words": [173, 174, 175, 176, 177, 178]}, {"id": 32, "text": "76.", "words": [179]}, {"id": 33, "text": "J'espère qu'il beau demain, mais j'ai peur qu'il froid.", "words": [180, 181, 182, 183, 184, 185, 186, 187, 188]}, {"id": 34, "text": "77.", "words": [189]}, {"id": 35, "text": "Pour que les enfants en forme, il faut qu'ils du sport.", "words": [190, 191, 192, 193, 194, 195, 196, 197, 198, 199, 200]}, {"id": 36, "text": "78.", "words": [201]}, {"id": 37, "text": "Je vais te raconter s'est passé à la réunion d'hier, tu n'es pas venu !", "words": [202, 203, 204, 205, 206, 207, 208, 209, 210, 211, 212, 213, 214, 215, 216]}, {"id": 38, "text": "79.", "words": [217]}, {"id": 39, "text": "Pour qu'un homme beau, il faut qu'il de la personnalité.", "words": [218, 219, 220, 221, 222, 223, 224, 225, 226, 227]}, {"id": 40, "text": "80.", "words": [228]}, {"id": 41, "text": "Si j'avais su que le film était si mauvais, je", "words": [229, 230, 231, 232, 233, 234, 235, 236, 237, 238]}, {"id": 42, "text": "voir !", "words": [239, 240]}, {"id": 43, "text": "276 e deux cent soixante-seize", "words": [241, 242, 243, 244, 245]}]}