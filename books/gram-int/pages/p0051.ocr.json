, 3]}, {"id": 1, "text": "La photocopie non autorisée est un délit.", "words": [4, 5, 6, 7, 8, 9, 10]}, {"id": 2, "text": "LE VERBE « AVOIR »", "words": [11, 12, 13, 14, 15]}, {"id": 3, "text": "Répondez aux questions, selon le modèle.", "words": [16, 17, 18, 19, 20, 21]}, {"id": 4, "text": "Sondage : le logement", "words": [22, 23, 24, 25]}, {"id": 5, "text": "Vous avez un appartement ou une maison ?", "words": [26, 27, 28, 29, 30, 31, 32, 33]}, {"id": 6, "text": "- J'ai un appartement.", "words": [34, 35, 36, 37]}, {"id": 7, "text": "Vous avez une, deux ou trois chambres ?", "words": [38, 39, 40, 41, 42, 43, 44, 45]}, {"id": 8, "text": "Vous avez des meubles anciens ou modernes?", "words": [46, 47, 48, 49, 50, 51, 52]}, {"id": 9, "text": "Vous avez un grand ou un petit salon ?", "words": [53, 54, 55, 56, 57, 58, 59, 60, 61]}, {"id": 10, "text": "Vous avez un chauffage électrique ou au gaz?", "words": [62, 63, 64, 65, 66, 67, 68, 69]}, {"id": 11, "text": "Vous avez des voisins calmes ou bruyants ?", "words": [70, 71, 72, 73, 74, 75, 76, 77]}, {"id": 12, "text": "Complétez les phrases avec « avoir », les pronoms sujets et les articles manquants.", "words": [78, 79, 80, 81, 82, 83, 84, 85, 86, 87, 88, 89, 90, 91]}, {"id": 13, "text": "1.", "words": [92]}, {"id": 14, "text": "Vous avez un stylo bleu?", "words": [93, 94, 95, 96, 97]}, {"id": 15, "text": "- Non, ai un stylo noir.", "words": [98, 99, 100, 101, 102, 103]}, {"id": 16, "text": "2.", "words": [104]}, {"id": 17, "text": "Cathy Yamaha.", "words": [105, 106]}, {"id": 18, "text": "- 3.", "words": [107, 108]}, {"id": 19, "text": "Les chienet 4.", "words": [109, 110, 111]}, {"id": 20, "text": "Paul et toi, diplômes ?", "words": [112, 113, 114, 115, 116]}, {"id": 21, "text": "- Oui, tous les deux licence d'histoire.", "words": [117, 118, 119, 120, 121, 122, 123]}, {"id": 22, "text": "Complétez avec les verbes ci-dessous.", "words": [124, 125, 126, 127, 128]}, {"id": 23, "text": "ED Complétez les dialogues.", "words": [129, 130, 131, 132]}, {"id": 24, "text": "1.", "words": [133]}, {"id": 25, "text": "- Vous avez besoin d'un café ?", "words": [134, 135, 136, 137, 138, 139, 140]}, {"id": 26, "text": "- Oui, j'ai besoin d'un café!", "words": [141, 142, 143, 144, 145, 146]}, {"id": 27, "text": "Pas vous ?", "words": [147, 148, 149]}, {"id": 28, "text": "1.", "words": [150]}, {"id": 29, "text": "Il'est tard, le bébé est fatigué : il 4 sommeil.", "words": [151, 152, 153, 154, 155, 156, 157, 158, 159, 160]}, {"id": 30, "text": "2.", "words": [161]}, {"id": 31, "text": "- Vous avez envie d'une glace ?", "words": [162, 163, 164, 165, 166, 167, 168]}, {"id": 32, "text": "2.", "words": [169]}, {"id": 33, "text": "Ilest midi : nous 3.", "words": [170, 171, 172, 173, 174]}, {"id": 34, "text": "Mon chien n'est pas courageux : il dessouris!", "words": [175, 176, 177, 178, 179, 180, 181, 182]}, {"id": 35, "text": "3, - Vous avez peur des serpents?", "words": [183, 184, 185, 186, 187, 188, 189]}, {"id": 36, "text": "4.", "words": [190]}, {"id": 37, "text": "Mon mari est chez le kiné : audos.", "words": [191, 192, 193, 194, 195, 196, 197, 198]}, {"id": 38, "text": "Posez des questions oralement avec « avoir besoin de », selon le modèle.", "words": [199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210, 211]}, {"id": 39, "text": "voyager en Europe écrire en français rester en forme travailler en France visa dictionnaire faire du sport parler français", "words": [212, 213, 214, 215, 216, 217, 218, 219, 220, 221, 222, 223, 224, 225, 226, 227, 228, 229, 230]}, {"id": 40, "text": "— Pour voyager en Europe, vous avez besoin d'un visa ?", "words": [231, 232, 233, 234, 235, 236, 237, 238, 239, 240, 241]}, {"id": 41, "text": "D> Faites des phrases oralement avec « avoir envie de ».", "words": [242, 243, 244, 245, 246, 247, 248, 249, 250, 251, 252]}, {"id": 42, "text": "Continuez librement.", "words": [253, 254]}, {"id": 43, "text": "thé/café/glace - manger au restaurant/chez sa mère/au McDo -lire/dormir/sortir - un chien/un chat/un lapin - Jai envie d'un thé.", "words": [255, 256, 257, 258, 259, 260, 261, 262, 263, 264, 265, 266, 267, 268, 269, 270, 271, 272, 273]}, {"id": 44, "text": "Mon mari a envie d'un café.", "words": [274, 275, 276, 277, 278, 279]}, {"id": 45, "text": "Les enfants > Exprimez vos envies et vos peurs, en vous inspirant des exemples.", "words": [280, 281, 282, 283, 284, 285, 286, 287, 288, 289, 290, 291, 292, 293]}, {"id": 46, "text": "envies : vacances au bord de la mer/nouvelle voiture/animal domestique/appartement plus grand peurs : chômage/krach boursier/futur /solitude/insectes/chiens/obscurité", "words": [294, 295, 296, 297, 298, 299, 300, 301, 302, 303, 304, 305, 306, 307, 308, 309, 310]}]}