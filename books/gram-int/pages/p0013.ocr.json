65, 66, 67, 68]}, {"id": 13, "text": "manquants.", "words": [69]}, {"id": 14, "text": "1.", "words": [70]}, {"id": 15, "text": "- Le professeur est là?", "words": [71, 72, 73, 74, 75]}, {"id": 16, "text": "- Oui, il est là.", "words": [76, 77, 78, 79, 80]}, {"id": 17, "text": "2.", "words": [81]}, {"id": 18, "text": "- La salle _ grande?- 3.", "words": [82, 83, 84, 85, 86, 87]}, {"id": 19, "text": "- Les chaises en bois?", "words": [88, 89, 90, 91, 92]}, {"id": 20, "text": "- 4.", "words": [93, 94]}, {"id": 21, "text": "- Votre livre bleu?", "words": [95, 96, 97, 98]}, {"id": 22, "text": "- 5.", "words": [99, 100]}, {"id": 23, "text": "- Nous mardi ?", "words": [101, 102, 103, 104]}, {"id": 24, "text": "- 6.", "words": [105, 106]}, {"id": 25, "text": "- On ___le4?- 7.", "words": [107, 108, 109, 110]}, {"id": 26, "text": "-Les étudiants en forme ?", "words": [111, 112, 113, 114, 115]}, {"id": 27, "text": "-", "words": [116]}, {"id": 28, "text": "Répondez aux questions à partir du texte.", "words": [117, 118, 119, 120, 121, 122, 123]}, {"id": 29, "text": "Informations", "words": [124]}, {"id": 30, "text": "Vous espagnols!", "words": [125, 126]}, {"id": 31, "text": "De quelle ville ?", "words": [127, 128, 129, 130]}, {"id": 32, "text": "Nous de Séville.", "words": [131, 132, 133]}, {"id": 33, "text": "Mes parents aussi espagnols, mais", "words": [134, 135, 136, 137, 138]}, {"id": 34, "text": "de Barcelone.", "words": [139, 140]}, {"id": 35, "text": "4.", "words": [141]}, {"id": 36, "text": "mon chéri?", "words": [142, 143]}, {"id": 37, "text": "prêts, les enfants ?", "words": [144, 145, 146, 147]}, {"id": 38, "text": "de Prague, madame ?", "words": [148, 149, 150, 151]}, {"id": 39, "text": "D Complétez avec « nous sommes » ou «on est » (plusieurs possibilités).", "words": [152, 153, 154, 155, 156, 157, 158, 159, 160, 161, 162, 163, 164]}, {"id": 40, "text": "Chère Marie, Cannes, le 15/09/12.", "words": [165, 166, 167, 168, 169]}, {"id": 41, "text": "Jean et moi, à Cannes.", "words": [170, 171, 172, 173, 174]}, {"id": 42, "text": "Depuis 10 heures, sur la plage.", "words": [175, 176, 177, 178, 179, 180]}, {"id": 43, "text": "Comme bien au soleil!", "words": [181, 182, 183, 184]}, {"id": 44, "text": "en pleine forme.", "words": [185, 186, 187]}, {"id": 45, "text": "Mais c'est normal : quand en vacances,", "words": [188, 189, 190, 191, 192, 193, 194]}, {"id": 46, "text": "toujours en forme!", "words": [195, 196, 197]}, {"id": 47, "text": "À bientôt.", "words": [198, 199]}, {"id": 48, "text": "Grosses bises!", "words": [200, 201]}, {"id": 49, "text": "Léa", "words": [202]}, {"id": 50, "text": "© CLE International 2017.", "words": [203, 204, 205, 206]}, {"id": 51, "text": "La photocopie non autorisée est un délit.", "words": [207, 208, 209, 210, 211, 212, 213]}, {"id": 52, "text": "- Allô ?", "words": [214, 215, 216]}, {"id": 53, "text": "Danièle ?", "words": [217, 218]}, {"id": 54, "text": "C'est Martine.", "words": [219, 220]}, {"id": 55, "text": "Je suis à Paris avec Jean et nos trois filles.", "words": [221, 222, 223, 224, 225, 226, 227, 228, 229, 230]}, {"id": 56, "text": "Nous sommes à l'hôtel Saint-Michel.", "words": [231, 232, 233, 234, 235]}, {"id": 57, "text": "Tu es libre aujourd'hui ?", "words": [236, 237, 238, 239, 240]}, {"id": 58, "text": "- Non!", "words": [241, 242]}, {"id": 59, "text": "Quel dommage, je suis occupée toute la journée.", "words": [243, 244, 245, 246, 247, 248, 249, 250]}, {"id": 60, "text": "Je suis à Versailles, chez un client.", "words": [251, 252, 253, 254, 255, 256, 257]}, {"id": 61, "text": "Vous êtes à Paris pour combien de temps ?", "words": [258, 259, 260, 261, 262, 263, 264, 265, 266]}, {"id": 62, "text": "- Nous sommes ici pour une semaine.", "words": [267, 268, 269, 270, 271, 272, 273]}, {"id": 63, "text": "Les filles sont en vacances : leur lycée est fermé pour travaux.", "words": [274, 275, 276, 277, 278, 279, 280, 281, 282, 283, 284, 285]}, {"id": 64, "text": "1.", "words": [286]}, {"id": 65, "text": "- Martine et Jean sont à Aix ?", "words": [287, 288, 289, 290, 291, 292, 293, 294]}, {"id": 66, "text": "—", "words": [295]}, {"id": 67, "text": "2.", "words": [296]}, {"id": 68, "text": "- Danièle est libre ou occupée aujourd'hui ?", "words": [297, 298, 299, 300, 301, 302, 303, 304]}, {"id": 69, "text": "- 3.", "words": [305, 306]}, {"id": 70, "text": "- Martine et Jean sont chez des amis?", "words": [307, 308, 309, 310, 311, 312, 313, 314]}, {"id": 71, "text": "-", "words": [315]}, {"id": 72, "text": "4.", "words": [316]}, {"id": 73, "text": "- Danièle est à Paris aujourd'hui ?", "words": [317, 318, 319, 320, 321, 322, 323]}, {"id": 74, "text": "-", "words": [324]}, {"id": 75, "text": "5.", "words": [325]}, {"id": 76, "text": "— Les filles sont au lycée ou en vacances ?", "words": [326, 327, 328, 329, 330, 331, 332, 333, 334, 335]}, {"id": 77, "text": "-", "words": [336]}, {"id": 78, "text": "onze e", "words": [337, 338]}]}