86, 87]}, {"id": 16, "text": "7.", "words": [88]}, {"id": 17, "text": "Tous les soirs, nous regardons le journal télévisé et nous parlons de politique.", "words": [89, 90, 91, 92, 93, 94, 95, 96, 97, 98, 99, 100, 101]}, {"id": 18, "text": "8.", "words": [102]}, {"id": 19, "text": "Tous les mercredis, Daniel et Mina préparent un plat exotique et invitent des amis.", "words": [103, 104, 105, 106, 107, 108, 109, 110, 111, 112, 113, 114, 115, 116]}, {"id": 20, "text": "ED Trouvez les verbes manquants.", "words": [117, 118, 119, 120, 121]}, {"id": 21, "text": "Faites l'élision, si c'est nécessaire.", "words": [122, 123, 124, 125, 126]}, {"id": 22, "text": "1.", "words": [127]}, {"id": 23, "text": "Hier matin, écouté la radio.", "words": [128, 129, 130, 131, 132]}, {"id": 24, "text": "6.", "words": [133]}, {"id": 25, "text": "Hier, tu la télévision ?", "words": [134, 135, 136, 137, 138]}, {"id": 26, "text": "2.", "words": [139]}, {"id": 27, "text": "À midi, vous un sandwich ?", "words": [140, 141, 142, 143, 144, 145]}, {"id": 28, "text": "7.", "words": [146]}, {"id": 29, "text": "Mardi dernier, nous aux échecs.", "words": [147, 148, 149, 150, 151]}, {"id": 30, "text": "3.", "words": [152]}, {"id": 31, "text": "La semaine dernière, je mes impôts.", "words": [153, 154, 155, 156, 157, 158]}, {"id": 32, "text": "8.", "words": [159]}, {"id": 33, "text": "Hier soir, on de la musique.", "words": [160, 161, 162, 163, 164, 165]}, {"id": 34, "text": "4.", "words": [166]}, {"id": 35, "text": "Avant-hier, mes amis le Louvre.", "words": [167, 168, 169, 170, 171]}, {"id": 36, "text": "9.", "words": [172]}, {"id": 37, "text": "Pour ma fête, je des amis.", "words": [173, 174, 175, 176, 177, 178]}, {"id": 38, "text": "5.", "words": [179]}, {"id": 39, "text": "Paul 1 000 € au Loto.", "words": [180, 181, 182, 183, 184, 185]}, {"id": 40, "text": "10.", "words": [186]}, {"id": 41, "text": "TU des légumes au marché ?", "words": [187, 188, 189, 190, 191, 192]}, {"id": 42, "text": ">» Faites des phrases au passé composé en donnant des précisions (quoi, où, quand, qui, etc.).", "words": [193, 194, 195, 196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208]}, {"id": 43, "text": "déjeurner/manger acheter/payer jouer/gagner inviter/parler commencer/terminer déjeuner/diner rencontrer/parler écouter/télécharger", "words": [209, 210, 211, 212, 213, 214, 215, 216]}, {"id": 44, "text": "Hier, j'ai déjeuné chez moi et j'ai mangé des pâtes.", "words": [217, 218, 219, 220, 221, 222, 223, 224, 225, 226]}, {"id": 45, "text": "176 + cent soixante-seize", "words": [227, 228, 229, 230]}]}