": "LES RELATIONS LOGIQUES", "words": [11, 12, 13]}, {"id": 3, "text": "@D «Parce que ».", "words": [14, 15, 16, 17]}, {"id": 4, "text": "Donnez la cause.", "words": [18, 19, 20]}, {"id": 5, "text": "être-matade être en panne faire la grève avoir faim", "words": [21, 22, 23, 24, 25, 26, 27, 28, 29]}, {"id": 6, "text": "1.", "words": [30]}, {"id": 7, "text": "- Jean est absent.", "words": [31, 32, 33, 34]}, {"id": 8, "text": "Pourquoi ?", "words": [35, 36]}, {"id": 9, "text": "- est absent parce qu'il est malade.", "words": [37, 38, 39, 40, 41, 42, 43]}, {"id": 10, "text": "2.", "words": [44]}, {"id": 11, "text": "- Le bébé pleure.", "words": [45, 46, 47, 48]}, {"id": 12, "text": "Pourquoi ?", "words": [49, 50]}, {"id": 13, "text": "-", "words": [51]}, {"id": 14, "text": "3.", "words": [52]}, {"id": 15, "text": "- Marie est triste.", "words": [53, 54, 55, 56]}, {"id": 16, "text": "Pourquoi ?", "words": [57, 58]}, {"id": 17, "text": "-", "words": [59]}, {"id": 18, "text": "4.", "words": [60]}, {"id": 19, "text": "- Les employés ne sont pas là.", "words": [61, 62, 63, 64, 65, 66, 67]}, {"id": 20, "text": "Pourquoi ?", "words": [68, 69]}, {"id": 21, "text": "-", "words": [70]}, {"id": 22, "text": "5.", "words": [71]}, {"id": 23, "text": "- L'ascenseur ne descend pas.", "words": [72, 73, 74, 75, 76]}, {"id": 24, "text": "Pourquoi ?", "words": [77, 78]}, {"id": 25, "text": "-", "words": [79]}, {"id": 26, "text": "utilisez « comme » ou « parce que ».", "words": [80, 81, 82, 83, 84, 85, 86, 87, 88]}, {"id": 27, "text": "Samedi soir", "words": [89, 90]}, {"id": 28, "text": "Je n'ai pas pu t'appeler, parce que j'avais perdu retard.", "words": [91, 92, 93, 94, 95, 96, 97, 98, 99, 100]}, {"id": 29, "text": "il y avait beaucoup de monde à ton numéro.", "words": [101, 102, 103, 104, 105, 106, 107, 108, 109]}, {"id": 30, "text": "il y a beaucoup de la station, j'ai attendu longtemps.", "words": [110, 111, 112, 113, 114, 115, 116, 117, 118, 119]}, {"id": 31, "text": "« Duval » dans l'annuaire, j'ai cherché longtemps.", "words": [120, 121, 122, 123, 124, 125, 126, 127]}, {"id": 32, "text": "le magasin de fleurs était fermé,", "words": [128, 129, 130, 131, 132, 133]}, {"id": 33, "text": "J'ai pris un taxi en je t'ai apporté des bonbons.", "words": [134, 135, 136, 137, 138, 139, 140, 141, 142, 143]}, {"id": 34, "text": "« Puisque ».", "words": [144, 145, 146]}, {"id": 35, "text": "Imaginez un dialogue.", "words": [147, 148, 149]}, {"id": 36, "text": "ED « Comme », « parce que » ou « puisque » ?", "words": [150, 151, 152, 153, 154, 155, 156, 157, 158, 159, 160, 161, 162]}, {"id": 37, "text": "1.", "words": [163]}, {"id": 38, "text": "Puisqu'il pleut, restons à la maison !", "words": [164, 165, 166, 167, 168, 169, 170]}, {"id": 39, "text": "1.", "words": [171]}, {"id": 40, "text": "- Je me dépêche je suis en retard.", "words": [172, 173, 174, 175, 176, 177, 178, 179]}, {"id": 41, "text": "2.", "words": [180]}, {"id": 42, "text": "- J'ai mal à la tête.", "words": [181, 182, 183, 184, 185, 186]}, {"id": 43, "text": "- 2.", "words": [187, 188]}, {"id": 44, "text": "- j'étais pressé, j'ai pris un taxi.", "words": [189, 190, 191, 192, 193, 194, 195]}, {"id": 45, "text": "3.", "words": [196]}, {"id": 46, "text": "- Le frigo est vide.", "words": [197, 198, 199, 200, 201]}, {"id": 47, "text": "- 3.", "words": [202, 203]}, {"id": 48, "text": "tu savais, pourquoi n'as-tu rien dit ?", "words": [204, 205, 206, 207, 208, 209, 210]}, {"id": 49, "text": "4.", "words": [211]}, {"id": 50, "text": "- Je sors.", "words": [212, 213, 214]}, {"id": 51, "text": "- 4, - Pars, tune m'aimes plus !", "words": [215, 216, 217, 218, 219, 220, 221, 222]}, {"id": 52, "text": "complétez avec « parce que », « comme », « puisque », « grâce à » et « à cause de ».", "words": [223, 224, 225, 226, 227, 228, 229, 230, 231, 232, 233, 234, 235, 236, 237, 238, 239, 240, 241, 242, 243, 244]}, {"id": 53, "text": "Hold-up", "words": [245]}, {"id": 54, "text": "Hier, il y a eu de l'agitation dans mon quartier la banque a été attaquée.", "words": [246, 247, 248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259, 260]}, {"id": 55, "text": "a en pleine journée, il y avait beaucoup de monde.", "words": [261, 262, 263, 264, 265, 266, 267, 268, 269, 270]}, {"id": 56, "text": "Le caissier a appelé la police alarme dissimulée sous son bureau.", "words": [271, 272, 273, 274, 275, 276, 277, 278, 279, 280, 281]}, {"id": 57, "text": "Mais la police est arrivée en retard Le", "words": [282, 283, 284, 285, 286, 287, 288, 289]}, {"id": 58, "text": "gangster a pu s'échapper, à la complicité d'une femme.", "words": [290, 291, 292, 293, 294, 295, 296, 297, 298]}, {"id": 59, "text": "le hold-up est tout à fait dans son style, la police a soupçonné tout de suite Pierrot Ferdinand.", "words": [299, 300, 301, 302, 303, 304, 305, 306, 307, 308, 309, 310, 311, 312, 313, 314, 315, 316]}, {"id": 60, "text": "Mais ce n'est sûrement pas lui, ilest déjà en prison!", "words": [317, 318, 319, 320, 321, 322, 323, 324, 325, 326]}, {"id": 61, "text": ">» Créez des publicités avec « à cause de » et « grâce à » à partir du modèle.", "words": [327, 328, 329, 330, 331, 332, 333, 334, 335, 336, 337, 338, 339, 340, 341, 342, 343, 344, 345]}, {"id": 62, "text": "1.", "words": [346]}, {"id": 63, "text": "Vos chaussures sont abimées à cause de la pluie.", "words": [347, 348, 349, 350, 351, 352, 353, 354, 355]}, {"id": 64, "text": "Grâce à « Souplor », elles retrouveront leur souplesse.", "words": [356, 357, 358, 359, 360, 361, 362, 363, 364]}, {"id": 65, "text": "2.", "words": [365]}, {"id": 66, "text": "Votre peau est sèche 3.", "words": [366, 367, 368, 369, 370]}, {"id": 67, "text": "Vous dormez mal bruit.", "words": [371, 372, 373, 374]}, {"id": 68, "text": "deux cent cinquante et un + 251", "words": [375, 376, 377, 378, 379, 380, 381]}]}