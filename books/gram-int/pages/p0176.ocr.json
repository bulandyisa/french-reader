9, 50, 51]}, {"id": 7, "text": "il", "words": [52]}, {"id": 8, "text": "elle à midi et demi.", "words": [53, 54, 55, 56, 57]}, {"id": 9, "text": "on nous ensemble.", "words": [58, 59, 60]}, {"id": 10, "text": "vous tard.", "words": [61, 62]}, {"id": 11, "text": "ils |", "words": [63, 64]}, {"id": 12, "text": "avec des amis.", "words": [65, 66, 67]}, {"id": 13, "text": "elles", "words": [68]}, {"id": 14, "text": "M Verbes en « -er » : le participe passé se forme sur le radical de + « 6 ».", "words": [69, 70, 71, 72, 73, 74, 75, 76, 77, 78, 79, 80, 81, 82, 83, 84, 85, 86, 87, 88]}, {"id": 15, "text": "Mang-er J'ai mangé Regard-er J'ai regard-é", "words": [89, 90, 91, 92, 93, 94]}, {"id": 16, "text": "+ Le participe passé ne s'accorde pas avec le sujet du verbe « avoir » :", "words": [95, 96, 97, 98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110]}, {"id": 17, "text": "Il a mangé un gâteau.", "words": [111, 112, 113, 114, 115]}, {"id": 18, "text": "Ils ont mangé un gâteau.", "words": [116, 117, 118, 119, 120]}, {"id": 19, "text": "M Le passé composé de la majorité des verbes se forme avec « avoir » : J'ai mangé.", "words": [121, 122, 123, 124, 125, 126, 127, 128, 129, 130, 131, 132, 133, 134, 135, 136, 137, 138]}, {"id": 20, "text": "J'ai bu.", "words": [139, 140]}, {"id": 21, "text": "J'ai dormi.", "words": [141, 142]}, {"id": 22, "text": "+ Le passé composé de « être » et « avoir » se forme aussi avec « avoir »: J'ai été malade.", "words": [143, 144, 145, 146, 147, 148, 149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159, 160, 161, 162, 163, 164]}, {"id": 23, "text": "J'ai eu mal à la gorge.", "words": [165, 166, 167, 168, 169, 170]}, {"id": 24, "text": "QUELQUES EXPRESSIONS de TEMPS", "words": [171, 172, 173, 174]}, {"id": 25, "text": "présent: Aujourd'hui Cette semaine Ce mois-ci Cette année passé: Hier La semaine dernière Le mois dernier L'année dernière", "words": [175, 176, 177, 178, 179, 180, 181, 182, 183, 184, 185, 186, 187, 188, 189, 190, 191, 192]}, {"id": 26, "text": "Tableau des participes passés, p.", "words": [193, 194, 195, 196, 197]}, {"id": 27, "text": "178", "words": [198]}, {"id": 28, "text": "174 e cent soixante-quatorze", "words": [199, 200, 201, 202]}]}