 53]}, {"id": 8, "text": "- Oui, 3.", "words": [54, 55, 56]}, {"id": 9, "text": "- Vous restez deux mois à Paris, Lucas ?", "words": [57, 58, 59, 60, 61, 62, 63, 64, 65]}, {"id": 10, "text": "- Oui,", "words": [66, 67]}, {"id": 11, "text": ".", "words": [68]}, {"id": 12, "text": "- Vous jouez aux échecs, Antoine ?", "words": [69, 70, 71, 72, 73, 74, 75]}, {"id": 13, "text": "- Oui, .", "words": [76, 77, 78]}, {"id": 14, "text": "- Vous fumez beaucoup, Zoé?", "words": [79, 80, 81, 82, 83]}, {"id": 15, "text": "- Oui,", "words": [84, 85]}, {"id": 16, "text": "5 6.", "words": [86, 87]}, {"id": 17, "text": "- Vous étudiez le chinois, John ?", "words": [88, 89, 90, 91, 92, 93, 94]}, {"id": 18, "text": "- Oui, 7.", "words": [95, 96, 97]}, {"id": 19, "text": "- Vous parlez italien, Emma ?", "words": [98, 99, 100, 101, 102, 103]}, {"id": 20, "text": "- Oui,", "words": [104, 105]}, {"id": 21, "text": "8", "words": [106]}, {"id": 22, "text": ".", "words": [107]}, {"id": 23, "text": "- Vous recopiez vos notes, Caroline ?", "words": [108, 109, 110, 111, 112, 113, 114]}, {"id": 24, "text": "- Oui,", "words": [115, 116]}, {"id": 25, "text": "Ajoutez les terminaisons manquantes.", "words": [117, 118, 119, 120]}, {"id": 26, "text": "1.", "words": [121]}, {"id": 27, "text": "- Je rarement la télévision; je écouter la radio.", "words": [122, 123, 124, 125, 126, 127, 128, 129, 130]}, {"id": 28, "text": "2.", "words": [131]}, {"id": 29, "text": "- Mes enfants jouer au tennis et parfois ils tout le week-end.", "words": [132, 133, 134, 135, 136, 137, 138, 139, 140, 141, 142, 143]}, {"id": 30, "text": "3.", "words": [144]}, {"id": 31, "text": "- Tu beaucoup trop et tu ne pas assez.", "words": [145, 146, 147, 148, 149, 150, 151, 152, 153]}, {"id": 32, "text": "4.", "words": [154]}, {"id": 33, "text": "- Les voisins fort et ils beaucoup.", "words": [155, 156, 157, 158, 159, 160, 161]}, {"id": 34, "text": "5.", "words": [162]}, {"id": 35, "text": "— À midi, nous souvent à la cantine et nous entre amis.", "words": [163, 164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174]}, {"id": 36, "text": "6.", "words": [175]}, {"id": 37, "text": "- Mon mari le cigare et moi, je des cigarillos.", "words": [176, 177, 178, 179, 180, 181, 182, 183, 184, 185]}, {"id": 38, "text": "7.", "words": [186]}, {"id": 39, "text": "- Tu les petites annonces?", "words": [187, 188, 189, 190, 191]}, {"id": 40, "text": "Tu un appartement?", "words": [192, 193, 194]}, {"id": 41, "text": "8.", "words": [195]}, {"id": 42, "text": "— Je avec des amis français et ils me quand je mal.", "words": [196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207]}, {"id": 43, "text": "9.", "words": [208]}, {"id": 44, "text": "— Vous vos vacances à Moscou ou vous à Paris?", "words": [209, 210, 211, 212, 213, 214, 215, 216, 217, 218]}, {"id": 45, "text": "10.", "words": [219]}, {"id": 46, "text": "- Nous la règle de grammaire et nous les exercices.", "words": [220, 221, 222, 223, 224, 225, 226, 227, 228, 229]}, {"id": 47, "text": "ED Répondez librement aux questions.", "words": [230, 231, 232, 233, 234]}, {"id": 48, "text": "Vie quotidienne", "words": [235, 236]}, {"id": 49, "text": "Où habitez-vous actuellement ?", "words": [237, 238, 239, 240]}, {"id": 50, "text": "Vous travaillez ou vous étudiez ?", "words": [241, 242, 243, 244, 245, 246]}, {"id": 51, "text": "— Quelle langue parlez-vous en classe ?", "words": [247, 248, 249, 250, 251, 252, 253]}, {"id": 52, "text": "— Quel journal achetez-vous, le plus souvent ?", "words": [254, 255, 256, 257, 258, 259, 260, 261]}, {"id": 53, "text": "— Où passez-vous vos vacances habituellement ?", "words": [262, 263, 264, 265, 266, 267, 268]}, {"id": 54, "text": "— En général, où dinez-vous le soir ?", "words": [269, 270, 271, 272, 273, 274, 275, 276]}, {"id": 55, "text": "— Où déjeunez-vous à midi ?", "words": [277, 278, 279, 280, 281, 282]}, {"id": 56, "text": "Vous étudiez des langues étrangères ?", "words": [283, 284, 285, 286, 287, 288]}, {"id": 57, "text": "78 + soixante-dix-huit", "words": [289, 290, 291]}]}