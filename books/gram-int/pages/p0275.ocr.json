, 87, 88, 89, 90, 91]}, {"id": 18, "text": ".", "words": [92]}, {"id": 19, "text": "Les dossiers sont sur bureau du directeur.", "words": [93, 94, 95, 96, 97, 98, 99]}, {"id": 20, "text": ".", "words": [100]}, {"id": 21, "text": "C'est l'hiver et froid.", "words": [101, 102, 103, 104]}, {"id": 22, "text": ".", "words": [105]}, {"id": 23, "text": "Souvent le soir, nous de la soupe avec de la salade.", "words": [106, 107, 108, 109, 110, 111, 112, 113, 114, 115, 116]}, {"id": 24, "text": ".", "words": [117]}, {"id": 25, "text": "- Vous vous levez tôt le matin ?", "words": [118, 119, 120, 121, 122, 123, 124, 125]}, {"id": 26, "text": "- Oui, trèstôt.", "words": [126, 127, 128]}, {"id": 27, "text": "10.- Qu'est-ce que vous au petit déjeuner ?", "words": [129, 130, 131, 132, 133, 134, 135, 136]}, {"id": 28, "text": "- Du café.", "words": [137, 138, 139]}, {"id": 29, "text": "11.- est votre profession ?", "words": [140, 141, 142, 143, 144]}, {"id": 30, "text": "- Je suis médecin.", "words": [145, 146, 147, 148]}, {"id": 31, "text": "12.", "words": [149]}, {"id": 32, "text": "Tous les hommes manger pour vivre.", "words": [150, 151, 152, 153, 154, 155]}, {"id": 33, "text": "13.", "words": [156]}, {"id": 34, "text": "Aujourd'hui, il y a vent, c'est désagréable.", "words": [157, 158, 159, 160, 161, 162, 163]}, {"id": 35, "text": "14.- Vous dînez tard le soir ?", "words": [164, 165, 166, 167, 168, 169, 170]}, {"id": 36, "text": "- Non, on vers 20 heures.", "words": [171, 172, 173, 174, 175, 176]}, {"id": 37, "text": "15.", "words": [177]}, {"id": 38, "text": "J'habite vingt ans dans le même quartier.", "words": [178, 179, 180, 181, 182, 183, 184]}, {"id": 39, "text": "16.", "words": [185]}, {"id": 40, "text": "Bientôt, il va chaud.", "words": [186, 187, 188, 189]}, {"id": 41, "text": "C'est l'été.", "words": [190, 191]}, {"id": 42, "text": "17.", "words": [192]}, {"id": 43, "text": "Hier, les enfants la télévision pendant deux heures.", "words": [193, 194, 195, 196, 197, 198, 199, 200]}, {"id": 44, "text": "18.- Si vous aux dents, allez vite chez le dentiste.", "words": [201, 202, 203, 204, 205, 206, 207, 208, 209, 210]}, {"id": 45, "text": "19.", "words": [211]}, {"id": 46, "text": "Ce matin, Pierre levé très tôt.", "words": [212, 213, 214, 215, 216, 217]}, {"id": 47, "text": "20.- Excusez-moi, je suis pressé : je partir !", "words": [218, 219, 220, 221, 222, 223, 224, 225, 226]}, {"id": 48, "text": "deux cent soixante-treize + 273", "words": [227, 228, 229, 230, 231]}]}