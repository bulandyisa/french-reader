8, 59, 60]}, {"id": 10, "text": "2.", "words": [61]}, {"id": 11, "text": "« Sophie ?", "words": [62, 63, 64]}, {"id": 12, "text": "C'est Charlie !", "words": [65, 66, 67]}, {"id": 13, "text": "Tu es libre pour le déjeuner ?", "words": [68, 69, 70, 71, 72, 73, 74]}, {"id": 14, "text": "Qu'est-ce que tu fais cet après-midi ?", "words": [75, 76, 77, 78, 79, 80, 81]}, {"id": 15, "text": "» - Que demande Charlie à Sophie ?", "words": [82, 83, 84, 85, 86, 87, 88, 89]}, {"id": 16, "text": "-", "words": [90]}, {"id": 17, "text": "3.", "words": [91]}, {"id": 18, "text": "« Mademoiselle Juliard, avez-vous une liste des hôtels du quartier ?", "words": [92, 93, 94, 95, 96, 97, 98, 99, 100, 101, 102]}, {"id": 19, "text": "Où se trouve Le Bristol ?", "words": [103, 104, 105, 106, 107, 108]}, {"id": 20, "text": "Combien coûte une chambre double ?", "words": [109, 110, 111, 112, 113, 114]}, {"id": 21, "text": "Notez toutes ces informations, s'il vous plaît.", "words": [115, 116, 117, 118, 119, 120, 121]}, {"id": 22, "text": "» - Que demande le directeur à sa secrétaire ?", "words": [122, 123, 124, 125, 126, 127, 128, 129, 130, 131]}, {"id": 23, "text": "-", "words": [132]}, {"id": 24, "text": "ED Le facteur est à l'interphone, Mme Dubois est sourde.", "words": [133, 134, 135, 136, 137, 138, 139, 140, 141, 142]}, {"id": 25, "text": "Elle pose des questions.", "words": [143, 144, 145, 146]}, {"id": 26, "text": "Sa fille explique.", "words": [147, 148, 149]}, {"id": 27, "text": "C'est le facteur !", "words": [150, 151, 152, 153]}, {"id": 28, "text": "J'ai un paquet.", "words": [154, 155, 156]}, {"id": 29, "text": "| facteur.", "words": [157, 158]}, {"id": 30, "text": "dit qu' Je n'ai pas le code.", "words": [159, 160, 161, 162, 163, 164, 165]}, {"id": 31, "text": "Qu'est-ce =) qu'il dit ?", "words": [166, 167, 168, 169, 170]}, {"id": 32, "text": "Vous pouvez ouvrir la porte ?", "words": [171, 172, 173, 174, 175, 176]}, {"id": 33, "text": "| | Qu'est-ce | qu'il dit ?", "words": [177, 178, 179, 180, 181, 182, 183]}, {"id": 34, "text": "= qu'il dit ?", "words": [184, 185, 186, 187]}, {"id": 35, "text": "Quelqu'un peut descendre ?", "words": [188, 189, 190, 191]}, {"id": 36, "text": "Qu'est-ce —+ | qu'il dit ?", "words": [192, 193, 194, 195, 196, 197]}, {"id": 37, "text": "ED Vous êtes metteur en scène.", "words": [198, 199, 200, 201, 202, 203]}, {"id": 38, "text": "Donnez les indications aux acteurs au style indirect.", "words": [204, 205, 206, 207, 208, 209, 210, 211]}, {"id": 39, "text": "Max : Qu'est-ce que tu fais, samedi ?", "words": [212, 213, 214, 215, 216, 217, 218, 219]}, {"id": 40, "text": "Max demande à Léa ce qu'elle fait samedi.", "words": [220, 221, 222, 223, 224, 225, 226, 227]}, {"id": 41, "text": "Léa : Je vais au cinéma avec Jules.", "words": [228, 229, 230, 231, 232, 233, 234, 235]}, {"id": 42, "text": "Elle lui répond qu'elle va au cinéma avec Jules.", "words": [236, 237, 238, 239, 240, 241, 242, 243, 244]}, {"id": 43, "text": "Max : Tu es libre dimanche ?", "words": [245, 246, 247, 248, 249, 250, 251]}, {"id": 44, "text": "Léa : Je vais écouter un concert.", "words": [252, 253, 254, 255, 256, 257, 258]}, {"id": 45, "text": "Max : Où vas-tu ?", "words": [259, 260, 261, 262, 263]}, {"id": 46, "text": "Léa : À l'église Saint-Médard.", "words": [264, 265, 266, 267, 268]}, {"id": 47, "text": "Max : Tu y vas seule ?", "words": [269, 270, 271, 272, 273, 274, 275]}, {"id": 48, "text": "J'adore le piano.", "words": [276, 277, 278]}, {"id": 49, "text": "Léa : Alors, viens à dix heures pile !", "words": [279, 280, 281, 282, 283, 284, 285, 286, 287]}, {"id": 50, "text": "ED >» Imaginez, puis racontez le dialogue entre un client et le serveur d'un restaurant.", "words": [288, 289, 290, 291, 292, 293, 294, 295, 296, 297, 298, 299, 300, 301, 302]}, {"id": 51, "text": "cent cinquante-sept + 157", "words": [303, 304, 305, 306]}]}