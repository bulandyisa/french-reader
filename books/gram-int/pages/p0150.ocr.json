:", "words": [96, 97, 98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 111]}, {"id": 25, "text": "— Où est-ce que vous allez ?", "words": [112, 113, 114, 115, 116, 117, 118]}, {"id": 26, "text": "- Quand est-ce que vous partez ?", "words": [119, 120, 121, 122, 123, 124, 125]}, {"id": 27, "text": "+ En français familier, on place l’interrogatif en fin de phrase : — Vous allez où ?", "words": [126, 127, 128, 129, 130, 131, 132, 133, 134, 135, 136, 137, 138, 139, 140, 141, 142]}, {"id": 28, "text": "- Vous partez quand ?", "words": [143, 144, 145, 146, 147]}, {"id": 29, "text": "D Avec les noms, on utilise un pronom de rappel : — Où vos amis vont-ils ?", "words": [148, 149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159, 160, 161, 162, 163, 164]}, {"id": 30, "text": "— Où Paul va:til ?", "words": [165, 166, 167, 168, 169]}, {"id": 31, "text": "- Quand ?", "words": [170, 171, 172]}, {"id": 32, "text": "(+ «-t-» entre deux voyelles)", "words": [173, 174, 175, 176, 177]}, {"id": 33, "text": "« QUI », « QUE », « QUOI » interrogatifs", "words": [178, 179, 180, 181, 182, 183, 184, 185, 186, 187]}, {"id": 34, "text": "D Qui » renvoie à une personne : D Que »/« quoi » renvoie à une chose :", "words": [188, 189, 190, 191, 192, 193, 194, 195, 196, 197, 198, 199, 200, 201, 202, 203, 204, 205]}, {"id": 35, "text": "— Qui cherchez-vous ?", "words": [206, 207, 208, 209]}, {"id": 36, "text": "— Que cherchez-vous ?", "words": [210, 211, 212, 213]}, {"id": 37, "text": "— Qui est-ce que vous cherchez ?", "words": [214, 215, 216, 217, 218, 219, 220]}, {"id": 38, "text": "— Qu'est-ce que vous cherchez ?", "words": [221, 222, 223, 224, 225, 226]}, {"id": 39, "text": "— Vous cherchez qui ?", "words": [227, 228, 229, 230, 231]}, {"id": 40, "text": "— Vous cherchez quoi ?", "words": [232, 233, 234, 235, 236]}, {"id": 41, "text": "(= M.", "words": [237, 238]}, {"id": 42, "text": "Dupond) (= mes clés)", "words": [239, 240, 241, 242]}, {"id": 43, "text": "À e En position sujet, distinguez :", "words": [243, 244, 245, 246, 247, 248, 249]}, {"id": 44, "text": "- Qui est-ce qui sonne ?", "words": [250, 251, 252, 253, 254, 255]}, {"id": 45, "text": "— C'est le facteur.", "words": [256, 257, 258, 259]}, {"id": 46, "text": "(personne) — Qu'est-ce qui sonne ?", "words": [260, 261, 262, 263, 264, 265]}, {"id": 47, "text": "- C'est le téléphone.", "words": [266, 267, 268, 269]}, {"id": 48, "text": "(chose)", "words": [270]}, {"id": 49, "text": "« Qui/Que » relatifs, p.", "words": [271, 272, 273, 274, 275]}, {"id": 50, "text": "140", "words": [276]}, {"id": 51, "text": "148 e cent quarante-huit", "words": [277, 278, 279, 280]}]}