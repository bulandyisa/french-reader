ion s'est améliorée ?", "words": [238, 239, 240, 241, 242, 243]}, {"id": 50, "text": "(bien) _", "words": [244, 245]}, {"id": 51, "text": "3.", "words": [246]}, {"id": 52, "text": "- Le personnel s'est investi ?", "words": [247, 248, 249, 250, 251, 252]}, {"id": 53, "text": "(beaucoup) -", "words": [253, 254]}, {"id": 54, "text": "4.", "words": [255]}, {"id": 55, "text": "- Les consommateurs ont réagi ?", "words": [256, 257, 258, 259, 260, 261]}, {"id": 56, "text": "(bien) -", "words": [262, 263]}, {"id": 57, "text": "5.", "words": [264]}, {"id": 58, "text": "- Les prix ont augmenté ?", "words": [265, 266, 267, 268, 269, 270]}, {"id": 59, "text": "(un peu) -", "words": [271, 272, 273]}, {"id": 60, "text": "cent quatre-vingt-treize - 193", "words": [274, 275, 276, 277]}]}