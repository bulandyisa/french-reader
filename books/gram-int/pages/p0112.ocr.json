[67, 68, 69, 70, 71, 72, 73, 74, 75, 76, 77, 78, 79, 80, 81, 82, 83, 84, 85]}, {"id": 7, "text": "Et : attendre, vendre,", "words": [86, 87, 88, 89]}, {"id": 8, "text": "perdre, descendre,", "words": [90, 91]}, {"id": 9, "text": "répondre...", "words": [92]}, {"id": 10, "text": "entend j'entends, tu entends, il entend", "words": [93, 94, 95, 96, 97, 98]}, {"id": 11, "text": "ENTEN-DRE entend nous entendons, vous entendez, ils entendent", "words": [99, 100, 101, 102, 103, 104, 105, 106]}, {"id": 12, "text": "J + Dites : Je mef Jebas J'entends Je réponds", "words": [107, 108, 109, 110, 111, 112, 113, 114, 115, 116]}, {"id": 13, "text": "Pour d'autres verbes, le radical s’allonge au pluriel.", "words": [117, 118, 119, 120, 121, 122, 123, 124]}, {"id": 14, "text": "écri j'écris, tu écris, il écrit", "words": [125, 126, 127, 128, 129, 130]}, {"id": 15, "text": "ÉCRI-RE ES rescrire…", "words": [131, 132, 133]}, {"id": 16, "text": "nous ecrIvons, VOUS ils écrivent P", "words": [134, 135, 136, 137, 138, 139]}, {"id": 17, "text": "li je lis, tu lis, il lit Et : interdire, prédire, contredire, plaire, lis nous lisons, vous lisez, ils lisent", "words": [140, 141, 142, 143, 144, 145, 146, 147, 148, 149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159]}, {"id": 18, "text": "Et : verbes en -uire", "words": [160, 161, 162, 163, 164]}, {"id": 19, "text": "condui je conduis, tu conduis, il conduit (construire, détruire...)", "words": [165, 166, 167, 168, 169, 170, 171, 172, 173]}, {"id": 20, "text": "COND-UIRE .", "words": [174, 175]}, {"id": 21, "text": ".", "words": [176]}, {"id": 22, "text": ".", "words": [177]}, {"id": 23, "text": "conduis nous conduisons, vous conduisez, ils conduisent", "words": [178, 179, 180, 181, 182, 183, 184]}, {"id": 24, "text": "Et : éteindre, craindre,", "words": [185, 186, 187, 188]}, {"id": 25, "text": "pein je peins, tu peins, il peint", "words": [189, 190, 191, 192, 193, 194, 195]}, {"id": 26, "text": "PEINDRE peignons, vous peignez, ils peignent", "words": [196, 197, 198, 199, 200, 201]}, {"id": 27, "text": "Cas particuliers + Savoir : Je sais/Nous savons/Ils savent + Valoir : Je vaux/Il vaut/Ils valent e Croire : Je crois/Vous croyez/Ils croient + Voir : Je vois/Vous voyez/Ils voient", "words": [202, 203, 204, 205, 206, 207, 208, 209, 210, 211, 212, 213, 214, 215, 216, 217, 218, 219, 220, 221, 222, 223, 224, 225, 226, 227, 228, 229, 230, 231]}, {"id": 28, "text": "À e Dites: /ls voient Ils croient Ne dites pas : Ils croyent", "words": [232, 233, 234, 235, 236, 237, 238, 239, 240, 241, 242, 243, 244]}, {"id": 29, "text": "+ Courir, rire et sourire ont un seul radical : Je cours / Vous courez / Ils courent", "words": [245, 246, 247, 248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259, 260, 261, 262]}, {"id": 30, "text": "Écrit, p.", "words": [263, 264]}, {"id": 31, "text": "112", "words": [265]}, {"id": 32, "text": "110 + cent dix", "words": [266, 267, 268, 269]}]}