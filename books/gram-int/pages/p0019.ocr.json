words": [88, 89, 90, 91]}, {"id": 23, "text": "Accordez les adjectifs.", "words": [92, 93, 94]}, {"id": 24, "text": "- Vous êtes suédois ou norvégien, Ingmar ?", "words": [95, 96, 97, 98, 99, 100, 101, 102]}, {"id": 25, "text": "- Je sus suédois.", "words": [103, 104, 105, 106]}, {"id": 26, "text": "— Et vous, Ingrid, vous ê£es suédoise également?", "words": [107, 108, 109, 110, 111, 112, 113, 114]}, {"id": 27, "text": "1.", "words": [115]}, {"id": 28, "text": "- Vous êtes étudiant ou lycéen, Marc ?", "words": [116, 117, 118, 119, 120, 121, 122, 123]}, {"id": 29, "text": "- lycéen.", "words": [124, 125]}, {"id": 30, "text": "- Et vous, Anne et Suzy, vous ?", "words": [126, 127, 128, 129, 130, 131, 132, 133]}, {"id": 31, "text": "2.", "words": [134]}, {"id": 32, "text": "- Vous êtes célibataire ou marié, Jean ?", "words": [135, 136, 137, 138, 139, 140, 141, 142]}, {"id": 33, "text": "- Et vous, Cathy, vous ?", "words": [143, 144, 145, 146, 147, 148]}, {"id": 34, "text": "3.", "words": [149]}, {"id": 35, "text": "- Vous êtes réservé ou bavard, Martin ?", "words": [150, 151, 152, 153, 154, 155, 156, 157]}, {"id": 36, "text": "- En général, - Et vous, Julie et Nadia, vous également ?", "words": [158, 159, 160, 161, 162, 163, 164, 165, 166, 167, 168, 169]}, {"id": 37, "text": "4.", "words": [170]}, {"id": 38, "text": "- Vous êtes optimiste ou pessimiste, Veronica ?", "words": [171, 172, 173, 174, 175, 176, 177, 178]}, {"id": 39, "text": "- En général, optimiste.", "words": [179, 180, 181, 182]}, {"id": 40, "text": "- Et vous, John, vous également ?", "words": [183, 184, 185, 186, 187, 188, 189]}, {"id": 41, "text": "5.", "words": [190]}, {"id": 42, "text": "- Vous êtes calme ou nerveux, avant un examen, Léo ?", "words": [191, 192, 193, 194, 195, 196, 197, 198, 199, 200, 201]}, {"id": 43, "text": "- En général, — Et vous, Paul et Marie, vous nous, on", "words": [202, 203, 204, 205, 206, 207, 208, 209, 210, 211, 212, 213]}, {"id": 44, "text": "> Associez les adjectifs.", "