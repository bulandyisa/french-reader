": [78, 79, 80, 81, 82]}, {"id": 12, "text": "Ils sont aux sports d'hiver.", "words": [83, 84, 85, 86, 87]}, {"id": 13, "text": "Ce sont les skis des enfants.", "words": [88, 89, 90, 91, 92, 93]}, {"id": 14, "text": "Ils vont aux sports d'hiver.", "words": [94, 95, 96, 97, 98]}, {"id": 15, "text": "M «À la », « à » et « de la », « de l’ » ne se contractent pas :", "words": [99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 111, 112, 113, 114, 115, 116, 117, 118, 119]}, {"id": 16, "text": "- Tu vas à la gare ou à ?", "words": [120, 121, 122, 123, 124, 125, 126, 127, 128]}, {"id": 17, "text": "— Tu pars de la gare ou de ?", "words": [129, 130, 131, 132, 133, 134, 135, 136, 137]}, {"id": 18, "text": "À e Il faut distinguer « des » contracté (« de » + « les ») et « des » indéfini :", "words": [138, 139, 140, 141, 142, 143, 144, 145, 146, 147, 148, 149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159]}, {"id": 19, "text": "Je parle des Français.", "words": [160, 161, 162, 163]}, {"id": 20, "text": "Je connais des Français.", "words": [164, 165, 166, 167]}, {"id": 21, "text": "« de » + «les » (= tous) pluriel de « un » (= quelques)", "words": [168, 169, 170, 171, 172, 173, 174, 175, 176, 177, 178, 179, 180, 181, 182]}, {"id": 22, "text": "M Constructions courantes avec « de » ou « à » + article :", "words": [183, 184, 185, 186, 187, 188, 189, 190, 191, 192, 193, 194, 195, 196]}, {"id": 23, "text": "Le vélo du professeur.", "words": [197, 198, 199, 200]}, {"id": 24, "text": "La couleur de la mer.", "words": [201, 202, 203, 204, 205]}, {"id": 25, "text": "Je suis à côté du métro, près de la poste.", "words": [206, 207, 208, 209, 210, 211, 212, 213, 214, 215]}, {"id": 26, "text": "|.", "words": [216]}, {"id": 27, "text": "À (lieu) Je suis au bureau.", "words": [217, 218, 219, 220, 221, 222]}, {"id": 28, "text": "Je vais au café.", "words": [223, 224, 225, 226]}, {"id": 29, "text": "Une pizza au jambon.", "words": [227, 228, 229, 230]}, {"id": 30, "text": "Un homme aux yeux bleus.", "words": [231, 232, 233, 234, 235]}, {"id": 31, "text": "Fa)", "words": [236]}, {"id": 32, "text": "Partitifs, p.", "words": [237, 238]}, {"id": 33, "text": "86 Verbes avec « à » et « de », p.", "words": [239, 240, 241, 242, 243, 244, 245, 246, 247, 248, 249]}, {"id": 34, "text": "160", "words": [250]}, {"id": 35, "text": "30 + trente", "words": [251, 252, 253]}]}