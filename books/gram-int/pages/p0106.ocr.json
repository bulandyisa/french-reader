": "Je pense à mon pays.", "words": [72, 73, 74, 75, 76]}, {"id": 12, "text": "J'y pense moi aussi.", "words": [77, 78, 79, 80]}, {"id": 13, "text": "Je participe à ce projet.", "words": [81, 82, 83, 84, 85]}, {"id": 14, "text": "J'y participe aussi.", "words": [86, 87, 88]}, {"id": 15, "text": "Je m'intéresse à la politique.", "words": [89, 90, 91, 92, 93]}, {"id": 16, "text": "Je m'y intéresse aussi.", "words": [94, 95, 96, 97]}, {"id": 17, "text": "D Pour les personnes, on utilise un pronom tonique :", "words": [98, 99, 100, 101, 102, 103, 104, 105, 106, 107]}, {"id": 18, "text": "Je pense à Paul.", "words": [108, 109, 110, 111]}, {"id": 19, "text": "Je pense à lui.", "words": [112, 113, 114, 115]}, {"id": 20, "text": "Je m'intéresse à Paul.", "words": [116, 117, 118, 119]}, {"id": 21, "text": "Je m'intéresse à lui.", "words": [120, 121, 122, 123]}, {"id": 22, "text": "+ Avec les verbes de communication, on utilise un pronom complément :", "words": [124, 125, 126, 127, 128, 129, 130, 131, 132, 133, 134, 135]}, {"id": 23, "text": "Je parle à Paul.", "words": [136, 137, 138, 139]}, {"id": 24, "text": "Je lui parle.", "words": [140, 141, 142]}, {"id": 25, "text": "Je téléphone à Lucie.", "words": [143, 144, 145, 146]}, {"id": 26, "text": "Je lui téléphone.", "words": [147, 148, 149]}, {"id": 27, "text": "M Expressions courantes avec « y » :", "words": [150, 151, 152, 153, 154, 155, 156, 157]}, {"id": 28, "text": "— Paul est un connaisseur en vin : il s'y connaît.", "words": [158, 159, 160, 161, 162, 163, 164, 165, 166, 167, 168]}, {"id": 29, "text": "— Je ne suis pas responsable : je n’y suis pour rien.", "words": [169, 170, 171, 172, 173, 174, 175, 176, 177, 178, 179, 180]}, {"id": 30, "text": "— N'oubliez pas de passer demain !", "words": [181, 182, 183, 184, 185, 186, 187]}, {"id": 31, "text": "- Je n'y pas !", "words": [188, 189, 190, 191, 192]}, {"id": 32, "text": "— Voilà, ça y est, c'est fini !", "words": [193, 194, 195, 196, 197, 198, 199, 200]}, {"id": 33, "text": "On peut partir.", "words": [201, 202, 203]}, {"id": 34, "text": "LA NÉGATION se place avant et après le bloc formé par le pronom et le verbe.", "words": [204, 205, 206, 207, 208, 209, 210, 211, 212, 213, 214, 215, 216, 217, 218, 219]}, {"id": 35, "text": "Jene m'yintéresse | pas.", "words": [220, 221, 222, 223]}, {"id": 36, "text": "Pronoms compléments, p.", "words": [224, 225, 226]}, {"id": 37, "text": "126-128 Pronoms toniques, p.", "words": [227, 228, 229, 230]}, {"id": 38, "text": "132", "words": [231]}, {"id": 39, "text": "104 e cent quatre", "words": [232, 233, 234, 235]}]}