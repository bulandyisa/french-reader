}, {"id": 15, "text": "Maintenant, les jeunes mangent des hamburgers,", "words": [72, 73, 74, 75, 76, 77]}, {"id": 16, "text": "au vingtième dessandwichs.", "words": [78, 79, 80]}, {"id": 17, "text": "5.", "words": [81]}, {"id": 18, "text": "Maintenant, les enfants boivent du Coca-Cola,", "words": [82, 83, 84, 85, 86, 87]}, {"id": 19, "text": "avant, dela limonade.", "words": [88, 89, 90]}, {"id": 20, "text": "6.", "words": [91]}, {"id": 21, "text": "Maintenant, la plupart des gens vivent dans des immeubles", "words": [92, 93, 94, 95, 96, 97, 98, 99, 100]}, {"id": 22, "text": "dans le passé, dans des maisons individuelles.", "words": [101, 102, 103, 104, 105, 106, 107]}, {"id": 23, "text": "7.", "words": [108]}, {"id": 24, "text": "Maintenant, on communique surtout par Internet, au Moyen Âge, surtout par la parole.", "words": [109, 110, 111, 112, 113, 114, 115, 116, 117, 118, 119, 120, 121]}, {"id": 25, "text": "2) Décrivez la vie quotidienne des hommes préhistoriques en trouvant les verbes manquants.", "words": [122, 123, 124, 125, 126, 127, 128, 129, 130, 131, 132, 133, 134]}, {"id": 26, "text": "Préhistoire Les hommes préhistoriques étaient nomades : ils une", "words": [135, 136, 137, 138, 139, 140, 141, 142, 143]}, {"id": 27, "text": "tente.", "words": [144]}, {"id": 28, "text": "Pour se protéger du froid, ils des peaux de bêtes.", "words": [145, 146, 147, 148, 149, 150, 151, 152, 153, 154]}, {"id": 29, "text": "Pour se nourrir, ils le gibier avec des flèches en pierre,", "words": [155, 156, 157, 158, 159, 160, 161, 162, 163, 164, 165]}, {"id": 30, "text": "ils le poisson dans les rivières et ils des fruits dans la forêt.", "words": [166, 167, 168, 169, 170, 171, 172, 173, 174, 175, 176, 177, 178]}, {"id": 31, "text": "Pour faire cuire les aliments, ils du feu avec", "words": [179, 180, 181, 182, 183, 184, 185, 186, 187]}, {"id": 32, "text": "du silex.", "words": [188, 189]}, {"id": 33, "text": "Sur les parois des grottes, ils des animaux.", "words": [190, 191, 192, 193, 194, 195, 196, 197]}, {"id": 34, "text": "Pour les colorer, ils des végétaux broyés.", "words": [198, 199, 200, 201, 202, 203, 204]}, {"id": 35, "text": "ED >» Imaginez la vie des jeunes filles au xix° siècle, dans l'Antiquité, etc.", "words": [205, 206, 207, 208, 209, 210, 211, 212, 213, 214, 215, 216, 217, 218]}, {"id": 36, "text": "DD D> Décrivez vos activités dans votre enfance.", "words": [219, 220, 221, 222, 223, 224, 225, 226]}, {"id": 37, "text": "deux cent neuf 209", "words": [227, 228, 229, 230]}]}