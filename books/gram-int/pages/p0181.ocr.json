h": 24, "conf": 96.0, "block": 10, "par": 1, "line": 3, "i": 262}, {"text": "être", "x": 505, "y": 2202, "w": 57, "h": 27, "conf": 96.0, "block": 10, "par": 1, "line": 3, "i": 263}, {"text": "arrêté", "x": 572, "y": 2201, "w": 88, "h": 28, "conf": 95.0, "block": 10, "par": 1, "line": 3, "i": 264}, {"text": "par", "x": 671, "y": 2209, "w": 46, "h": 27, "conf": 96.0, "block": 10, "par": 1, "line": 3, "i": 265}, {"text": "la", "x": 729, "y": 2201, "w": 22, "h": 28, "conf": 96.0, "block": 10, "par": 1, "line": 3, "i": 266}, {"text": "police", "x": 763, "y": 2201, "w": 84, "h": 35, "conf": 96.0, "block": 10, "par": 1, "line": 3, "i": 267}, {"text": "Plaire", "x": 171, "y": 2259, "w": 77, "h": 29, "conf": 92.0, "block": 11, "par": 1, "line": 1, "i": 268}, {"text": "au", "x": 259, "y": 2267, "w": 34, "h": 21, "conf": 96.0, "block": 11, "par": 1, "line": 1, "i": 269}, {"text": "gendarme", "x": 303, "y": 2260, "w": 147, "h": 36, "conf": 96.0, "block": 11, "par": 1, "line": 1, "i": 270}, {"text": "et", "x": 460, "y": 2263, "w": 28, "h": 25, "conf": 95.0, "block": 11, "par": 1, "line": 1, "i": 271}, {"text": "payer", "x": 499, "y": 2267, "w": 79, "h": 29, "conf": 96.0, "block": 11, "par": 1, "line": 1, "i": 272}, {"text": "une", "x": 589, "y": 2267, "w": 52, "h": 21, "conf": 96.0, "block": 11, "par": 1, "line": 1, "i": 273}, {"text": "légère", "x": 652, "y": 2259, "w": 88, "h": 37, "conf": 96.0, "block": 11, "par": 1, "line": 1, "i": 274}, {"text": "amende", "x": 750, "y": 2259, "w": 116, "h": 29, "conf": 96.0, "block": 11, "par": 1, "line": 1, "i": 275}], "sentences": [{"id": 0, "text": "© CLE International 2017.", "words": [0, 1, 2, 3]}, {"id": 1, "text": "La photocopie non autorisée est un délit.", "words": [4, 5, 6, 7, 8, 9, 10]}, {"id": 2, "text": "LE PASSÉ COMPOSÉ", "words": [11, 12, 13]}, {"id": 3, "text": "mettez les phrases au passé composé.", "words": [14, 15, 16, 17, 18, 19]}, {"id": 4, "text": "Je mange un croissant et je bois un café.", "words": [20, 21, 22, 23, 24, 25, 26, 27, 28]}, {"id": 5, "text": "J'ai mangé un croissant et j'ai Eu un café,", "words": [29, 30, 31, 32, 33, 34, 35, 36, 37]}, {"id": 6, "text": "1.", "words": [38]}, {"id": 7, "text": "Georges achète le journal et il prend l'autobus.", "words": [39, 40, 41, 42, 43, 44, 45, 46]}, {"id": 8, "text": "2.", "words": [47]}, {"id": 9, "text": "Marie met un imperméable et elle prend un parapluie.", "words": [48, 49, 50, 51, 52, 53, 54, 55, 56]}, {"id": 10, "text": "3.", "words": [57]}, {"id": 11, "text": "Nous buvons un café et nous mangeons un croissant.", "words": [58, 59, 60, 61, 62, 63, 64, 65, 66]}, {"id": 12, "text": "4.", "words": [67]}, {"id": 13, "text": "Vous lisez le journal et vous voyez une annonce intéressante.", "words": [68, 69, 70, 71, 72, 73, 74, 75, 76, 77]}, {"id": 14, "text": "5.", "words": [78]}, {"id": 15, "text": "Julie écrit à sa mère et elle poste la lettre.", "words": [79, 80, 81, 82, 83, 84, 85, 86, 87, 88]}, {"id": 16, "text": "6.", "words": [89]}, {"id": 17, "text": "Tu finis ton travail et tu écris à tes amis.", "words": [90, 91, 92, 93, 94, 95, 96, 97, 98, 99]}, {"id": 18, "text": "7.", "words": [100]}, {"id": 19, "text": "Nous perdons nos clés et nous devons appeler les pompiers.", "words": [101, 102, 103, 104, 105, 106, 107, 108, 109, 110]}, {"id": 20, "text": "8.", "words": [111]}, {"id": 21, "text": "Il y a une grève des transports et je dois rentrer à pied.", "words": [112, 113, 114, 115, 116, 117, 118, 119, 120, 121, 122, 123, 124]}, {"id": 22, "text": "complétez, selon le modèle.", "words": [125, 126, 127, 128]}, {"id": 23, "text": "En général, je bois une tisane le soir, mais hier soir, jai bu un double nhisky.", "words": [129, 130, 131, 132, 133, 134, 135, 136, 137, 138, 139, 140, 141, 142, 143, 144]}, {"id": 24, "text": "1.", "words": [145]}, {"id": 25, "text": "Chaque mois, je reçois une ou deux cartes postales, mais la semaine dernière, huitlettres!", "words": [146, 147, 148, 149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159]}, {"id": 26, "text": "2.", "words": [160]}, {"id": 27, "text": "D'habitude, je bois deux cafés par jour, pas plus, mais hier, moins cinq cafés.", "words": [161, 162, 163, 164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174]}, {"id": 28, "text": "3.", "words": [175]}, {"id": 29, "text": "En général, je lis un roman par mois, mais le mois dernier, trois romans et deux pièces de théâtre.", "words": [176, 177, 178, 179, 180, 181, 182, 183, 184, 185, 186, 187, 188, 189, 190, 191, 192, 193, 194]}, {"id": 30, "text": "4.", "words": [195]}, {"id": 31, "text": "Le matin, j'attends le bus cinq minutes environ, mais hier matin, plus de trente minutes.", "words": [196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210]}, {"id": 32, "text": "5.", "words": [211]}, {"id": 33, "text": "En général, je perds trois parapluies par hiver, mais l'hiver dernier, au moins dix parapluies.", "words": [212, 213, 214, 215, 216, 217, 218, 219, 220, 221, 222, 223, 224, 225, 226]}, {"id": 34, "text": "ŒD mettez au passé composé.", "words": [227, 228, 229, 230, 231]}, {"id": 35, "text": "Ta lettre", "words": [232, 233]}, {"id": 36, "text": "Ouvrir une lettre et avoir un choc", "words": [234, 235, 236, 237, 238, 239, 240]}, {"id": 37, "text": "Boire de l'alcool et avoir mal à la tête Prendre sa voiture et conduire dans la nuit Brûler un feu rouge et être arrêté par la police", "words": [241, 242, 243, 244, 245, 246, 247, 248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259, 260, 261, 262, 263, 264, 265, 266, 267]}, {"id": 38, "text": "Plaire au gendarme et payer une légère amende", "words": [268, 269, 270, 271, 272, 273, 274, 275]}]}