s": [84, 85, 86, 87, 88]}, {"id": 17, "text": "M Pour choisir entre plusieurs possibilités, on utilise « lequel » :", "words": [89, 90, 91, 92, 93, 94, 95, 96, 97, 98, 99, 100]}, {"id": 18, "text": "— Quel stylo ?", "words": [101, 102, 103, 104]}, {"id": 19, "text": "(je ne vois pas de stylo.)", "words": [105, 106, 107, 108, 109, 110]}, {"id": 20, "text": "Passe-moi le stylo.", "words": [111, 112, 113]}, {"id": 21, "text": "- Lequel ?", "words": [114, 115, 116]}, {"id": 22, "text": "(le bleu ou le rouge ?)", "words": [117, 118, 119, 120, 121, 122]}, {"id": 23, "text": "Masculin Singulier lequel Pluriel", "words": [123, 124, 125, 126]}, {"id": 24, "text": "Féminin laquelle", "words": [127, 128]}, {"id": 25, "text": "lesquels lesquelles", "words": [129, 130]}, {"id": 26, "text": "L’'EXCLAMATION exprime un sentiment intense (joie, étonnement, etc.)", "words": [131, 132, 133, 134, 135, 136, 137, 138]}, {"id": 27, "text": ":", "words": [139]}, {"id": 28, "text": "Le temps est splendide !", "words": [140, 141, 142, 143, 144]}, {"id": 29, "text": "Il fait chaud !", "words": [145, 146, 147, 148]}, {"id": 30, "text": "L'eau est glacée !", "words": [149, 150, 151, 152]}, {"id": 31, "text": "Cette fille est superbe !", "words": [153, 154, 155, 156, 157]}, {"id": 32, "text": "Pour renforcer l’exclamation, on peut utiliser :", "words": [158, 159, 160, 161, 162, 163, 164]}, {"id": 33, "text": "Quel(s) », « quelles(s) » « Qu'est-ce que »/« que »/« comme » — Quel temps splendide !", "words": [165, 166, 167, 168, 169, 170, 171, 172, 173, 174, 175, 176, 177, 178, 179, 180, 181, 182]}, {"id": 34, "text": "— Qu'est-ce qu'il fait chaud !", "words": [183, 184, 185, 186, 187, 188]}, {"id": 35, "text": "— Quelle jolie fille !", "words": [189, 190, 191, 192, 193]}, {"id": 36, "text": "— Qu'elle est jolie !", "words": [194, 195, 196, 197, 198]}, {"id": 37, "text": "- Quel idiot !", "words": [199, 200, 201, 202]}, {"id": 38, "text": "— Comme je suis bête !", "words": [203, 204, 205, 206, 207, 208]}, {"id": 39, "text": "(fam.)", "words": [209]}, {"id": 40, "text": "150 + cent cinquante", "words": [210, 211, 212, 213]}]}