"words": [30, 31, 32, 33, 34, 35]}, {"id": 7, "text": "Les dossiers sur je travaille sont ennuyeux.", "words": [36, 37, 38, 39, 40, 41, 42]}, {"id": 8, "text": "Les clients pour je travaille sont insupportables.", "words": [43, 44, 45, 46, 47, 48, 49]}, {"id": 9, "text": "L'ordinateur avec je travaille est toujours en panne.", "words": [50, 51, 52, 53, 54, 55, 56, 57]}, {"id": 10, "text": "La", "words": [58]}, {"id": 11, "text": "société je travaille a des ennuis financiers...", "words": [59, 60, 61, 62, 63, 64, 65]}, {"id": 12, "text": "ŒD répondez avec les relatifs composés manquants.", "words": [66, 67, 68, 69, 70, 71, 72]}, {"id": 13, "text": "- Vous dormez dans un lit confortable ?", "words": [73, 74, 75, 76, 77, 78, 79, 80]}, {"id": 14, "text": "- Le lit dans lequet je dors est confortable.", "words": [81, 82, 83, 84, 85, 86, 87, 88, 89]}, {"id": 15, "text": "1.", "words": [90]}, {"id": 16, "text": "- Vous travaillez sur une table en verre ?", "words": [91, 92, 93, 94, 95, 96, 97, 98, 99]}, {"id": 17, "text": "- 2.", "words": [100, 101]}, {"id": 18, "text": "- Vous écrivez avec un stylo rechargeable ?", "words": [102, 103, 104, 105, 106, 107, 108, 109]}, {"id": 19, "text": "- 3.", "words": [110, 111]}, {"id": 20, "text": "- Vous travaillez avec des étudiants anglais ?", "words": [112, 113, 114, 115, 116, 117, 118, 119]}, {"id": 21, "text": "- 4.", "words": [120, 121]}, {"id": 22, "text": "- Vous appartenez à un groupe sympathique ?", "words": [122, 123, 124, 125, 126, 127, 128, 129]}, {"id": 23, "text": "5.", "words": [130]}, {"id": 24, "text": "- Vous assistez à des cours intéressants ?", "words": [131, 132, 133, 134, 135, 136, 137, 138]}, {"id": 25, "text": "-", "words": [139]}, {"id": 26, "text": "> Complétez avec des relatifs et avec « pour », « à », « chez », « dans », « avec ».", "words": [140, 141, 142, 143, 144, 145, 146, 147, 148, 149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159, 160, 161]}, {"id": 27, "text": "Chère Daisy", "words": [162, 163]}, {"id": 28, "text": "Je ne comprends pas la raison pour laquelle vous refusez mon invitation.", "words": [164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174, 175]}, {"id": 29, "text": "Les amis je vais passer le week-end sont des gens charmants et la ferme habitent est très confortable.", "words": [176, 177, 178, 179, 180, 181, 182, 183, 184, 185, 186, 187, 188, 189, 190, 191, 192, 193]}, {"id": 30, "text": "Il y", "words": [194, 195]}, {"id": 31, "text": "a d'autres Anglais pourrez discuter et, le samedi soir, mes amis organisent toujours un", "words": [196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209]}, {"id": 32, "text": "concert participent de bons musiciens.", "words": [210, 211, 212, 213, 214]}, {"id": 33, "text": "Alors venez, je vous en prie !", "words": [215, 216, 217, 218, 219, 220, 221]}, {"id": 34, "text": "Benoît", "words": [222]}, {"id": 35, "text": "Complétez avec les prépositions et les relatifs manquants.", "words": [223, 224, 225, 226, 227, 228, 229, 230]}, {"id": 36, "text": "1.", "words": [231]}, {"id": 37, "text": "- Est-ce que la société avec laquellevous travaillez est à Paris ?", "words": [232, 233, 234, 235, 236, 237, 238, 239, 240, 241, 242, 243]}, {"id": 38, "text": "- 2.", "words": [244, 245]}, {"id": 39, "text": "- Est-ce que le fauteuil", "words": [246, 247, 248, 249, 250]}, {"id": 40, "text": "vous êtes assis est en cuir ?", "words": [251, 252, 253, 254, 255, 256, 257]}, {"id": 41, "text": "- 3.", "words": [258, 259]}, {"id": 42, "text": "- Quel sont les sports vous vous intéressez ?", "words": [260, 261, 262, 263, 264, 265, 266, 267, 268]}, {"id": 43, "text": "- 4.", "words": [269, 270]}, {"id": 44, "text": "- Quels sont les journaux vous êtes abonnés ?", "words": [271, 272, 273, 274, 275, 276, 277, 278, 279]}, {"id": 45, "text": "- 5.", "words": [280, 281]}, {"id": 46, "text": "- Est-ce que les collègues", "words": [282, 283, 284, 285, 286]}, {"id": 47, "text": "vous déjeunez sont sympathiques ?", "words": [287, 288, 289, 290, 291]}, {"id": 48, "text": "- 6.", "words": [292, 293]}, {"id": 49, "text": "- Comment s'appelle le musée en face tuhabites et à l'intérieur ya de si belles fresques ?", "words": [294, 295, 296, 297, 298, 299, 300, 301, 302, 303, 304, 305, 306, 307, 308, 309, 310]}, {"id": 50, "text": "D> Faites des descriptions en utilisant des relatifs composés.", "words": [311, 312, 313, 314, 315, 316, 317, 318, 319]}, {"id": 51, "text": "sombre clair grand sympathique blond brun en bois en fer", "words": [320, 321, 322, 323, 324, 325, 326, 327, 328, 329]}, {"id": 52, "text": "La salle Le professeur La chaise Le bureau", "words": [330, 331, 332, 333, 334, 335, 336, 337]}, {"id": 53, "text": "- cent quarante-cinq 145", "words": [338, 339, 340, 341]}]}