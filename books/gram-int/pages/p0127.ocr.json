w": 12, "h": 27, "conf": 92.0, "block": 26, "par": 1, "line": 3, "i": 347}], "sentences": [{"id": 0, "text": "© CLE International 2017.", "words": [0, 1, 2, 3]}, {"id": 1, "text": "La photocopie non autorisée est un délit.", "words": [4, 5, 6, 7, 8, 9, 10]}, {"id": 2, "text": "LES PRONOMS COMPLÉMENTS", "words": [11, 12, 13]}, {"id": 3, "text": "|", "words": [14]}, {"id": 4, "text": "Répondez aux questions, selon le modèle.", "words": [15, 16, 17, 18, 19, 20]}, {"id": 5, "text": "Les médias et vous", "words": [21, 22, 23, 24]}, {"id": 6, "text": "Vous regardez la télé tous les jours ?", "words": [25, 26, 27, 28, 29, 30, 31, 32]}, {"id": 7, "text": "Oui, je la regarde tous les jours.", "words": [33, 34, 35, 36, 37, 38, 39]}, {"id": 8, "text": "Vous regardez régulièrement la météo ?", "words": [40, 41, 42, 43, 44, 45]}, {"id": 9, "text": "Vous regardez parfois les publicités ?", "words": [46, 47, 48, 49, 50, 51]}, {"id": 10, "text": "Vous consultez souvent le site de Google ?", "words": [52, 53, 54, 55, 56, 57, 58, 59]}, {"id": 11, "text": "Vous lisez les rubriques sportives ?", "words": [60, 61, 62, 63, 64, 65]}, {"id": 12, "text": "Vous gardez les vieux journaux ?", "words": [66, 67, 68, 69, 70, 71]}, {"id": 13, "text": "D Répondez oralement à l'exercice précédent à la forme négative (précisez, selon le modèle).", "words": [72, 73, 74, 75, 76, 77, 78, 79, 80, 81, 82, 83, 84, 85]}, {"id": 14, "text": "- Non, je ne la regarde pas tous Les jours (je la regarde de temps en temps).", "words": [86, 87, 88, 89, 90, 91, 92, 93, 94, 95, 96, 97, 98, 99, 100, 101, 102]}, {"id": 15, "text": "D Complétez, selon le modèle.", "words": [103, 104, 105, 106, 107]}, {"id": 16, "text": "1.", "words": [108]}, {"id": 17, "text": "- Vous connaissez Martine ?", "words": [109, 110, 111, 112, 113]}, {"id": 18, "text": "4.", "words": [114]}, {"id": 19, "text": "- Tu emmènes ton fils au cinéma ?", "words": [115, 116, 117, 118, 119, 120, 121, 122]}, {"id": 20, "text": "- Oui, je la connais depuis quinze ans !", "words": [123, 124, 125, 126, 127, 128, 129, 130, 131]}, {"id": 21, "text": "— Non, auzoo.", "words": [132, 133, 134]}, {"id": 22, "text": "2.", "words": [135]}, {"id": 23, "text": "- Tu regardes le match chez Joseph ?", "words": [136, 137, 138, 139, 140, 141, 142, 143]}, {"id": 24, "text": "5.", "words": [144]}, {"id": 25, "text": "- Vous laissez vos clés à l'hôtel ?", "words": [145, 146, 147, 148, 149, 150, 151, 152]}, {"id": 26, "text": "- Non, chezÉric.", "words": [153, 154, 155]}, {"id": 27, "text": "- réception.", "words": [156, 157]}, {"id": 28, "text": "3.", "words": [158]}, {"id": 29, "text": "- Vous arrosez les fleurs tous les jours ?", "words": [159, 160, 161, 162, 163, 164, 165, 166, 167]}, {"id": 30, "text": "6.", "words": [168]}, {"id": 31, "text": "- Vous faites ces exercices à l'école ?", "words": [169, 170, 171, 172, 173, 174, 175, 176]}, {"id": 32, "text": "— Oui, soirs.", "words": [177, 178, 179]}, {"id": 33, "text": "- Non, moi.", "words": [180, 181, 182]}, {"id": 34, "text": "€» Complétez avec les pronoms et les verbes manquants.", "words": [183, 184, 185, 186, 187, 188, 189, 190, 191]}, {"id": 35, "text": "- Vous achetez vos chaussures à Paris ?", "words": [192, 193, 194, 195, 196, 197, 198, 199]}, {"id": 36, "text": "- Non, je Les achète à Florence !", "words": [200, 201, 202, 203, 204, 205, 206, 207]}, {"id": 37, "text": "1.", "words": [208]}, {"id": 38, "text": "- Alex emporte ses dossiers chez lui ?", "words": [209, 210, 211, 212, 213, 214, 215, 216]}, {"id": 39, "text": "- Oui, pour le week-end.", "words": [217, 218, 219, 220, 221]}, {"id": 40, "text": "2.", "words": [222]}, {"id": 41, "text": "- Marie nous attend dans la rue ?", "words": [223, 224, 225, 226, 227, 228, 229, 230]}, {"id": 42, "text": "- Non, au bar.", "words": [231, 232, 233, 234]}, {"id": 43, "text": "3.", "words": [235]}, {"id": 44, "text": "- Vous connaissez bien cet homme ?", "words": [236, 237, 238, 239, 240, 241, 242]}, {"id": 45, "text": "- Non, seulement de vue.", "words": [243, 244, 245, 246, 247]}, {"id": 46, "text": "4.", "words": [248]}, {"id": 47, "text": "Est-ce que vous m'entendez ?", "words": [249, 250, 251, 252, 253]}, {"id": 48, "text": "- Oui, très bien !", "words": [254, 255, 256, 257, 258]}, {"id": 49, "text": "5.", "words": [259]}, {"id": 50, "text": "- Attention : vous oubliez vos clés !", "words": [260, 261, 262, 263, 264, 265, 266, 267]}, {"id": 51, "text": "- Ah oui, tout le temps !", "words": [268, 269, 270, 271, 272, 273, 274]}, {"id": 52, "text": "6.", "words": [275]}, {"id": 53, "text": "- Vous aimez le poulet au curry ?", "words": [276, 277, 278, 279, 280, 281, 282, 283]}, {"id": 54, "text": "- Oui, .", "words": [284, 285, 286]}, {"id": 55, "text": "C'est bon.", "words": [287, 288]}, {"id": 56, "text": "> Répondez librement en vous inspirant du modèle.", "words": [289, 290, 291, 292, 293, 294, 295, 296]}, {"id": 57, "text": "Quand allumez-vous le chauffage ?", "words": [297, 298, 299, 300, 301]}, {"id": 58, "text": "Je lallume quand il fait froid.", "words": [302, 303, 304, 305, 306, 307]}, {"id": 59, "text": "Quand rechargez-vous votre portable ?", "words": [308, 309, 310, 311, 312]}, {"id": 60, "text": "Quand nettoyez-vous vos vêtements ?", "words": [313, 314, 315, 316, 317]}, {"id": 61, "text": "Quand appelez-vous le médecin ?", "words": [318, 319, 320, 321, 322]}, {"id": 62, "text": "Quand mettez-vous l'alarme de votre réveil ?", "words": [323, 324, 325, 326, 327, 328, 329]}, {"id": 63, "text": "Quand videz-vous la corbeille de votre ordinateur ?", "words": [330, 331, 332, 333, 334, 335, 336, 337]}, {"id": 64, "text": "Quand allumez-vous la lumière ?", "words": [338, 339, 340, 341, 342]}, {"id": 65, "text": "Quand éteignez-vous le chauffage ?", "words": [343, 344, 345, 346, 347]}]}