, {"id": 12, "text": "poli poliment absolu absolument modéré modérément vrai vraiment Mais : gai — gaiement e Quand l'adjectif masculin se termine par « -ent » ou « -ant », l’adverbe se termine par « -emment » où « -amment » : récent récemment", "words": [72, 73, 74, 75, 76, 77, 78, 79, 80, 81, 82, 83, 84, 85, 86, 87, 88, 89, 90, 91, 92, 93, 94, 95, 96, 97, 98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 111, 112]}, {"id": 13, "text": "fréquent fréquemment On prononce : a-ment.", "words": [113, 114, 115, 116, 117, 118]}, {"id": 14, "text": "suffisant suffisamment", "words": [119, 120]}, {"id": 15, "text": "M Cas particuliers :", "words": [121, 122, 123, 124]}, {"id": 16, "text": "précis précisément énorme énormément profond profondément intense intensément", "words": [125, 126, 127, 128, 129, 130, 131, 132]}, {"id": 17, "text": "QUELQUES ADVERBES de TEMPS et de LIEU", "words": [133, 134, 135, 136, 137, 138, 139]}, {"id": 18, "text": "M Adverbes de temps :", "words": [140, 141, 142, 143, 144]}, {"id": 19, "text": "toujours ne …", "words": [145, 146, 147]}, {"id": 20, "text": "pas toujours | de temps en temps rarement ne jamais souvent ne …", "words": [148, 149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159, 160]}, {"id": 21, "text": "pas souvent |de temps en temps rarement ne …", "words": [161, 162, 163, 164, 165, 166, 167, 168, 169]}, {"id": 22, "text": "jamais quelquefois |ne …", "words": [170, 171, 172, 173]}, {"id": 23, "text": "pas toujours | de temps en temps rarement ne …", "words": [174, 175, 176, 177, 178, 179, 180, 181, 182, 183]}, {"id": 24, "text": "jamais", "words": [184]}, {"id": 25, "text": "assez tôt assez tard très tard", "words": [185, 186, 187, 188, 189, 190]}, {"id": 26, "text": "M Adverbes de lieu :", "words": [191, 192, 193, 194, 195]}, {"id": 27, "text": "— Îl fait chaud dedans!", "words": [196, 197, 198, 199, 200]}, {"id": 28, "text": "- Oui, mais dehors, il fait froid.", "words": [201, 202, 203, 204, 205, 206, 207]}, {"id": 