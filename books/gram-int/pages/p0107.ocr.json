xt": "5.", "words": [84]}, {"id": 16, "text": "- Vous êtes chez vous jusqu'à 8 h ou jusqu'à 9 h ?", "words": [85, 86, 87, 88, 89, 90, 91, 92, 93, 94, 95, 96, 97]}, {"id": 17, "text": "-", "words": [98]}, {"id": 18, "text": "Répondez en utilisant « y », selon le modèle.", "words": [99, 100, 101, 102, 103, 104, 105, 106, 107]}, {"id": 19, "text": "Je vais à la piscine à 16 h.", "words": [108, 109, 110, 111, 112, 113, 114, 115]}, {"id": 20, "text": "Et vous ?", "words": [116, 117, 118]}, {"id": 21, "text": "J'y vais aussi à 16 h.", "words": [119, 120, 121, 122, 123, 124]}, {"id": 22, "text": "— Nous théâtre jeudi soir.", "words": [125, 126, 127, 128, 129]}, {"id": 23, "text": "Et vous ?", "words": [130, 131, 132]}, {"id": 24, "text": "- Nous — Mon frère Grèce en juin.", "words": [133, 134, 135, 136, 137, 138, 139, 140]}, {"id": 25, "text": "Etvosamis?", "words": [141]}, {"id": 26, "text": "— Ils", "words": [142, 143]}, {"id": 27, "text": "— Mes États-Unis à Noël.", "words": [144, 145, 146, 147, 148]}, {"id": 28, "text": "Et Max ?", "words": [149, 150, 151]}, {"id": 29, "text": "- Il", "words": [152, 153]}, {"id": 30, "text": "— Nous cinéma samedi.", "words": [154, 155, 156, 157]}, {"id": 31, "text": "Et Paula ?", "words": [158, 159, 160]}, {"id": 32, "text": "- Elle", "words": [161, 162]}, {"id": 33, "text": "3%) Répondez aux questions à partir du texte en utilisant « y ».", "words": [163, 164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174, 175]}, {"id": 34, "text": "Arts et Sciences", "words": [176, 177, 178]}, {"id": 35, "text": "Aujourd'hui, Antoine va au Louvre avec son amie | d'Antoine, Gloria, ne s'intéresse pas à l'art.", "words": [179, 180, 181, 182, 183, 184, 185, 186, 187, 188, 189, 190, 191, 192, 193, 194]}, {"id": 36, "text": "Elle Isabelle.", "words": [195, 196]}, {"id": 37, "text": "Ils s'intéressent tous les deux à la peinture | s'intéresse plutôt à la science et aux techniques.", "words": [197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210, 211, 212, 213]}, {"id": 38, "text": "et ils vont toujours ensemble voir les expositions.", "words": [214, 215, 216, 217, 218, 219, 220, 221]}, {"id": 39, "text": "Il | Ce soir, Gloria va à La Villette à bicyclette avec", "words": [222, 223, 224, 225, 226, 227, 228, 229, 230, 231, 232, 233]}, {"id": 40, "text": "fait beau.", "words": [234, 235]}, {"id": 41, "text": "Antoine et Isabelle vont jusqu'au Louvre | François, le mari d'Isabelle.", "words": [236, 237, 238, 239, 240, 241, 242, 243, 244, 245, 246]}, {"id": 42, "text": "Puis les deux couples se à pied en marchant le long de la Seine.", "words": [247, 248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259, 260]}, {"id": 43, "text": "La femme | retrouvent dans une brasserie vers 22 h.", "words": [261, 262, 263, 264, 265, 266, 267, 268, 269, 270]}, {"id": 44, "text": "1.", "words": [271]}, {"id": 45, "text": "Antoine va au Louvre avec qui ?", "words": [272, 273, 274, 275, 276, 277, 278]}, {"id": 46, "text": "2.", "words": [279]}, {"id": 47, "text": "Est-ce que Gloria s'intéresse à la science ?", "words": [280, 281, 282, 283, 284, 285, 286, 287]}, {"id": 48, "text": "3.", "words": [288]}, {"id": 49, "text": "Est-ce qu'elle s'intéresse à la peinture ?", "words": [289, 290, 291, 292, 293, 294, 295]}, {"id": 50, "text": "4.", "words": [296]}, {"id": 51, "text": "Antoine va au Louvre en voiture ?", "words": [297, 298, 299, 300, 301, 302, 303]}, {"id": 52, "text": "5.", "words": [304]}, {"id": 53, "text": "Gloria et François vont à la Villette en métro ?", "words": [305, 306, 307, 308, 309, 310, 311, 312, 313, 314]}, {"id": 54, "text": "ED > Répondez à la forme négative et imaginez des explications.", "words": [315, 316, 317, 318, 319, 320, 321, 322, 323, 324, 325]}, {"id": 55, "text": "1.", "words": [326]}, {"id": 56, "text": "Vous allez à la piscine le samedi ?- Non, je H}y vais pas Le samedi parce quil y a trop de monde.", "words": [327, 328, 329, 330, 331, 332, 333, 334, 335, 336, 337, 338, 339, 340, 341, 342, 343, 344, 345, 346, 347, 348]}, {"id": 57, "text": "2.", "words": [349]}, {"id": 58, "text": "Vous allez au bureau à pied ?", "words": [350, 351, 352, 353, 354, 355, 356]}, {"id": 59, "text": "3.", "words": [357]}, {"id": 60, "text": "Vous allez au cinéma en semaine ?", "words": [358, 359, 360, 361, 362, 363, 364]}, {"id": 61, "text": "4.", "words": [365]}, {"id": 62, "text": "Vous allez à la plage à midi ?", "words": [366, 367, 368, 369, 370, 371, 372, 373]}]}