156]}, {"id": 16, "text": "en Canada.", "words": [157, 158]}, {"id": 17, "text": "Je vais à Je vais en Je vais aux États-Unis.", "words": [159, 160, 161, 162, 163, 164, 165, 166, 167, 168]}, {"id": 18, "text": "û en aux Pays-Bas.", "words": [169, 170, 171, 172]}, {"id": 19, "text": "e « en » devant tout pays singulier qui commence par une voyelle :", "words": [173, 174, 175, 176, 177, 178, 179, 180, 181, 182, 183, 184, 185, 186]}, {"id": 20, "text": "> — {Angola — en_Angola n n", "words": [187, 188, 189, 190, 191, 192, 193]}, {"id": 21, "text": "e Villes avec article : Je vais à La Havane et au Caire.", "words": [194, 195, 196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206]}, {"id": 22, "text": "44 e quarante-quatre", "words": [207, 208, 209]}]}