62, 63]}, {"id": 11, "text": "Il'est anglais.", "words": [64, 65]}, {"id": 12, "text": "Il est protestant.", "words": [66, 67, 68]}, {"id": 13, "text": "Il est marié.", "words": [69, 70, 71]}, {"id": 14, "text": "M On met un article pour apporter une précision :", "words": [72, 73, 74, 75, 76, 77, 78, 79, 80, 81]}, {"id": 15, "text": "Paul est un professeur exceptionnel.", "words": [82, 83, 84, 85, 86]}, {"id": 16, "text": "Paul est un bon professeur.", "words": [87, 88, 89, 90, 91]}, {"id": 17, "text": "+ On ne met pas d'article quand la précision indique une catégorie professionnelle :", "words": [92, 93, 94, 95, 96, 97, 98, 99, 100, 101, 102, 103, 104, 105]}, {"id": 18, "text": "Paul est médecin généraliste Paul est un bon médecin.", "words": [106, 107, 108, 109, 110, 111, 112, 113, 114]}, {"id": 19, "text": "(« Médecin généraliste » est une catégorie professionnelle, mais pas « bon médecin ».)", "words": [115, 116, 117, 118, 119, 120, 121, 122, 123, 124, 125, 126, 127, 128]}, {"id": 20, "text": "e Onutilise « c'est » au lieu de « il est » devant un nom déterminé :", "words": [129, 130, 131, 132, 133, 134, 135, 136, 137, 138, 139, 140, 141, 142, 143, 144, 145]}, {"id": 21, "text": "— C’est mon voisin.", "words": [146, 147, 148, 149]}, {"id": 22, "text": "- Îlest sympathique ?", "words": [150, 151, 152, 153]}, {"id": 23, "text": "- C'est un professeur.", "words": [154, 155, 156, 157]}, {"id": 24, "text": "- professeur de quoi ?", "words": [158, 159, 160, 161, 162]}, {"id": 25, "text": "- C’est un jeune professeur d'anglais.", "words": [163, 164, 165, 166, 167, 168]}, {"id": 26, "text": "Ah, il est prof d'anglais!", "words": [169, 170, 171, 172, 173]}, {"id": 27, "text": "« C’est » + nom déterminé «Il est » + adjectif ou profession", "words": [174, 175, 176, 177, 178, 179, 180, 181, 182, 183, 184, 185, 186]}, {"id": 28, "text": "À e Dites: Ne dites pas :", "words": [187, 188, 189, 190, 191, 192, 193]}, {"id": 29, "text": "C’est un bon professeur.", "words": [194, 195, 196, 197]}, {"id": 30, "text": "Ilest px...", "words": [198, 199]}, {"id": 31, "text": "C’est mon voisin.", "words": [200, 201, 202]}, {"id": 32, "text": "Il est …", "words": [203, 204, 205]}, {"id": 33, "text": "M Certains noms de profession qui n'avaient pas de féminin ont aujourd’hui deux formes.", "words": [206, 207, 208, 209, 210, 211, 212, 213, 214, 215, 216, 217, 218, 219]}, {"id": 34, "text": "professeur.", "words": [220]}, {"id": 35, "text": "professeur/professeure.", "words": [221]}, {"id": 36, "text": "Paul est | écrivain.", "words": [222, 223, 224, 225]}, {"id": 37, "text": "Marie est | écrivain/écrivaine.", "words": [226, 227, 228, 229]}, {"id": 38, "text": "auteur.", "words": [230]}, {"id": 39, "text": "auteur/auteure.", "words": [231]}, {"id": 40, "text": "À e À la question : + Répondez:", "words": [232, 233, 234, 235, 236, 237, 238, 239]}, {"id": 41, "text": "— Quelle est votre profession?", "words": [240, 241, 242, 243, 244]}, {"id": 42, "text": "— Je suis professeur/comptable…", "words": [245, 246, 247, 248]}, {"id": 43, "text": "— Qu'est-ce que vous faites - Je travaille dans une école/banque…", "words": [249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259]}, {"id": 44, "text": "(comme travail/dans la vie) ?", "words": [260, 261, 262, 263, 264]}, {"id": 45, "text": "Maæprofessiorest-comptabte-", "words": [265]}, {"id": 46, "text": "34 trente-quatre", "words": [266, 267]}]}