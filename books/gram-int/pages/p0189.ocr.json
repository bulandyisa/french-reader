22, 123, 124, 125, 126, 127, 128]}, {"id": 24, "text": "- Ma femme 3.", "words": [129, 130, 131, 132]}, {"id": 25, "text": "- Je me suis dépêché pour arriver à l'heure.", "words": [133, 134, 135, 136, 137, 138, 139, 140, 141]}, {"id": 26, "text": "- Je", "words": [142, 143]}, {"id": 27, "text": "4.", "words": [144]}, {"id": 28, "text": "- On s'est couchés tard hier soir.", "words": [145, 146, 147, 148, 149, 150, 151]}, {"id": 29, "text": "- Nous", "words": [152, 153]}, {"id": 30, "text": "GD Répondez en utilisant des pronominaux réciproques, selon le modèle.", "words": [154, 155, 156, 157, 158, 159, 160, 161, 162, 163]}, {"id": 31, "text": "1.", "words": [164]}, {"id": 32, "text": "- Quand avez-vous connu vos amis espagnols ?", "words": [165, 166, 167, 168, 169, 170, 171, 172]}, {"id": 33, "text": "(1990, Barcelone) - Nous nous sommes connus en 1990, à Barcelone.", "words": [173, 174, 175, 176, 177, 178, 179, 180, 181, 182, 183]}, {"id": 34, "text": "2.", "words": [184]}, {"id": 35, "text": "- Où avez-vous rencontré votre femme ?", "words": [185, 186, 187, 188, 189, 190, 191]}, {"id": 36, "text": "(plage de Saint-Tropez, hiver)", "words": [192, 193, 194, 195]}, {"id": 37, "text": "3.", "words": [196]}, {"id": 38, "text": "- Où vous êtes-vous mariés ?", "words": [197, 198, 199, 200, 201, 202]}, {"id": 39, "text": "(église de la Madeleine, printemps)", "words": [203, 204, 205, 206, 207]}, {"id": 40, "text": "4.", "words": [208]}, {"id": 41, "text": "- Quand avez-vous connu Arthur ?", "words": [209, 210, 211, 212, 213, 214]}, {"id": 42, "text": "(1981, concert des Clash)", "words": [215, 216, 217, 218]}, {"id": 43, "text": "5.", "words": [219]}, {"id": 44, "text": "- Quand vous êtes-vous revus ?", "words": [220, 221, 222, 223, 224, 225]}, {"id": 45, "text": "(2007, concert des Rita Mitsuko)", "words": [226, 227, 228, 229, 230]}, {"id": 46, "text": "€» Énumérez vos activités de ce matin GD >> Racontez au passé en utilisant les", "words": [231, 232, 233, 234, 235, 236, 237, 238, 239, 240, 241, 242, 243, 244, 245]}, {"id": 47, "text": "verbes pronominaux ci-dessous.", "words": [246, 247, 248]}, {"id": 48, "text": "F Une bagarre : se disputer, s'insulter, se battre, se réconcilier, se serrer la main.", "words": [249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259, 260, 261, 262, 263]}, {"id": 49, "text": "Les deux se", "words": [264, 265, 266]}, {"id": 50, "text": "Je me suis réveillé(e) à 7h, puis je me", "words": [267, 268, 269, 270, 271, 272, 273, 274, 275]}, {"id": 51, "text": "cent quatre-vingt-sept + 187", "words": [276, 277, 278, 279]}]}