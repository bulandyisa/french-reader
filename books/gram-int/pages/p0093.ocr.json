39, 40, 41, 42, 43, 44]}, {"id": 10, "text": "-", "words": [45]}, {"id": 11, "text": "2.", "words": [46]}, {"id": 12, "text": "- Vous mangez des produits bio ?", "words": [47, 48, 49, 50, 51, 52, 53]}, {"id": 13, "text": "-", "words": [54]}, {"id": 14, "text": "3.", "words": [55]}, {"id": 15, "text": "- Vous portez des fibres synthétiques ?", "words": [56, 57, 58, 59, 60, 61, 62]}, {"id": 16, "text": "- 4.", "words": [63, 64]}, {"id": 17, "text": "- Vous consommez de l'alcool ?", "words": [65, 66, 67, 68, 69, 70]}, {"id": 18, "text": "-", "words": [71]}, {"id": 19, "text": "5.", "words": [72]}, {"id": 20, "text": "- Vous avez du cholestérol ?", "words": [73, 74, 75, 76, 77, 78]}, {"id": 21, "text": "-", "words": [79]}, {"id": 22, "text": "D Répondez aux questions, selon le modèle.", "words": [80, 81, 82, 83, 84, 85, 86]}, {"id": 23, "text": "Abondance", "words": [87]}, {"id": 24, "text": "Non, il en a dix !", "words": [88, 89, 90, 91, 92, 93]}, {"id": 25, "text": "Votre mari a neuf sœurs ?", "words": [94, 95, 96, 97, 98, 99]}, {"id": 26, "text": "Vos parents ont deux télés ?", "words": [100, 101, 102, 103, 104, 105]}, {"id": 27, "text": "Vos enfants ont un ordinateur ?", "words": [106, 107, 108, 109, 110, 111]}, {"id": 28, "text": "Vous avez trois chats ?", "words": [112, 113, 114, 115, 116]}, {"id": 29, "text": "Vous avez une carte de crédit ?", "words": [117, 118, 119, 120, 121, 122, 123]}, {"id": 30, "text": "Posez la question et répondez selon le modèle.", "words": [124, 125, 126, 127, 128, 129, 130, 131]}, {"id": 31, "text": "tomates (2) eau (1 bouteille) yaourts (quelques-uns) beurre (un peu) viande (100 grammes) glaçons (beaucoup) lait (0) coca (0)", "words": [132, 133, 134, 135, 136, 137, 138, 139, 140, 141, 142, 143, 144, 145, 146, 147, 148, 149, 150]}, {"id": 32, "text": "= Dans le frigo, il y a des tomates ?", "words": [151, 152, 153, 154, 155, 156, 157, 158, 159, 160]}, {"id": 33, "text": "- Oui, ily en a deux.", "words": [161, 162, 163, 164, 165, 166]}, {"id": 34, "text": "A) Complétez à la forme négative.", "words": [167, 168, 169, 170, 171, 172]}, {"id": 35, "text": "Il y a du pétrole en Norvège, mais en France, // ny en à pas.", "words": [173, 174, 175, 176, 177, 178, 179, 180, 181, 182, 183, 184, 185, 186, 187]}, {"id": 36, "text": "1.", "words": [188]}, {"id": 37, "text": "J'ai des lunettes, mais ma fille 4,.1ly a de l'eau sur la Terre, mais sur Mars, 2.", "words": [189, 190, 191, 192, 193, 194, 195, 196, 197, 198, 199, 200, 201, 202, 203, 204, 205]}, {"id": 38, "text": "Léa a une voiture, mais son mari 5.", "words": [206, 207, 208, 209, 210, 211, 212, 213]}, {"id": 39, "text": "Je mange de la viande, mais mes amis 3.", "words": [214, 215, 216, 217, 218, 219, 220, 221, 222]}, {"id": 40, "text": "Max a de la chance au jeu.", "words": [223, 224, 225, 226, 227, 228, 229]}, {"id": 41, "text": "Moi, je 6.", "words": [230, 231, 232]}, {"id": 42, "text": "J'ai des cheveux blancs, mais vous", "words": [233, 234, 235, 236, 237, 238]}, {"id": 43, "text": "(53 >» Devinez de quoi il s'agit.", "words": [239, 240, 241, 242, 243, 244, 245]}, {"id": 44, "text": "Trouvez d'autres devinettes.", "words": [246, 247, 248]}, {"id": 45, "text": "GS", "words": [249]}, {"id": 46, "text": "1.", "words": [250]}, {"id": 47, "text": "J'en bois le matin.", "words": [251, 252, 253, 254]}, {"id": 48, "text": "Du thé.", "words": [255, 256]}, {"id": 49, "text": "4, J'en prends à la banque.", "words": [257, 258, 259, 260, 261, 262]}, {"id": 50, "text": "2.", "words": [263]}, {"id": 51, "text": "J'en mets sur mes 5.", "words": [264, 265, 266, 267, 268]}, {"id": 52, "text": "J'en mets sur mes tartines.", "words": [269, 270, 271, 272, 273]}, {"id": 53, "text": "3.", "words": [274]}, {"id": 54, "text": "J'en mets sur les frites.", "words": [275, 276, 277, 278, 279]}, {"id": 55, "text": "6.", "words": [280]}, {"id": 56, "text": "J'en prends à la station-service.", "words": [281, 282, 283, 284, 285]}, {"id": 57, "text": "Je m’évalue quatre-vingt-onze + 91", "words": [286, 287, 288, 289, 290]}]}