16, "text": "4.", "words": [73]}, {"id": 17, "text": "est la profession de monsieur Livingstone ?", "words": [74, 75, 76, 77, 78, 79, 80]}, {"id": 18, "text": "(explorateur imprudent) 5: est la profession de monsieur et madame Verdon ?", "words": [81, 82, 83, 84, 85, 86, 87, 88, 89, 90, 91, 92]}, {"id": 19, "text": "(comptables précis)", "words": [93, 94]}, {"id": 20, "text": "Complétez avec « il est »/« elle est » ou « c'est », selon le modèle.", "words": [95, 96, 97, 98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110]}, {"id": 21, "text": "Vous connaissez :1.", "words": [111, 112, 113]}, {"id": 22, "text": "Robert Doisneau?", "words": [114, 115]}, {"id": 23, "text": "- Oui, // est photographe.", "words": [116, 117, 118, 119, 120]}, {"id": 24, "text": "un très grand photographe.", "words": [121, 122, 123, 124]}, {"id": 25, "text": "2.", "words": [125]}, {"id": 26, "text": "Marie Ravel?", "words": [126, 127]}, {"id": 27, "text": "— Oui, __ architecte d'intérieur.", "words": [128, 129, 130, 131, 132]}, {"id": 28, "text": "notre architecte.", "words": [133, 134]}, {"id": 29, "text": "3.", "words": [135]}, {"id": 30, "text": "Céline Dion?", "words": [136, 137]}, {"id": 31, "text": "- Oui, une chanteuse.", "words": [138, 139, 140, 141]}, {"id": 32, "text": "4.", "words": [142]}, {"id": 33, "text": "Monsieur Jones?", "words": [143, 144]}, {"id": 34, "text": "- Oui, __ le chat du voisin.", "words": [145, 146, 147, 148, 149, 150, 151]}, {"id": 35, "text": "Complétez le dialogue avec «il est »/« elle est » ou « c'est ».", "words": [152, 153, 154, 155, 156, 157, 158, 159, 160, 161, 162, 163, 164, 165]}, {"id": 36, "text": "Continuez librement.", "words": [166, 167]}, {"id": 37, "text": "Mondanités — Qui est cet homme?", "words": [168, 169, 170, 171, 172, 173]}, {"id": 38, "text": "- Julie est mariée ?", "words": [174, 175, 176, 177, 178]}, {"id": 39, "text": "- Cest Paul Marat.", "words": [179, 180, 181, 182]}, {"id": 40, "text": "un ami de Julie.", "words": [183, 184, 185, 186]}, {"id": 41, "text": "— Non, célibataire.", "words": [187, 188, 189]}, {"id": 42, "text": "— Qu'est-ce qu'il fait?", "words": [190, 191, 192, 193]}, {"id": 43, "text": "— Qu'est-ce qu'elle fait maintenant ?", "words": [194, 195, 196, 197, 198, 199]}, {"id": 44, "text": "— : - Maintenant, professeur de yoga.", "words": [200, 201, 202, 203, 204, 205, 206]}, {"id": 45, "text": "journaliste très connu.", "words": [207, 208, 209]}, {"id": 46, "text": "— Ah oui, bouddhiste, je crois.", "words": [210, 211, 212, 213, 214, 215]}, {"id": 47, "text": "— Et cette femme : qui est-ce ?", "words": [216, 217, 218, 219, 220, 221, 222, 223]}, {"id": 48, "text": "— Oui, et une végétarienne — la mère de Julie.", "words": [224, 225, 226, 227, 228, 229, 230, 231, 232, 233]}, {"id": 49, "text": "convaincue.", "words": [234]}, {"id": 50, "text": "— jeune!", "words": [235, 236]}, {"id": 51, "text": "Qu'est-ce qu'elle fait?", "words": [237, 238, 239]}, {"id": 52, "text": "- Et la jolie brune là-bas, qui est-ce ?", "words": [240, 241, 242, 243, 244, 245, 246, 247, 248]}, {"id": 53, "text": "— pédiatre.", "words": [249, 250]}, {"id": 54, "text": "| 42 > Donnez les noms de deux personnalités de votre pays.", "words": [251, 252, 253, 254, 255, 256, 257, 258, 259, 260, 261, 262]}, {"id": 55, "text": "Faites deviner leur profession.", "words": [263, 264, 265, 266]}]}