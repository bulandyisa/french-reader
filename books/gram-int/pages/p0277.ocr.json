d": 15, "text": "46.", "words": [76]}, {"id": 16, "text": "Pierre est malade : c'est la raison il est absent.", "words": [77, 78, 79, 80, 81, 82, 83, 84, 85, 86]}, {"id": 17, "text": "47.", "words": [87]}, {"id": 18, "text": "Nous passerons chez toi demain si nous le temps.", "words": [88, 89, 90, 91, 92, 93, 94, 95, 96]}, {"id": 19, "text": "48.", "words": [97]}, {"id": 20, "text": "ma voiture était en panne, je suis venu en métro.", "words": [98, 99, 100, 101, 102, 103, 104, 105, 106, 107]}, {"id": 21, "text": "49.", "words": [108]}, {"id": 22, "text": "Le directeur m'appelle dans son bureau.", "words": [109, 110, 111, 112, 113, 114]}, {"id": 23, "text": "Il faut que je tout de suite.", "words": [115, 116, 117, 118, 119, 120, 121]}, {"id": 24, "text": "50.", "words": [122]}, {"id": 25, "text": "Jean est à l'hôpital : il un accident sur l'autoroute hier soir.", "words": [123, 124, 125, 126, 127, 128, 129, 130, 131, 132, 133, 134]}, {"id": 26, "text": "51.", "words": [135]}, {"id": 27, "text": "Nous allons au cinéma : tu ?", "words": [136, 137, 138, 139, 140, 141, 142]}, {"id": 28, "text": "52.", "words": [143]}, {"id": 29, "text": "une aspirine avec un verre d'eau si vous avez mal à la tête.", "words": [144, 145, 146, 147, 148, 149, 150, 151, 152, 153, 154, 155, 156]}, {"id": 30, "text": "53.- passe dehors ?", "words": [157, 158, 159, 160]}, {"id": 31, "text": "- Je ne sais pas ce qui se passe !", "words": [161, 162, 163, 164, 165, 166, 167, 168, 169, 170]}, {"id": 32, "text": "54, Pour voter, plus de dix-huit ans.", "words": [171, 172, 173, 174, 175, 176, 177]}, {"id": 33, "text": "55.", "words": [178]}, {"id": 34, "text": "Je me suis levé à 5 h du matin et je une douche glacée !", "words": [179, 180, 181, 182, 183, 184, 185, 186, 187, 188, 189, 190, 191, 192, 193]}, {"id": 35, "text": "56.- Vous avez assez de café ou vous encore ?", "words": [194, 195, 196, 197, 198, 199, 200, 201, 202, 203]}, {"id": 36, "text": "57.", "words": [204]}, {"id": 37, "text": "La tour Eiffel construite il y a plus de cent ans.", "words": [205, 206, 207, 208, 209, 210, 211, 212, 213, 214, 215]}, {"id": 38, "text": "58.", "words": [216]}, {"id": 39, "text": "Je ne savais pas que le directeur", "words": [217, 218, 219, 220, 221, 222, 223]}, {"id": 40, "text": "59.", "words": [224]}, {"id": 41, "text": "Je n'ai pas montré mon projet à ma mère, mais je", "words": [225, 226, 227, 228, 229, 230, 231, 232, 233, 234, 235]}, {"id": 42, "text": "y a quelqu'un dans la salle 8 ?", "words": [236, 237, 238, 239, 240, 241, 242, 243]}, {"id": 43, "text": "- Non, il", "words": [244, 245, 246]}, {"id": 44, "text": "deux cent soixante-quinze + 275", "words": [247, 248, 249, 250, 251]}]}