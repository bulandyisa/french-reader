: [70, 71, 72, 73, 74, 75, 76, 77, 78, 79]}, {"id": 11, "text": "3.", "words": [80]}, {"id": 12, "text": "- Est-ce que vous pouvez faire vos calculs sans calculatrice ?", "words": [81, 82, 83, 84, 85, 86, 87, 88, 89, 90, 91]}, {"id": 13, "text": "4.", "words": [92]}, {"id": 14, "text": "— Est-ce que vous pouvez toucher le plafond de la main ?", "words": [93, 94, 95, 96, 97, 98, 99, 100, 101, 102, 103, 104]}, {"id": 15, "text": "5.", "words": [105]}, {"id": 16, "text": "- Est-ce que vous pouvez fumer en classe ?", "words": [106, 107, 108, 109, 110, 111, 112, 113, 114]}, {"id": 17, "text": "Complétez avec « on doit » ou « on peut ».", "words": [115, 116, 117, 118, 119, 120, 121, 122, 123, 124, 125]}, {"id": 18, "text": "Quand on prend l'avion", "words": [126, 127, 128, 129]}, {"id": 19, "text": "On doit se présenter 1 heure avant le départ.", "words": [130, 131, 132, 133, 134, 135, 136, 137, 138]}, {"id": 20, "text": "fumer dans l'avion.", "words": [139, 140, 141]}, {"id": 21, "text": "faire le check-in.", "words": [142, 143, 144]}, {"id": 22, "text": "attacher sa ceinture au décollage.", "words": [145, 146, 147, 148, 149]}, {"id": 23, "text": "avoir plus de 20 kg de bagages.", "words": [150, 151, 152, 153, 154, 155, 156]}, {"id": 24, "text": "écouter de la musique.", "words": [157, 158, 159, 160]}, {"id": 25, "text": "passer les contrôles de sécurité.", "words": [161, 162, 163, 164, 165]}, {"id": 26, "text": "s'allonger complètement", "words": [166, 167]}, {"id": 27, "text": "transporter des objets dangereux.", "words": [168, 169, 170, 171]}, {"id": 28, "text": "acheter des produits hors taxes.", "words": [172, 173, 174, 175, 176]}, {"id": 29, "text": "Probabilité.", "words": [177]}, {"id": 30, "text": "Complétez selon le modèle.", "words": [178, 179, 180, 181]}, {"id": 31, "text": "1.", "words": [182]}, {"id": 32, "text": "- Quelle heure il est ?", "words": [183, 184, 185, 186, 187, 188]}, {"id": 33, "text": "- Je ne sais pas, mais j'ai sommeil.", "words": [189, 190, 191, 192, 193, 194, 195, 196]}, {"id": 34, "text": "Il éére minuit passé.", "words": [197, 198, 199, 200]}, {"id": 35, "text": "2.", "words": [201]}, {"id": 36, "text": "- Combien font 5 dollars ?", "words": [202, 203, 204, 205, 206, 207]}, {"id": 37, "text": "- Je ne sais pas, mais ça environ 4 euros.", "words": [208, 209, 210, 211, 212, 213, 214, 215, 216, 217]}, {"id": 38, "text": "3.", "words": [218]}, {"id": 39, "text": "- Combien coûte une limousine ?", "words": [219, 220, 221, 222, 223, 224]}, {"id": 40, "text": "- Je ne sais pas, mais ça une fortune.", "words": [225, 226, 227, 228, 229, 230, 231, 232, 233]}, {"id": 41, "text": "4.", "words": [234]}, {"id": 42, "text": "- Ma connexion Internet ne marche pas : il un problème avec mon serveur.", "words": [235, 236, 237, 238, 239, 240, 241, 242, 243, 244, 245, 246, 247, 248]}, {"id": 43, "text": "D Complétez le texte avec « pouvoir », « devoir » ou « falloir ».", "words": [249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259, 260, 261, 262, 263]}, {"id": 44, "text": "Pour pouvoir voter en France, avoir la nationalité française, et être majeur.", "words": [264, 265, 266, 267, 268, 269, 270, 271, 272, 273, 274, 275]}, {"id": 45, "text": "En France, les femmes voter seulement depuis 1945 !", "words": [276, 277, 278, 279, 280, 281, 282, 283, 284]}, {"id": 46, "text": "Pour être élu, le président de la", "words": [285, 286, 287, 288, 289, 290, 291]}, {"id": 47, "text": "République rassembler la majorité des voix.", "words": [292, 293, 294, 295, 296, 297]}, {"id": 48, "text": "Pour être valables, les bulletins de vote ne pas porter d'inscription.", "words": [298, 299, 300, 301, 302, 303, 304, 305, 306, 307, 308]}, {"id": 49, "text": "Certains électeurs voter par correspondance, mais", "words": [309, 310, 311, 312, 313, 314]}, {"id": 50, "text": "ils prouver qu'ilsne pas se déplacer.", "words": [315, 316, 317, 318, 319, 320]}, {"id": 51, "text": "> >» Dans votre pays, à quel âge peut-on voter, conduire un scooter, c