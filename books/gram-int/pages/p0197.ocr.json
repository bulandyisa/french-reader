: [4, 5, 6, 7, 8, 9, 10]}, {"id": 2, "text": "LE PASSÉ COMPOSÉ", "words": [11, 12, 13]}, {"id": 3, "text": "|", "words": [14]}, {"id": 4, "text": "Répondez à la forme négative.", "words": [15, 16, 17, 18, 19]}, {"id": 5, "text": "- Êtes-vous allé au cinéma samedi dernier ?", "words": [20, 21, 22, 23, 24, 25, 26, 27]}, {"id": 6, "text": "- Mon, je ne suis pas allé au cinéma.", "words": [28, 29, 30, 31, 32, 33, 34, 35, 36]}, {"id": 7, "text": "1.", "words": [37]}, {"id": 8, "text": "- Êtes-vous allé à la campagne ?", "words": [38, 39, 40, 41, 42, 43, 44]}, {"id": 9, "text": "-", "words": [45]}, {"id": 10, "text": "2.", "words": [46]}, {"id": 11, "text": "- Êtes-vous monté sur la tour Eiffel ?", "words": [47, 48, 49, 50, 51, 52, 53, 54]}, {"id": 12, "text": "- 3.", "words": [55, 56]}, {"id": 13, "text": "- Avez-vous dîné au restaurant ?", "words": [57, 58, 59, 60, 61, 62]}, {"id": 14, "text": "-", "words": [63]}, {"id": 15, "text": "4.", "words": [64]}, {"id": 16, "text": "- Avez-vous invité vos amis ?", "words": [65, 66, 67, 68, 69, 70]}, {"id": 17, "text": "—", "words": [71]}, {"id": 18, "text": "5.", "words": [72]}, {"id": 19, "text": "- Avez-vous révisé vos leçons ?", "words": [73, 74, 75, 76, 77, 78]}, {"id": 20, "text": "-", "words": [79]}, {"id": 21, "text": "ŒD Donnez un avis opposé, à la forme négative.", "words": [80, 81, 82, 83, 84, 85, 86, 87, 88]}, {"id": 22, "text": "Au théâtre", "words": [89, 90]}, {"id": 23, "text": "Ma femme a aimé.", "words": [91, 92, 93, 94]}, {"id": 24, "text": "Elle a ri.", "words": [95, 96, 97]}, {"id": 25, "text": "Elle a pleuré.", "words": [98, 99, 100]}, {"id": 26, "text": "Elle a crié.", "words": [101, 102, 103]}, {"id": 27, "text": "Elle a applaudi.", "words": [104, 105, 106]}, {"id": 28, "text": "Moi, je pas aimé.", "words": [107, 108, 109, 110]}, {"id": 29, "text": "ED Répondez en utilisant la négation et les pronoms, et en faisant les accords si c'est nécessaire.", "words": [111, 112, 113, 114, 115, 116, 117, 118, 119, 120, 121, 122, 123, 124, 125, 126, 127]}, {"id": 30, "text": "1.", "words": [128]}, {"id": 31, "text": "- Vous avez retrouvé vos clés ?", "words": [129, 130, 131, 132, 133, 134, 135]}, {"id": 32, "text": "- No, je ne Les ai pas retrouvées.", "words": [136, 137, 138, 139, 140, 141, 142, 143]}, {"id": 33, "text": "2.", "words": [144]}, {"id": 34, "text": "- Vous avez fini vos exercices ?", "words": [145, 146, 147, 148, 149, 150, 151]}, {"id": 35, "text": "- 3.", "words": [152, 153]}, {"id": 36, "text": "- Vous avez fait votre valise ?", "words": [154, 155, 156, 157, 158, 159, 160]}, {"id": 37, "text": "— 4.", "words": [161, 162]}, {"id": 38, "text": "- Vous avez pris vos affaires ?", "words": [163, 164, 165, 166, 167, 168, 169]}, {"id": 39, "text": "- 5.", "words": [170, 171]}, {"id": 40, "text": "- Vous avez payé vos impôts ?", "words": [172, 173, 174, 175, 176, 177, 178]}, {"id": 41, "text": "—", "words": [179]}, {"id": 42, "text": "an) Posez les questions, selon le modèle.", "words": [180, 181, 182, 183, 184, 185, 186]}, {"id": 43, "text": "> Interrogez des amis sur leurs dernières vacances.", "words": [187, 188, 189, 190, 191, 192, 193, 194]}, {"id": 44, "text": "- Où êtes-vous allés pour les vacances ?", "words": [195, 196, 197, 198, 199, 200, 201, 202]}, {"id": 45, "text": "1.", "words": [203]}, {"id": 46, "text": "2.", "words": [204]}, {"id": 47, "text": "3.", "words": [205]}, {"id": 48, "text": "4.", "words": [206]}, {"id": 49, "text": "- 5.", "words": [207, 208]}, {"id": 50, "text": "6.", "words": [209]}, {"id": 51, "text": "7.", "words": [210]}, {"id": 52, "text": "> Répondez négativement.", "words": [211, 212, 213]}, {"id": 53, "text": "— Nous sommes allés en Russie.", "words": [214, 215, 216, 217, 218, 219]}, {"id": 54, "text": "— Nous y sommes restés deux semaines.", "words": [220, 221, 222, 223, 224, 225, 226]}, {"id": 55, "text": "— Nous sommes allés à l'hôtel Kalinka.", "words": [227, 228, 229, 230, 231, 232, 233]}, {"id": 56, "text": "— Nous avons visité Saint-Pétersbourg et Moscou.", "words": [234, 235, 236, 237, 238, 239, 240]}, {"id": 57, "text": "- Nous sommes partis le 15 juillet.", "words": [241, 242, 243, 244, 245, 246, 247]}, {"id": 58, "text": "— Nous avons dépensé deux mille euros.", "words": [248, 249, 250, 251, 252, 253, 254]}, {"id": 59, "text": "- Nous sommes rentrés", "words": [255, 256, 257, 258]}, {"id": 60, "text": "Vous avez mangé quelque chose à onze heures ?", "words": [259, 260, 261, 262, 263, 264, 265, 266, 267]}, {"id": 61, "text": "Vous avez bu quelque chose ?", "words": [268, 269, 270, 271, 272, 273]}, {"id": 62, "text": "Vous avez rencontré quelqu'un ?", "words": [274, 275, 276, 277, 278]}, {"id": 63, "text": "Vous avez fait quelque chose le week-end dernier?", "words": [279, 280, 281, 282, 283, 284, 285, 286]}, {"id": 64, "text": "Vous avez invité quelqu'un?", "words": [287, 288, 289, 290]}, {"id": 65, "text": "cent quatre-vingt-quinze + 195", "words": [291, 292, 293, 294]}]}