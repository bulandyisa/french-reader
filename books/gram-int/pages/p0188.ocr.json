3, 24, 25, 26, 27, 28, 29]}, {"id": 6, "text": "Je me suis levé(e) tôt.", "words": [30, 31, 32, 33, 34]}, {"id": 7, "text": "Tu es couché(e) tard.", "words": [35, 36, 37, 38]}, {"id": 8, "text": "Il", "words": [39]}, {"id": 9, "text": "Elle s’ est douché(e)(s).", "words": [40, 41, 42, 43]}, {"id": 10, "text": "On", "words": [44]}, {"id": 11, "text": "Nous sommes promené(e }s.", "words": [45, 46, 47, 48]}, {"id": 12, "text": "Vous êtes assis(e)(s).", "words": [49, 50, 51]}, {"id": 13, "text": "Ils", "words": [52]}, {"id": 14, "text": "Elles sont embrassé(e)s", "words": [53, 54, 55]}, {"id": 15, "text": "D En général, le participe passé (comme un adjectif) avec le sujet :", "words": [56, 57, 58, 59, 60, 61, 62, 63, 64, 65, 66, 67, 68]}, {"id": 16, "text": "Il s'est couché tôt.", "words": [69, 70, 71, 72]}, {"id": 17, "text": "Elle s'est couchée tard.", "words": [73, 74, 75, 76]}, {"id": 18, "text": "Ils se sont endormis tout de suite.", "words": [77, 78, 79, 80, 81, 82, 83]}, {"id": 19, "text": "« ÊTRE » ou « AVOIR » ?", "words": [84, 85, 86, 87, 88, 89, 90, 91]}, {"id": 20, "text": "Les verbes de type «arriver/partir », habituellement utilisés avec « être », se construisent avec « avoir » quand ils ont un complément d'objet direct :", "words": [92, 93, 94, 95, 96, 97, 98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 111, 112, 113, 114, 115, 116, 117]}, {"id": 21, "text": "e Sans complément d'objet direct + Avec complément d'objet direct — «être » — « avoir » Il'est sorti dans la rue.", "words": [118, 119, 120, 121, 122, 123, 124, 125, 126, 127, 128, 129, 130, 131, 132, 133, 134, 135, 136, 137, 138, 139]}, {"id": 22, "text": "Il a sorti le chien.", "words": [140, 141, 142, 143, 144]}, {"id": 23, "text": "Nous sommes rentrés tôt.", "words": [145, 146, 147, 148]}, {"id": 24, "text": "Nous avons rentré la voiture.", "words": [149, 150, 151, 152, 153]}, {"id": 25, "text": "Ils sont passés devant la banque.", "words": [154, 155, 156, 157, 158, 159]}, {"id": 26, "text": "Ils ont passé de bonnes vacances.", "words": [160, 161, 162, 163, 164, 165]}, {"id": 27, "text": "Elle est descendue à la cave.", "words": [166, 167, 168, 169, 170, 171]}, {"id": 28, "text": "Elle a descendu la poubelle.", "words": [172, 173, 174, 175, 176]}, {"id": 29, "text": "Je suis monté à pied.", "words": [177, 178, 179, 180, 181]}, {"id": 30, "text": "J'ai monté l'escalier.", "words": [182, 183, 184]}, {"id": 31, "text": "Je suis retourné au bureau.", "words": [185, 186, 187, 188, 189]}, {"id": 32, "text": "J'ai retourné le matelas.", "words": [190, 191, 192, 193]}, {"id": 33, "text": "Accord des participes passés, p.", "words": [194, 195, 196, 197, 198]}, {"id": 34, "text": "190", "words": [199]}, {"id": 35, "text": "186 + cent quatre-vingt-six", "words": [200, 201, 202, 203]}]}