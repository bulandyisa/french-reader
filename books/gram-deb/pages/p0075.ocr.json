90]}, {"id": 5, "text": "LA DATE: «es + (jour) + numéro", "words": [91, 92, 93, 94, 95, 96, 97]}, {"id": 6, "text": "le mardi trois mai.", "words": [98, 99, 100, 101]}, {"id": 7, "text": "Nous sommes le trois mai.", "words": [102, 103, 104, 105, 106]}, {"id": 8, "text": "Â * Dites: Le mardi trois.", "words": [107, 108, 109, 110, 111, 112]}, {"id": 9, "text": "Ne dites pas : Mardi-te-trois.", "words": [113, 114, 115, 116, 117]}, {"id": 10, "text": "* Avec un nom de mois, on dit «le premier», mais «le deux», «le trois», etc.", "words": [118, 119, 120, 121, 122, 123, 124, 125, 126, 127, 128, 129, 130, 131, 132, 133]}, {"id": 11, "text": "le premier mai?", "words": [134, 135, 136]}, {"id": 12, "text": "le deux mai?", "words": [137, 138, 139]}, {"id": 13, "text": "le trois mai?", "words": [140, 141, 142]}, {"id": 14, "text": "Nous sommes", "words": [143, 144]}, {"id": 15, "text": "# LE JOUR: lundi, mardi, mercredi, jeudi, vendredi, samedi, dimanche", "words": [145, 146, 147, 148, 149, 150, 151, 152, 153, 154]}, {"id": 16, "text": "Aujourd'hui, c'est mardi.", "words": [155, 156, 157]}, {"id": 17, "text": ".", "words": [158]}, {"id": 18, "text": "on est mardi.", "words": [159, 160, 161]}, {"id": 19, "text": "Lundi = ce lundi: * Le lundi = tous les lundis: Lundi, je commence à 7 h.", "words": [162, 163, 164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174, 175, 176, 177, 178]}, {"id": 20, "text": "Le lundi, je suis fatigué.", "words": [179, 180, 181, 182, 183]}, {"id": 21, "text": "Mardi, je commence à 10h.", "words": [184, 185, 186, 187, 188]}, {"id": 22, "text": "Le mardi, je suis en forme.", "words": [189, 190, 191, 192, 193, 194]}, {"id": 23, "text": "74 + soixante-quatorze", "words": [195, 196, 197]}]}