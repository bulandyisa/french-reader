: [90, 91, 92, 93, 94, 95, 96, 97]}, {"id": 11, "text": "2 6.", "words": [98, 99]}, {"id": 12, "text": "- ?", "words": [100, 101]}, {"id": 13, "text": "— Je travaille dans une banque.", "words": [102, 103, 104, 105, 106, 107]}, {"id": 14, "text": "2 7.", "words": [108, 109]}, {"id": 15, "text": "- ?", "words": [110, 111]}, {"id": 16, "text": "- Je pars en vacances en août.", "words": [112, 113, 114, 115, 116, 117, 118]}, {"id": 17, "text": "2 8.", "words": [119, 120]}, {"id": 18, "text": "- ?", "words": [121, 122]}, {"id": 19, "text": "— je cherche mes lunettes.", "words": [123, 124, 125, 126, 127]}, {"id": 20, "text": "2 9.", "words": [128, 129]}, {"id": 21, "text": "— Est-ce que vous connaissez quelqu'un à Rio?", "words": [130, 131, 132, 133, 134, 135, 136, 137]}, {"id": 22, "text": "— Non, 3 10.", "words": [138, 139, 140, 141]}, {"id": 23, "text": "- Tu as mangé quelque chose à midi?", "words": [142, 143, 144, 145, 146, 147, 148, 149]}, {"id": 24, "text": "- Non, 3 11.", "words": [150, 151, 152, 153]}, {"id": 25, "text": "— Est-ce que tu as rencontré quelqu'un dans le couloir ?", "words": [154, 155, 156, 157, 158, 159, 160, 161, 162, 163, 164]}, {"id": 26, "text": "- Non, 3 12.", "words": [165, 166, 167, 168]}, {"id": 27, "text": "—- Vous avez déjà fait du judo?", "words": [169, 170, 171, 172, 173, 174, 175]}, {"id": 28, "text": "- Non, judo.", "words": [176, 177, 178]}, {"id": 29, "text": "4 Conjuguez les verbes manquants.", "words": [179, 180, 181, 182, 183]}, {"id": 30, "text": "Faites l'élision si c'est nécessaire.", "words": [184, 185, 186, 187, 188]}, {"id": 31, "text": "{10 points) Ludwig Berg (compositeur) — Monsieur Berg, vous en France depuis plus de vingt ans, je crois ?", "words": [189, 190, 191, 192, 193, 194, 195, 196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207]}, {"id": 32, "text": "habiter - Oui, je ici depuis exactement vingt-deux ans.", "words": [208, 209, 210, 211, 212, 213, 214, 215, 216]}, {"id": 33, "text": "vivre - Vous un Oscar pour la musique du film Gun 999, il y a deux ans, et | recevoir vous trois millions de disques de votre album «Stellor» l'année | vendre dernière.", "words": [217, 218, 219, 220, 221, 222, 223, 224, 225, 226, 227, 228, 229, 230, 231, 232, 233, 234, 235, 236, 237, 238, 239, 240, 241, 242, 243, 244, 245, 246, 247, 248, 249]}, {"id": 34, "text": "Vos commentaires ?", "words": [250, 251, 252]}, {"id": 35, "text": "- Je «Gun Melody» en deux jours et «Stellor» en deux semaines.", "words": [253, 254, 255, 256, 257, 258, 259, 260, 261, 262, 263, 264]}, {"id": 36, "text": "| écrire Je plus d'argent en trois ans que depuis que je suis né.", "words": [265, 266, 267, 268, 269, 270, 271, 272, 273, 274, 275, 276, 277, 278]}, {"id": 37, "text": "Vive le cinéma!", "words": [279, 280, 281]}, {"id": 38, "text": "| gagner — Quels sont vos projets ?", "words": [282, 283, 284, 285, 286, 287, 288, 289]}, {"id": 39, "text": "- Quand mon nouvel album , dans un mois, je sortir - partir en vacances en Jamaïque pour un an.", "words": [290, 291, 292, 293, 294, 295, 296, 297, 298, 299, 300, 301, 302, 303, 304, 305, 306, 307, 308, 309]}, {"id": 40, "text": "- La musique est votre seule passion ?", "words": [310, 311, 312, 313, 314, 315, 316, 317]}, {"id": 41, "text": "de fumer et je le violoncelle.", "words": [318, 319, 320, 321, 322, 323]}, {"id": 42, "text": "arrêter -commencer", "words": [324, 325]}, {"id": 43, "text": "— Oui, à sept ans, je", "words": [326, 327, 328, 329, 330, 331]}, {"id": 44, "text": "cent trente-sept + 137", "words": [332, 333, 334, 335]}]}