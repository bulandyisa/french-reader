2]}, {"id": 5, "text": "À midi, i Le soir", "words": [43, 44, 45, 46, 47]}, {"id": 6, "text": "Avec le poisson, | |", "words": [48, 49, 50, 51, 52]}, {"id": 7, "text": ".", "words": [53]}, {"id": 8, "text": "Avec le fromage,", "words": [54, 55, 56]}, {"id": 9, "text": "b.", "words": [57]}, {"id": 10, "text": "Posez des questions à partir de l'exercice n°1 et répondez librement.", "words": [58, 59, 60, 61, 62, 63, 64, 65, 66, 67, 68]}, {"id": 11, "text": "- Le malin, qu'est-ce que uous buvez ?", "words": [69, 70, 71, 72, 73, 74, 75, 76]}, {"id": 12, "text": "- Le matin, - À midi, -", "words": [77, 78, 79, 80, 81, 82, 83]}, {"id": 13, "text": "Conjuguez le verbe «prendre », selon le modèle.", "words": [84, 85, 86, 87, 88, 89, 90, 91]}, {"id": 14, "text": "Moyens de transports: RER — bus — train — métro - tramway - taxi.", "words": [92, 93, 94, 95, 96, 97, 98, 99, 100, 101, 102, 103, 104, 105]}, {"id": 15, "text": "Je prenda le RER.", "words": [106, 107, 108, 109]}, {"id": 16, "text": "Nous Tu Vous Mike Mes parents", "words": [110, 111, 112, 113, 114, 115]}, {"id": 17, "text": "| 32 Complétez avec « prendre », « apprendre » et «comprendre ».", "words": [116, 117, 118, 119, 120, 121, 122, 123, 124, 125, 126, 127, 128]}, {"id": 18, "text": "1.- Vous prenez le bus ou le train ?", "words": [129, 130, 131, 132, 133, 134, 135, 136, 137]}, {"id": 19, "text": "- Je le bus.", "words": [138, 139, 140, 141]}, {"id": 20, "text": "Mes amis le train.", "words": [142, 143, 144, 145]}, {"id": 21, "text": "2.- Vous l'anglais ou le français ?", "words": [146, 147, 148, 149, 150, 151, 152]}, {"id": 22, "text": "l'anglais.", "words": [153]}, {"id": 23, "text": "Mes sœurs le français.", "words": [154, 155, 156, 157]}, {"id": 24, "text": "3,- Vous tout ou presque tout ?", "words": [158, 159, 160, 161, 162, 163, 164]}, {"id": 25, "text": "- Je tout.", "words": [165, 166, 167]}, {"id": 26, "text": "Mes parents presque tout.", "words": [168, 169, 170, 171]}, {"id": 27, "text": "(4 Complétez av