ext": "5.", "words": [68]}, {"id": 11, "text": "- sur la table ?", "words": [69, 70, 71, 72, 73]}, {"id": 12, "text": "— Sur la table, des fleurs.", "words": [74, 75, 76, 77, 78, 79]}, {"id": 13, "text": "6.", "words": [80]}, {"id": 14, "text": "- ?- mon frère Laurent.", "words": [81, 82, 83, 84, 85]}, {"id": 15, "text": "étudiant.", "words": [86]}, {"id": 16, "text": "?- un ordinateur portable.", "words": [87, 88, 89, 90]}, {"id": 17, "text": "très léger.", "words": [91, 92]}, {"id": 18, "text": "8.", "words": [93]}, {"id": 19, "text": "— Qui est cet acteur ?", "words": [94, 95, 96, 97, 98, 99]}, {"id": 20, "text": "- Toshiro Mifune.", "words": [100, 101, 102]}, {"id": 21, "text": "un grand acteur japonais.", "words": [103, 104, 105, 106]}, {"id": 22, "text": "9.", "words": [107]}, {"id": 23, "text": "- mandarine?", "words": [108, 109]}, {"id": 24, "text": "- Non, pas une mandarine, une orange.", "words": [110, 111, 112, 113, 114, 115, 116]}, {"id": 25, "text": "10.", "words": [117]}, {"id": 26, "text": "- La Danse Music, formidable !", "words": [118, 119, 120, 121, 122, 123]}, {"id": 27, "text": "- Oh non, horrible !", "words": [124, 125, 126, 127, 128]}, {"id": 28, "text": "11.", "words": [129]}, {"id": 29, "text": "la place, une statue.", "words": [130, 131, 132, 133]}, {"id": 30, "text": "une statue de Miré.", "words": [134, 135, 136, 137]}, {"id": 31, "text": "très colorée.", "words": [138, 139]}, {"id": 32, "text": "12.", "words": [140]}, {"id": 33, "text": "jardin, fleurs, des roses.", "words": [141, 142, 143, 144]}, {"id": 34, "text": "Points 2", "words": [145, 146]}, {"id": 35, "text": "ON WW ON M9", "words": [147, 148, 149, 150]}, {"id": 36, "text": "(T2 Complétez avec «qui est-ce ?», « qu'est-ce que c'est?», «c'est» ou «ce sont».", "words": [151, 152, 153, 154, 155, 156, 157, 158, 159, 160, 161, 162, 163, 164]}, {"id": 37, "text": "{10 points} joe Wild — Ce chanteur, à la télévision, ?", "words": [165, 166, 167, 168, 169, 170, 171, 172, 173, 174, 175]}, 