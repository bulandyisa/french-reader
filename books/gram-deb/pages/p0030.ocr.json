": 28, "h": 24, "conf": 95.0, "block": 12, "par": 1, "line": 1, "i": 242}], "sentences": [{"id": 0, "text": "BILAN N°", "words": [0, 1]}, {"id": 1, "text": "Complétez avec les éléments manquants.", "words": [2, 3, 4, 5, 6]}, {"id": 2, "text": "Faîtes des phrases complètes,", "words": [7, 8, 9, 10]}, {"id": 3, "text": "(30 points} Points 1.", "words": [11, 12, 13, 14]}, {"id": 4, "text": "Bonjour.", "words": [15]}, {"id": 5, "text": "Je m'appelle Paolo Bruni.", "words": [16, 17, 18, 19]}, {"id": 6, "text": "Je italien.", "words": [20, 21]}, {"id": 7, "text": "1 2.", "words": [22, 23]}, {"id": 8, "text": "Vous étudiant, Marco ?", "words": [24, 25, 26, 27]}, {"id": 9, "text": "1 3.", "words": [28, 29]}, {"id": 10, "text": "- Paul est français ou belge ?", "words": [30, 31, 32, 33, 34, 35, 36]}, {"id": 11, "text": "- belge.", "words": [37, 38]}, {"id": 12, "text": "2 4.", "words": [39, 40]}, {"id": 13, "text": "Jean est grand et blond.", "words": [41, 42, 43, 44, 45]}, {"id": 14, "text": "Marie est et comme lui.", "words": [46, 47, 48, 49, 50]}, {"id": 15, "text": "2 5.", "words": [51, 52]}, {"id": 16, "text": "Ann et Léa sont anglaises.", "words": [53, 54, 55, 56, 57]}, {"id": 17, "text": "Elles étudiantes 3 très gentilles.", "words": [58, 59, 60, 61, 62]}, {"id": 18, "text": "6.", "words": [63]}, {"id": 19, "text": "- médecin ou dentiste, monsieur Morin ?", "words": [64, 65, 66, 67, 68, 69, 70]}, {"id": 20, "text": "- Je 3 dentiste.", "words": [71, 72, 73, 74]}, {"id": 21, "text": "7.", "words": [75]}, {"id": 22, "text": "- Vous êtes fatigué, Jean ?", "words": [76, 77, 78, 79, 80, 81]}, {"id": 23, "text": "- Non, fatigué !", "words": [82, 83, 84, 85]}, {"id": 24, "text": "4 8.", "words": [86, 87]}, {"id": 25, "text": "Keiko japonaise.", "words": [88, 89]}, {"id": 26, "text": "Elle à Tokyo.", "words": [90, 91, 92]}, {"id": 27, "text": "3 Elle étudiante.", "words": [93, 94, 95]}, {"id": 28, "text": "9.", "words": [96]}, {"id": 29, "text": "J'aime le football, mais le tennis.", "words": [97, 98, 99, 100, 101, 102]}, {"id": 30, "text": "4 10.", "words": [103, 104]}, {"id": 31, "text": "Le samedi soir, nous des pâtes, puis nous 3 la télévision ou nous la radio.", "words": [105, 106, 107, 108, 109, 110, 111, 112, 113, 114, 115, 116, 117, 118, 119]}, {"id": 32, "text": "11.", "words": [120]}, {"id": 33, "text": "- Le samedi, vous vous couchez tôt?", "words": [121, 122, 123, 124, 125, 126, 127]}, {"id": 34, "text": "- Non, tard.", "words": [128, 129, 130]}, {"id": 35, "text": "è 12, - le samedi?", "words": [131, 132, 133, 134, 135]}, {"id": 36, "text": "- Non, je ne travaille pas le samedi.", "words": [136, 137, 138, 139, 140, 141, 142, 143]}, {"id": 37, "text": "2 Complétez avec les verbes manquants.", "words": [144, 145, 146, 147, 148, 149]}, {"id": 38, "text": "Faites l'élision si c'est nécessaire.", "words": [150, 151, 152, 153, 154]}, {"id": 39, "text": "(10 points} Debra être - travailler - habiter - étudier — visiter parler - rentrer - manger - se coucher Je m'appelle Debra.", "words": [155, 156, 157, 158, 159, 160, 161, 162, 163, 164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174, 175, 176, 177]}, {"id": 40, "text": "Je américaine.", "words": [178, 179]}, {"id": 41, "text": "Je ingénieur.", "words": [180, 181]}, {"id": 42, "text": "Je pour une société pétrolière, Actuellement, je à Paris, dans un petit hôtel.", "words": [182, 183, 184, 185, 186, 187, 188, 189, 190, 191, 192, 193, 194]}, {"id": 43, "text": "Le matin, je le français dans une école de langues et l'après-midi, je la ville avec un ami.", "words": [195, 196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210, 211, 212]}, {"id": 44, "text": "Je français toute la journée et le soir, quand je à l'hôtel, je suis très fatiguée.", "words": [213, 214, 215, 216, 217, 218, 219, 220, 221, 222, 223, 224, 225, 226, 227, 228]}, {"id": 45, "text": "Pour diner, je seulement une pomme et je tout de suite.", "words": [229, 230, 231, 232, 233, 234, 235, 236, 237, 2