": "composé.", "words": [58]}, {"id": 17, "text": "1.", "words": [59]}, {"id": 18, "text": "passer lis ant les vacances à Côme et sont passés par la Suisse.", "words": [60, 61, 62, 63, 64, 65, 66, 67, 68, 69, 70, 71, 72]}, {"id": 19, "text": "2.", "words": [73]}, {"id": 20, "text": "sortir ils de la voiture et les bagages.", "words": [74, 75, 76, 77, 78, 79, 80, 81]}, {"id": 21, "text": "3.", "words": [82]}, {"id": 22, "text": "rentrer ils la voiture au garage et dans la maison.", "words": [83, 84, 85, 86, 87, 88, 89, 90, 91, 92]}, {"id": 23, "text": "4.", "words": [93]}, {"id": 24, "text": "monter ils l'escalier à pied et au huitième étage.", "words": [94, 95, 96, 97, 98, 99, 100, 101, 102]}, {"id": 25, "text": "5.", "words": [103]}, {"id": 26, "text": "descendre Ils à la cave et la poubelle.", "words": [104, 105, 106, 107, 108, 109, 110, 111]}, {"id": 27, "text": "€ «Être» ou «avoir »: complétez au passé composé.", "words": [112, 113, 114, 115, 116, 117, 118, 119, 120]}, {"id": 28, "text": "1.", "words": [121]}, {"id": 29, "text": "(entrer/sortir} Les gangsters 4ant par la porte et par la fenêtre.", "words": [122, 123, 124, 125, 126, 127, 128, 129, 130, 131, 132]}, {"id": 30, "text": "2.", "words": [133]}, {"id": 31, "text": "(arriver/sortir} Les enfants de Fécole et ils tous leurs jouets.", "words": [134, 135, 136, 137, 138, 139, 140, 141, 142, 143]}, {"id": 32, "text": "3.", "words": [144]}, {"id": 33, "text": "(descendre/monter) Jean à la cave et il au grenier.", "words": [145, 146, 147, 148, 149, 150, 151, 152, 153]}, {"id": 34, "text": "4.", "words": [154]}, {"id": 35, "text": "(sortir/monter) Carlo de la voiture et il les valises.", "words": [155, 156, 157, 158, 159, 160, 161, 162, 163]}, {"id": 36, "text": "5.", "words": [164]}, {"id": 37, "text": "(rentrer/sortir) Anne la voiture et elle la poubelle.", "words": [165, 166, 167, 168, 169, 170, 171, 172]}, {"id": 38, "text": "| 4 2 Répondez au passé composé.", "words": [173, 174, 175, 176, 177, 178, 179]}, {"id": 39, "text": "1.", "words": [180]}, {"id": 40, "text": "- Ce matin, vous vous êtes levé(e) tôt ?", "words": [181, 182, 183, 184, 185, 186, 187, 188, 189]}, {"id": 41, "text": "2.", "words": [190]}, {"id": 42, "text": "- Hier soir, vous vous êtes couché(e) tard ?", "words": [191, 192, 193, 194, 195, 196, 197, 198, 199]}, {"id": 43, "text": "3.", "words": [200]}, {"id": 44, "text": "— Vous vous êtes endormi(e) tout de suite ?", "words": [201, 202, 203, 204, 205, 206, 207, 208, 209]}, {"id": 45, "text": "4, - Samedi dernier, vous vous êtes reposé(e) ?", "words": [210, 211, 212, 213, 214, 215, 216, 217, 218]}, {"id": 46, "text": "5", "words": [219]}, {"id": 47, "text": "| 5 2 Décrivez les actions au passé composé :", "words": [220, 221, 222, 223, 224, 225, 226, 227, 228, 229]}, {"id": 48, "text": "Des voyageurs dans un train de nuit aller à la gare - monter dans le train - s'installer se laver se déshabiller - se coucher - se réveiller - etc.", "words": [230, 231, 232, 233, 234, 235, 236, 237, 238, 239, 240, 241, 242, 243, 244, 245, 246, 247, 248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259]}, {"id": 49, "text": "sont allés à la gare", "words": [260, 261, 262, 263, 264]}, {"id": 50, "text": ".", "words": [265]}, {"id": 51, "text": "— Dimanche dernier, vous vous êtes promené(e) ?", "words": [266, 267, 268, 269, 270, 271, 272, 273]}, {"id": 52, "text": "- Oui, je me têt.", "words": [274, 275, 276, 277, 278]}, {"id": 53, "text": "Deux jeunes filles avant une fête se laver - s'habiller - se se coiffer - se parfumer - partir — etc.", "words": [279, 280, 281, 282, 283, 284, 285, 286, 287, 288, 289, 290, 291, 292, 293, 294, 295, 296, 297, 298, 299]}, {"id": 54, "text": "cent dix-sept + 117", "words": [300, 301, 302, 303]}]}