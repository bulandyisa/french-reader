 21, 22, 23]}, {"id": 3, "text": "C2D Lisez.", "words": [24, 25]}, {"id": 4, "text": "Transformez.", "words": [26]}, {"id": 5, "text": "Décrivez des commerçants de votre quartier.", "words": [27, 28, 29, 30, 31, 32]}, {"id": 6, "text": "Monsieur Juliot | Madame Janin", "words": [33, 34, 35, 36, 37]}, {"id": 7, "text": "boulanger.", "words": [38]}, {"id": 8, "text": "jeune et il est beau.", "words": [39, 40, 41, 42, 43]}, {"id": 9, "text": "ILest souriant.", "words": [44, 45]}, {"id": 10, "text": "Il est très gentil.", "words": [46, 47, 48, 49]}, {"id": 11, "text": "Associez librement les adjectifs et les professions.", "words": [50, 51, 52, 53, 54, 55, 56]}, {"id": 12, "text": "Accordez si c'est nécessaire.", "words": [57, 58, 59, 60]}, {"id": 13, "text": "calme - souriant - curieux - rapide - précis - patient - dynamique - gai", "words": [61, 62, 63, 64, 65, 66, 67, 68, 69, 70, 71, 72, 73, 74, 75]}, {"id": 14, "text": "1.", "words": [76]}, {"id": 15, "text": "Un bon chirurgien: 9€ eat calme et précis.", "words": [77, 78, 79, 80, 81, 82, 83, 84]}, {"id": 16, "text": "2.", "words": [85]}, {"id": 17, "text": "Une bonne journaliste :", "words": [86, 87, 88, 89]}, {"id": 18, "text": "3.", "words": [90]}, {"id": 19, "text": "Un bon vendeur:", "words": [91, 92, 93]}, {"id": 20, "text": "4.", "words": [94]}, {"id": 21, "text": "Une bonne institutrice :", "words": [95, 96, 97, 98]}, {"id": 22, "text": "Vous avez plusieurs professions : imaginez...", "words": [99, 100, 101, 102, 103, 104]}, {"id": 23, "text": "Accordez les adjectifs si c'est nécessaire.", "words": [105, 106, 107, 108, 109, 110]}, {"id": 24, "text": "facteur - serveur - boulanger - restaurateur — médecin - professeur — infirmier - agriculteur", "words": [111, 112, 113, 114, 115, 116, 117, 118, 119, 120, 121, 122, 123, 124, 125]}, {"id": 25, "text": "Le malin, je facteur.", "words": [126, 127, 128, 129]}, {"id": 26, "text": "je suis Le sain, je", "words": [130, 131, 132, 133, 134]}, {"id": 27, "text": "5 2 Associez les noms féminins de la nature et les couleurs.", "words": [135, 136, 137, 138, 139, 140, 141, 142, 143, 144, 145, 146]}, {"id": 28, "text": "Accordez les adjectifs.", "words": [147, 148, 149]}, {"id": 29, "text": "la mer +.", "words": [150, 151, 152]}, {"id": 30, "text": "blanc La mer est + bleu", "words": [153, 154, 155, 156, 157, 158]}, {"id": 31, "text": "l'herbe + vert", "words": [159, 160, 161]}, {"id": 32, "text": "la neige + + noir", "words": [162, 163, 164, 165, 166]}, {"id": 33, "text": "| 6 3 Le Premier ministre, la voisine, le professeur, etc.", "words": [167, 168, 169, 170, 171, 172, 173, 174, 175, 176, 177]}, {"id": 34, "text": "Donnez une qualité et un défaut.", "words": [178, 179, 180, 181, 182, 183]}, {"id": 35, "text": "treize » 13", "words": [184, 185, 186]}]}