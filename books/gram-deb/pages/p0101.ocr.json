 "words": [58]}, {"id": 9, "text": "a DEVOIR : obligation en général", "words": [59, 60, 61, 62, 63, 64]}, {"id": 10, "text": "[ Jde dois Nous dev-ons Tu dois Vous devez l/Elle/On doit", "words": [65, 66, 67, 68, 69, 70, 71, 72, 73, 74, 75]}, {"id": 11, "text": "faut » est l'équivalent de «on doit » (nécessité générale) : Il faut manger pour vivre.", "words": [76, 77, 78, 79, 80, 81, 82, 83, 84, 85, 86, 87, 88, 89, 90, 91]}, {"id": 12, "text": "= On doit manger.", "words": [92, 93, 94, 95]}, {"id": 13, "text": "PAN + Dites: Je dois partir.", "words": [96, 97, 98, 99, 100, 101]}, {"id": 14, "text": "Ne dites pas: Dites : Je peux rester.", "words": [102, 103, 104, 105, 106, 107, 108, 109]}, {"id": 15, "text": "Ne dites pas:", "words": [110, 111, 112]}, {"id": 16, "text": "100 cent", "words": [113, 114]}]}