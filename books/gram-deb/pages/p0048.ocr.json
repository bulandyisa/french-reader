, {"id": 13, "text": "Ma mère a cinquante-huit ans.", "words": [77, 78, 79, 80, 81]}, {"id": 14, "text": "Mon professeur à environ quarante ans.", "words": [82, 83, 84, 85, 86, 87]}, {"id": 15, "text": "32 Associez les personnes et les âges, selon le modèle.", "words": [88, 89, 90, 91, 92, 93, 94, 95, 96, 97]}, {"id": 16, "text": "25 ans - 15 ans - 65 ans — 22 ans - 120 ans", "words": [98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 111]}, {"id": 17, "text": ".", "words": [112]}, {"id": 18, "text": "Max est footballeur professionnel.", "words": [113, 114, 115, 116]}, {"id": 19, "text": "3€ a vingt-cinq ana.", "words": [117, 118, 119, 120]}, {"id": 20, "text": ".", "words": [121]}, {"id": 21, "text": "Paul est à la retraite.", "words": [122, 123, 124, 125, 126]}, {"id": 22, "text": "1 2 3.", "words": [127, 128, 129]}, {"id": 23, "text": "Anna est l'actuelle Miss Monde.", "words": [130, 131, 132, 133, 134]}, {"id": 24, "text": "4.", "words": [135]}, {"id": 25, "text": "Marie est lycéenne.", "words": [136, 137, 138]}, {"id": 26, "text": "5", "words": [139]}, {"id": 27, "text": ".", "words": [140]}, {"id": 28, "text": "Jeanne est très vieille.", "words": [141, 142, 143, 144]}, {"id": 29, "text": "Complétez avec «il est» ou «il a».", "words": [145, 146, 147, 148, 149, 150, 151]}, {"id": 30, "text": "Ensuite, décrivez de Bruno.", "words": [152, 153, 154, 155]}, {"id": 31, "text": "Bruno est très jeune: a quinze ans.", "words": [156, 157, 158, 159, 160, 161, 162]}, {"id": 32, "text": "beau et très intelligent.", "words": [163, 164, 165, 166]}, {"id": 33, "text": "les cheveux blonds.", "words": [167, 168, 169]}, {"id": 34, "text": "beaucoup d'amis, parce que très gentil.", "words": [170, 171, 172, 173, 174, 175]}, {"id": 35, "text": "défaut: très paresseux.", "words": [176, 177, 178]}, {"id": 36, "text": "Barbara", "words": [179]}, {"id": 37, "text": "les yeux noirs et seulement un gros", "words": [180, 181, 182, 183, 184, 185, 186]}, {"id": 38, "text": "oo a.", "words": [187, 188]}, {"id": 39, "text": "Décrivez-vous.", "words": [189]}, {"id": 40, "text": "Décrivez un parent, une amie.", "words": [190, 191, 192, 193, 194]}, {"id": 41, "text": ", Imaginez: u XeUr, nt, , b.", "words": [195, 196, 197, 198, 199, 200, 201]}, {"id": 42, "text": "| n boxeur, le Prince charmant, la femme de l'inspecteur Columbo", "words": [202, 203, 204, 205, 206, 207, 208, 209, 210, 211, 212]}, {"id": 43, "text": "quarante-sept « 47", "words": [213, 214, 215]}]}