 [26, 27, 28, 29, 30, 31, 32, 33, 34]}, {"id": 6, "text": "3.", "words": [35]}, {"id": 7, "text": "- Vous regardez la télé le soir ?", "words": [36, 37, 38, 39, 40, 41, 42, 43]}, {"id": 8, "text": "4.", "words": [44]}, {"id": 9, "text": "- Vous écoutez la radio le matin ?", "words": [45, 46, 47, 48, 49, 50, 51, 52]}, {"id": 10, "text": "5.", "words": [53]}, {"id": 11, "text": "- Vous faites les exercices tout seul ?", "words": [54, 55, 56, 57, 58, 59, 60, 61]}, {"id": 12, "text": "— Oui, je Le prends à fuit heures.", "words": [62, 63, 64, 65, 66, 67, 68, 69]}, {"id": 13, "text": "22 Remplacez les noms par les pronoms «le », «la», «les ».", "words": [70, 71, 72, 73, 74, 75, 76, 77, 78, 79, 80, 81]}, {"id": 14, "text": "1, Elle gare sa voiture dans la rue.", "words": [82, 83, 84, 85, 86, 87, 88, 89]}, {"id": 15, "text": "2.", "words": [90]}, {"id": 16, "text": "Elle achète le journal dans un kiosque.", "words": [91, 92, 93, 94, 95, 96, 97]}, {"id": 17, "text": "3.", "words": [98]}, {"id": 18, "text": "Elle ouvre son courrier dans l'ascenseur.", "words": [99, 100, 101, 102, 103, 104]}, {"id": 19, "text": "4.", "words": [105]}, {"id": 20, "text": "Elle enlève ses chaussures dans l'entrée.", "words": [106, 107, 108, 109, 110, 111]}, {"id": 21, "text": "5, Elle prépare le repas dans la cuisine.", "words": [112, 113, 114, 115, 116, 117, 118, 119]}, {"id": 22, "text": "Elle la gare dana la nue.", "words": [120, 121, 122, 123, 124, 125]}, {"id": 23, "text": "0 32 Transformez avec «le » ou «la», selon le modèle, Continuez librement.", "words": [126, 127, 128, 129, 130, 131, 132, 133, 134, 135, 136, 137, 138]}, {"id": 24, "text": "Un ticket de métro", "words": [139, 140, 141, 142]}, {"id": 25, "text": "acheter -composter - déchirer - jeter", "words": [143, 144, 145, 146, 147, 148]}, {"id": 26, "text": "de l'achète, je", "words": [149, 150, 151]}, {"id": 27, "text": "Une chemise", "words": [152, 153]}, {"id": 28, "text": "mettre - enlever - laver repasser - ranger", "words": [1