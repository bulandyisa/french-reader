ion ?", "words": [56, 57, 58, 59, 60, 61, 62]}, {"id": 14, "text": "4.", "words": [63]}, {"id": 15, "text": "— C'est leur ballon:", "words": [64, 65, 66, 67]}, {"id": 16, "text": "32 Faites des phrases avec des prépositions et des pronoms toniques.", "words": [68, 69, 70, 71, 72, 73, 74, 75, 76, 77, 78]}, {"id": 17, "text": "1.", "words": [79]}, {"id": 18, "text": "Je parle avec Katia.", "words": [80, 81, 82, 83]}, {"id": 19, "text": "Je parle avec elle.", "words": [84, 85, 86, 87]}, {"id": 20, "text": "2.", "words": [88]}, {"id": 21, "text": "Vous dînez chez monsieur Dubois.", "words": [89, 90, 91, 92, 93]}, {"id": 22, "text": "3.", "words": [94]}, {"id": 23, "text": "Il travaille avec Waldek.", "words": [95, 96, 97, 98]}, {"id": 24, "text": "4.", "words": [99]}, {"id": 25, "text": "Elie est chez Anne et Sophie.", "words": [100, 101, 102, 103, 104, 105]}, {"id": 26, "text": "5.", "words": [106]}, {"id": 27, "text": "Nous partons sans les enfants.", "words": [107, 108, 109, 110, 111]}, {"id": 28, "text": "CaD Complétez selon le modèle, .", "words": [112, 113, 114, 115, 116, 117]}, {"id": 29, "text": "— Jenush est polonais.", "words": [118, 119, 120, 121]}, {"id": 30, "text": "Et Waldek ?", "words": [122, 123, 124]}, {"id": 31, "text": "polonais, lui aussi.", "words": [125, 126, 127]}, {"id": 32, "text": ".", "words": [128]}, {"id": 33, "text": "— Gilles est professeur.", "words": [129, 130, 131, 132]}, {"id": 34, "text": "Et Patrick ?", "words": [133, 134, 135]}, {"id": 35, "text": "-", "words": [136]}, {"id": 36, "text": "1 2 3.", "words": [137, 138, 139]}, {"id": 37, "text": "- Chico est brésilien.", "words": [140, 141, 142, 143]}, {"id": 38, "text": "Et Caetano ?", "words": [144, 145, 146]}, {"id": 39, "text": "-", "words": [147]}, {"id": 40, "text": "4.", "words": [148]}, {"id": 41, "text": "- Anne n'est pas française.", "words": [149, 150, 151, 152, 153]}, {"id": 42, "text": "Et Max ?", "words": [154, 155, 156]}, {"id": 43, "text": "- SE n'est pas français, lui non plus.", "words": [157, 158, 159, 160, 161, 162, 163, 164]}, {"id": 44, "text": "5", "words": [165]}, {"id": 45, "text": "6", "words": [166]}, {"id": 46, "text": ".", "words": [167]}, {"id": 47, "text": "— Lisa n'est pas anglaise.", "words": [168, 169, 170, 171, 172]}, {"id": 48, "text": "Et David ?", "words": [173, 174, 175]}, {"id": 49, "text": "-", "words": [176]}, {"id": 50, "text": ".", "words": [177]}, {"id": 51, "text": "- Jean n'est pas sympathique.", "words": [178, 179, 180, 181, 182]}, {"id": 52, "text": "Et Marie ?", "words": [183, 184, 185]}, {"id": 53, "text": "-", "words": [186]}, {"id": 54, "text": "05 2 Complétez, selon le modèle.", "words": [187, 188, 189, 190, 191, 192]}, {"id": 55, "text": "Moi, je suis célibataire.", "words": [193, 194, 195, 196]}, {"id": 56, "text": "sommes fatigués.", "words": [197, 198]}, {"id": 57, "text": "es marié êtes en forme!", "words": [199, 200, 201, 202, 203]}, {"id": 58, "text": "est anglais.", "words": [204, 205]}, {"id": 59, "text": "sont courageux.", "words": [206, 207]}, {"id": 60, "text": "est française.", "words": [208, 209]}, {"id": 61, "text": "sont paresseuses.", "words": [210, 211]}, {"id": 62, "text": "Placez les personnes selon le modèle.", "words": [212, 213, 214, 215, 216, 217]}, {"id": 63, "text": "Photo de groupe |", "words": [218, 219, 220, 221]}, {"id": 64, "text": "— Toi, tu es à gauche.", "words": [222, 223, 224, 225, 226, 227]}, {"id": 65, "text": "= ils sont devant.", "words": [228, 229, 230, 231]}, {"id": 66, "text": "- derrière.", "words": [232, 233]}, {"id": 67, "text": "- , vous êtes là.", "words": [234, 235, 236, 237, 238]}, {"id": 68, "text": ", elle est au centre.", "words": [239, 240, 241, 242, 243]}, {"id": 69, "text": ", je suis ici.", "words": [244, 245, 246, 247]}, {"id": 70, "text": "i", "words": [248]}, {"id": 71, "text": "Continuez.", "words": [249]}, {"id": 72, "text": "cent quarante-sept « 147", "words": [250, 251, 252, 253]}]}