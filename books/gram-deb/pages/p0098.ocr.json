3, "i": 295}, {"text": ".", "x": 791, "y": 2042, "w": 4, "h": 4, "conf": 81.0, "block": 26, "par": 2, "line": 3, "i": 296}, {"text": "|", "x": 1226, "y": 2003, "w": 2, "h": 37, "conf": 78.0, "block": 26, "par": 2, "line": 3, "i": 297}, {"text": "croire/voir", "x": 1297, "y": 2024, "w": 110, "h": 19, "conf": 88.0, "block": 26, "par": 2, "line": 3, "i": 298}, {"text": "quatre-vingt-dix-sept", "x": 1147, "y": 2126, "w": 265, "h": 32, "conf": 90.0, "block": 27, "par": 1, "line": 1, "i": 299}, {"text": "+", "x": 1422, "y": 2136, "w": 10, "h": 11, "conf": 64.0, "block": 27, "par": 1, "line": 1, "i": 300}, {"text": "97", "x": 1443, "y": 2125, "w": 29, "h": 25, "conf": 94.0, "block": 27, "par": 1, "line": 1, "i": 301}], "sentences": [{"id": 0, "text": "#7", "words": [0]}, {"id": 1, "text": "«Savoir ».", "words": [1, 2]}, {"id": 2, "text": "Complétez, selon le modèle.", "words": [3, 4, 5, 6]}, {"id": 3, "text": "Vous savez conduire ?", "words": [7, 8, 9, 10]}, {"id": 4, "text": "- Oui, je sais conduire.", "words": [11, 12, 13, 14, 15]}, {"id": 5, "text": "- Mon, je ne sais conduire.", "words": [16, 17, 18, 19, 20, 21]}, {"id": 6, "text": "- Vous savez nager ?", "words": [22, 23, 24, 25, 26]}, {"id": 7, "text": "-", "words": [27]}, {"id": 8, "text": "- Vous savez skier ?", "words": [28, 29, 30, 31, 32]}, {"id": 9, "text": "L", "words": [33]}, {"id": 10, "text": "Vous savez taper à la machine ?", "words": [34, 35, 36, 37, 38, 39, 40]}, {"id": 11, "text": "® « Savoir ».", "words": [41, 42, 43, 44]}, {"id": 12, "text": "Complétez.", "words": [45]}, {"id": 13, "text": "Mettez au pluriel.", "words": [46, 47, 48]}, {"id": 14, "text": "Un enfant 4ai£ marcher vers un an.", "words": [49, 50, 51, 52, 53, 54, 55]}, {"id": 15, "text": "Les enfants savent marcher un an.", "words": [56, 57, 58, 59, 60, 61]}, {"id": 16, "text": "parler vers deux ans.", "words": [62, 63, 64, 65]}, {"id": 17, "text": "compter vers quatre ans.", "words": [66, 67, 68, 69]}, {"id": 18, "text": "lire vers six ans.", "words": [70, 71, 72, 73]}, {"id": 19, "text": "ED «savoir» et «connaître».", "words": [74, 75, 76, 77]}, {"id": 20, "text": "Compiétez.", "words": [78]}, {"id": 21, "text": "1.", "words": [79]}, {"id": 22, "text": "Elle 4ait taper à la machine mais elle ne pas l'informatique.", "words": [80, 81, 82, 83, 84, 85, 86, 87, 88, 89, 90]}, {"id": 23, "text": "2.", "words": [91]}, {"id": 24, "text": "- Est-ce que tu l'adresse de Max ?", "words": [92, 93, 94, 95, 96, 97, 98, 99]}, {"id": 25, "text": "- Oui, je où il habite.", "words": [100, 101, 102, 103, 104, 105]}, {"id": 26, "text": "3.", "words": [106]}, {"id": 27, "text": "- TU parler espagnol ?", "words": [107, 108, 109, 110, 111]}, {"id": 28, "text": "- Non, je dire seulement hombre!", "words": [112, 113, 114, 115, 116, 117]}, {"id": 29, "text": "4.", "words": [118]}, {"id": 30, "text": "pas le frère de Zoé, mais je qu'il est très beau.", "words": [119, 120, 121, 122, 123, 124, 125, 126, 127, 128, 129]}, {"id": 31, "text": "ED «voir» et «croire ».", "words": [130, 131, 132, 133, 134]}, {"id": 32, "text": "Complétez.", "words": [135]}, {"id": 33, "text": "a.", "words": [136]}, {"id": 34, "text": "Voir", "words": [137]}, {"id": 35, "text": "1.", "words": [138]}, {"id": 36, "text": "Tu cette lumière bleue dans le ciel: c’est un satellite.", "words": [139, 140, 141, 142, 143, 144, 145, 146, 147, 148]}, {"id": 37, "text": "- 2.", "words": [149, 150]}, {"id": 38, "text": "Si vous un taxi, appelez-le.", "words": [151, 152, 153, 154, 155]}, {"id": 39, "text": "3.", "words": [156]}, {"id": 40, "text": "Les animaux moins de couleurs que nous.", "words": [157, 158, 159, 160, 161, 162, 163]}, {"id": 41, "text": "Je mal sans mes lunettes.", "words": [164, 165, 166, 167, 168]}, {"id": 42, "text": "b.", "words": [169]}, {"id": 43, "text": "Croire", "words": [170]}, {"id": 44, "text": "1.", "words": [171]}, {"id": 45, "text": "- Quelle est la nationalité de Max?", "words": [172, 173, 174, 175, 176, 177, 178]}, {"id": 46, "text": "- Je qu'il est anglais.", "words": [179, 180, 181, 182, 183]}, {"id": 47, "text": "- Vous qu'il va pleuvoir ?", "words": [184, 185, 186, 187, 188, 189]}, {"id": 48, "text": "3.", "words": [190]}, {"id": 49, "text": "Les bouddhistes à la réincarnation.", "words": [191, 192, 193, 194, 195]}, {"id": 50, "text": "-4.", "words": [196]}, {"id": 51, "text": "- Tu que les Martiens existent ?", "words": [197, 198, 199, 200, 201, 202, 203]}, {"id": 52, "text": "CSD Complétez avec les verbes manquants.", "words": [204, 205, 206, 207, 208, 209]}, {"id": 53, "text": "Le père Noël", "words": [210, 211, 212]}, {"id": 54, "text": "Mes enfants Luc et Thomas encore au Père Noël.", "words": [213, 214, 215, 216, 217, 218, 219, 220, 221]}, {"id": 55, "text": "Tous les ans, ils croire/mettre leurs chaussures devant la cheminée et ils avec impatience la nuit.", "words": [222, 223, 224, 225, 226, 227, 228, 229, 230, 231, 232, 233, 234, 235, 236, 237]}, {"id": 56, "text": "Tous les attendre ans, ils dans le jardin lorsqu'ils un bruit de clochettes.", "words": [238, 239, 240, 241, 242, 243, 244, 245, 246, 247, 248, 249, 250]}, {"id": 57, "text": "Quand nous leurs petits visages émerveillés devant les cadeaux, nous voir/croire", "words": [251, 252, 253, 254, 255, 256, 257, 258, 259, 260, 261]}, {"id": 58, "text": "| nous aussi que le vieil homme existe.", "words": [262, 263, 264, 265, 266, 267, 268, 269]}, {"id": 59, "text": "Un service de la poste depuis répondre quelques années aux lettres que les enfants .", "words": [270, 271, 272, 273, 274, 275, 276, 277, 278, 279, 280, 281, 282, 283, 284]}, {"id": 60, "text": "Alors, c'est normal, Luc et | écrire Thomas seulement ce qu'ils .", "words": [285, 286, 287, 288, 289, 290, 291, 292, 293, 294, 295, 296]}, {"id": 61, "text": "| croire/voir", "words": [297, 298]}, {"id": 62, "text": "quatre-vingt-dix-sept + 97", "words": [299, 300, 301]}]}