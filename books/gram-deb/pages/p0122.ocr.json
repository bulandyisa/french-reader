{"text": "un", "x": 1378, "y": 2180, "w": 32, "h": 17, "conf": 95.0, "block": 40, "par": 1, "line": 1, "i": 260}, {"text": "+", "x": 1421, "y": 2184, "w": 10, "h": 10, "conf": 52.0, "block": 40, "par": 1, "line": 1, "i": 261}, {"text": "121", "x": 1443, "y": 2172, "w": 40, "h": 24, "conf": 96.0, "block": 40, "par": 1, "line": 1, "i": 262}], "sentences": [{"id": 0, "text": "EXERCICES", "words": [0]}, {"id": 1, "text": "12 Mettez au futur simple.", "words": [1, 2, 3, 4, 5]}, {"id": 2, "text": "Continuez librement.", "words": [6, 7]}, {"id": 3, "text": "!", "words": [8]}, {"id": 4, "text": "Actuellement, Plus tard, : j'habite dans une grande ville.", "words": [9, 10, 11, 12, 13, 14, 15, 16, 17]}, {"id": 5, "text": "j'habiterai en Prouence.", "words": [18, 19, 20]}, {"id": 6, "text": "Je travaille 12 heures par jour.", "words": [21, 22, 23, 24, 25, 26]}, {"id": 7, "text": "| | Je mange des produits surgelés.", "words": [27, 28, 29, 30, 31, 32, 33]}, {"id": 8, "text": "J'ai un appartement moderne.", "words": [34, 35, 36, 37]}, {"id": 9, "text": "Je vois des tours par ma fenêtre.", "words": [38, 39, 40, 41, 42, 43, 44]}, {"id": 10, "text": "H fait presque toujours froid,", "words": [45, 46, 47, 48, 49]}, {"id": 11, "text": "Je suis pâle et fatigué.", "words": [50, 51, 52, 53, 54]}, {"id": 12, "text": "Mettez au futur simple.", "words": [55, 56, 57, 58]}, {"id": 13, "text": "Continuez librement.", "words": [59, 60]}, {"id": 14, "text": "se lever - se laver — prendre le métro - aller au boulot - sourire - manger - se coucher - pleurer", "words": [61, 62, 63, 64, 65, 66, 67, 68, 69, 70, 71, 72, 73, 74, 75, 76, 77, 78, 79, 80, 81, 82]}, {"id": 15, "text": "Demain:", "words": [83]}, {"id": 16, "text": "Comme d'habitude, je me lèverai.", "words": [84, 85, 86, 87, 88]}, {"id": 17, "text": "d'habitude,", "words": [89]}, {"id": 18, "text": "32 Complétez les prédictions d'un sorcier indien du siècle.", "words": [90, 91, 92, 93, 94, 95, 96, 97, 98]}, {"id": 19, "text": "Continuez.", "words": [99]}, {"id": 20, "text": "Un jour, les hommes uaferant dans le ciel dans des oiseaux de fer", "words": [100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 111, 112]}, {"id": 21, "text": "qui un bruit de tonnerre.", "words": [113, 114, 115, 116, 117]}, {"id": 22, "text": "Ils les mers et ils jusqu'au bout de la terre.", "words": [118, 119, 120, 121, 122, 123, 124, 125, 126, 127]}, {"id": 23, "text": "Ils dans des maisons hautes comme des montagnes où le soleil même la nuit.", "words": [128, 129, 130, 131, 132, 133, 134, 135, 136, 137, 138, 139, 140, 141]}, {"id": 24, "text": "ils du feu sans bois.", "words": [142, 143, 144, 145, 146]}, {"id": 25, "text": "Ils dans des cornes et, même sans crier, on les de très loin.", "words": [147, 148, 149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159]}, {"id": 26, "text": "Les hommes leurs nuits à regarder dans des boîtes noires des esprits qui sans cesse.", "words": [160, 161, 162, 163, 164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174]}, {"id": 27, "text": "Complétez avec des verbes au futur simple.", "words": [175, 176, 177, 178, 179, 180, 181]}, {"id": 28, "text": "Continuez librement.", "words": [182, 183]}, {"id": 29, "text": "1.", "words": [184]}, {"id": 30, "text": "revenir/amener Quand je neuiendrai en France, ma fille.", "words": [185, 186, 187, 188, 189, 190, 191, 192]}, {"id": 31, "text": "2.", "words": [193]}, {"id": 32, "text": "trouver/être Quand tu cette lettre, je", "words": [194, 195, 196, 197, 198, 199]}, {"id": 33, "text": "3.", "words": [200]}, {"id": 34, "text": "venir/manger Quand vous chez nous, on", "words": [201, 202, 203, 204, 205, 206]}, {"id": 35, "text": "4, avoir {passer Quand tu 18 ans, tu", "words": [207, 208, 209, 210, 211, 212, 213, 214]}, {"id": 36, "text": "5.", "words": [215]}, {"id": 37, "text": "faire/aller Quand il chaud, nous", "words": [216, 217, 218, 219, 220]}, {"id": 38, "text": "5] Que ferez-vous: demain, à la même heure ?", "words": [221, 222, 223, 224, 225, 226, 227, 228, 229]}, {"id": 39, "text": "le 31 décembre ?", "words": [230, 231, 232, 233]}, {"id": 40, "text": "l'été prochain ?", "words": [234, 235, 236]}, {"id": 41, "text": "ri", "words": [237]}, {"id": 42, "text": "(voler)", "words": [238]}, {"id": 43, "text": "(aller/habiter) (briller) (faire/parler) (entendre) (passer)", "words": [239, 240, 241, 242, 243]}, {"id": 44, "text": "(se battre)", "words": [244, 245]}, {"id": 45, "text": "loin.", "words": [246]}, {"id": 46, "text": "dans le jardin.", "words": [247, 248, 249]}, {"id": 47, "text": "le permis de conduire.", "words": [250, 251, 252, 253]}, {"id": 48, "text": "à la plage.", "words": [254, 255, 256]}, {"id": 49, "text": "cent vingt et un + 121", "words": [257, 258, 259, 260, 261, 262]}]}