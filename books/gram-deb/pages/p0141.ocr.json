ds": [80]}, {"id": 19, "text": "VAN + Dites: J'y vais!", "words": [81, 82, 83, 84, 85]}, {"id": 20, "text": "On y va!", "words": [86, 87, 88]}, {"id": 21, "text": "J'habite dans cefte rue.", "words": [89, 90, 91, 92]}, {"id": 22, "text": "J'y vais en taxi.", "words": [93, 94, 95, 96]}, {"id": 23, "text": "J'y vais en avion.", "words": [97, 98, 99, 100]}, {"id": 24, "text": "J'y suis jusqu'à six heures.", "words": [101, 102, 103, 104, 105]}, {"id": 25, "text": "J'y habite depuis deux mois.", "words": [106, 107, 108, 109, 110]}, {"id": 26, "text": "J'y pense souvent.", "words": [111, 112, 113]}, {"id": 27, "text": "Elle y croit.", "words": [114, 115, 116]}, {"id": 28, "text": "Nous ÿ habitons.", "words": [117, 118, 119]}, {"id": 29, "text": "FA", "words": [120]}, {"id": 30, "text": "Ne dites pas: vais", "words": [121, 122, 123, 124]}, {"id": 31, "text": "140 « cent quarante", "words": [125, 126, 127, 128]}]}