20, "conf": 96.0, "block": 41, "par": 1, "line": 1, "i": 245}, {"text": "un", "x": 1387, "y": 2109, "w": 29, "h": 17, "conf": 87.0, "block": 41, "par": 1, "line": 1, "i": 246}, {"text": "51", "x": 1450, "y": 2102, "w": 25, "h": 24, "conf": 96.0, "block": 41, "par": 1, "line": 1, "i": 247}], "sentences": [{"id": 0, "text": "EXERCICES", "words": [0]}, {"id": 1, "text": "SD avec le verbe «avoir».", "words": [1, 2, 3, 4, 5]}, {"id": 2, "text": "1.", "words": [6]}, {"id": 3, "text": "Paul a vingt ans 5.", "words": [7, 8, 9, 10, 11]}, {"id": 4, "text": "Marie un saxophone.", "words": [12, 13, 14]}, {"id": 5, "text": "2.", "words": [15]}, {"id": 6, "text": "Nous ____une maison de campagne.", "words": [16, 17, 18, 19, 20]}, {"id": 7, "text": "6.", "words": [21]}, {"id": 8, "text": "Ils __ trois enfants.", "words": [22, 23, 24, 25]}, {"id": 9, "text": "3.", "words": [26]}, {"id": 10, "text": "Les enfants sommeil.", "words": [27, 28, 29]}, {"id": 11, "text": "7, On soif!", "words": [30, 31, 32]}, {"id": 12, "text": "4.", "words": [33]}, {"id": 13, "text": "Vous _ envie d’un café ?", "words": [34, 35, 36, 37, 38, 39]}, {"id": 14, "text": "8.", "words": [40]}, {"id": 15, "text": "Tu ____ faim?", "words": [41, 42, 43]}, {"id": 16, "text": "SD complétez en conjuguant le verbe «avoir».", "words": [44, 45, 46, 47, 48, 49, 50]}, {"id": 17, "text": "J'ai un fils.", "words": [51, 52, 53]}, {"id": 18, "text": "I s'appelle Thibaud, Il huit ans.", "words": [54, 55, 56, 57, 58, 59]}, {"id": 19, "text": "Il un très bon copain qui s'appelle Antoine.", "words": [60, 61, 62, 63, 64, 65, 66, 67]}, {"id": 20, "text": "Is", "words": [68]}, {"id": 21, "text": "tous les deux les yeux verts et les cheveux roux.", "words": [69, 70, 71, 72, 73, 74, 75, 76, 77, 78]}, {"id": 22, "text": "La mère d'Antoine et moi, nous aussi les", "words": [79, 80, 81, 82, 83, 84, 85, 86]}, {"id": 23, "text": "cheveux roux.", "words": [87, 88]}, {"id": 24, "text": "On à peu près le même âge: elle trente et un ans, moi trente-deux", "words": [89, 90, 91, 92, 93, 94, 95, 96, 97, 98, 99, 100, 101, 102]}, {"id": 25, "text": "ans.", "words": [103]}, {"id": 26, "text": "Nous les mêmes goûts, nous les mêmes disques et les mêmes livres, Nos enfants", "words": [104, 105, 106, 107, 108, 109, 110, 111, 112, 113, 114, 115, 116, 117]}, {"id": 27, "text": "aussi les mêmes livres, les mêmes jouets et ils les mêmes copains.", "words": [118, 119, 120, 121, 122, 123, 124, 125, 126, 127, 128, 129]}, {"id": 28, "text": "Posez des questions et répondez négativement, selon le modèle.", "words": [130, 131, 132, 133, 134, 135, 136, 137, 138]}, {"id": 29, "text": "avoir faim — avoir soif - avoir froid - avoir mal à la tête", "words": [139, 140, 141, 142, 143, 144, 145, 146, 147, 148, 149, 150, 151, 152]}, {"id": 30, "text": "- que tu a4 faim ?", "words": [153, 154, 155, 156, 157, 158]}, {"id": 31, "text": "- Mon, je n'ai pas faim.", "words": [159, 160, 161, 162, 163, 164]}, {"id": 32, "text": "a.", "words": [165]}, {"id": 33, "text": "Faites des phrases avec «il ests /« il a # ou « elle est » /« elle a ».", "words": [166, 167, 168, 169, 170, 171, 172, 173, 174, 175, 176, 177, 178, 179, 180, 181, 182, 183, 184]}, {"id": 34, "text": "b.", "words": [185]}, {"id": 35, "text": "Mettez au pluriel.", "words": [186, 187, 188]}, {"id": 36, "text": "1.", "words": [189]}, {"id": 37, "text": "mannequin - 2.", "words": [190, 191, 192]}, {"id": 38, "text": "chanteur — 4.", "words": [193, 194, 195]}, {"id": 39, "text": "architecte 4.", "words": [196, 197]}, {"id": 40, "text": "lycéen une belle maison - de jolies jambes — un gros cartable - une belle voix", "words": [198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210, 211, 212, 213]}, {"id": 41, "text": "1.", "words": [214]}, {"id": 42, "text": "Elle mannequin.", "words": [215, 216]}, {"id": 43, "text": "Elle a de jolies jambes.", "words": [217, 218, 219, 220, 221]}, {"id": 44, "text": "2.", "words": [222]}, {"id": 45, "text": "3.", "words": [223]}, {"id": 46, "text": "Elle 4.", "words": [224, 225]}, {"id": 47, "text": "Posez des questions à votre vos enfants.", "words": [226, 227, 228, 229, 230, 231, 232]}, {"id": 48, "text": "sac - papiers - carte de transport - clés - gants", "words": [233, 234, 235, 236, 237, 238, 239, 240, 241, 242, 243]}, {"id": 49, "text": "cinquante et un 51", "words": [244, 245, 246, 247]}]}