xt": "Avant, écolier.", "words": [23, 24]}, {"id": 8, "text": "Plus tard, à Berlin.", "words": [25, 26, 27, 28]}, {"id": 9, "text": "Plus tard, je étudiant.", "words": [29, 30, 31, 32]}, {"id": 10, "text": "2.", "words": [33]}, {"id": 11, "text": "Maintenant, je un peu français.", "words": [34, 35, 36, 37, 38]}, {"id": 12, "text": "4.", "words": [39]}, {"id": 13, "text": "Maintenant, un appartement.", "words": [40, 41, 42]}, {"id": 14, "text": "Avant, très mal.", "words": [43, 44, 45]}, {"id": 15, "text": "Avant, un studio.", "words": [46, 47, 48]}, {"id": 16, "text": "Plus tard, parfaitement.", "words": [49, 50, 51]}, {"id": 17, "text": "Plus tard, une maison.", "words": [52, 53, 54, 55]}, {"id": 18, "text": "D librement au futur simple.", "words": [56, 57, 58, 59, 60]}, {"id": 19, "text": "Continuez à toutes les personnes.", "words": [61, 62, 63, 64, 65]}, {"id": 20, "text": "1.", "words": [66]}, {"id": 21, "text": "Quand je serai grand, je 2.", "words": [67, 68, 69, 70, 71, 72]}, {"id": 22, "text": "Quand Ada aura assez d'argent, elle 3.", "words": [73, 74, 75, 76, 77, 78, 79]}, {"id": 23, "text": "Quand il fers plus chaud, on 4.", "words": [80, 81, 82, 83, 84, 85, 86]}, {"id": 24, "text": "Quand j'irai en France, je", "words": [87, 88, 89, 90, 91]}, {"id": 25, "text": "€ a.", "words": [92, 93]}, {"id": 26, "text": "Complétez avec des verbes au présent puis à limparfait, selon le modèle.", "words": [94, 95, 96, 97, 98, 99, 100, 101, 102, 103, 104, 105]}, {"id": 27, "text": "sortir - prendre - lire - jouer - monter - aller - se promener", "words": [106, 107, 108, 109, 110, 111, 112, 113, 114, 115, 116, 117, 118, 119]}, {"id": 28, "text": "Maintenant, Avant, .", "words": [120, 121, 122]}, {"id": 29, "text": "M.", "words": [123]}, {"id": 30, "text": "Dupré à 11 h du matin.", "words": [124, 125, 126, 127, 128, 129]}, {"id": 31, "text": "i : M.", "words": [130, 131, 132]}, {"id": 32, "text": "Dupré à 7 h du matin.", "words": [133, 134, 135, 136, 137, 138]}, {"id": 33, "text": ": Il son café au « Monaco's ».", "words": [139, 140, 141, 142, 143, 144, 145, 146]}, {"id": 34, "text": "a son café « Chez Lulu ».", "words": [147, 148, 149, 150, 151, 152, 153]}, {"id": 35, "text": "| le Journal de la Bourse.", "words": [154, 155, 156, 157, 158, 159]}, {"id": 36, "text": "| il Paris-Turf.", "words": [160, 161, 162]}, {"id": 37, "text": "Il au casino.", "words": [163, 164, 165]}, {"id": 38, "text": "au tiercé.", "words": [166, 167]}, {"id": 39, "text": "dans sa Roils.", "words": [168, 169, 170]}, {"id": 40, "text": "[il dans sa vieille Peugeot.", "words": [171, 172, 173, 174, 175]}, {"id": 41, "text": "Il à la plage.", "words": [176, 177, 178, 179]}, {"id": 42, "text": "al au bureau.", "words": [180, 181, 182]}, {"id": 43, "text": "| Il avec ses enfants.", "words": [183, 184, 185, 186, 187]}, {"id": 44, "text": "avec son chien.", "words": [188, 189, 190]}, {"id": 45, "text": "b.", "words": [191]}, {"id": 46, "text": "Imaginez les raisons du changement de M.", "words": [192, 193, 194, 195, 196, 197, 198]}, {"id": 47, "text": "Dupré.", "words": [199]}, {"id": 48, "text": "(héritage, déménagement, rencontres, etc.)", "words": [200, 201, 202, 203]}, {"id": 49, "text": "Complétez avec des verbes au présent, à l'imparfait ou au passé composé.", "words": [204, 205, 206, 207, 208, 209, 210, 211, 212, 213, 214, 215]}, {"id": 50, "text": "1.", "words": [216]}, {"id": 51, "text": "acheter: Avant j'achetais mes habits chez « Spring».", "words": [217, 218, 219, 220, 221, 222, 223, 224]}, {"id": 52, "text": "Un jour, f'ai acheté mes habits par correspon-", "words": [225, 226, 227, 228, 229, 230, 231, 232]}, {"id": 53, "text": "2.", "words": [233]}, {"id": 54, "text": "boire:", "words": [234]}, {"id": 55, "text": "3.", "words": [235]}, {"id": 56, "text": "aller:", "words": [236]}, {"id": 57, "text": "dance.", "words": [237]}, {"id": 58, "text": "Maintenant, j'achète mes habits par correspondance.", "words": [238, 239, 240, 241, 242, 243]}, {"id": 59, "text": "Avant, Léa du café « Latazza ».", "words": [244, 245, 246, 247, 248, 249, 250]}, {"id": 60, "text": "Un jour, du café « Kawa».", "words": [251, 252, 253, 254, 255, 256]}, {"id": 61, "text": "Maintenant,", "words": [257]}, {"id": 62, "text": "Avant, nous à l'hôtel Tourista.", "words": [258, 259, 260, 261, 262]}, {"id": 63, "text": "Un jour, nous à l'hôtel Panorama.", "words": [263, 264, 265, 266, 267, 268]}, {"id": 64, "text": "Maintenant,", "words": [269]}, {"id": 65, "text": "cent vingt-trois « 123", "words": [270, 271, 272, 273]}]}