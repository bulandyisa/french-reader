]}, {"id": 18, "text": "LE DISCOURS DIRECT ET INDIRECT", "words": [79, 80, 81, 82, 83]}, {"id": 19, "text": "Il dit: «Il fait beau.", "words": [84, 85, 86, 87, 88]}, {"id": 20, "text": "» Il dit qu'il fait beau.", "words": [89, 90, 91, 92, 93, 94]}, {"id": 21, "text": "Il dit : «Est-ce qu'il pleut?»", "words": [95, 96, 97, 98, 99, 100]}, {"id": 22, "text": "Il demande s’il pleut.", "words": [101, 102, 103, 104]}, {"id": 23, "text": "Îl dit: «Qu'est-ce que tu fais ?»", "words": [105, 106, 107, 108, 109, 110, 111]}, {"id": 24, "text": "Il demande ce que tu fais.", "words": [112, 113, 114, 115, 116, 117]}, {"id": 25, "text": "Il dit: « Viens!»", "words": [118, 119, 120, 121]}, {"id": 26, "text": "Îl lui dit de venir.", "words": [122, 123, 124, 125, 126]}, {"id": 27, "text": "mms 7.", "words": [127, 128]}, {"id": 28, "text": "LE PASSÉ PROCHE (PASSÉ RÉCENT)", "words": [129, 130, 131, 132, 133]}, {"id": 29, "text": "+ «Venir de» + infinitif exprime un passé très récent:", "words": [134, 135, 136, 137, 138, 139, 140, 141, 142, 143]}, {"id": 30, "text": "I!", "words": [144]}, {"id": 31, "text": "vient de sortir = Il est sorti il y a quelques minutes.", "words": [145, 146, 147, 148, 149, 150, 151, 152, 153, 154, 155, 156]}, {"id": 32, "text": "Je viens de manger = J'ai mangé il y a quelques minutes.", "words": [157, 158, 159, 160, 161, 162, 163, 164, 165, 166, 167, 168]}, {"id": 33, "text": "mms LES PRONOMS DÉMONSTRATIFS", "words": [169, 170, 171, 172]}, {"id": 34, "text": "+ On peut remplacer un adjectif démonstratif et un nom par un pronom:", "words": [173, 174, 175, 176, 177, 178, 179, 180, 181, 182, 183, 184, 185]}, {"id": 35, "text": "ce livre \\ celui-ci celui-là", "words": [186, 187, 188, 189, 190]}, {"id": 36, "text": "cette voiture celle-ci celle-là", "words": [191, 192, 193, 194]}, {"id": 37, "text": "ces livres ceux-ci ceuxlà de différence ces voitures | celles-ci celleslàä :", "words": [195, 196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206]}, {"id": 38, "text": "9.", "words": [207]}, {"id": 39, "text": "LES PRONOMS POSSESSIFS", "words": [208, 209, 210]}, {"id": 40, "text": "+ On peut remplacer un adjectif possessif et un nom par un pronom:", "words": [211, 212, 213, 214, 215, 216, 217, 218, 219, 220, 221, 222, 223]}, {"id": 41, "text": "livre voiture livres voitures mon / ma le mien | la mienne | mes | les miens , les miennes ton/ta | latienne | tes lestiens les tiennes son/sa lesien |lasienne | ses | lessiens | lessiennes | notre le nôtre : la nôtre | nos les nôtres les nôtres | votre le vôtre | la vôtre vos les vôtres | lesvôtres : leur leleur : laleur | leurs | lesleurs | lesleurs :", "words": [224, 225, 226, 227, 228, 229, 230, 231, 232, 233, 234, 235, 236, 237, 238, 239, 240, 241, 242, 243, 244, 245, 246, 247, 248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259, 260, 261, 262, 263, 264, 265, 266, 267, 268, 269, 270, 271, 272, 273, 274, 275, 276, 277, 278, 279, 280, 281, 282, 283, 284, 285, 286, 287, 288, 289, 290, 291, 292, 293, 294, 295, 296, 297]}, {"id": 42, "text": "cent cinquante-trois + 153", "words": [298, 299, 300, 301]}]}