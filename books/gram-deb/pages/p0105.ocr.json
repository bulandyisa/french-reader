6, 27]}, {"id": 5, "text": "« ALLER » est, en général, suivi d’un lieu:", "words": [28, 29, 30, 31, 32, 33, 34, 35, 36]}, {"id": 6, "text": "Je vais à Paris.", "words": [37, 38, 39, 40]}, {"id": 7, "text": "Nous allons en France.", "words": [41, 42, 43, 44]}, {"id": 8, "text": "Tu vas à la plage.", "words": [45, 46, 47, 48, 49]}, {"id": 9, "text": "Vous allez au Maroc.", "words": [50, 51, 52, 53]}, {"id": 10, "text": "H/Elle/On va au cinéma.", "words": [54, 55, 56, 57]}, {"id": 11, "text": "vont chez des amis.", "words": [58, 59, 60, 61]}, {"id": 12, "text": "À» indique le lieu où on est, mais aussi le lieu où on va: Je suis à Milan.", "words": [62, 63, 64, 65, 66, 67, 68, 69, 70, 71, 72, 73, 74, 75, 76, 77, 78, 79]}, {"id": 13, "text": "Je vais à Rome.", "words": [80, 81, 82, 83]}, {"id": 14, "text": "Avec une personne, on utilise «chez»: Je vais chez Paul.", "words": [84, 85, 86, 87, 88, 89, 90, 91, 92, 93]}, {"id": 15, "text": "/ chez des amis.", "words": [94, 95, 96, 97]}, {"id": 16, "text": "(Voir «au», «à la», «à l'», p.", "words": [98, 99, 100, 101, 102, 103, 104]}, {"id": 17, "text": "38.)", "words": [105]}, {"id": 18, "text": "« EN TRAIN », « EN AVION », « À PIED »", "words": [106, 107, 108, 109, 110, 111, 112, 113, 114, 115, 116, 117]}, {"id": 19, "text": "+ «En» + moyen de transport (fermé en général)", "words": [118, 119, 120, 121, 122, 123, 124, 125, 126]}, {"id": 20, "text": "en train.", "words": [127, 128]}, {"id": 21, "text": "Je vais à Rome | en voiture.", "words": [129, 130, 131, 132, 133, 134, 135]}, {"id": 22, "text": "en avion.", "words": [136, 137]}, {"id": 23, "text": "+ Je vais au bureau à pied, à bicyclette ou à cheval!", "words": [138, 139, 140, 141, 142, 143, 144, 145, 146, 147, 148, 149]}, {"id": 24, "text": "104 + cent quatre", "words": [150, 151, 152, 153]}]}