: "«ON» = « NOUS » “ONn» = «en général»", "words": [91, 92, 93, 94, 95, 96, 97, 98, 99]}, {"id": 15, "text": "L'INTERROGATION et LA NÉGATION (révision)", "words": [100, 101, 102, 103, 104]}, {"id": 16, "text": "* L'interrogation: « La négation: — Vous parlez anglais ?", "words": [105, 106, 107, 108, 109, 110, 111, 112, 113, 114]}, {"id": 17, "text": "— Non, je ne parie pas anglais.", "words": [115, 116, 117, 118, 119, 120, 121]}, {"id": 18, "text": "— Vous habitez en France ?", "words": [122, 123, 124, 125, 126, 127]}, {"id": 19, "text": "— Non, je n’habite pas en France.", "words": [128, 129, 130, 131, 132, 133, 134]}, {"id": 20, "text": "— Estce que Marie travaille ?", "words": [135, 136, 137, 138, 139, 140]}, {"id": 21, "text": "— Non, elle ne travaille pas.", "words": [141, 142, 143, 144, 145, 146]}, {"id": 22, "text": "— Est-ce que Paul et Max étudient ?", "words": [147, 148, 149, 150, 151, 152, 153, 154]}, {"id": 23, "text": "— Non, üs n'étudient pas.", "words": [155, 156, 157, 158, 159]}, {"id": 24, "text": "22 + vingt-deux", "words": [160, 161, 162]}]}