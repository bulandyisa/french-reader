118]}, {"id": 17, "text": "+ «Pendant» + passé composé J'ai été secrétaire pendant 6 jours.", "words": [119, 120, 121, 122, 123, 124, 125, 126, 127, 128, 129]}, {"id": 18, "text": "J'ai dormi pendant 4 heures.", "words": [130, 131, 132, 133, 134]}, {"id": 19, "text": "Dites : J'ai dormi pendant 2 heures.", "words": [135, 136, 137, 138, 139, 140, 141]}, {"id": 20, "text": "Ne dites pas: J'ai dormi peur 2 heures.", "words": [142, 143, 144, 145, 146, 147, 148, 149]}, {"id": 21, "text": "«DANS » : moment dans le futur", "words": [150, 151, 152, 153, 154, 155, 156]}, {"id": 22, "text": "Je passerai la licence dans six mois.", "words": [157, 158, 159, 160, 161, 162, 163]}, {"id": 23, "text": "Je partirai dans trois semaines.", "words": [164, 165, 166, 167, 168]}, {"id": 24, "text": "m «EN » : courte quantité de temps utilisé", "words": [169, 170, 171, 172, 173, 174, 175, 176, 177]}, {"id": 25, "text": "J'ai fait le voyage en 8 heures.", "words": [178, 179, 180, 181, 182, 183, 184]}, {"id": 26, "text": "J'ai tout fini en 3 jours.", "words": [185, 186, 187, 188, 189, 190]}, {"id": 27, "text": "126 * cent vingt-six", "words": [191, 192, 193, 194]}]}