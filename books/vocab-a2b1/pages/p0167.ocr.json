 11, "text": "5.", "words": [61]}, {"id": 12, "text": "Elle Lexprime | prend |organise| anime | une réunion.", "words": [62, 63, 64, 65, 66, 67, 68, 69, 70]}, {"id": 13, "text": "ED Associez pour constituer une phrase complète.", "words": [71, 72, 73, 74, 75, 76, 77]}, {"id": 14, "text": "1.", "words": [78]}, {"id": 15, "text": "J'aimerais connaître a.", "words": [79, 80, 81]}, {"id": 16, "text": "l'ordre du jour.", "words": [82, 83, 84]}, {"id": 17, "text": "2.", "words": [85]}, {"id": 18, "text": "I] m'a encore coupé b.", "words": [86, 87, 88, 89, 90]}, {"id": 19, "text": "avec lui.", "words": [91, 92]}, {"id": 20, "text": "3.", "words": [93]}, {"id": 21, "text": "Je ne suis pas d'accord c.", "words": [94, 95, 96, 97, 98, 99]}, {"id": 22, "text": "raison !", "words": [100, 101]}, {"id": 23, "text": "4.", "words": [102]}, {"id": 24, "text": "Nous devons organiser d.", "words": [103, 104, 105, 106]}, {"id": 25, "text": "la parole.", "words": [107, 108]}, {"id": 26, "text": "5.", "words": [109]}, {"id": 27, "text": "Tu as e.", "words": [110, 111, 112]}, {"id": 28, "text": "une réunion avec nos collègues.", "words": [113, 114, 115, 116, 117]}, {"id": 29, "text": "6.", "words": [118]}, {"id": 30, "text": "Il faut envoyer f.", "words": [119, 120, 121, 122]}, {"id": 31, "text": "ton point de vue.", "words": [123, 124, 125, 126]}, {"id": 32, "text": "ED Vrai ou faux ?", "words": [127, 128, 129, 130, 131]}, {"id": 33, "text": "VRAI FAUX", "words": [132, 133]}, {"id": 34, "text": ".", "words": [134]}, {"id": 35, "text": "Adèle intervient dans la réunion = elle donne la parole à quelqu'un.", "words": [135, 136, 137, 138, 139, 140, 141, 142, 143, 144, 145, 146]}, {"id": 36, "text": ".", "words": [147]}, {"id": 37, "text": "Je partage votre opinion = je suis du même avis que vous.", "words": [148, 149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159]}, {"id": 38, "text": ".", "words": [160]}, {"id": 39, "text": "Christophe me coupe la parole = Christophe est d'accord avec moi.", "words": [161, 162, 163, 164, 165, 166, 167, 168, 169, 170, 171]}, {"id": 40, "text": ".", "words": [172]}, {"id": 41, "text": "Vous avez raison = vous exposez votre point de vue.", "words": [173, 174, 175, 176, 177, 178, 179, 180, 181, 182]}, {"id": 42, "text": ".", "words": [183]}, {"id": 43, "text": "Judith coupe la parole à Chloé = Judith interrompt Chloé.", "words": [184, 185, 186, 187, 188, 189, 190, 191, 192, 193]}, {"id": 44, "text": "L_]", "words": [194]}, {"id": 45, "text": ".", "words": [195]}, {"id": 46, "text": "Je ne connais pas l'ordre du jour = je ne connais pas ton point de vue.", "words": [196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210, 211]}, {"id": 47, "text": "ND 1 —", "words": [212, 213, 214]}, {"id": 48, "text": ".", "words": [215]}, {"id": 49, "text": "Zoé anime la réunion = Zoé donne la parole aux participants.", "words": [216, 217, 218, 219, 220, 221, 222, 223, 224, 225, 226]}, {"id": 50, "text": "D Complétez.", "words": [227, 228]}, {"id": 51, "text": "1.", "words": [229]}, {"id": 52, "text": "Si Véronique parle, elle parole.", "words": [230, 231, 232, 233, 234]}, {"id": 53, "text": "2.", "words": [235]}, {"id": 54, "text": "Si nous interrompons Véronique, nous lui parole.", "words": [236, 237, 238, 239, 240, 241, 242]}, {"id": 55, "text": "w", "words": [243]}, {"id": 56, "text": ".", "words": [244]}, {"id": 57, "text": "Madeleine n'est pas Véronique : elles pasle même point de vue sur la question.", "words": [245, 246, 247, 248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258]}, {"id": 58, "text": "4.", "words": [259]}, {"id": 59, "text": "Dans ce débat, c'est désagréable, tout le monde en même temps!", "words": [260, 261, 262, 263, 264, 265, 266, 267, 268, 269, 270]}, {"id": 60, "text": "5.", "words": [271]}, {"id": 61, "text": "Frédéric anime la réunion, c'est lui qui parole aux participants.", "words": [272, 273, 274, 275, 276, 277, 278, 279, 280, 281]}, {"id": 62, "text": "6.", "words": [282]}, {"id": 63, "text": "quelle est la meilleure solution ?", "words": [283, 284, 285, 286, 287, 288]}, {"id": 64, "text": "7.", "words": [289]}, {"id": 65, "text": "TU sais qui la réunion ?", "words": [290, 291, 292, 293, 294, 295]}, {"id": 66, "text": "- Non, je ne connais pas les", "words": [296, 297, 298, 299, 300, 301, 302]}, {"id": 67, "text": "Vous avez l'intention de célébrer l'anniversaire d'un(e) ami(e).", "words": [303, 304, 305, 306, 307, 308, 309, 310]}, {"id": 68, "text": "Vous discutez avec quelques", "words": [311, 312, 313, 314]}, {"id": 69, "text": "personnes des différentes possibilités et chacun donne son point de vue et ses idées.", "words": [315, 316, 317, 318, 319, 320, 321, 322, 323, 324, 325, 326, 327, 328]}, {"id": 70, "text": "Faites le dialogue.", "words": [329, 330, 331]}, {"id": 71, "text": "Tests 287 à 289 cent soixante-cinq + 165", "words": [332, 333, 334, 335, 336, 337, 338, 339]}]}