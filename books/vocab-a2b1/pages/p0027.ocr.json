": "l'est fantastique / elle est d'une méchanceté incroyable / elle a bon caractère / ils manquent de patience / elle est vraiment chouette / il n'est pas gentil du tout /il est vraiment antipathique / elle est assez cultivée /", "words": [75, 76, 77, 78, 79, 80, 81, 82, 83, 84, 85, 86, 87, 88, 89, 90, 91, 92, 93, 94, 95, 96, 97, 98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 111, 112, 113, 114]}, {"id": 16, "text": "c'est quelqu'un de paresseux / ils sont aimables / c'est quelqu'un de très dur /il est très intelligent / il est", "words": [115, 116, 117, 118, 119, 120, 121, 122, 123, 124, 125, 126, 127, 128, 129, 130, 131, 132, 133, 134, 135]}, {"id": 17, "text": "absolument odieux / elle n'est pas très généreuse / elle ne manque pas d'autorité / elle est super", "words": [136, 137, 138, 139, 140, 141, 142, 143, 144, 145, 146, 147, 148, 149, 150, 151, 152, 153]}, {"id": 18, "text": "(63) Associez les phrases de sens équivalent.", "words": [154, 155, 156, 157, 158, 159, 160]}, {"id": 19, "text": "1.", "words": [161]}, {"id": 20, "text": "manque pas de courage.", "words": [162, 163, 164, 165]}, {"id": 21, "text": "a.", "words": [166]}, {"id": 22, "text": "Il n'est pas gentil.", "words": [167, 168, 169, 170]}, {"id": 23, "text": "2.", "words": [171]}, {"id": 24, "text": "|| manque de courage.", "words": [172, 173, 174, 175]}, {"id": 25, "text": "b.", "words": [176]}, {"id": 26, "text": "Il n'est pas courageux.", "words": [177, 178, 179, 180]}, {"id": 27, "text": "3.", "words": [181]}, {"id": 28, "text": "Il n'est pas méchant.", "words": [182, 183, 184, 185]}, {"id": 29, "text": "c.", "words": [186]}, {"id": 30, "text": "Il a du courage.", "words": [187, 188, 189, 190]}, {"id": 31, "text": "4.", "words": [191]}, {"id": 32, "text": "manque de gentillesse.", "words": [192, 193, 194]}, {"id": 33, "text": "d.", "words": [195]}, {"id": 34, "text": "vraiment gentil.", "words": [196, 197]}, {"id": 35, "text": "5.", "words": [198]}, {"id": 36, "text": "Il est d'une gentillesse !", "words": [199, 200, 201, 202, 203]}, {"id": 37, "text": "e.", "words": [204]}, {"id": 38, "text": "Il'est assez gentil.", "words": [205, 206, 207]}, {"id": 39, "text": "ED Vrai ou faux ?", "words": [208, 209, 210, 211, 212]}, {"id": 40, "text": ".", "words": [213]}, {"id": 41, "text": "Elle manque de patience = elle est plutôt impatiente.", "words": [214, 215, 216, 217, 218, 219, 220, 221, 222]}, {"id": 42, "text": "VRAI FAUX", "words": [223, 224]}, {"id": 43, "text": ".", "words": [225]}, {"id": 44, "text": "Ils ont bon caractère = ils ont une forte personnalité.", "words": [226, 227, 228, 229, 230, 231, 232, 233, 234, 235]}, {"id": 45, "text": ".", "words": [236]}, {"id": 46, "text": "Elle n'est pas honnête du tout = elle est d'une honnêteté !", "words": [237, 238, 239, 240, 241, 242, 243, 244, 245, 246, 247, 248]}, {"id": 47, "text": ".", "words": [249]}, {"id": 48, "text": "C'est quelqu'un de nerveux = il manque vraiment de calme.", "words": [250, 251, 252, 253, 254, 255, 256, 257, 258, 259]}, {"id": 49, "text": ".", "words": [260]}, {"id": 50, "text": "super = il est merveilleux !", "words": [261, 262, 263, 264, 265, 266]}, {"id": 51, "text": ".", "words": [267]}, {"id": 52, "text": "Elle n'a pas le sens de l'humour = elle manque vraiment d'humour.", "words": [268, 269, 270, 271, 272, 273, 274, 275, 276, 277, 278, 279]}, {"id": 53, "text": "ND 1 BB WU —", "words": [280, 281, 282, 283, 284]}, {"id": 54, "text": ".", "words": [285]}, {"id": 55, "text": "Ils ne manquent pas de générosité = ils sont plutôt généreux.", "words": [286, 287, 288, 289, 290, 291, 292, 293, 294, 295, 296]}, {"id": 56, "text": "Tests 33 à vingt-cinq e 25", "words": [297, 298, 299, 300, 301, 302]}]}