s": [84]}, {"id": 25, "text": "quelqu'un lui a prêté de l'argent.", "words": [85, 86, 87, 88, 89, 90]}, {"id": 26, "text": "6.", "words": [91]}, {"id": 27, "text": "Il achète à crédit, donc...", "words": [92, 93, 94, 95, 96]}, {"id": 28, "text": "f.", "words": [97]}, {"id": 29, "text": "il a des dettes.", "words": [98, 99, 100, 101]}, {"id": 30, "text": "7.", "words": [102]}, {"id": 31, "text": "Il rend de l'argent, donc.", "words": [103, 104, 105, 106, 107]}, {"id": 32, "text": "g.", "words": [108]}, {"id": 33, "text": "il a emprunté de l'argent à la banque.", "words": [109, 110, 111, 112, 113, 114, 115, 116]}, {"id": 34, "text": "La personne qui parle a-t-elle prêté ou emprunté quelque chose ?", "words": [117, 118, 119, 120, 121, 122, 123, 124, 125, 126, 127]}, {"id": 35, "text": ".", "words": [128]}, {"id": 36, "text": "«Tu peux garder mon dictionnaire jusqu'à vendredi.", "words": [129, 130, 131, 132, 133, 134, 135]}, {"id": 37, "text": "» —", "words": [136, 137]}, {"id": 38, "text": ".", "words": [138]}, {"id": 39, "text": "« J'ai presque fini de rembourser mon prêt.", "words": [139, 140, 141, 142, 143, 144, 145, 146]}, {"id": 40, "text": "» — .", "words": [147, 148, 149]}, {"id": 41, "text": "« Vous pouvez payer en trois fois, sans frais.", "words": [150, 151, 152, 153, 154, 155, 156, 157, 158]}, {"id": 42, "text": "» — .", "words": [159, 160, 161]}, {"id": 43, "text": "« Je ne sais pas dire non à un ami qui manque d'argent.", "words": [162, 163, 164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174]}, {"id": 44, "text": "» —", "words": [175, 176]}, {"id": 45, "text": ".", "words": [177]}, {"id": 46, "text": "je n'ai pas de stylo !", "words": [178, 179, 180, 181, 182, 183]}, {"id": 47, "text": "Vous auriez un stylo pour signer le chèque ?", "words": [184, 185, 186, 187, 188, 189, 190, 191, 192]}, {"id": 48, "text": "» —", "words": [193, 194]}, {"id": 49, "text": "D BB —", "words": [195, 196, 197]}, {"id": 50, "text": ".", "words": [198]}, {"id": 51, "text": "« Mes mensualités sont un peu trop lourdes pour mon budget !", "words": [199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210]}, {"id": 52, "text": "» —", "words": [211, 212]}, {"id": 53, "text": "ED Que vont faire ces personnes ?", "words": [213, 214, 215, 216, 217, 218, 219]}, {"id": 54, "text": "1.", "words": [220]}, {"id": 55, "text": "Yaëlle et Antoine vont acheter un petit appartement, mais ils n’ont pas assez d'argent.", "words": [221, 222, 223, 224, 225, 226, 227, 228, 229, 230, 231, 232, 233, 234]}, {"id": 56, "text": "2.", "words": [235]}, {"id": 57, "text": "Yves est millionnaire et il va acheter une voiture, sans problème !", "words": [236, 237, 238, 239, 240, 241, 242, 243, 244, 245, 246, 247]}, {"id": 58, "text": "—_ 3.", "words": [248, 249]}, {"id": 59, "text": "Sylvain doit 500 euros à une amie.", "words": [250, 251, 252, 253, 254, 255, 256]}, {"id": 60, "text": "Heureusement, il a trouvé un travail et aura un bon salaire.", "words": [257, 258, 259, 260, 261, 262, 263, 264, 265, 266, 267]}, {"id": 61, "text": "—", "words": [268]}, {"id": 62, "text": "4.", "words": [269]}, {"id": 63, "text": "Augustin est banquier, il a devant lui des clients qui vont acheter une maison.", "words": [270, 271, 272, 273, 274, 275, 276, 277, 278, 279, 280, 281, 282, 283]}, {"id": 64, "text": "—_", "words": [284]}, {"id": 65, "text": "5.", "words": [285]}, {"id": 66, "text": "Serge n'arrête pas d'emprunter de l'argent, et il ne rembourse rien.", "words": [286, 287, 288, 289, 290, 291, 292, 293, 294, 295, 296]}, {"id": 67, "text": "2", "words": [297]}, {"id": 68, "text": "6.", "words": [298]}, {"id": 69, "text": "Colette a un peu d'argent de côté et elle sait que son neveu à besoin de 2 000 euros.", "words": [299, 300, 301, 302, 303, 304, 305, 306, 307, 308, 309, 310, 311, 312, 313, 314, 315, 316, 317]}, {"id": 70, "text": "—", "words": [318]}, {"id": 71, "text": "ED Complétez par un terme approprié.", "words": [319, 320, 321, 322, 323, 324]}, {"id": 72, "text": "1.", 