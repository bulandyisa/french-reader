": 1, "line": 3, "i": 366}, {"text": "âgées.", "x": 1093, "y": 2203, "w": 89, "h": 34, "conf": 96.0, "block": 11, "par": 1, "line": 3, "i": 367}, {"text": "Tests", "x": 166, "y": 2468, "w": 85, "h": 25, "conf": 96.0, "block": 13, "par": 1, "line": 1, "i": 368}, {"text": "133", "x": 262, "y": 2468, "w": 51, "h": 25, "conf": 95.0, "block": 13, "par": 1, "line": 1, "i": 369}, {"text": "à", "x": 325, "y": 2466, "w": 17, "h": 27, "conf": 95.0, "block": 13, "par": 1, "line": 1, "i": 370}, {"text": "soixante-dix-neuf", "x": 1345, "y": 2463, "w": 294, "h": 30, "conf": 91.0, "block": 13, "par": 1, "line": 1, "i": 371}, {"text": "e", "x": 1652, "y": 2475, "w": 14, "h": 14, "conf": 52.0, "block": 13, "par": 1, "line": 1, "i": 372}, {"text": "79", "x": 1681, "y": 2463, "w": 36, "h": 30, "conf": 96.0, "block": 13, "par": 1, "line": 1, "i": 373}], "sentences": [{"id": 0, "text": "© CLE International 2017.", "words": [0, 1, 2, 3]}, {"id": 1, "text": "La photocopie non autorisée est un délit.", "words": [4, 5, 6, 7, 8, 9, 10]}, {"id": 2, "text": "LES ACTIVITÉS QUOTIDIENNES", "words": [11, 12, 13]}, {"id": 3, "text": "E XE", "words": [14, 15]}, {"id": 4, "text": "ED Choisissez dans la colonne de droite l'explication convenable.", "words": [16, 17, 18, 19, 20, 21, 22, 23, 24]}, {"id": 5, "text": "a.", "words": [25]}, {"id": 6, "text": "Elles s'asseyent autour de la table.", "words": [26, 27, 28, 29, 30, 31]}, {"id": 7, "text": "1.", "words": [32]}, {"id": 8, "text": "Eva et Chloé sont à table.", "words": [33, 34, 35, 36, 37, 38]}, {"id": 9, "text": "b.", "words": [39]}, {"id": 10, "text": "Elles commencent à cuisiner.", "words": [40, 41, 42, 43]}, {"id": 11, "text": "2.", "words": [44]}, {"id": 12, "text": "Eva et Chloé débarrassent la table.", "words": [45, 46, 47, 48, 49, 50]}, {"id": 13, "text": "c.", "words": [51]}, {"id": 14, "text": "Elles apportent le poulet sur la table.", "words": [52, 53, 54, 55, 56, 57, 58]}, {"id": 15, "text": "3.", "words": [59]}, {"id": 16, "text": "Eva et Chloé mettent la table.", "words": [60, 61, 62, 63, 64, 65]}, {"id": 17, "text": "d.", "words": [66]}, {"id": 18, "text": "Elles enlèvent les assiettes, les verres et les couverts 4.", "words": [67, 68, 69, 70, 71, 72, 73, 74, 75, 76]}, {"id": 19, "text": "Eva et Chloé se mettent à table.", "words": [77, 78, 79, 80, 81, 82, 83]}, {"id": 20, "text": "et les emportent à la cuisine.", "words": [84, 85, 86, 87, 88, 89]}, {"id": 21, "text": "e.", "words": [90]}, {"id": 22, "text": "Elles sont assises autour de la table.", "words": [91, 92, 93, 94, 95, 96, 97]}, {"id": 23, "text": "f.", "words": [98]}, {"id": 24, "text": "Elles placent les assiettes, les verres et les couverts", "words": [99, 100, 101, 102, 103, 104, 105, 106, 107]}, {"id": 25, "text": "sur la table.", "words": [108, 109, 110]}, {"id": 26, "text": "ED Complétez les phrases à l'aide des verbes suivants.", "words": [111, 112, 113, 114, 115, 116, 117, 118, 119]}, {"id": 27, "text": "(Attention : certains verbes doivent être conjugués ; les pronoms changent selon la personne.)", "words": [120, 121, 122, 123, 124, 125, 126, 127, 128, 129, 130, 131, 132, 133]}, {"id": 28, "text": "réveiller - se réveiller - se lever - habiller - essuyer - débarrasser - se préparer - se dépêcher - prendre - coucher - se coucher - faire - dormir - mettre - se mettre - déshabiller - endormir - lire.", "words": [134, 135, 136, 137, 138, 139, 140, 141, 142, 143, 144, 145, 146, 147, 148, 149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159, 160, 161, 162, 163, 164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174]}, {"id": 29, "text": "1.", "words": [175]}, {"id": 30, "text": "Le matin, je préfère pour avoir le temps de ment.", "words": [176, 177, 178, 179, 180, 181, 182, 183, 184, 185]}, {"id": 31, "text": "J'aime petit déjeuner et journal avant de ma toilette.", "words": [186, 187, 188, 189, 190, 191, 192, 193, 194]}, {"id": 32, "text": "Ensuite seulement, je enfants.", "words": [195, 196, 197, 198]}, {"id": 33, "text": "C'est moi qui la petite qui a quatre ans, mais le grand s'habille tout seul.", "words": [199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210, 211, 212, 213]}, {"id": 34, "text": "2.", "words": [214]}, {"id": 35, "text": "Moi, c'est le contraire : j'ai beaucoup de mal à matin.", "words": [215, 216, 217, 218, 219, 220, 221, 222, 223, 224, 225]}, {"id": 36, "text": "Je me toujours en retard et je dois partir au lycée.", "words": [226, 227, 228, 229, 230, 231, 232, 233, 234, 235, 236]}, {"id": 37, "text": "3.", "words": [237]}, {"id": 38, "text": "En ce moment, je suis très fatiguée : je tôt pour aller travailler, je très tard tous les soirs et en plus, je mal.", "words": [238, 239, 240, 241, 242, 243, 244, 245, 246, 247, 248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259, 260, 261]}, {"id": 39, "text": "4.", "words": [262]}, {"id": 40, "text": "Pablo a trois ans.", "words": [263, 264, 265, 266]}, {"id": 41, "text": "Quand il est l'heure d'aller au lit, son père , puis lui raconte une histoire pour 5.", "words": [267, 268, 269, 270, 271, 272, 273, 274, 275, 276, 277, 278, 279, 280, 281, 282, 283]}, {"id": 42, "text": "« J'ai renversé de l'eau sur la table, tu veux bien peux prendre le torchon qui est là.", "words": [284, 285, 286, 287, 288, 289, 290, 291, 292, 293, 294, 295, 296, 297, 298, 299, 300, 301]}, {"id": 43, "text": "Après ça, tu couvert et nous pourrons 6.", "words": [302, 303, 304, 305, 306, 307, 308, 309]}, {"id": 44, "text": "- Qui est-ce qui vaisselle, ce soir ?", "words": [310, 311, 312, 313, 314, 315, 316, 317]}, {"id": 45, "text": "- Moi, j'ai déjà", "words": [318, 319, 320, 321]}, {"id": 46, "text": "> À vous !", "words": [322, 323, 324, 325]}, {"id": 47, "text": "1.", "words": [326]}, {"id": 48, "text": "Dites dans quel ordre vous faites les choses quand vous vous préparez le matin.", "words": [327, 328, 329, 330, 331, 332, 333, 334, 335, 336, 337, 338, 339, 340]}, {"id": 49, "text": "2.", "words": [341]}, {"id": 50, "text": "Racontez le dîner et la soirée d'une famille avec deux enfants de quatre et treize ans.", "words": [342, 343, 344, 345, 346, 347, 348, 349, 350, 351, 352, 353, 354, 355, 356, 357]}, {"id": 51, "text": "3.", "words": [358]}, {"id": 52, "text": "Imaginez les activités quotidiennes d'un couple de personnes âgées.", "words": [359, 360, 361, 362, 363, 364, 365, 366, 367]}, {"id": 53, "text": "Tests 133 à soixante-dix-neuf e 79", "words": [368, 369, 370, 371, 372, 373]}]}