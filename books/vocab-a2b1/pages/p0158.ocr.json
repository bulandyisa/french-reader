"id": 4, "text": "(- vous êtes madame...", "words": [27, 28, 29, 30]}, {"id": 5, "text": "?)", "words": [31]}, {"id": 6, "text": "- De la part de Manon Gaubert.", "words": [32, 33, 34, 35, 36, 37, 38]}, {"id": 7, "text": "- Un instant, s’il vous plaît.", "words": [39, 40, 41, 42, 43, 44]}, {"id": 8, "text": "(..)", "words": [45]}, {"id": 9, "text": "Il est en ligne, vous patientez ?", "words": [46, 47, 48, 49, 50, 51, 52]}, {"id": 10, "text": "- Non merci, je le rappellerai plus tard.", "words": [53, 54, 55, 56, 57, 58, 59, 60]}, {"id": 11, "text": "+ AIG, bonjour, est-ce que je pourrais parler à Sébastien Garcia, s’il vous plaît ?", "words": [61, 62, 63, 64, 65, 66, 67, 68, 69, 70, 71, 72, 73, 74, 75]}, {"id": 12, "text": "- Non, je suis désolé(e), il n’est pas là.", "words": [76, 77, 78, 79, 80, 81, 82, 83, 84]}, {"id": 13, "text": "Je peux prendre un message ?", "words": [85, 86, 87, 88, 89, 90]}, {"id": 14, "text": "- Oui, s’il vous plaît.", "words": [91, 92, 93, 94, 95]}, {"id": 15, "text": "Vous pouvez lui demander de rappeler Étienne ?", "words": [96, 97, 98, 99, 100, 101, 102, 103]}, {"id": 16, "text": "- Il a vos coordonnées ?", "words": [104, 105, 106, 107, 108, 109]}, {"id": 17, "text": "— Oui, je crois, mais je vous donne mon numéro.", "words": [110, 111, 112, 113, 114, 115, 116, 117, 118, 119]}, {"id": 18, "text": "C’est le 01 72 36 30 65.", "words": [120, 121, 122, 123, 124, 125, 126]}, {"id": 19, "text": "- Je lui transmettrai votre message.", "words": [127, 128, 129, 130, 131, 132]}, {"id": 20, "text": "Au revoir, monsieur.", "words": [133, 134, 135]}, {"id": 21, "text": "En contexte personnel", "words": [136, 137, 138]}, {"id": 22, "text": "+ bonjour, je voudrais parler à Joëlle, s’il vous plaît.", "words": [139, 140, 141, 142, 143, 144, 145, 146, 147, 148]}, {"id": 23, "text": "- Ne quittez pas / Un instant, s’il vous plaît, je vous la passe.", "words": [149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159, 160, 161, 162]}, {"id": 24, "text": "+ bonjour, je suis bien chez M.", "words": [163, 164, 165, 166, 167, 168, 169]}, {"id": 25, "text": "et Mme Meyer ?", "words": [170, 171, 172, 173]}, {"id": 26, "text": "- Oui.", "words": [174, 175]}, {"id": 27, "text": "- Bonjour, madame.", "words": [176, 177, 178]}, {"id": 28, "text": "Je suis Tiphaine, une amie de Franck.", "words": [179, 180, 181, 182, 183, 184, 185]}, {"id": 29, "text": "Est-ce qu'il est là ?", "words": [186, 187, 188, 189, 190]}, {"id": 30, "text": "AIG, Magali ?", "words": [191, 192, 193]}, {"id": 31, "text": "C’est Romain, à", "words": [194, 195, 196]}, {"id": 32, "text": "- Non, vous avez fait erreur, je ne suis pas Magali !", "words": [197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208]}, {"id": 33, "text": "— Oh, excusez-moi, madame !", "words": [209, 210, 211, 212, 213]}, {"id": 34, "text": "- Je vous en prie.", "words": [214, 215, 216, 217, 218]}, {"id": 35, "text": "SUR LE RÉPONDEUR", "words": [219, 220, 221]}, {"id": 36, "text": "«Bonjour, vous êtes bien chez Ninon et Frédéric.", "words": [222, 223, 224, 225, 226, 227, 228, 229]}, {"id": 37, "text": "Nous sommes absents pour le moment, mais vous pouvez nous laisser un message après le bip qui va suivre.", "words": [230, 231, 232, 233, 234, 235, 236, 237, 238, 239, 240, 241, 242, 243, 244, 245, 246, 247, 248]}, {"id": 38, "text": "Nous vous rappellerons dès que possible.", "words": [249, 250, 251, 252, 253, 254]}, {"id": 39, "text": "»", "words": [255]}, {"id": 40, "text": "+ «Bonjour, vous êtes bien au 01 72 36 30 65, mais je ne peux pas vous répondre à l'instant.", "words": [256, 257, 258, 259, 260, 261, 262, 263, 264, 265, 266, 267, 268, 269, 270, 271, 272, 273, 274, 275]}, {"id": 41, "text": "Laissez-moi votre message et vos coordonnées, et je vous rappellerai.", "words": [276, 277, 278, 279, 280, 281, 282, 283, 284, 285]}, {"id": 42, "text": "Merci et à bientôt.", "words": [286, 287, 288, 289]}, {"id": 43, "text": "»", "words": [290]}, {"id": 44, "text": "Remarques.", "words": [291]}, {"id": 45, "text": "1.", "words": [292]}, {"id": 46, "text": "Les « coordonnées » sont les informations permettant de joindre quelqu'un : nom, numéro de téléphone ou de mobile, adresse, adresse électronique.", "words": [293, 294, 295, 296, 297, 298, 299, 300, 301, 302, 303, 304, 305, 306, 307, 308, 309, 310, 311, 312, 313, 314]}, {"id": 47, "text": "2.", "words": [315]}, {"id": 48, "text": "L'adverbe « bien » s'emploie pour vérifier ou confirmer une information.", "words": [316, 317, 318, 319, 320, 321, 322, 323, 324, 325, 326]}, {"id": 49, "text": "« Vous habitez bien à Lausanne ?", "words": [327, 328, 329, 330, 331, 332, 333]}, {"id": 50, "text": "- Oui, j'habite bien à Lausanne.", "words": [334, 335, 336, 337, 338, 339]}, {"id": 51, "text": "»", "words": [340]}, {"id": 52, "text": "156 + cent cinquante-six", "words": [341, 342, 343, 344]}]}