"id": 10, "text": "See,", "words": [90]}, {"id": 11, "text": "mn", "words": [91]}, {"id": 12, "text": "Il lave le carrelage (le sol) Elle cire le parquet : avec une serpillière ça brille !", "words": [92, 93, 94, 95, 96, 97, 98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108]}, {"id": 13, "text": "AT et un balai-brosse.", "words": [109, 110, 111, 112]}, {"id": 14, "text": "Madame Landrin s'occupe du linge.", "words": [113, 114, 115, 116, 117]}, {"id": 15, "text": "Elle a une machine à laver toute neuve.", "words": [118, 119, 120, 121, 122, 123, 124, 125]}, {"id": 16, "text": "L 0 ° 2", "words": [126, 127, 128, 129]}, {"id": 17, "text": "F \\) HN K Elle fait à peu près trois lessives Elle lave certains Elle étend le linge Quand il est sec, par semaine.", "words": [130, 131, 132, 133, 134, 135, 136, 137, 138, 139, 140, 141, 142, 143, 144, 145, 146, 147, 148, 149, 150, 151, 152, 153]}, {"id": 18, "text": "Elle utilise une vêtements délicats avec des pinces à linge.", "words": [154, 155, 156, 157, 158, 159, 160, 161, 162, 163]}, {"id": 19, "text": "elle le ramasse.", "words": [164, 165, 166]}, {"id": 20, "text": "lessive écologique.", "words": [167, 168]}, {"id": 21, "text": "à la main.", "words": [169, 170, 171]}, {"id": 22, "text": "Remarque.", "words": [172]}, {"id": 23, "text": "La lessive désigne le produit que l’on met dans la machine à laver mais aussi l’action de laver le linge à la machine.", "words": [173, 174, 175, 176, 177, 178, 179, 180, 181, 182, 183, 184, 185, 186, 187, 188, 189, 190, 191, 192, 193, 194, 195]}, {"id": 24, "text": "LA", "words": [196]}, {"id": 25, "text": "Les Landrin pas non plus les plie.", "words": [197, 198, 199, 200, 201, 202, 203]}, {"id": 26, "text": "et les range dans les placards et armoires.", "words": [204, 205, 206, 207, 208, 209, 210, 211]}, {"id": 27, "text": "faire le repassage.", "words": [212, 213, 214]}, {"id": 28, "text": "Chacun repasse ses vêtements (avec un fer à", "words": [215, 216, 217, 218, 219, 220, 221, 222]}, {"id": 29, "text": "Heureusement, Léa porte surtout des vêtements qui ne se repassent pas.", "words": [223, 224, 225, 226, 227, 228, 229, 230, 231, 232, 233]}, {"id": 30, "text": "Il reste une dernière activité quotidienne, réservée à Léa : sortir le chien.", "words": [234, 235, 236, 237, 238, 239, 240, 241, 242, 243, 244, 245, 246]}, {"id": 31, "text": "82 + quatre-vingt-deux", "words": [247, 248, 249]}]}