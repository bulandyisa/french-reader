[63, 64, 65, 66]}, {"id": 9, "text": "(«Cela m'attriste beaucoup.", "words": [67, 68, 69]}, {"id": 10, "text": "» se réjouir, être gai être triste", "words": [70, 71, 72, 73, 74, 75, 76]}, {"id": 11, "text": "être, se sentir heureux être, se sentir malheureux — le bonheur — le malheur", "words": [77, 78, 79, 80, 81, 82, 83, 84, 85, 86, 87, 88, 89, 90]}, {"id": 12, "text": "Remarque.", "words": [91]}, {"id": 13, "text": "Les larmes ne traduisent pas toujours la tristesse : on pleure parfois de joie ou de rire — rire aux larmes.", "words": [92, 93, 94, 95, 96, 97, 98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 111, 112]}, {"id": 14, "text": "Quelques expressions :", "words": [113, 114, 115]}, {"id": 15, "text": "+ avoir les larmes aux yeux = être à la limite de pleurer.", "words": [116, 117, 118, 119, 120, 121, 122, 123, 124, 125, 126, 127, 128]}, {"id": 16, "text": "e avoir le fou rire = rire à ne plus pouvoir s'arrêter.", "words": [129, 130, 131, 132, 133, 134, 135, 136, 137, 138, 139, 140]}, {"id": 17, "text": "+ c'est pour rire : ce n'est pas sérieux.", "words": [141, 142, 143, 144, 145, 146, 147, 148, 149]}, {"id": 18, "text": "B La mort", "words": [150, 151, 152]}, {"id": 19, "text": "+ Annette, la mère de Sylvie vient de mourir.", "words": [153, 154, 155, 156, 157, 158, 159, 160, 161]}, {"id": 20, "text": "Elle est décédée hier matin.", "words": [162, 163, 164, 165, 166]}, {"id": 21, "text": "Sylvie vient de perdre sa mère.", "words": [167, 168, 169, 170, 171, 172]}, {"id": 22, "text": "Elle annonce la triste nouvelle du décès de sa mère à ses meilleurs amis.", "words": [173, 174, 175, 176, 177, 178, 179, 180, 181, 182, 183, 184, 185, 186]}, {"id": 23, "text": "Son père essaie de ne pas il n’est pas complètement abattu (il fait des efforts pour réagir).", "words": [187, 188, 189, 190, 191, 192, 193, 194, 195, 196, 197, 198, 199, 200, 201, 202, 203]}, {"id": 24, "text": "Il fait preuve d'un grand courage.", "words": [204, 205, 206, 207, 208, 209]}, {"id": 25, "text": "Les amis veulent savoir quand aura lieu l'enterrement (- les obsèques), quand la famille va enterrer Annette.", "words": [210, 211, 212, 213, 214, 215, 216, 217, 218, 219, 220, 221, 222, 223, 224, 225, 226]}, {"id": 26, "text": "Sylvie explique que sa mère ne sera pas enterrée, mais incinérée.", "words": [227, 228, 229, 230, 231, 232, 233, 234, 235, 236, 237]}, {"id": 27, "text": "La crémation (- cérémonie aura lieu mardi après-midi.", "words": [238, 239, 240, 241, 242, 243, 244, 245]}, {"id": 28, "text": "Le crématorium (où on incinère les morts) se trouve à l'entrée du cimetière (où on les enterre).", "words": [246, 247, 248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259, 260, 261, 262]}, {"id": 29, "text": "Expression : faire une tête d’enterrement = avoir très triste", "words": [263, 264, 265, 266, 267, 268, 269, 270, 271, 272]}, {"id": 30, "text": "+ Quand on perd un ami ou un parent proche, on est en deuil.", "words": [273, 274, 275, 276, 277, 278, 279, 280, 281, 282, 283, 284, 285, 286]}, {"id": 31, "text": "Un enfant qui a perdu ses parents est orphelin(e).", "words": [287, 288, 289, 290, 291, 292, 293, 294, 295]}, {"id": 32, "text": "Une femme qui a perdu son mari est veuve.", "words": [296, 297, 298, 299, 300, 301, 302, 303, 304]}, {"id": 33, "text": "Un homme qui a perdu sa femme est veuf.", "words": [305, 306, 307, 308, 309, 310, 311, 312, 313]}, {"id": 34, "text": "Lors de on dépose généralement des gerbes, des couronnes ou de simples bouquets de fleurs sur la tombe du mort, au cimetière.", "words": [314, 315, 316, 317, 318, 319, 320, 321, 322, 323, 324, 325, 326, 327, 328, 329, 330, 331, 332, 333, 334, 335]}, {"id": 35, "text": "20 + vingt", "words": [336, 337, 338]}]}