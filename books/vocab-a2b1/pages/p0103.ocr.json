"i": 330}], "sentences": [{"id": 0, "text": "© CLE International 2017.", "words": [0, 1, 2, 3]}, {"id": 1, "text": "La photocopie non autorisée est un délit.", "words": [4, 5, 6, 7, 8, 9, 10]}, {"id": 2, "text": "LOISIRS - JEUX - SPORTS", "words": [11, 12, 13, 14, 15]}, {"id": 3, "text": "ED Vrai ou faux ?", "words": [16, 17, 18, 19, 20]}, {"id": 4, "text": ".", "words": [21]}, {"id": 5, "text": "Un jeu de construction est un jeu de société.", "words": [22, 23, 24, 25, 26, 27, 28, 29, 30]}, {"id": 6, "text": "VRAI FAUX", "words": [31, 32]}, {"id": 7, "text": ".", "words": [33]}, {"id": 8, "text": "Une poupée est un jouet.", "words": [34, 35, 36, 37, 38]}, {"id": 9, "text": ".", "words": [39]}, {"id": 10, "text": "On joue tout seul aux dames.", "words": [40, 41, 42, 43, 44, 45]}, {"id": 11, "text": ".", "words": [46]}, {"id": 12, "text": "Elle fait les magasins = elle adore se déguiser.", "words": [47, 48, 49, 50, 51, 52, 53, 54, 55]}, {"id": 13, "text": ".", "words": [56]}, {"id": 14, "text": "Stéphanie ne sait pas quoi faire = elle s'ennuie.", "words": [57, 58, 59, 60, 61, 62, 63, 64, 65]}, {"id": 15, "text": "D 1 BB —", "words": [66, 67, 68, 69]}, {"id": 16, "text": ".", "words": [70]}, {"id": 17, "text": "Alice et Antoine ont envie de se balader, vont en boîte.", "words": [71, 72, 73, 74, 75, 76, 77, 78, 79, 80, 81]}, {"id": 18, "text": "B Complétez par un verbe approprié.", "words": [82, 83, 84, 85, 86, 87]}, {"id": 19, "text": ".", "words": [88]}, {"id": 20, "text": "Ma fille adore les vêtements, elle passe ses samedis à magasins!", "words": [89, 90, 91, 92, 93, 94, 95, 96, 97, 98, 99]}, {"id": 21, "text": ".", "words": [100]}, {"id": 22, "text": "Pour une fête, Thomas en Martien !", "words": [101, 102, 103, 104, 105, 106, 107]}, {"id": 23, "text": "Personne ne l’a reconnu.", "words": [108, 109, 110, 111]}, {"id": 24, "text": ".", "words": [112]}, {"id": 25, "text": "Est-ce que tu peux cartes ?", "words": [113, 114, 115, 116, 117, 118]}, {"id": 26, "text": "Elles ne sont pas bien mélangées !", "words": [119, 120, 121, 122, 123, 124, 125]}, {"id": 27, "text": ".", "words": [126]}, {"id": 28, "text": "Théo et Fabien ce soir.", "words": [127, 128, 129, 130, 131]}, {"id": 29, "text": ".", "words": [132]}, {"id": 30, "text": "La petite Manon trouve le temps long, elle", "words": [133, 134, 135, 136, 137, 138, 139, 140]}, {"id": 31, "text": ".", "words": [141]}, {"id": 32, "text": "Ce dimanche, je n'ai pas travaillé, je la journée.", "words": [142, 143, 144, 145, 146, 147, 148, 149, 150]}, {"id": 33, "text": "ND BB —", "words": [151, 152, 153]}, {"id": 34, "text": ".", "words": [154]}, {"id": 35, "text": "1 son temps libre au bricolage et au jardinage.", "words": [155, 156, 157, 158, 159, 160, 161, 162, 163]}, {"id": 36, "text": "Associez les phrases de sens équivalent.", "words": [164, 165, 166, 167, 168, 169]}, {"id": 37, "text": "1.", "words": [170]}, {"id": 38, "text": "Il va danser.", "words": [171, 172, 173]}, {"id": 39, "text": "a.", "words": [174]}, {"id": 40, "text": "Il se promène.", "words": [175, 176, 177]}, {"id": 41, "text": "2.", "words": [178]}, {"id": 42, "text": "llse détend.", "words": [179, 180]}, {"id": 43, "text": "b.", "words": [181]}, {"id": 44, "text": "il porte un costume.", "words": [182, 183, 184, 185]}, {"id": 45, "text": "3.", "words": [186]}, {"id": 46, "text": "Il se balade.", "words": [187, 188, 189]}, {"id": 47, "text": "c.", "words": [190]}, {"id": 48, "text": "Il se sert de ses outils.", "words": [191, 192, 193, 194, 195, 196]}, {"id": 49, "text": "4.", "words": [197]}, {"id": 50, "text": "Il bricole.", "words": [198, 199]}, {"id": 51, "text": "d.", "words": [200]}, {"id": 52, "text": "Il sort en boîte.", "words": [201, 202, 203, 204]}, {"id": 53, "text": "5.", "words": [205]}, {"id": 54, "text": "Il s'ennuie.", "words": [206, 207]}, {"id": 55, "text": "e.", "words": [208]}, {"id": 56, "text": "Il se repose.", "words": [209, 210, 211]}, {"id": 57, "text": "6.", "words": [212]}, {"id": 58, "text": "Il se déguise.", "words": [213, 214, 215]}, {"id": 59, "text": "f.", "words": [216]}, {"id": 60, "text": "Il trouve le temps long.", "words": [217, 218, 219, 220, 221]}, {"id": 61, "text": "ED Quel(s) loisir(s) conseilleriez-vous à ces personnes ?", "words": [222, 223, 224, 225, 226, 227, 228, 229]}, {"id": 62, "text": "1.", "words": [230]}, {"id": 63, "text": "Olivier est patient et adore les combinaisons mathématiques.", "words": [231, 232, 233, 234, 235, 236, 237, 238]}, {"id": 64, "text": "2.", "words": [239]}, {"id": 65, "text": "Yasmina aime beaucoup la mode !", "words": [240, 241, 242, 243, 244, 245]}, {"id": 66, "text": "3.", "words": [246]}, {"id": 67, "text": "Justin aime danser et déteste se coucher tôt.", "words": [247, 248, 249, 250, 251, 252, 253, 254]}, {"id": 68, "text": "4.", "words": [255]}, {"id": 69, "text": "Laurence aime la nature, les fleurs et les plantes.", "words": [256, 257, 258, 259, 260, 261, 262, 263, 264]}, {"id": 70, "text": "5.", "words": [265]}, {"id": 71, "text": "La petite Julie adore les bébés !", "words": [266, 267, 268, 269, 270, 271, 272]}, {"id": 72, "text": "©", "words": [273]}, {"id": 73, "text": "1.", "words": [274]}, {"id": 74, "text": "Comment occupez-vous vos loisirs ?", "words": [275, 276, 277, 278, 279]}, {"id": 75, "text": "2.", "words": [280]}, {"id": 76, "text": "Quels jeux de société connaissez-vous ?", "words": [281, 282, 283, 284, 285, 286]}, {"id": 77, "text": "Les avez-vous pratiqués ?", "words": [287, 288, 289, 290]}, {"id": 78, "text": "Pourquoi ?", "words": [291, 292]}, {"id": 79, "text": "3.", "words": [293]}, {"id": 80, "text": "Avez-vous déjà porté un déguisement ?", "words": [294, 295, 296, 297, 298, 299]}, {"id": 81, "text": "Si oui, dans quelles circonstances ?", "words": [300, 301, 302, 303, 304, 305]}, {"id": 82, "text": "En quoi étiez-vous déguisé(e) ?", "words": [306, 307, 308, 309, 310]}, {"id": 83, "text": "4.", "words": [311]}, {"id": 84, "text": "Avec quels jouets les enfants de votre entourage s'amusent-ils ?", "words": [312, 313, 314, 315, 316, 317, 318, 319, 320, 321]}, {"id": 85, "text": "Tests 173 à 175 } cent un + 101", "words": [322, 323, 324, 325, 326, 327, 328, 329, 330]}]}