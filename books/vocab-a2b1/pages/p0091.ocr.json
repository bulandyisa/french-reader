 [56]}, {"id": 19, "text": "Fabrice a besoin d'| une douzaine | un kilo | d'œufs.", "words": [57, 58, 59, 60, 61, 62, 63, 64, 65, 66, 67]}, {"id": 20, "text": "3.", "words": [68]}, {"id": 21, "text": "Rémi cherche le de mayonnaise.", "words": [69, 70, 71, 72, 73]}, {"id": 22, "text": "4.", "words": [74]}, {"id": 23, "text": "Béatrice a acheté un canard à rôtir.", "words": [75, 76, 77, 78, 79, 80, 81]}, {"id": 24, "text": "5", "words": [82]}, {"id": 25, "text": "6", "words": [83]}, {"id": 26, "text": ".", "words": [84]}, {"id": 27, "text": "Vous pouvez me donner une | botte | boîte | de radis ?", "words": [85, 86, 87, 88, 89, 90, 91, 92, 93, 94, 95, 96, 97]}, {"id": 28, "text": ".", "words": [98]}, {"id": 29, "text": "Il me faudrait une | tablette de chocolat au", "words": [99, 100, 101, 102, 103, 104, 105, 106, 107]}, {"id": 30, "text": "Trouvez une autre manière de dire.", "words": [108, 109, 110, 111, 112, 113]}, {"id": 31, "text": ".", "words": [114]}, {"id": 32, "text": "Je voudrais 500 grammes de haricots verts.", "words": [115, 116, 117, 118, 119, 120, 121]}, {"id": 33, "text": "— .", "words": [122, 123]}, {"id": 34, "text": "Il me faudrait environ dix oranges.", "words": [124, 125, 126, 127, 128, 129]}, {"id": 35, "text": "—", "words": [130]}, {"id": 36, "text": ".", "words": [131]}, {"id": 37, "text": "Est-ce que vous auriez environ quinze boîtes de sardines ?", "words": [132, 133, 134, 135, 136, 137, 138, 139, 140, 141]}, {"id": 38, "text": "—", "words": [142]}, {"id": 39, "text": "1 2 3.", "words": [143, 144, 145]}, {"id": 40, "text": "Donnez-moi 250 grammes de beurre.", "words": [146, 147, 148, 149, 150]}, {"id": 41, "text": "— 4 5.", "words": [151, 152, 153]}, {"id": 42, "text": "Je voudrais deux demi-litres d'huile de tournesol.", "words": [154, 155, 156, 157, 158, 159, 160]}, {"id": 43, "text": "—", "words": [161]}, {"id": 44, "text": "ED Chez quel(s) commerçant(s) pourriez-vous entendre les phrases suivantes ?", "words": [162, 163, 164, 165, 166, 167, 168, 169, 170, 171]}, {"id": 45, "text": "« Vous avez reçu Le Monde d'aujourd'hui ?", "words": [172, 173, 174, 175, 176, 177, 178, 179]}, {"id": 46, "text": "» — « Vous en voulez une barquette ?", "words": [180, 181, 182, 183, 184, 185, 186, 187, 188]}, {"id": 47, "text": "» — « C'est pour offrir ?", "words": [189, 190, 191, 192, 193, 194, 195]}, {"id": 48, "text": "» — « Vos camemberts sont fermiers ?", "words": [196, 197, 198, 199, 200, 201, 202, 203]}, {"id": 49, "text": "»—", "words": [204]}, {"id": 50, "text": "«Il me faudrait une livraison à domicile.", "words": [205, 206, 207, 208, 209, 210, 211]}, {"id": 51, "text": "» — « Je vous prends ces tasses et ce petit vase pour 15 € !", "words": [212, 213, 214, 215, 216, 217, 218, 219, 220, 221, 222, 223, 224, 225, 226, 227]}, {"id": 52, "text": "» —", "words": [228, 229]}, {"id": 53, "text": "1.", "words": [230]}, {"id": 54, "text": "2.", "words": [231]}, {"id": 55, "text": "3.", "words": [232]}, {"id": 56, "text": "4.", "words": [233]}, {"id": 57, "text": "5.", "words": [234]}, {"id": 58, "text": "« Vous avez une ordonnance ?", "words": [235, 236, 237, 238, 239, 240]}, {"id": 59, "text": "» — 6.", "words": [241, 242, 243]}, {"id": 60, "text": "7.", "words": [244]}, {"id": 61, "text": "8.", "words": [245]}, {"id": 62, "text": "« Où sont les caddies, s'il vous plaît ?", "words": [246, 247, 248, 249, 250, 251, 252, 253, 254]}, {"id": 63, "text": "» — 9.", "words": [255, 256, 257]}, {"id": 64, "text": "« Vous auriez un dictionnaire français-roumain ?", "words": [258, 259, 260, 261, 262, 263, 264]}, {"id": 65, "text": "» — 10.", "words": [265, 266, 267]}, {"id": 66, "text": "« Donnez-m'en la moitié, s'il vous plaît !", "words": [268, 269, 270, 271, 272, 273, 274, 275]}, {"id": 67, "text": "» —", "words": [276, 277]}, {"id": 68, "text": "Tests 152 à 154 } quatre-vingt-neuf e 89", "words": [278, 279, 280, 281, 282, 283, 284, 285]}]}