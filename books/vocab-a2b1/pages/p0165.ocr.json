4, 35, 36, 37, 38, 39, 40, 41, 42, 43]}, {"id": 9, "text": ".", "words": [44]}, {"id": 10, "text": "Zohra va quitter son mari.", "words": [45, 46, 47, 48, 49]}, {"id": 11, "text": "- Ça alors !", "words": [50, 51, 52, 53]}, {"id": 12, "text": "Ce n'est pas |", "words": [54, 55, 56, 57]}, {"id": 13, "text": ".", "words": [58]}, {"id": 14, "text": "Oscar n'a rien il s'est tu, il n'a pas la bouche !", "words": [59, 60, 61, 62, 63, 64, 65, 66, 67, 68, 69, 70]}, {"id": 15, "text": ".", "words": [71]}, {"id": 16, "text": "Est-ce que vous pouvez le nom, s'il vous plaît ?", "words": [72, 73, 74, 75, 76, 77, 78, 79, 80, 81]}, {"id": 17, "text": ".", "words": [82]}, {"id": 18, "text": "Benoît et Louise vont se marier !", "words": [83, 84, 85, 86, 87, 88, 89]}, {"id": 19, "text": "- Ça !", "words": [90, 91, 92]}, {"id": 20, "text": "Quelle surprise !", "words": [93, 94, 95]}, {"id": 21, "text": ".", "words": [96]}, {"id": 22, "text": "Comme dit le proverbe, | le silence | la parole | est d'or !", "words": [97, 98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110]}, {"id": 23, "text": "Répondez aux questions.", "words": [111, 112, 113]}, {"id": 24, "text": "Vous avez parlé de politique ?", "words": [114, 115, 116, 117, 118, 119]}, {"id": 25, "text": "- Oui, nous avons eu une bonne sur la politique.", "words": [120, 121, 122, 123, 124, 125, 126, 127, 128, 129]}, {"id": 26, "text": "ND 1 BB —", "words": [130, 131, 132, 133]}, {"id": 27, "text": "1.", "words": [134]}, {"id": 28, "text": "2.", "words": [135]}, {"id": 29, "text": "Est-ce que l'acteur est passé à la télévision ?", "words": [136, 137, 138, 139, 140, 141, 142, 143, 144]}, {"id": 30, "text": "- Oui, il a donné", "words": [145, 146, 147, 148, 149]}, {"id": 31, "text": "3.", "words": [150]}, {"id": 32, "text": "Vous avez parlé, pendant la réunion ?", "words": [151, 152, 153, 154, 155, 156, 157]}, {"id": 33, "text": "- Non, au contraire, je", "words": [158, 159, 160, 161, 162]}, {"id": 34, "text": "4.", "words": [163]}, {"id": 35, "text": "Vous regardez les débats à la télévision ?", "words": [164, 165, 166, 167, 168, 169, 170, 171]}, {"id": 36, "text": "- Oui, j'aime bien quand les gens de différents sujets.", "words": [172, 173, 174, 175, 176, 177, 178, 179, 180, 181]}, {"id": 37, "text": "5.", "words": [182]}, {"id": 38, "text": "Votre fille a trouvé un travail ?", "words": [183, 184, 185, 186, 187, 188, 189]}, {"id": 39, "text": "- Peut-être !", "words": [190, 191, 192]}, {"id": 40, "text": "Elle a eu un ce matin.", "words": [193, 194, 195, 196, 197, 198]}, {"id": 41, "text": "> Que font-ils ?", "words": [199, 200, 201, 202]}, {"id": 42, "text": "Pouvez-vous imaginer ce qu'ils disent ?", "words": [203, 204, 205, 206, 207, 208]}, {"id": 43, "text": "À vous !", "words": [209, 210, 211]}, {"id": 44, "text": "Parlez de votre culture.", "words": [212, 213, 214, 215]}, {"id": 45, "text": "1.", "words": [216]}, {"id": 46, "text": "Quelle place tient la conversation dans un dîner amical ?", "words": [217, 218, 219, 220, 221, 222, 223, 224, 225, 226]}, {"id": 47, "text": "2.", "words": [227]}, {"id": 48, "text": "Les débats sont-ils courants dans les médias ?", "words": [228, 229, 230, 231, 232, 233, 234, 235]}, {"id": 49, "text": "Comment se passent-ils ?", "words": [236, 237, 238, 239]}, {"id": 50, "text": "3.", "words": [240]}, {"id": 51, "text": "Existe-t-il des proverbes sur le silence et la parole ?", "words": [241, 242, 243, 244, 245, 246, 247, 248, 249, 250]}, {"id": 52, "text": "Si oui, que disent-ils ?", "words": [251, 252, 253, 254, 255]}, {"id": 53, "text": "4.", "words": [256]}, {"id": 54, "text": "Est-il courant, entre amis, de confronter des opinions différentes ?", "words": [257, 258, 259, 260, 261, 262, 263, 264, 265, 266]}, {"id": 55, "text": "Tests 284 à 286} cent soixante-trois e 163", "words": [267, 268, 269, 270, 271, 272, 273, 274]}]}