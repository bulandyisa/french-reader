id": 7, "text": "Emma a des cheveux magnifiques !", "words": [53, 54, 55, 56, 57, 58]}, {"id": 8, "text": "Cyrano de Bergerac a un grand nez, un très grand nez!", "words": [59, 60, 61, 62, 63, 64, 65, 66, 67, 68, 69]}, {"id": 9, "text": "+ avoir + nom précédé de l’article défini + adjectif Frank a les yeux verts et les cheveux châtains.", "words": [70, 71, 72, 73, 74, 75, 76, 77, 78, 79, 80, 81, 82, 83, 84, 85, 86, 87, 88]}, {"id": 10, "text": "Laurent a le teint pâle.", "words": [89, 90, 91, 92, 93]}, {"id": 11, "text": "Jacotte a la peau claire et les cheveux gris.", "words": [94, 95, 96, 97, 98, 99, 100, 101, 102]}, {"id": 12, "text": "+ être + article indéfini + adjectif + caractéristiques des cheveux", "words": [103, 104, 105, 106, 107, 108, 109, 110, 111, 112, 113]}, {"id": 13, "text": "Christian est un beau brun.", "words": [114, 115, 116, 117, 118]}, {"id": 14, "text": "Virginie est une jolie rousse.", "words": [119, 120, 121, 122, 123]}, {"id": 15, "text": "C'est un grand blond aux yeux verts (= il est grand, blond et il a les yeux verts).", "words": [124, 125, 126, 127, 128, 129, 130, 131, 132, 133, 134, 135, 136, 137, 138, 139, 140, 141]}, {"id": 16, "text": "C'est une petite brune aux cheveux courts.", "words": [142, 143, 144, 145, 146, 147, 148]}, {"id": 17, "text": "C’est une fausse blonde (- ce n'est pas sa couleur naturelle).", "words": [149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159]}, {"id": 18, "text": "LA TAILLE ET LE POIDS", "words": [160, 161, 162, 163, 164]}, {"id": 19, "text": "Combien est-ce qu’il mesure ?", "words": [165, 166, 167, 168, 169]}, {"id": 20, "text": "ILest.…", "words": [170]}, {"id": 21, "text": "petit detaille moyenne grand très grand immense 1m55 Im75 1 m 80 1 m 90", "words": [171, 172, 173, 174, 175, 176, 177, 178, 179, 180, 181, 182, 183, 184, 185]}, {"id": 22, "text": "B Combien est-ce qu’elle pèse ?", "words": [186, 187, 188, 189, 190, 191]}, {"id": 23, "text": "Chloé s’est pesée sur sa balance : elle pèse 65 kilos, elle a pris 5 kilos en deux mois, elle a grossi de 5 kilos !", "words": [192, 193, 194, 195, 196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210, 211, 212, 213, 214, 215, 216, 217]}, {"id": 24, "text": "Quelle horreur !", "words": [218, 219, 220]}, {"id": 25, "text": "Elle doit maigrir / perdre du poids, si elle veut garder la ligne.", "words": [221, 222, 223, 224, 225, 226, 227, 228, 229, 230, 231, 232, 233]}, {"id": 26, "text": "« Demain, c’est décidé, je commence un régime (amaigrissant).", "words": [234, 235, 236, 237, 238, 239, 240, 241, 242]}, {"id": 27, "text": "» Et bien sûr, elle va faire de la gymnastique pour rester souple, car elle se sent un peu raide en ce moment.", "words": [243, 244, 245, 246, 247, 248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259, 260, 261, 262, 263, 264, 265]}, {"id": 28, "text": "elle est maigre mince", "words": [266, 267, 268, 269]}, {"id": 29, "text": "56 + cinquante-six", "words": [270, 271, 272]}]}