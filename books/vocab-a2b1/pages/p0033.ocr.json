56]}, {"id": 15, "text": ".", "words": [57]}, {"id": 16, "text": "Thomas est arrivé à [moins dix.", "words": [58, 59, 60, 61, 62, 63]}, {"id": 17, "text": ".", "words": [64]}, {"id": 18, "text": "Hier soir, nous avons admiré un beau | lever | coucher | de soleil.", "words": [65, 66, 67, 68, 69, 70, 71, 72, 73, 74, 75, 76, 77, 78]}, {"id": 19, "text": ".", "words": [79]}, {"id": 20, "text": "Mes amis sont originaires du minuit | Midi", "words": [80, 81, 82, 83, 84, 85, 86, 87]}, {"id": 21, "text": "ŒD Associez une question à une réponse.", "words": [88, 89, 90, 91, 92, 93, 94]}, {"id": 22, "text": "D —", "words": [95, 96]}, {"id": 23, "text": "1.", "words": [97]}, {"id": 24, "text": "Vous avez l'heure ?", "words": [98, 99, 100, 101]}, {"id": 25, "text": "a.", "words": [102]}, {"id": 26, "text": "Non, il fait encore nuit.", "words": [103, 104, 105, 106, 107]}, {"id": 27, "text": "2.", "words": [108]}, {"id": 28, "text": "resté combien de temps ?", "words": [109, 110, 111, 112, 113]}, {"id": 29, "text": "b.", "words": [114]}, {"id": 30, "text": "À midi.", "words": [115, 116]}, {"id": 31, "text": "3.", "words": [117]}, {"id": 32, "text": "Elle vient de quelle région ?", "words": [118, 119, 120, 121, 122, 123]}, {"id": 33, "text": "c.", "words": [124]}, {"id": 34, "text": "Oui, 7 jours sur 7.", "words": [125, 126, 127, 128, 129]}, {"id": 35, "text": "4.", "words": [130]}, {"id": 36, "text": "Il fait jour ?", "words": [131, 132, 133, 134]}, {"id": 37, "text": "d.", "words": [135]}, {"id": 38, "text": "Un bon moment !", "words": [136, 137, 138, 139]}, {"id": 39, "text": "5.", "words": [140]}, {"id": 40, "text": "C'est ouvert tous les jours ?", "words": [141, 142, 143, 144, 145, 146]}, {"id": 41, "text": "e.", "words": [147]}, {"id": 42, "text": "Oui, il est midi.", "words": [148, 149, 150, 151]}, {"id": 43, "text": "6.", "words": [152]}, {"id": 44, "text": "À quelle heure tu déjeunes ?", "words": [153, 154, 155, 156, 157, 158]}, {"id": 45, "text": "f.", "words": [159]}, {"id": 46, "text": "Non, elle avance.", "words": [160, 161, 162]}, {"id": 47, "text": "7.", "words": [163]}, {"id": 48, "text": "Ta montre retarde ?", "words": [164, 165, 166, 167]}, {"id": 49, "text": "g.", "words": [168]}, {"id": 50, "text": "Du Midi.", "words": [169, 170]}, {"id": 51, "text": "ED Vrai ou faux ?", "words": [171, 172, 173, 174, 175]}, {"id": 52, "text": "Le train est arrivé à 14h30 = il est arrivé à deux heures et demie.", "words": [176, 177, 178, 179, 180, 181, 182, 183, 184, 185, 186, 187, 188, 189, 190]}, {"id": 53, "text": "VRAI FAUX", "words": [191, 192]}, {"id": 54, "text": "Ma pendule retarde = elle est à l'heure.", "words": [193, 194, 195, 196, 197, 198, 199, 200]}, {"id": 55, "text": "J'ai attendu trois quarts d'heure = j'ai attendu 35 minutes.", "words": [201, 202, 203, 204, 205, 206, 207, 208, 209, 210]}, {"id": 56, "text": "Ilest midi, donc il fait nuit.", "words": [211, 212, 213, 214, 215, 216]}, {"id": 57, "text": "Le matin, le jour se lève.", "words": [217, 218, 219, 220, 221, 222]}, {"id": 58, "text": "Je suis parti très tôt ce matin, à midi.", "words": [223, 224, 225, 226, 227, 228, 229, 230, 231]}, {"id": 59, "text": "1.", "words": [232]}, {"id": 60, "text": "2: 3.", "words": [233, 234]}, {"id": 61, "text": "4.", "words": [235]}, {"id": 62, "text": "5.", "words": [236]}, {"id": 63, "text": "La nuit tombe le matin.", "words": [237, 238, 239, 240, 241]}, {"id": 64, "text": "6.", "words": [242]}, {"id": 65, "text": "FA 8.", "words": [243, 244]}, {"id": 66, "text": "Ce magasin est ouvert 7 jours sur 7 = tous les jours, sauf le dimanche.", "words": [245, 246, 247, 248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259]}, {"id": 67, "text": "ED À vous !", "words": [260, 261, 262, 263]}, {"id": 68, "text": "Répondez librement aux questions.", "words": [264, 265, 266, 267]}, {"id": 69, "text": ".", "words": [268]}, {"id": 70, "text": "Vous avez l'heure ?", "words": [269, 270, 271, 272]}, {"id": 71, "text": ".", "words": [273]}, {"id": 7