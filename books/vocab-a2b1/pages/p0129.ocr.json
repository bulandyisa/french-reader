 27, "conf": 67.0, "block": 12, "par": 1, "line": 1, "i": 348}, {"text": "cent", "x": 1363, "y": 2467, "w": 73, "h": 26, "conf": 93.0, "block": 12, "par": 1, "line": 1, "i": 349}, {"text": "vingt-sept", "x": 1448, "y": 2465, "w": 169, "h": 35, "conf": 91.0, "block": 12, "par": 1, "line": 1, "i": 350}, {"text": "127", "x": 1664, "y": 2463, "w": 53, "h": 29, "conf": 96.0, "block": 12, "par": 1, "line": 1, "i": 351}], "sentences": [{"id": 0, "text": "© CLE International 2017.", "words": [0, 1, 2, 3]}, {"id": 1, "text": "La photocopie non autorisée est un délit.", "words": [4, 5, 6, 7, 8, 9, 10]}, {"id": 2, "text": "L'ENSEIGNEMENT", "words": [11]}, {"id": 3, "text": "E XE", "words": [12, 13]}, {"id": 4, "text": "ED Complétez par un terme approprié.", "words": [14, 15, 16, 17, 18, 19]}, {"id": 5, "text": ".", "words": [20]}, {"id": 6, "text": "Mathilde préfère les mots aux chiffres.", "words": [21, 22, 23, 24, 25, 26]}, {"id": 7, "text": "Elle aime le", "words": [27, 28, 29]}, {"id": 8, "text": ".", "words": [30]}, {"id": 9, "text": "Elle n'aime pas compter.", "words": [31, 32, 33, 34]}, {"id": 10, "text": "Elle déteste les", "words": [35, 36, 37]}, {"id": 11, "text": ".", "words": [38]}, {"id": 12, "text": "Romain préfère jouer dans la cour avec ses copains.", "words": [39, 40, 41, 42, 43, 44, 45, 46, 47]}, {"id": 13, "text": "Il adore la", "words": [48, 49, 50]}, {"id": 14, "text": ".", "words": [51]}, {"id": 15, "text": "Il'aime aussi courir, sauter, jouer au ballon.", "words": [52, 53, 54, 55, 56, 57, 58]}, {"id": 16, "text": "Sa matière préférée est le", "words": [59, 60, 61, 62, 63]}, {"id": 17, "text": ".", "words": [64]}, {"id": 18, "text": "Malek veut devenir médecin.", "words": [65, 66, 67, 68]}, {"id": 19, "text": "À seize ans, il aime déjà beaucoup la", "words": [69, 70, 71, 72, 73, 74, 75, 76]}, {"id": 20, "text": ".", "words": [77]}, {"id": 21, "text": "Agathe veut devenir avocate.", "words": [78, 79, 80, 81]}, {"id": 22, "text": "Elle est actuellement en troisième année de", "words": [82, 83, 84, 85, 86, 87, 88]}, {"id": 23, "text": ".", "words": [89]}, {"id": 24, "text": "Thomas aime lire, réfléchir aux grandes questions humaines.", "words": [90, 91, 92, 93, 94, 95, 96, 97]}, {"id": 25, "text": "Il s'intéresse beaucoup à la", "words": [98, 99, 100, 101, 102]}, {"id": 26, "text": "ND un BB WW —", "words": [103, 104, 105, 106, 107]}, {"id": 27, "text": "— Complétez.", "words": [108, 109]}, {"id": 28, "text": ".", "words": [110]}, {"id": 29, "text": "Lucile a eu 18 en maths, 12 en science de la vie, 16 en français, 13 en allemand, 12 en physique, 14 en philo et 13 en histoire-géo.", "words": [111, 112, 113, 114, 115, 116, 117, 118, 119, 120, 121, 122, 123, 124, 125, 126, 127, 128, 129, 130, 131, 132, 133, 134, 135, 136, 137, 138]}, {"id": 30, "text": "Ça lui fait une 14/20.", "words": [139, 140, 141, 142, 143]}, {"id": 31, "text": "2.", "words": [144]}, {"id": 32, "text": "Frédérique a eu sa licence avec tout juste 10 de moyenne.", "words": [145, 146, 147, 148, 149, 150, 151, 152, 153, 154, 155]}, {"id": 33, "text": "Elle a obtenu la", "words": [156, 157, 158, 159]}, {"id": 34, "text": "passable.", "words": [160]}, {"id": 35, "text": "3.", "words": [161]}, {"id": 36, "text": "Olivier a presque terminé d'écrire son thèse.", "words": [162, 163, 164, 165, 166, 167, 168]}, {"id": 37, "text": "Il ne lui reste plus qu'à compléter sa qui est très longue car il a lu beaucoup de livres.", "words": [169, 170, 171, 172, 173, 174, 175, 176, 177, 178, 179, 180, 181, 182, 183, 184, 185, 186, 187]}, {"id": 38, "text": "4.", "words": [188]}, {"id": 39, "text": "Zulma a été malade et n'a pas pu ses examens.", "words": [189, 190, 191, 192, 193, 194, 195, 196, 197, 198]}, {"id": 40, "text": "Elle doit son année de master.", "words": [199, 200, 201, 202, 203, 204]}, {"id": 41, "text": "5.", "words": [205]}, {"id": 42, "text": "Pour séminaire de civilisation espagnole, les étudiants peuvent choisir entre un oral et un écrit à la maison.", "words": [206, 207, 208, 209, 210, 211, 212, 213, 214, 215, 216, 217, 218, 219, 220, 221, 222, 223]}, {"id": 43, "text": "6.", "words": [224]}, {"id": 44, "text": "Dans quelques mois, Tom va a l'intention de", "words": [225, 226, 227, 228, 229, 230, 231, 232]}, {"id": 45, "text": "l’université l'année prochaine, mais il hésite encore entre plusieurs", "words": [233, 234, 235, 236, 237, 238, 239, 240, 241]}, {"id": 46, "text": "Racontez la vie scolaire et universitaire de Baptiste selon les indications suivantes.", "words": [242, 243, 244, 245, 246, 247, 248, 249, 250, 251, 252, 253]}, {"id": 47, "text": "- École maternelle à trois ans.", "words": [254, 255, 256, 257, 258, 259]}, {"id": 48, "text": "- École primaire à six ans : apprentissage de la lecture, de l'écriture, du calcul.", "words": [260, 261, 262, 263, 264, 265, 266, 267, 268, 269, 270, 271, 272, 273, 274]}, {"id": 49, "text": "- Collège à 11 ans.", "words": [275, 276, 277, 278, 279]}, {"id": 50, "text": "Intérêt pour les matières scientifiques.", "words": [280, 281, 282, 283, 284]}, {"id": 51, "text": "Difficultés en français.", "words": [285, 286, 287]}, {"id": 52, "text": "- Redoublement de la quatrième (moyenne générale de 8/20).", "words": [288, 289, 290, 291, 292, 293, 294, 295, 296]}, {"id": 53, "text": "- Lycée à 16 ans : pas de problèmes.", "words": [297, 298, 299, 300, 301, 302, 303, 304, 305]}, {"id": 54, "text": "Passion pour la technique et les technologies.", "words": [306, 307, 308, 309, 310, 311, 312]}, {"id": 55, "text": "Bac scientifique à dix-huit ans avec mention bien.", "words": [313, 314, 315, 316, 317, 318, 319, 320]}, {"id": 56, "text": "- Après le bac : classe prépa scientifique.", "words": [321, 322, 323, 324, 325, 326, 327, 328]}, {"id": 57, "text": "- Réussite au concours d'entrée de Supelec (grande école d'ingénieur).", "words": [329, 330, 331, 332, 333, 334, 335, 336, 337, 338]}, {"id": 58, "text": "- Premier travail à 25 ans.", "words": [339, 340, 341, 342, 343, 344]}, {"id":