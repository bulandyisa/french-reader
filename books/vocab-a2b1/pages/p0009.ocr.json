]}, {"id": 8, "text": "Elles se disent bonjour ou au revoir.", "words": [38, 39, 40, 41, 42, 43, 44]}, {"id": 9, "text": "3.", "words": [45]}, {"id": 10, "text": "Ils s'embrassent.", "words": [46, 47]}, {"id": 11, "text": "Faux!", "words": [48]}, {"id": 12, "text": "Vrai!", "words": [49]}, {"id": 13, "text": "Faux!", "words": [50]}, {"id": 14, "text": "Pod LE LPS \"4", "words": [51, 52, 53, 54]}, {"id": 15, "text": "LIT", "words": [55]}, {"id": 16, "text": "4.", "words": [56]}, {"id": 17, "text": "Ils sont père et fils.", "words": [57, 58, 59, 60, 61]}, {"id": 18, "text": "5.", "words": [62]}, {"id": 19, "text": "Elles sont amies.", "words": [63, 64, 65]}, {"id": 20, "text": "6.", "words": [66]}, {"id": 21, "text": "Ils font connaissance.", "words": [67, 68, 69]}, {"id": 22, "text": "Vrai!", "words": [70]}, {"id": 23, "text": "Vrai", "words": [71]}, {"id": 24, "text": "2%) Choisissez la ou les bonne(s) réponse(s).", "words": [72, 73, 74, 75, 76, 77, 78]}, {"id": 25, "text": "1.", "words": [79]}, {"id": 26, "text": "Excusez-moi, !", "words": [80, 81]}, {"id": 27, "text": "2.", "words": [82]}, {"id": 28, "text": "Au revoir, | Quentin | monsieur chéri] je t'appelle ce soir.", "words": [83, 84, 85, 86, 87, 88, 89, 90, 91, 92, 93]}, {"id": 29, "text": "3.", "words": [94]}, {"id": 30, "text": "Pour dire bonjour, je fais [un] deux] dix | bisous.", "words": [95, 96, 97, 98, 99, 100, 101, 102, 103, 104]}, {"id": 31, "text": "4.", "words": [105]}, {"id": 32, "text": "Au revoir !", "words": [106, 107, 108]}, {"id": 33, "text": "[Bisous [Je vous embrasse] Grosses bises:", "words": [109, 110, 111, 112, 113, 114]}, {"id": 34, "text": "5:", "words": [115]}, {"id": 35, "text": "6.", "words": [116]}, {"id": 36, "text": "Quand on fait connaissance, |on peut se serrer la main|s'embrasser|se dire au revoir} Bonjour, monsieur, enchanté de |vous| te |lel connaître !", "words": [117, 118, 119, 120, 121, 122, 123, 124, 125, 126, 127, 128, 129, 130, 131, 132, 133, 134, 135, 136, 137, 138]}, {"id": 37, "text": "Vrai ou faux ?", "words": [139, 140, 141, 142]}, {"id": 38, "text": "VRAI FAUX 1.", "words": [143, 144, 145]}, {"id": 39, "text": "Embrasser quelqu'un est toujours impoli.", "words": [146, 147, 148, 149, 150]}, {"id": 40, "text": "C] 2.", "words": [151, 152]}, {"id": 41, "text": "On peut se serrer la main pour dire au revoir.", "words": [153, 154, 155, 156, 157, 158, 159, 160, 161, 162]}, {"id": 42, "text": "ei 3.", "words": [163, 164]}, {"id": 43, "text": "Le nombre de baisers n'est pas toujours le même.", "words": [165, 166, 167, 168, 169, 170, 171, 172, 173]}, {"id": 44, "text": "4.", "words": [174]}, {"id": 45, "text": "On peut tutoyer un enfant.", "words": [175, 176, 177, 178, 179]}, {"id": 46, "text": "5.", "words": [180]}, {"id": 47, "text": "On peut vouvoyer quelqu'un et l'appeler par son prénom.", "words": [181, 182, 183, 184, 185, 186, 187, 188, 189]}, {"id": 48, "text": "C] 6.", "words": [190, 191]}, {"id": 49, "text": "Tutoyer est parfois une insulte.", "words": [192, 193, 194, 195, 196]}, {"id": 50, "text": "C] C]", "words": [197, 198]}, {"id": 51, "text": "Tests1à4 sept e 7", "words": [199, 200, 201, 202]}]}