": 348}, {"text": "en", "x": 1343, "y": 2226, "w": 39, "h": 20, "conf": 96.0, "block": 11, "par": 1, "line": 3, "i": 349}, {"text": "urgence.", "x": 1393, "y": 2223, "w": 137, "h": 31, "conf": 96.0, "block": 11, "par": 1, "line": 3, "i": 350}, {"text": "+", "x": 450, "y": 2297, "w": 12, "h": 14, "conf": 79.0, "block": 12, "par": 1, "line": 1, "i": 351}, {"text": "Le", "x": 474, "y": 2290, "w": 35, "h": 28, "conf": 95.0, "block": 12, "par": 1, "line": 1, "i": 352}, {"text": "médecin", "x": 521, "y": 2290, "w": 130, "h": 28, "conf": 96.0, "block": 12, "par": 1, "line": 1, "i": 353}, {"text": "soigne", "x": 662, "y": 2291, "w": 100, "h": 35, "conf": 96.0, "block": 12, "par": 1, "line": 1, "i": 354}, {"text": "ses", "x": 773, "y": 2298, "w": 48, "h": 20, "conf": 96.0, "block": 12, "par": 1, "line": 1, "i": 355}, {"text": "patients.", "x": 832, "y": 2289, "w": 135, "h": 37, "conf": 91.0, "block": 12, "par": 1, "line": 1, "i": 356}, {"text": "peut", "x": 1008, "y": 2293, "w": 67, "h": 33, "conf": 96.0, "block": 12, "par": 1, "line": 1, "i": 357}, {"text": "prescrire", "x": 1087, "y": 2289, "w": 146, "h": 37, "conf": 95.0, "block": 12, "par": 1, "line": 1, "i": 358}, {"text": "des", "x": 1244, "y": 2290, "w": 52, "h": 28, "conf": 96.0, "block": 12, "par": 1, "line": 1, "i": 359}, {"text": "médicaments", "x": 1309, "y": 2290, "w": 206, "h": 28, "conf": 95.0, "block": 12, "par": 1, "line": 1, "i": 360}, {"text": "(il", "x": 1527, "y": 2290, "w": 30, "h": 35, "conf": 96.0, "block": 12, "par": 1, "line": 1, "i": 361}, {"text": "fait", "x": 1569, "y": 2289, "w": 47, "h": 29, "conf": 96.0, "block": 12, "par": 1, "line": 1, "i": 362}, {"text": "une", "x": 447, "y": 2350, "w": 59, "h": 20, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 363}, {"text": "ordonnance)", "x": 517, "y": 2341, "w": 207, "h": 36, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 364}, {"text": "et/ou", "x": 736, "y": 2343, "w": 79, "h": 32, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 365}, {"text": "des", "x": 826, "y": 2341, "w": 55, "h": 29, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 366}, {"text": "analyses,", "x": 891, "y": 2341, "w": 144, "h": 37, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 367}, {"text": "par", "x": 1047, "y": 2350, "w": 51, "h": 28, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 368}, {"text": "exemple", "x": 1109, "y": 2342, "w": 129, "h": 36, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 369}, {"text": "une", "x": 1249, "y": 2350, "w": 58, "h": 20, "conf": 95.0, "block": 12, "par": 1, "line": 2, "i": 370}, {"text": "analyse", "x": 1318, "y": 2341, "w": 122, "h": 37, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 371}, {"text": "de", "x": 1450, "y": 2341, "w": 39, "h": 29, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 372}, {"text": "sang.", "x": 1499, "y": 2348, "w": 81, "h": 30, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 373}, {"text": "54", "x": 152, "y": 2465, "w": 38, "h": 29, "conf": 93.0, "block": 14, "par": 1, "line": 1, "i": 374}, {"text": "cinquante-quatre", "x": 231, "y": 2467, "w": 295, "h": 35, "conf": 91.0, "block": 14, "par": 1, "line": 1, "i": 375}], "sentences": [{"id": 0, "text": "LE CORPS - LA SANTÉ", "words": [0, 1, 2, 3, 4]}, {"id": 1, "text": "LA SANTÉ La bonne et la mauvaise santé", "words": [5, 6, 7, 8, 9, 10, 11, 12]}, {"id": 2, "text": "Martha va/se sent (très) bien.", "words": [13, 14, 15, 16, 17]}, {"id": 3, "text": "+ Pedro va/se sent (très) mal.", "words": [18, 19, 20, 21, 22, 23]}, {"id": 4, "text": "Elle est en bonne/excellente santé.", "words": [24, 25, 26, 27, 28]}, {"id": 5, "text": "7 Il est en (très) mauvaise santé.", "words": [29, 30, 31, 32, 33, 34, 35]}, {"id": 6, "text": "Elle est en (pleine) forme.", "words": [36, 37, 38, 39, 40]}, {"id": 7, "text": "x Il n’est pas (du tout) en forme.", "words": [41, 42, 43, 44, 45, 46, 47, 48]}, {"id": 8, "text": "Elle a bon appétit (elle mange bien).", "words": [49, 50, 51, 52, 53, 54, 55]}, {"id": 9, "text": "x Il n’a pas d’appétit.", "words": [56, 57, 58, 59, 60]}, {"id": 10, "text": "M La fatigue, le stress", "words": [61, 62, 63, 64, 65]}, {"id": 11, "text": "Éric se sent fatigué, il est épuisé, crevé*, lessivé*, mort de fatigue, il n’en peut plus, il a vraiment besoin de repos, il manque de sommeil, d'énergie.", "words": [66, 67, 68, 69, 70, 71, 72, 73, 74, 75, 76, 77, 78, 79, 80, 81, 82, 83, 84, 85, 86, 87, 88, 89, 90, 91, 92]}, {"id": 12, "text": "Il travaille trop et s'inquiète.", "words": [93, 94, 95, 96, 97]}, {"id": 13, "text": "Il est en état de (grand) stress.", "words": [98, 99, 100, 101, 102, 103, 104]}, {"id": 14, "text": "Il est assez déprimé, il est presque en dépression nerveuse.", "words": [105, 106, 107, 108, 109, 110, 111, 112, 113, 114]}, {"id": 15, "text": "Mais il va se reposer car il est en vacances ce soir.", "words": [115, 116, 117, 118, 119, 120, 121, 122, 123, 124, 125, 126]}, {"id": 16, "text": "Ça (il) ira mieux après !", "words": [127, 128, 129, 130, 131, 132]}, {"id": 17, "text": "du visage", "words": [133, 134]}, {"id": 18, "text": "Louise était assez fatiguée, mais elle a l'air d'aller mieux.", "words": [135, 136, 137, 138, 139, 140, 141, 142, 143, 144]}, {"id": 19, "text": "Elle se sent mieux.", "words": [145, 146, 147, 148]}, {"id": 20, "text": "Elle a bonne mine, elle a même une mine superbe, elle a meilleure mine que la semaine dernière.", "words": [149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159, 160, 161, 162, 163, 164, 165, 166]}, {"id": 21, "text": "Antoine, au contraire, a mauvaise mine, il est blanc comme un linge, il est tout pâle.", "words": [167, 168, 169, 170, 171, 172, 173, 174, 175, 176, 177, 178, 179, 180, 181, 182]}, {"id": 22, "text": "B La douleur", "words": [183, 184, 185]}, {"id": 23, "text": "Léa a mal au dos, a une douleur terrible dans le dos : elle s’est fait mal", "words": [186, 187, 188, 189, 190, 191, 192, 193, 194, 195, 196, 197, 198, 199, 200, 201, 202]}, {"id": 24, "text": "en tombant.", "words": [203, 204]}, {"id": 25, "text": "Il faut dire qu'elle souffre souvent du dos (- elle a le dos fragile).", "words": [205, 206, 207, 208, 209, 210, 211, 212, 213, 214, 215, 216, 217, 218]}, {"id": 26, "text": "La dépendance", "words": [219, 220]}, {"id": 27, "text": "Le tabagisme, et la toxicomanie (la dépendance au tabac,", "words": [221, 222, 223, 224, 225, 226, 227, 228, 229]}, {"id": 28, "text": "à et aux drogues dures) sont très dangereux pour la santé.", "words": [230, 231, 232, 233, 234, 235, 236, 237, 238, 239, 240]}, {"id": 29, "text": "La maladie", "words": [241, 242]}, {"id": 30, "text": "+ René est atteint d’une grave maladie : il a un cancer.", "words": [243, 244, 245, 246, 247, 248, 249, 250, 251, 252, 253, 254]}, {"id": 31, "text": "Il s’est fait opérer (= il a subi une opération).", "words": [255, 256, 257, 258, 259, 260, 261, 262, 263, 264]}, {"id": 32, "text": "René est très faible, mais son état s'améliore.", "words": [265, 266, 267, 268, 269, 270, 271, 272]}, {"id": 33, "text": "Il va guérir, il sera bientôt guéri (= il ne sera plus malade).", "words": [273, 274, 275, 276, 277, 278, 279, 280, 281, 282, 283, 284, 285]}, {"id": 34, "text": "+ Laurent, lui, a le sida.", "words": [286, 287, 288, 289, 290, 291]}, {"id": 35, "text": "Il avait perdu et avait beaucoup maigri, mais maintenant, il est sous traitement et va mieux !", "words": [292, 293, 294, 295, 296, 297, 298, 299, 300, 301, 302, 303, 304, 305, 306, 307, 308]}, {"id": 36, "text": "B Se soigner", "words": [309, 310, 311]}, {"id": 37, "text": "+ Quand on tombe malade, on se soigne, on se fait soigner par un médecin, on consulte, on va voir un médecin et on suit un traitement : souvent, on prend des médicaments.", "words": [312, 313, 314, 315, 316, 317, 318, 319, 320, 321, 322, 323, 324, 325, 326, 327, 328, 329, 330, 331, 332, 333, 334, 335, 336, 337, 338, 339, 340, 341, 342, 343, 344]}, {"id": 38, "text": "Quelquefois, on est hospitalisé en urgence.", "words": [345, 346, 347, 348, 349, 350]}, {"id": 39, "text": "+ Le médecin soigne ses patients.", "words": [351, 352, 353, 354, 355, 356]}, {"id": 40, "text": "peut prescrire des médicaments (il fait une ordonnance) et/ou des analyses, par exemple une analyse de sang.", "words": [357, 358, 359, 360, 361, 362, 363, 364, 365, 366, 367, 368, 369, 370, 371, 372, 373]}, {"id": 41, "text": "54 cinquante-quatre", "words": [374, 375]}]}