18]}, {"id": 4, "text": "1.", "words": [19]}, {"id": 5, "text": "Ça se / Les températures sont en hausse.", "words": [20, 21, 22, 23, 24, 25, 26, 27]}, {"id": 6, "text": "/ Ça se refroidit.", "words": [28, 29, 30, 31]}, {"id": 7, "text": "/ La température baisse.", "words": [32, 33, 34, 35]}, {"id": 8, "text": "2.", "words": [36]}, {"id": 9, "text": "Le ciel est chargé.", "words": [37, 38, 39, 40]}, {"id": 10, "text": "/ Le ciel est dégagé.", "words": [41, 42, 43, 44, 45]}, {"id": 11, "text": "/ Il fait soleil.", "words": [46, 47, 48, 49]}, {"id": 12, "text": "/ Le temps est clair.", "words": [50, 51, 52, 53, 54]}, {"id": 13, "text": "3.", "words": [55]}, {"id": 14, "text": "un hiver froid / un hiver rude / un hiver rigoureux / un hiver doux", "words": [56, 57, 58, 59, 60, 61, 62, 63, 64, 65, 66, 67, 68, 69, 70]}, {"id": 15, "text": "4.", "words": [71]}, {"id": 16, "text": "canicule / chaleur torride / fraîcheur / 40 °C", "words": [72, 73, 74, 75, 76, 77, 78, 79, 80]}, {"id": 17, "text": "(25 Vrai ou faux ?", "words": [81, 82, 83, 84, 85]}, {"id": 18, "text": ".", "words": [86]}, {"id": 19, "text": "Le temps est clair donc il va pleuvoir.", "words": [87, 88, 89, 90, 91, 92, 93, 94]}, {"id": 20, "text": "VRAI FAUX", "words": [95, 96]}, {"id": 21, "text": ".", "words": [97]}, {"id": 22, "text": "Le temps est changeant : un jour il fait beau et le lendemain il fait gris.", "words": [98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 111, 112, 113]}, {"id": 23, "text": ".", "words": [114]}, {"id": 24, "text": "Le temps est au beau fixe : il fait beau depuis trois semaines et ça va durer.", "words": [115, 116, 117, 118, 119, 120, 121, 122, 123, 124, 125, 126, 127, 128, 129, 130, 131]}, {"id": 25, "text": ".", "words": [132]}, {"id": 26, "text": "Le temps se dégrade : il fera beau demain.", "words": [133, 134, 135, 136, 137, 138, 139, 140, 141]}, {"id": 27, "text": ".", "words": [142]}, {"id": 28, "text": "Le temps s'améliore : il fera beau demain.", "words": 