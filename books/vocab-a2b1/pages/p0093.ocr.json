words": [43]}, {"id": 14, "text": "C'est de la !", "words": [44, 45, 46, 47]}, {"id": 15, "text": ".", "words": [48]}, {"id": 16, "text": "245 €, ce n'est pas !", "words": [49, 50, 51, 52, 53, 54]}, {"id": 17, "text": ".", "words": [55]}, {"id": 18, "text": "Je suis mécontent de ce produit, je vais faire une [réparation | réclamation |", "words": [56, 57, 58, 59, 60, 61, 62, 63, 64, 65, 66, 67, 68, 69]}, {"id": 19, "text": ".", "words": [70]}, {"id": 20, "text": "Pour être remboursé, vous devez apporter | le ticket de caisse.", "words": [71, 72, 73, 74, 75, 76, 77, 78, 79, 80, 81]}, {"id": 21, "text": "© © M BB NN", "words": [82, 83, 84, 85, 86]}, {"id": 22, "text": "ED Comment demanderiez-vous le prix dans ces situations ?", "words": [87, 88, 89, 90, 91, 92, 93, 94, 95]}, {"id": 23, "text": ".", "words": [96]}, {"id": 24, "text": "Vous êtes au marché, vous parlez des fraises.", "words": [97, 98, 99, 100, 101, 102, 103, 104]}, {"id": 25, "text": "— .", "words": [105, 106]}, {"id": 26, "text": "Vous êtes dans une boutique, vous parlez d'un manteau.", "words": [107, 108, 109, 110, 111, 112, 113, 114, 115]}, {"id": 27, "text": "—", "words": [116]}, {"id": 28, "text": ".", "words": [117]}, {"id": 29, "text": "Vous êtes chez le médecin, vous voulez régler la consultation.", "words": [118, 119, 120, 121, 122, 123, 124, 125, 126, 127]}, {"id": 30, "text": "— .", "words": [128, 129]}, {"id": 31, "text": "Vous allez payer les oignons et les tomates au marchand.", "words": [130, 131, 132, 133, 134, 135, 136, 137, 138, 139]}, {"id": 32, "text": "—", "words": [140]}, {"id": 33, "text": ".", "words": [141]}, {"id": 34, "text": "Vous désirez louer un vélo pour une demi-journée.", "words": [142, 143, 144, 145, 146, 147, 148, 149]}, {"id": 35, "text": "—", "words": [150]}, {"id": 36, "text": ".", "words": [151]}, {"id": 37, "text": "Vous allez acheter un ticket de bus.", "words": [152, 153, 154, 155, 156, 157, 158]}, {"id": 38, "text": "—", "words": [159]}, {"id": 39, "text": "ND 1 BB —", "words": [160, 161, 162, 163]}, {"id": 40, "text": ".", "words": [164]}, {"id": 41, "text": "Vous allez rembourser un ami.", "words": [165, 166, 167, 168, 169]}, {"id": 42, "text": "—", "words": [170]}, {"id": 43, "text": "Quel(s) commentaire(s) sur le prix serai(en)t approprié(s) ?", "words": [171, 172, 173, 174, 175, 176, 177, 178]}, {"id": 44, "text": "1.", "words": [179]}, {"id": 45, "text": "Vous avez acheté une table et des chaises au marché aux puces.", "words": [180, 181, 182, 183, 184, 185, 186, 187, 188, 189, 190, 191]}, {"id": 46, "text": "Vous avez bien marchandé.", "words": [192, 193, 194, 195]}, {"id": 47, "text": "2.", "words": [196]}, {"id": 48, "text": "Vous désirez louer une petite chambre d'hôtel, on vous annonce 200 € comme prix !", "words": [197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210, 211]}, {"id": 49, "text": "3.", "words": [212]}, {"id": 50, "text": "Vous venez d'essayer un pantalon.", "words": [213, 214, 215, 216, 217]}, {"id": 51, "text": "Vous pensiez qu'il coûtait 80 €, mais il coûte en réalité 300 € 4.", "words": [218, 219, 220, 221, 222, 223, 224, 225, 226, 227, 228, 229, 230, 231]}, {"id": 52, "text": "Vous avez acheté une voiture d'occasion pour un prix très bas.", "words": [232, 233, 234, 235, 236, 237, 238, 239, 240, 241, 242]}, {"id": 53, "text": "5.", "words": [243]}, {"id": 54, "text": "Vous ne contestez pas le prix de ce livre d'art.", "words": [244, 245, 246, 247, 248, 249, 250, 251, 252, 253]}, {"id": 55, "text": "6.", "words": [254]}, {"id": 56, "text": "Vous regardez le prix d'un château du siècle à vendre...", "words": [255, 256, 257, 258, 259, 260, 261, 262, 263, 264]}, {"id": 57, "text": "Tests 155 à 158 }> quatre-vingt-onze 91", "words": [265, 266, 267, 268, 269, 270, 271]}]}