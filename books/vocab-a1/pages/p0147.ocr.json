pt", "x": 1345, "y": 2352, "w": 228, "h": 32, "conf": 91.0, "block": 10, "par": 1, "line": 1, "i": 280}, {"text": "147", "x": 1615, "y": 2349, "w": 52, "h": 28, "conf": 97.0, "block": 10, "par": 1, "line": 1, "i": 281}], "sentences": [{"id": 0, "text": "LES ARTS - LES SPECTACLES", "words": [0, 1, 2, 3, 4]}, {"id": 1, "text": "Vrai ou faux ?", "words": [5, 6, 7, 8]}, {"id": 2, "text": "a VRAI FAUX (| [J", "words": [9, 10, 11, 12, 13]}, {"id": 3, "text": "1.", "words": [14]}, {"id": 4, "text": "Les spectateurs jouent dans le film.", "words": [15, 16, 17, 18, 19, 20]}, {"id": 5, "text": "2.", "words": [21]}, {"id": 6, "text": "Le public est content, alors il applaudit.", "words": [22, 23, 24, 25, 26, 27, 28]}, {"id": 7, "text": "Q Q", "words": [29, 30]}, {"id": 8, "text": "3.", "words": [31]}, {"id": 9, "text": "On va voir une pièce au cinéma.", "words": [32, 33, 34, 35, 36, 37, 38]}, {"id": 10, "text": "Q Q", "words": [39, 40]}, {"id": 11, "text": "4.", "words": [41]}, {"id": 12, "text": "Il reste des places = le théâtre est complet.", "words": [42, 43, 44, 45, 46, 47, 48, 49, 50]}, {"id": 13, "text": "Q 0", "words": [51, 52]}, {"id": 14, "text": "5.", "words": [53]}, {"id": 15, "text": "On va au théâtre pour voir un film.", "words": [54, 55, 56, 57, 58, 59, 60, 61]}, {"id": 16, "text": "Q Q", "words": [62, 63]}, {"id": 17, "text": "6.", "words": [64]}, {"id": 18, "text": "On peut réserver des places de théâtre par téléphone.", "words": [65, 66, 67, 68, 69, 70, 71, 72, 73]}, {"id": 19, "text": "Q Q", "words": [74, 75]}, {"id": 20, "text": "622 Devinette.", "words": [76, 77]}, {"id": 21, "text": "De quoi ou de qui parle-t-on ?", "words": [78, 79, 80, 81, 82, 83, 84]}, {"id": 22, "text": "1.", "words": [85]}, {"id": 23, "text": "Ils regardent le spectacle.", "words": [86, 87, 88, 89]}, {"id": 24, "text": "2.", "words": [90]}, {"id": 25, "text": "J'en réserve deux pour mardi soir.", "words": [91, 92, 93, 94, 95, 96]}, {"id": 26, "text": "3.", "words": [97]}, {"id": 27, "text": "Elle joue dans un film de Rohmer.", "words": [98, 99, 100, 101, 102, 103, 104]}, {"id": 28, "text": "4.", "words": [105]}, {"id": 29, "text": "Il passe au cinéma Saint-Germain.", "words": [106, 107, 108, 109, 110]}, {"id": 30, "text": "5.", "words": [111]}, {"id": 31, "text": "On la joue tous les soirs sauf dimanche.", "words": [112, 113, 114, 115, 116, 117, 118, 119]}, {"id": 32, "text": "6.", "words": [120]}, {"id": 33, "text": "1l pratique un art.", "words": [121, 122, 123, 124]}, {"id": 34, "text": "7.", "words": [125]}, {"id": 35, "text": "Elles sont très positives.", "words": [126, 127, 128, 129]}, {"id": 36, "text": "ED Choisissez la bonne réponse.", "words": [130, 131, 132, 133, 134]}, {"id": 37, "text": "1.", "words": [135]}, {"id": 38, "text": "Qu'est-ce qu'on joue, en ce moment ?", "words": [136, 137, 138, 139, 140, 141, 142]}, {"id": 39, "text": "4.", "words": [143]}, {"id": 40, "text": "Tu veux aller au théâtre ?", "words": [144, 145, 146, 147, 148, 149]}, {"id": 41, "text": "a.", "words": [150]}, {"id": 42, "text": "Un film de Clouzot.", "words": [151, 152, 153, 154]}, {"id": 43, "text": "Q a.", "words": [155, 156]}, {"id": 44, "text": "Oui, mais pour voir quelle pièce ?", "words": [157, 158, 159, 160, 161, 162, 163]}, {"id": 45, "text": "Q b.", "words": [164, 165]}, {"id": 46, "text": "Une pièce de Musset.", "words": [166, 167, 168, 169]}, {"id": 47, "text": "Q b.", "words": [170, 171]}, {"id": 48, "text": "Oui, mais pour voir quel film ?", "words": [172, 173, 174, 175, 176, 177, 178]}, {"id": 49, "text": "Q", "words": [179]}, {"id": 50, "text": "2.", "words": [180]}, {"id": 51, "text": "Qu'est-ce que tu penses de ce film ?", "words": [181, 182, 183, 184, 185, 186, 187, 188]}, {"id": 52, "text": "5.", "words": [189]}, {"id": 53, "text": "C'est une grande artiste ?", "words": [190, 191, 192, 193, 194]}, {"id": 54, "text": "a.", "words": [195]}, {"id": 55, "text": "C'est un chef-d'œuvre.", "words": [196, 197, 198]}, {"id": 56, "text": "a.", "words": [199]}, {"id": 57, "text": "Oui, elle a beaucoup de talent.", "words": [200, 201, 202, 203, 204, 205]}, {"id": 58, "text": "Q b.", "words": [206, 207]}, {"id": 59, "text": "Il a du talent.", "words": [208, 209, 210, 211]}, {"id": 60, "text": "Q b.", "words": [212, 213]}, {"id": 61, "text": "Oui, c'est un chef-d'œuvre.", "words": [214, 215, 216, 217]}, {"id": 62, "text": "Q", "words": [218]}, {"id": 63, "text": "3.", "words": [219]}, {"id": 64, "text": "Est-ce qu'il reste des places ?", "words": [220, 221, 222, 223, 224, 225]}, {"id": 65, "text": "6.", "words": [226]}, {"id": 66, "text": "Le public est content ?", "words": [227, 228, 229, 230, 231]}, {"id": 67, "text": "a.", "words": [232]}, {"id": 68, "text": "Non, il ne joue pas.", "words": [233, 234, 235, 236, 237]}, {"id": 69, "text": "Q a.", "words": [238, 239]}, {"id": 70, "text": "Oui, les critiques sont bonnes.", "words": [240, 241, 242, 243, 244]}, {"id": 71, "text": "Q b.", "words": [245, 246]}, {"id": 72, "text": "Non, c'est complet.", "words": [247, 248, 249]}, {"id": 73, "text": "Q b.", "words": [250, 251]}, {"id": 74, "text": "Oui, il applaudit.", "words": [252, 253, 254]}, {"id": 75, "text": "Q", "words": [255]}, {"id": 76, "text": "Trouvez au moins un mot de la même famille.", "words": [256, 257, 258, 259, 260, 261, 262, 263, 264]}, {"id": 77, "text": "1.", "words": [265]}, {"id": 78, "text": "art 2.", "words": [266, 267]}, {"id": 79, "text": "spectacle", "words": [268]}, {"id": 80, "text": "3.", "words": [269]}, {"id": 81, "text": "culture — 4.", "words": [270, 271, 272]}, {"id": 82, "text": "génie", "words": [273]}, {"id": 83, "text": "5.", "words": [274]}, {"id": 84, "text": "applaudir", "words": [275]}, {"id": 85, "text": "Tests 243 à cent quarante-sept 147", "words": [276, 277, 278, 279, 280, 281]}]}