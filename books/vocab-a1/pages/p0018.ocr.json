": 1097, "y": 2126, "w": 77, "h": 25, "conf": 93.0, "block": 18, "par": 3, "line": 3, "i": 276}, {"text": "»,", "x": 1183, "y": 2134, "w": 13, "h": 15, "conf": 91.0, "block": 18, "par": 3, "line": 3, "i": 277}, {"text": "«", "x": 1206, "y": 2134, "w": 7, "h": 10, "conf": 92.0, "block": 18, "par": 3, "line": 3, "i": 278}, {"text": "mon", "x": 1222, "y": 2132, "w": 50, "h": 14, "conf": 96.0, "block": 18, "par": 3, "line": 3, "i": 279}, {"text": "copain", "x": 1280, "y": 2126, "w": 77, "h": 25, "conf": 93.0, "block": 18, "par": 3, "line": 3, "i": 280}, {"text": "».", "x": 1366, "y": 2134, "w": 14, "h": 12, "conf": 93.0, "block": 18, "par": 3, "line": 3, "i": 281}, {"text": "18", "x": 249, "y": 2253, "w": 30, "h": 24, "conf": 92.0, "block": 20, "par": 1, "line": 1, "i": 282}, {"text": "dix-huit", "x": 316, "y": 2253, "w": 115, "h": 24, "conf": 94.0, "block": 20, "par": 1, "line": 1, "i": 283}], "sentences": [{"id": 0, "text": "3", "words": [0]}, {"id": 1, "text": "L'AMOUR - LES ÉMOTIONS", "words": [1, 2, 3, 4]}, {"id": 2, "text": "L'AMOUR", "words": [5]}, {"id": 3, "text": "+ Gabriel rencontre Mathilde chez des amis.", "words": [6, 7, 8, 9, 10, 11, 12]}, {"id": 4, "text": "Il tombe amoureux de Mathilde immédiatement.", "words": [13, 14, 15, 16, 17, 18]}, {"id": 5, "text": "Mathilde, qui était seule, tombe amoureuse aussi.", "words": [19, 20, 21, 22, 23, 24, 25]}, {"id": 6, "text": "Un soir, Gabriel invite Mathilde chez lui.", "words": [26, 27, 28, 29, 30, 31, 32]}, {"id": 7, "text": "Il l’embrasse, ils s'embrassent.", "words": [33, 34, 35, 36]}, {"id": 8, "text": "Puis ils passent la nuit ensemble, ils font l’amour.", "words": [37, 38, 39, 40, 41, 42, 43, 44, 45]}, {"id": 9, "text": "Gabriel dit « Je t'aime » à Mathilde.", "words": [46, 47, 48, 49, 50, 51, 52, 53]}, {"id": 10, "text": "+ Ils commencent une relation.", "words": [54, 55, 56, 57, 58]}, {"id": 11, "text": "Gabriel est célibataire, il vit seul, mais au bout de quelques mois, il accepte de vivre avec Mathilde.", "words": [59, 60, 61, 62, 63, 64, 65, 66, 67, 68, 69, 70, 71, 72, 73, 74, 75, 76]}, {"id": 12, "text": "Ils prennent un appartement ensemble.", "words": [77, 78, 79, 80, 81]}, {"id": 13, "text": "+ Patricia: - Est-ce que tu sais que Gabriel sort avec Mathilde ?", "words": [82, 83, 84, 85, 86, 87, 88, 89, 90, 91, 92, 93, 94]}, {"id": 14, "text": "Sandrine : - Mais oui, ils vivent ensemble.", "words": [95, 96, 97, 98, 99, 100, 101, 102]}, {"id": 15, "text": "Patricia: - Ils sont amoureux ?", "words": [103, 104, 105, 106, 107, 108]}, {"id": 16, "text": "Sandrine : — Ah oui, c’est la passion!", "words": [109, 110, 111, 112, 113, 114, 115, 116]}, {"id": 17, "text": "+ Gabriel et Mathilde décident de se marier.", "words": [117, 118, 119, 120, 121, 122, 123, 124]}, {"id": 18, "text": "Gabriel voudrait seulement un mariage civil, mais Mathilde voudrait aussi un mariage religieux.", "words": [125, 126, 127, 128, 129, 130, 131, 132, 133, 134, 135, 136, 137]}, {"id": 19, "text": "+ Gabriel et Mathilde organisent leur mariage.", "words": [138, 139, 140, 141, 142, 143, 144]}, {"id": 20, "text": "Samedi, à 11 heures, ils vont à la mairie.", "words": [145, 146, 147, 148, 149, 150, 151, 152, 153]}, {"id": 21, "text": "L’après-midi, à 15 heures, ils vont à l’église.", "words": [154, 155, 156, 157, 158, 159, 160, 161]}, {"id": 22, "text": "Le soir, il y a une grande fête.", "words": [162, 163, 164, 165, 166, 167, 168, 169]}, {"id": 23, "text": "Mathilde porte une belle robe de mariée.", "words": [170, 171, 172, 173, 174, 175, 176]}, {"id": 24, "text": "Remarque culturelle : En France, seul le mariage civil a une valeur légale.", "words": [177, 178, 179, 180, 181, 182, 183, 184, 185, 186, 187, 188, 189]}, {"id": 25, "text": "+ Simon et Alain sont homosexuels.", "words": [190, 191, 192, 193, 194, 195]}, {"id": 26, "text": "Ils vivent en couple depuis cinq ans.", "words": [196, 197, 198, 199, 200, 201, 202]}, {"id": 27, "text": "Maintenant, en France, leur liaison peut être officielle, car il existe le «pacs».", "words": [203, 204, 205, 206, 207, 208, 209, 210, 211, 212, 213, 214, 215]}, {"id": 28, "text": "Remarques:", "words": [216]}, {"id": 29, "text": "1.", "words": [217]}, {"id": 30, "text": "Le «PACS»: le Pacte Civil de Solidarité, garantit certains droits aux couples non mariés.", "words": [218, 219, 220, 221, 222, 223, 224, 225, 226, 227, 228, 229, 230, 231]}, {"id": 31, "text": "2.", "words": [232]}, {"id": 32, "text": "Pour parler de la personne avec qui on vit, on dit: «ma femme», «mon mari», quand on est marié(e) ; «mon amie», «mon ami», quand on n’est pas marié(e).", "words": [233, 234, 235, 236, 237, 238, 239, 240, 241, 242, 243, 244, 245, 246, 247, 248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259, 260, 261]}, {"id": 33, "text": "Les jeunes disent «ma petite amie», «mon petit ami» ou, plus familèrement, « ma copine », « mon copain ».", "words": [262, 263, 264, 265, 266, 267, 268, 269, 270, 271, 272, 273, 274, 275, 276, 277, 278, 279, 280, 281]}, {"id": 34, "text": "18 dix-huit", "words": [282, 283]}]}