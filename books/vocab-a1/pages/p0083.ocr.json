1}, {"text": "129", "x": 279, "y": 2351, "w": 47, "h": 21, "conf": 96.0, "block": 13, "par": 1, "line": 1, "i": 192}, {"text": "à", "x": 342, "y": 2358, "w": 14, "h": 14, "conf": 95.0, "block": 13, "par": 1, "line": 1, "i": 193}], "sentences": [{"id": 0, "text": "LE TEMPS QUI PASSE", "words": [0, 1, 2, 3]}, {"id": 1, "text": "Quelle heure est-il ?", "words": [4, 5, 6, 7]}, {"id": 2, "text": "Trouvez plusieurs possibilités.", "words": [8, 9, 10]}, {"id": 3, "text": "a.", "words": [11]}, {"id": 4, "text": "b.", "words": [12]}, {"id": 5, "text": "G d.", "words": [13, 14]}, {"id": 6, "text": "e.", "words": [15]}, {"id": 7, "text": "Vrai ou faux ?", "words": [16, 17, 18, 19]}, {"id": 8, "text": "Vérifiez sur l'agenda de Raphaël.", "words": [20, 21, 22, 23, 24]}, {"id": 9, "text": "tennis avec Nicolas", "words": [25, 26, 27]}, {"id": 10, "text": "der avec Alain et Martine VRAI FAUX", "words": [28, 29, 30, 31, 32, 33, 34]}, {"id": 11, "text": "1.", "words": [35]}, {"id": 12, "text": "Raphaël a un rendez-vous mardi après-midi.", "words": [36, 37, 38, 39, 40, 41]}, {"id": 13, "text": "2.", "words": [42]}, {"id": 14, "text": "Deux après-midi par semaine, Raphaël a un cours d'espagnol.", "words": [43, 44, 45, 46, 47, 48, 49, 50, 51]}, {"id": 15, "text": "Q 3.", "words": [52, 53]}, {"id": 16, "text": "Il passe le week-end avec Émilie.", "words": [54, 55, 56, 57, 58, 59]}, {"id": 17, "text": "4.", "words": [60]}, {"id": 18, "text": "|| fait du sport dimanche matin.", "words": [61, 62, 63, 64, 65, 66]}, {"id": 19, "text": "Q Q 5.", "words": [67, 68, 69]}, {"id": 20, "text": "Il va au cinéma dimanche après-midi.", "words": [70, 71, 72, 73, 74, 75]}, {"id": 21, "text": "Q Q 6.", "words": [76, 77, 78]}, {"id": 22, "text": "Mercredi, il passe toute la journée à la bibliothèque.", "words": [79, 80, 81, 82, 83, 84, 85, 86, 87]}, {"id": 23, "text": "Q Q 7.", "words": [88, 89, 90]}, {"id": 24, "text": "Il n'a pas de rendez-vous jeudi matin.", "words": [91, 92, 93, 94, 95, 96, 97]}, {"id": 25, "text": "Q Q 8.", "words": [98, 99, 100]}, {"id": 26, "text": "Il voit Alain et Martine un soir du week-end.", "words": [101, 102, 103, 104, 105, 106, 107, 108, 109]}, {"id": 27, "text": "© Associez les phrases de même sens.", "words": [110, 111, 112, 113, 114, 115, 116]}, {"id": 28, "text": "1.", "words": [117]}, {"id": 29, "text": "Il est parti à 6h 30 du soir.", "words": [118, 119, 120, 121, 122, 123, 124, 125]}, {"id": 30, "text": "a.", "words": [126]}, {"id": 31, "text": "Il est zéro heure.", "words": [127, 128, 129, 130]}, {"id": 32, "text": "2.", "words": [131]}, {"id": 33, "text": "Elle a pris huit jours de vacances.", "words": [132, 133, 134, 135, 136, 137, 138]}, {"id": 34, "text": "est resté 45 minutes.", "words": [139, 140, 141, 142]}, {"id": 35, "text": "3.", "words": [143]}, {"id": 36, "text": "J'ai un rendez-vous à midi.", "words": [144, 145, 146, 147, 148]}, {"id": 37, "text": "c.", "words": [149]}, {"id": 38, "text": "15h45.", "words": [150]}, {"id": 39, "text": "4.", "words": [151]}, {"id": 40, "text": "Il est resté trois quarts d'heure à la banque.", "words": [152, 153, 154, 155, 156, 157, 158, 159, 160]}, {"id": 41, "text": "d.Il est parti à 18h 30.", "words": [161, 162, 163, 164, 165, 166]}, {"id": 42, "text": "5.", "words": [167]}, {"id": 43, "text": "Il est quatre heures moins le quart.", "words": [168, 169, 170, 171, 172, 173, 174]}, {"id": 44, "text": "e.", "words": [175]}, {"id": 45, "text": "J'ai rendez-vous à 12h00.", "words": [176, 177, 178, 179]}, {"id": 46, "text": "A 6.", "words": [180, 181]}, {"id": 47, "text": "minuit.", "words": [182]}, {"id": 48, "text": "f.", "words": [183]}, {"id": 49, "text": "Elle a pris une semaine.", "words": [184, 185, 186, 187, 188]}, {"id": 50, "text": "quatre-vingt-trois 83", "words": [189, 190]}, {"id": 51, "text": "Tests 129 à", "words": [191, 192, 193]}]}