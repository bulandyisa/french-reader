xt": "l'allemand", "x": 691, "y": 2203, "w": 142, "h": 28, "conf": 74.0, "block": 15, "par": 1, "line": 1, "i": 297}, {"text": "au", "x": 843, "y": 2211, "w": 33, "h": 20, "conf": 96.0, "block": 15, "par": 1, "line": 1, "i": 298}, {"text": "collège", "x": 886, "y": 2204, "w": 97, "h": 34, "conf": 96.0, "block": 15, "par": 1, "line": 1, "i": 299}, {"text": "de", "x": 993, "y": 2204, "w": 33, "h": 27, "conf": 96.0, "block": 15, "par": 1, "line": 1, "i": 300}, {"text": "notre", "x": 1036, "y": 2208, "w": 74, "h": 24, "conf": 96.0, "block": 15, "par": 1, "line": 1, "i": 301}, {"text": "ville.", "x": 1119, "y": 2204, "w": 62, "h": 28, "conf": 96.0, "block": 15, "par": 1, "line": 1, "i": 302}, {"text": "Tests", "x": 179, "y": 2360, "w": 81, "h": 21, "conf": 96.0, "block": 16, "par": 1, "line": 1, "i": 303}, {"text": "141", "x": 277, "y": 2360, "w": 43, "h": 21, "conf": 96.0, "block": 16, "par": 1, "line": 1, "i": 304}, {"text": "à", "x": 336, "y": 2366, "w": 14, "h": 16, "conf": 92.0, "block": 16, "par": 1, "line": 1, "i": 305}, {"text": "144h", "x": 366, "y": 2359, "w": 80, "h": 23, "conf": 72.0, "block": 16, "par": 1, "line": 1, "i": 306}, {"text": "quatre-vingt-neuf", "x": 1304, "y": 2347, "w": 279, "h": 34, "conf": 91.0, "block": 16, "par": 1, "line": 1, "i": 307}, {"text": "89", "x": 1621, "y": 2347, "w": 36, "h": 27, "conf": 96.0, "block": 16, "par": 1, "line": 1, "i": 308}], "sentences": [{"id": 0, "text": "L'ÉCOLE - L'ENSEIGNEMENT", "words": [0, 1, 2]}, {"id": 1, "text": "Dites si la personne est professeur ou élève.", "words": [3, 4, 5, 6, 7, 8, 9, 10]}, {"id": 2, "text": "[] PROFESSEUR ÉLÈVE", "words": [11, 12, 13]}, {"id": 3, "text": "1.", "words": [14]}, {"id": 4, "text": "Viviane a beaucoup de devoirs à faire.", "words": [15, 16, 17, 18, 19, 20, 21]}, {"id": 5, "text": "2.", "words": [22]}, {"id": 6, "text": "Gabriel prend des cours de chimie.", "words": [23, 24, 25, 26, 27, 28]}, {"id": 7, "text": "3.", "words": [29]}, {"id": 8, "text": "Mathilde enseigne la musique.", "words": [30, 31, 32, 33]}, {"id": 9, "text": "4.", "words": [34]}, {"id": 10, "text": "Anne corrige des copies.", "words": [35, 36, 37, 38]}, {"id": 11, "text": "5.", "words": [39]}, {"id": 12, "text": "Damien passe un examen.", "words": [40, 41, 42, 43]}, {"id": 13, "text": "6.", "words": [44]}, {"id": 14, "text": "Laurent fait un exercice de physique.", "words": [45, 46, 47, 48, 49, 50]}, {"id": 15, "text": "7.", "words": [51]}, {"id": 16, "text": "Cécile donne des cours d'économie.", "words": [52, 53, 54, 55, 56]}, {"id": 17, "text": "EE Choisissez les termes possibles.", "words": [57, 58, 59, 60, 61]}, {"id": 18, "text": "1.", "words": [62]}, {"id": 19, "text": "a [une bourse en terminale Jun cours [au lycée [son Bac une Bonne not.", "words": [63, 64, 65, 66, 67, 68, 69, 70, 71, 72, 73, 74, 75, 76]}, {"id": 20, "text": "2.", "words": [77]}, {"id": 21, "text": "Elle fait | un examen | une école de coiffure | un exercice | à la maternelle | ses devoirs | un cours!", "words": [78, 79, 80, 81, 82, 83, 84, 85, 86, 87, 88, 89, 90, 91, 92, 93, 94, 95, 96, 97, 98, 99, 100]}, {"id": 22, "text": "[ae études de médecne] 4 1 étudie [une note rentrées leçon] un la géographe] leva [Aa [en Français [à matemel au", "words": [101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 111, 112, 113, 114, 115, 116, 117, 118, 119, 120, 121]}, {"id": 23, "text": ">» Choisissez la bonne réponse.", "words": [122, 123, 124, 125, 126]}, {"id": 24, "text": "1.", "words": [127]}, {"id": 25, "text": "Quelle matière est-ce que tu aimes ?", "words": [128, 129, 130, 131, 132, 133, 134]}, {"id": 26, "text": "4.", "words": [135]}, {"id": 27, "text": "C'est quand, la rentrée ?", "words": [136, 137, 138, 139, 140]}, {"id": 28, "text": "a.", "words": [141]}, {"id": 29, "text": "En maths.", "words": [142, 143]}, {"id": 30, "text": "Q a.", "words": [144, 145]}, {"id": 31, "text": "Le 3 juin.", "words": [146, 147, 148]}, {"id": 32, "text": "Q b.", "words": [149, 150]}, {"id": 33, "text": "Les maths.", "words": [151, 152]}, {"id": 34, "text": "b.", "words": [153]}, {"id": 35, "text": "Le 3 septembre.", "words": [154, 155, 156]}, {"id": 36, "text": "Q 2.", "words": [157, 158]}, {"id": 37, "text": "Il est bon élève ?", "words": [159, 160, 161, 162, 163]}, {"id": 38, "text": "5.", "words": [164]}, {"id": 39, "text": "Elle a eu une bonne note ?", "words": [165, 166, 167, 168, 169, 170, 171]}, {"id": 40, "text": "a.", "words": [172]}, {"id": 41, "text": "Oui, il a de bonnes notes.", "words": [173, 174, 175, 176, 177, 178]}, {"id": 42, "text": "Q a.", "words": [179, 180]}, {"id": 43, "text": "Oui, parce qu'elle a son diplôme.", "words": [181, 182, 183, 184, 185, 186]}, {"id": 44, "text": "Q b.", "words": [187, 188]}, {"id": 45, "text": "Oui, il passe un examen.", "words": [189, 190, 191, 192, 193]}, {"id": 46, "text": "Q b.", "words": [194, 195]}, {"id": 47, "text": "Non, parce qu'elle n'a pas appris sa leçon.", "words": [196, 197, 198, 199, 200, 201, 202, 203]}, {"id": 48, "text": "Q 3.", "words": [204, 205]}, {"id": 49, "text": "Tu as des devoirs à faire ?", "words": [206, 207, 208, 209, 210, 211, 212]}, {"id": 50, "text": "6.", "words": [213]}, {"id": 51, "text": "Il a eu son bac?", "words": [214, 215, 216, 217, 218]}, {"id": 52, "text": "a.", "words": [219]}, {"id": 53, "text": "Oui, je donne un exercice d'anglais.", "words": [220, 221, 222, 223, 224, 225]}, {"id": 54, "text": "Q a.", "words": [226, 227]}, {"id": 55, "text": "Oui, il a passé son bac.", "words": [228, 229, 230, 231, 232, 233]}, {"id": 56, "text": "Q b.", "words": [234, 235]}, {"id": 57, "text": "Oui, j'ai un exercice d'anglais.", "words": [236, 237, 238, 239, 240]}, {"id": 58, "text": "Q b.", "words": [241, 242]}, {"id": 59, "text": "Non, il a raté son bac.", "words": [243, 244, 245, 246, 247, 248]}, {"id": 60, "text": "Q", "words": [249]}, {"id": 61, "text": "[4 2 Complétez par un verbe approprié.", "words": [250, 251, 252, 253, 254, 255, 256]}, {"id": 62, "text": "1.", "words": [257]}, {"id": 63, "text": "Ma sœur ses exercices de maths pour demain.", "words": [258, 259, 260, 261, 262, 263, 264, 265]}, {"id": 64, "text": "2.", "words": [266]}, {"id": 65, "text": "Le professeur des copies.", "words": [267, 268, 269, 270]}, {"id": 66, "text": "3.", "words": [271]}, {"id": 67, "text": "Le meilleur élève de la classe toujours de bonnes notes !", "words": [272, 273, 274, 275, 276, 277, 278, 279, 280, 281, 282]}, {"id": 68, "text": "4.", "words": [283]}, {"id": 69, "text": "Quentin n'est pas sérieux, il n° jamais ses leçons !", "words": [284, 285, 286, 287, 288, 289, 290, 291, 292, 293]}, {"id": 70, "text": "5.", "words": [294]}, {"id": 71, "text": "Monsieur Fischer l'allemand au collège de notre ville.", "words": [295, 296, 297, 298, 299, 300, 301, 302]}, {"id": 72, "text": "Tests 141 à 144h quatre-vingt-neuf 89", "words": [303, 304, 305, 306, 307, 308]}]}