[53, 54]}, {"id": 24, "text": "Son compte est créditeur.", "words": [55, 56, 57, 58]}, {"id": 25, "text": "ED Devinette.", "words": [59, 60]}, {"id": 26, "text": "1.", "words": [61]}, {"id": 27, "text": "Qu'est-ce qui est C'est", "words": [62, 63, 64, 65]}, {"id": 28, "text": "2.", "words": [66]}, {"id": 29, "text": "Qu'est-ce qui est automatique ?", "words": [67, 68, 69, 70, 71]}, {"id": 30, "text": "C'est", "words": [72]}, {"id": 31, "text": "3.", "words": [73]}, {"id": 32, "text": "Qu'est-ce qui peut être en rouge ?", "words": [74, 75, 76, 77, 78, 79, 80]}, {"id": 33, "text": "C'est 4.", "words": [81, 82]}, {"id": 34, "text": "Qu'est-ce qui peut être courant ?", "words": [83, 84, 85, 86, 87, 88]}, {"id": 35, "text": "C'est 5.", "words": [89, 90]}, {"id": 36, "text": "Qu'est-ce qui est secret ?", "words": [91, 92, 93, 94, 95]}, {"id": 37, "text": "C'est", "words": [96]}, {"id": 38, "text": "6.", "words": [97]}, {"id": 39, "text": "Qu'est-ce qui peut être créditeur ?", "words": [98, 99, 100, 101, 102, 103]}, {"id": 40, "text": "C'est 7.", "words": [104, 105]}, {"id": 41, "text": "Qu'est-ce qui peut être bancaire ?", "words": [106, 107, 108, 109, 110, 111]}, {"id": 42, "text": "C'est", "words": [112]}, {"id": 43, "text": "> Choisissez le verbe correct.", "words": [113, 114, 115, 116, 117]}, {"id": 44, "text": "1.", "words": [118]}, {"id": 45, "text": "Ils beaucoup d'argent.", "words": [119, 120, 121]}, {"id": 46, "text": "2.", "words": [122]}, {"id": 47, "text": "Nous allons au distributeur pour | avoir | prendre| de l'argent.", "words": [123, 124, 125, 126, 127, 128, 129, 130, 131, 132, 133]}, {"id": 48, "text": "3.", "words": [134]}, {"id": 49, "text": "Elle voudrait acheter une voiture, alors elle de l'argent de côté.", "words": [135, 136, 137, 138, 139, 140, 141, 142, 143, 144, 145]}, {"id": 50, "text": "4.", "words": [146]}, {"id": 51, "text": "Tu dois des économies, si tu veux une nouvelle télévision !", "words": [147, 148, 149, 150, 151, 152, 153, 154, 155, 156, 157]}, {"id": 52, "text": "5.", "words": [158]}, {"id": 53, "text": "Il a 18 ans, il a enfin | ouvert | acheté | composé | un compte courant.", "words": [159, 160, 161, 162, 163, 164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174, 175]}, {"id": 54, "text": "6.", "words": [176]}, {"id": 55, "text": "Le vendeur nous a | retiré | dépensé | rendu | la monnaie.", "words": [177, 178, 179, 180, 181, 182, 183, 184, 185, 186, 187, 188, 189]}, {"id": 56, "text": "7.", "words": [190]}, {"id": 57, "text": "Vous pouvez votre code secret.", "words": [191, 192, 193, 194, 195]}]}