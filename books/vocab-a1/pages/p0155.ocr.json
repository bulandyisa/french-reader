 "h": 28, "conf": 96.0, "block": 12, "par": 1, "line": 1, "i": 157}, {"text": "vous", "x": 349, "y": 2281, "w": 74, "h": 21, "conf": 95.0, "block": 12, "par": 1, "line": 1, "i": 158}, {"text": "êtes", "x": 432, "y": 2275, "w": 65, "h": 27, "conf": 96.0, "block": 12, "par": 1, "line": 1, "i": 159}, {"text": "et", "x": 506, "y": 2278, "w": 32, "h": 24, "conf": 96.0, "block": 12, "par": 1, "line": 1, "i": 160}, {"text": "ce", "x": 547, "y": 2282, "w": 33, "h": 20, "conf": 95.0, "block": 12, "par": 1, "line": 1, "i": 161}, {"text": "que", "x": 590, "y": 2282, "w": 58, "h": 27, "conf": 96.0, "block": 12, "par": 1, "line": 1, "i": 162}, {"text": "vous", "x": 658, "y": 2282, "w": 73, "h": 21, "conf": 95.0, "block": 12, "par": 1, "line": 1, "i": 163}, {"text": "faites.", "x": 740, "y": 2274, "w": 94, "h": 29, "conf": 96.0, "block": 12, "par": 1, "line": 1, "i": 164}, {"text": "cent", "x": 1258, "y": 2358, "w": 71, "h": 26, "conf": 93.0, "block": 13, "par": 1, "line": 1, "i": 165}, {"text": "cinquante-cinq", "x": 1340, "y": 2357, "w": 243, "h": 34, "conf": 88.0, "block": 13, "par": 1, "line": 1, "i": 166}, {"text": "155", "x": 1626, "y": 2355, "w": 52, "h": 29, "conf": 96.0, "block": 13, "par": 1, "line": 1, "i": 167}], "sentences": [{"id": 0, "text": "ACTIVITÉS COMMUNICATIVES", "words": [0, 1]}, {"id": 1, "text": "Cartes postales.", "words": [2, 3]}, {"id": 2, "text": "DE BELLES VACANCES !", "words": [4, 5, 6, 7]}, {"id": 3, "text": "CE Associez.", "words": [8, 9]}, {"id": 4, "text": "1.", "words": [10]}, {"id": 5, "text": "Ils font du sport.", "words": [11, 12, 13, 14]}, {"id": 6, "text": "2.", "words": [15]}, {"id": 7, "text": "Ils se baignent.", "words": [16, 17, 18]}, {"id": 8, "text": "3.", "words": [19]}, {"id": 9, "text": "Ils adorent la région.", "words": [20, 21, 22, 23]}, {"id": 10, "text": "4.", "words": [24]}, {"id": 11, "text": "Ils font du tourisme.", "words": [25, 26, 27, 28]}, {"id": 12, "text": "5.", "words": [29]}, {"id": 13, "text": "Ils prennent l'air.", "words": [30, 31, 32]}, {"id": 14, "text": "6.", "words": [33]}, {"id": 15, "text": "Ils marchent beaucoup.", "words": [34, 35, 36]}, {"id": 16, "text": "7.", "words": [37]}, {"id": 17, "text": "Le matin, ils se lèvent quand ils veulent.", "words": [38, 39, 40, 41, 42, 43, 44, 45]}, {"id": 18, "text": "8.", "words": [46]}, {"id": 19, "text": "Ils mangent à l'intérieur.", "words": [47, 48, 49, 50]}, {"id": 20, "text": "9.", "words": [51]}, {"id": 21, "text": "Ils se reposent.", "words": [52, 53, 54]}, {"id": 22, "text": "10.", "words": [55]}, {"id": 23, "text": "Ils habitent près d'une grande ville.", "words": [56, 57, 58, 59, 60, 61]}, {"id": 24, "text": "Choisissez la bonne réponse.", "words": [62, 63, 64, 65]}, {"id": 25, "text": "1.", "words": [66]}, {"id": 26, "text": "On peut visiter [un château lune rivière].", "words": [67, 68, 69, 70, 71, 72, 73]}, {"id": 27, "text": "2.", "words": [74]}, {"id": 28, "text": "Je une semaine à la campagne.", "words": [75, 76, 77, 78, 79, 80]}, {"id": 29, "text": "3.", "words": [81]}, {"id": 30, "text": "À midi, nous | dinons|.", "words": [82, 83, 84, 85, 86]}, {"id": 31, "text": "4.", "words": [87]}, {"id": 32, "text": "Ils se baignent dans la [neige | rivière].", "words": [88, 89, 90, 91, 92, 93, 94, 95]}, {"id": 33, "text": "5.", "words": [96]}, {"id": 34, "text": "Elle a un studio à la montagne.", "words": [97, 98, 99, 100, 101, 102, 103]}, {"id": 35, "text": "6.", "words": [104]}, {"id": 36, "text": "Est-ce que tu as | fait | mis | le réveil ?", "words": [105, 106, 107, 108, 109, 110, 111, 112, 113, 114, 115, 116]}, {"id": 37, "text": "7.", "words": [117]}, {"id": 38, "text": "Ils sont en pleine | vacances | forme |.", "words": [118, 119, 120, 121, 122, 123, 124, 125, 126]}, {"id": 39, "text": "a.", "words": [127]}, {"id": 40, "text": "Virginie et Boniface (| b.", "words": [128, 129, 130, 131, 132]}, {"id": 41, "text": "Adèle et Étienne", "words": [133, 134, 135]}, {"id": 42, "text": "c.", "words": [136]}, {"id": 43, "text": "Les deux.", "words": [137, 138]}, {"id": 44, "text": "> À vous !", "words": [139, 140, 141, 142]}, {"id": 45, "text": "Vous êtes en vacances et vous écrivez une carte postale à des amis.", "words": [143, 144, 145, 146, 147, 148, 149, 150, 151, 152, 153, 154, 155]}, {"id": 46, "text": "Expliquez", "words": [156]}, {"id": 47, "text": "où vous êtes et ce que vous faites.", "words": [157, 158, 159, 160, 161, 162, 163, 164]}, {"id": 48, "text": "cent cinquante-cinq 155", "words": [165, 166, 167]}]}