}, {"id": 23, "text": "- Je voudrais quatre pommes et une de fraises, s'il vous plaît.", "words": [103, 104, 105, 106, 107, 108, 109, 110, 111, 112, 113, 114]}, {"id": 24, "text": "- Voilà, monsieur.", "words": [115, 116, 117]}, {"id": 25, "text": "Et avec ?", "words": [118, 119, 120]}, {"id": 26, "text": "- Les cerises sont -4,10€ le ; monsieur.", "words": [121, 122, 123, 124, 125, 126, 127, 128]}, {"id": 27, "text": "- Alors, un kilo, s'il vous plaît.", "words": [129, 130, 131, 132, 133, 134, 135]}, {"id": 28, "text": "Ça combien ?", "words": [136, 137, 138]}, {"id": 29, "text": "- 9,20€, monsieur.", "words": [139, 140, 141]}, {"id": 30, "text": "2.", "words": [142]}, {"id": 31, "text": "- Madame ?", "words": [143, 144, 145]}, {"id": 32, "text": "- Je quatre de jambon blanc, s'il vous plaît.", "words": [146, 147, 148, 149, 150, 151, 152, 153, 154]}, {"id": 33, "text": "- Oui, madame.", "words": [155, 156, 157]}, {"id": 34, "text": "ou épaisses ?", "words": [158, 159, 160]}, {"id": 35, "text": "- Bien", "words": [161, 162]}, {"id": 36, "text": "- Et ceci ?", "words": [163, 164, 165, 166]}, {"id": 37, "text": "- Un petit de pâté de canard.", "words": [167, 168, 169, 170, 171, 172, 173]}, {"id": 38, "text": "D Trouvez la question.", "words": [174, 175, 176, 177]}, {"id": 39, "text": "- 10,10€ au total, madame.", "words": [178, 179, 180, 181, 182]}, {"id": 40, "text": "2 - Un peu moins, s'il vous plaît.", "words": [183, 184, 185, 186, 187, 188, 189, 190]}, {"id": 41, "text": "3.", "words": [191]}, {"id": 42, "text": "- ?", "words": [192, 193]}, {"id": 43, "text": "- C'est tout, merci.", "words": [194, 195, 196, 197]}, {"id": 44, "text": "?", "words": [198]}, {"id": 45, "text": "- Je voudrais quatre bananes et un kilo de poires, s'il vous plaît.", "words": [199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210, 211]}, {"id": 46, "text": "5.", "words": [212]}, {"id": 47, "text": "?", "words": [213]}, {"id": 48, "text": "- Les pommes de terre sont à 1,40€ le kilo.",