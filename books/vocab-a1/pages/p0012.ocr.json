 "y": 2106, "w": 101, "h": 24, "conf": 90.0, "block": 12, "par": 1, "line": 2, "i": 296}, {"text": "bien.", "x": 1172, "y": 2106, "w": 65, "h": 24, "conf": 95.0, "block": 12, "par": 1, "line": 2, "i": 297}, {"text": "Il", "x": 1248, "y": 2106, "w": 15, "h": 23, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 298}, {"text": "est", "x": 1272, "y": 2108, "w": 39, "h": 22, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 299}, {"text": "plus", "x": 1321, "y": 2106, "w": 56, "h": 30, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 300}, {"text": "personnel", "x": 1388, "y": 2106, "w": 136, "h": 30, "conf": 96.0, "block": 12, "par": 1, "line": 2, "i": 301}, {"text": "de", "x": 503, "y": 2151, "w": 32, "h": 25, "conf": 96.0, "block": 12, "par": 1, "line": 3, "i": 302}, {"text": "les", "x": 545, "y": 2151, "w": 36, "h": 25, "conf": 96.0, "block": 12, "par": 1, "line": 3, "i": 303}, {"text": "écrire", "x": 591, "y": 2151, "w": 79, "h": 25, "conf": 96.0, "block": 12, "par": 1, "line": 3, "i": 304}, {"text": "à", "x": 679, "y": 2152, "w": 15, "h": 24, "conf": 96.0, "block": 12, "par": 1, "line": 3, "i": 305}, {"text": "la", "x": 703, "y": 2151, "w": 23, "h": 25, "conf": 96.0, "block": 12, "par": 1, "line": 3, "i": 306}, {"text": "main.", "x": 735, "y": 2152, "w": 73, "h": 24, "conf": 96.0, "block": 12, "par": 1, "line": 3, "i": 307}, {"text": "12", "x": 249, "y": 2253, "w": 29, "h": 24, "conf": 89.0, "block": 14, "par": 1, "line": 1, "i": 308}, {"text": "douze", "x": 316, "y": 2253, "w": 91, "h": 24, "conf": 96.0, "block": 14, "par": 1, "line": 1, "i": 309}], "sentences": [{"id": 0, "text": "LES USAGES - LA POLITESSE", "words": [0, 1, 2, 3, 4]}, {"id": 1, "text": "SOUHAITER", "words": [5]}, {"id": 2, "text": "+ Bonne journée!", "words": [6, 7, 8]}, {"id": 3, "text": "+ Bonne après-midi !", "words": [9, 10, 11, 12]}, {"id": 4, "text": "+ Bonne soirée!", "words": [13, 14, 15]}, {"id": 5, "text": "+ Juste avant de dormir : Bonne nuit !", "words": [16, 17, 18, 19, 20, 21, 22, 23, 24]}, {"id": 6, "text": "Dors bien !", "words": [25, 26, 27]}, {"id": 7, "text": "(Dormez bien !)", "words": [28, 29, 30]}, {"id": 8, "text": "+ Bon week-end!", "words": [31, 32, 33]}, {"id": 9, "text": "+ Avant des vacances : Bonnes vacances !", "words": [34, 35, 36, 37, 38, 39, 40, 41]}, {"id": 10, "text": "Repose-toi bien !", "words": [42, 43, 44]}, {"id": 11, "text": "(Reposez-vous bien!)", "words": [45, 46]}, {"id": 12, "text": "+ Avant un voyage : Bon voyage!", "words": [47, 48, 49, 50, 51, 52, 53]}, {"id": 13, "text": "+ Avant de manger : Bon appétit!", "words": [54, 55, 56, 57, 58, 59, 60]}, {"id": 14, "text": "+ Pour un anniversaire: Bon anniversaire, Viviane!", "words": [61, 62, 63, 64, 65, 66, 67]}, {"id": 15, "text": "- Joyeux anniversaire !", "words": [68, 69, 70, 71]}, {"id": 16, "text": "+ Avant un examen: Bonne chance!", "words": [72, 73, 74, 75, 76, 77]}, {"id": 17, "text": "+ Avant Noël: Joyeux Noël !", "words": [78, 79, 80, 81, 82, 83]}, {"id": 18, "text": "- Bon Noël!", "words": [84, 85, 86]}, {"id": 19, "text": "° À partir du 1‘ janvier : Bonne année !", "words": [87, 88, 89, 90, 91, 92, 93, 94, 95, 96]}, {"id": 20, "text": "Tous mes vœux!", "words": [97, 98, 99]}, {"id": 21, "text": "QUELQUES USAGES", "words": [100, 101]}, {"id": 22, "text": "+ Traditionnellement, les femmes ont la priorité.", "words": [102, 103, 104, 105, 106, 107, 108]}, {"id": 23, "text": "Un homme ouvre la porte à une dame et la laisse passer.", "words": [109, 110, 111, 112, 113, 114, 115, 116, 117, 118, 119, 120]}, {"id": 24, "text": "Un enfant fait la même chose.", "words": [121, 122, 123, 124, 125, 126]}, {"id": 25, "text": "Dans le bus,", "words": [127, 128, 129]}, {"id": 26, "text": "le tram, le métro, on laisse sa place à une personne âgée.", "words": [130, 131, 132, 133, 134, 135, 136, 137, 138, 139, 140, 141]}, {"id": 27, "text": "On peut dire : «Madame/monsieur, vous voulez vous asseoir ?", "words": [142, 143, 144, 145, 146, 147, 148, 149, 150, 151]}, {"id": 28, "text": "» ou, plus simplement : «Je vous en prie, madame/monsieur !", "words": [152, 153, 154, 155, 156, 157, 158, 159, 160, 161, 162]}, {"id": 29, "text": "»", "words": [163]}, {"id": 30, "text": "+ Quand on est invité à dîner chez une personne, on apporte un petit cadeau: — un bouquet de fleurs, une boîte de chocolats, quand on ne connaît pas très bien la personne;", "words": [164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174, 175, 176, 177, 178, 179, 180, 181, 182, 183, 184, 185, 186, 187, 188, 189, 190, 191, 192, 193, 194, 195, 196]}, {"id": 31, "text": "- des fleurs, une bouteille de bon vin ou de champagne, quand on est amis.", "words": [197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210, 211]}, {"id": 32, "text": "Au moment de l'invitation, on peut demander : que je peux apporter ?»", "words": [212, 213, 214, 215, 216, 217, 218, 219, 220, 221, 222, 223, 224]}, {"id": 33, "text": "+ Si est à 20 heures par exemple, la politesse demande qu'on arrive environ 10 minutes plus tard.", "words": [225, 226, 227, 228, 229, 230, 231, 232, 233, 234, 235, 236, 237, 238, 239, 240, 241, 242]}, {"id": 34, "text": "+ Au moment de Noël, on donne une petite somme d’argent (des étrennes) au facteur (la poste), aux éboueurs (qui ramassent les poubelles) et aux pompiers.", "words": [243, 244, 245, 246, 247, 248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259, 260, 261, 262, 263, 264, 265, 266, 267, 268]}, {"id": 35, "text": "Généralement, ils viennent directement sonner à la porte.", "words": [269, 270, 271, 272, 273, 274, 275, 276]}, {"id": 36, "text": "+ Fin décembre ou début janvier, on envoie des cartes de vœux aux personnes qu’on aime bien et qu’on connaît bien.", "words": [277, 278, 279, 280, 281, 282, 283, 284, 285, 286, 287, 288, 289, 290, 291, 292, 293, 294, 295, 296, 297]}, {"id": 37, "text": "Il est plus personnel de les écrire à la main.", "words": [298, 299, 300, 301, 302, 303, 304, 305, 306, 307]}, {"id": 38, "text": "12 douze", "words": [308, 309]}]}