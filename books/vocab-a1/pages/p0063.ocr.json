{"id": 1, "text": "Éliminez l'intrus.", "words": [3, 4]}, {"id": 2, "text": "1.", "words": [5]}, {"id": 3, "text": "portefeuille / peigne / porte-monnaie 5.", "words": [6, 7, 8, 9, 10, 11]}, {"id": 4, "text": "parapluie / crayon / gomme 2.", "words": [12, 13, 14, 15, 16, 17]}, {"id": 5, "text": "chéquier / carnet / agenda 6.", "words": [18, 19, 20, 21, 22, 23]}, {"id": 6, "text": "allumettes / briquet / trousse 3.", "words": [24, 25, 26, 27, 28, 29]}, {"id": 7, "text": "papier / clé / stylo 7.", "words": [30, 31, 32, 33, 34, 35]}, {"id": 8, "text": "peigne / trousse de maquillage / papier à lettres", "words": [36, 37, 38, 39, 40, 41, 42, 43, 44]}, {"id": 9, "text": "4, ampoule / bougie / sac", "words": [45, 46, 47, 48, 49, 50]}, {"id": 10, "text": "De quel(s) objet(s) a-t-on besoin pour.", "words": [51, 52, 53, 54, 55, 56]}, {"id": 11, "text": "1.", "words": [57]}, {"id": 12, "text": "allumer une bougie ?", "words": [58, 59, 60, 61]}, {"id": 13, "text": ".", "words": [62]}, {"id": 14, "text": "couper du papier ?", "words": [63, 64, 65, 66]}, {"id": 15, "text": "2.", "words": [67]}, {"id": 16, "text": "se moucher ?", "words": [68, 69, 70]}, {"id": 17, "text": ".", "words": [71]}, {"id": 18, "text": "mettre les produits de maquillage ?", "words": [72, 73, 74, 75, 76, 77]}, {"id": 19, "text": "3.", "words": [78]}, {"id": 20, "text": "prendre le bus ?", "words": [79, 80, 81, 82]}, {"id": 21, "text": ".", "words": [83]}, {"id": 22, "text": "se coiffer ?", "words": [84, 85, 86]}, {"id": 23, "text": "on", "words": [87]}, {"id": 24, "text": "4.", "words": [88]}, {"id": 25, "text": "mettre les cartes de crédit ?", "words": [89, 90, 91, 92, 93, 94]}, {"id": 26, "text": ".", "words": [95]}, {"id": 27, "text": "noter les rendez-vous ?", "words": [96, 97, 98, 99]}, {"id": 28, "text": "ES Devinez de quel objet on parle.", "words": [100, 101, 102, 103, 104, 105, 106]}, {"id": 29, "text": "1.", "words": [107]}, {"id": 30, "text": "Je les mets s'il y a beaucoup de soleil.", "words": [108, 109, 110, 111, 112, 113, 114, 115, 116]}, {"id": 31, "text": "2.", "words": [117]}, {"id": 32, "text": "Je les utilise pour ouvrir ma porte.", "words": [118, 119, 120, 121, 122, 123, 124]}, {"id": 33, "text": "3.", "words": [125]}, {"id": 34, "text": "Je le prends s'il pleut.", "words": [126, 127, 128, 129, 130]}, {"id": 35, "text": "4, C'est commode pour téléphoner dans la rue.", "words": [131, 132, 133, 134, 135, 136, 137, 138]}, {"id": 36, "text": "5.", "words": [139]}, {"id": 37, "text": "Je mets une lettre dans cet objet.", "words": [140, 141, 142, 143, 144, 145, 146]}, {"id": 38, "text": "6.", "words": [147]}, {"id": 39, "text": "J'écris avec cet objet (deux possibilités).", "words": [148, 149, 150, 151, 152, 153]}, {"id": 40, "text": "7.", "words": [154]}, {"id": 41, "text": "J'en achète pour mettre sur un gâteau d'anniversaire.", "words": [155, 156, 157, 158, 159, 160, 161, 162]}, {"id": 42, "text": "8.", "words": [163]}, {"id": 43, "text": "Tous mes rendez-vous sont notés dans cet objet.", "words": [164, 165, 166, 167, 168, 169, 170, 171]}, {"id": 44, "text": "Replacez les mots suivants dans le texte.", "words": [172, 173, 174, 175, 176, 177, 178]}, {"id": 45, "text": "sac à main - agenda - me raser - te préparer - clés - téléphone - prêt - me maquille - me lave", "words": [179, 180, 181, 182, 183, 184, 185, 186, 187, 188, 189, 190, 191, 192, 193, 194, 195, 196, 197, 198, 199, 200, 201]}, {"id": 46, "text": "Un matin comme les autres.", "words": [202, 203, 204, 205, 206]}, {"id": 47, "text": "1.", "words": [207]}, {"id": 48, "text": "- Bastien, tu es ?", "words": [208, 209, 210, 211, 212]}, {"id": 49, "text": "2.", "words": [213]}, {"id": 50, "text": "- Oui, maman, presque !", "words": [214, 215, 216, 217, 218]}, {"id": 51, "text": "les dents et j'arrive !", "words": [219, 220, 221, 222, 223]}, {"id": 52, "text": "3.", "words": [224]}, {"id": 53, "text": "- Estelle, tu viens ?", "words": [225, 226, 227, 228, 229]}, {"id": 54, "text": "4.", "words": [230]}, {"id": 55, "text": "- Oui, maman, je et j'arrive!", "words": [231, 232, 233, 234, 235, 236]}, {"id": 56, "text": "5.", "words": [237]}, {"id": 57, "text": "— Chéri, viens !", "words": [238, 239, 240, 241]}, {"id": 58, "text": "Nous allons être en retard!", "words": [242, 243, 244, 245, 246]}, {"id": 59, "text": "6.", "words": [247]}, {"id": 60, "text": "- Oui, ma chérie, je finis de et j'arrive !", "words": [248, 249, 250, 251, 252, 253, 254, 255, 256, 257]}, {"id": 61, "text": "7.", "words": [258]}, {"id": 62, "text": "- Je ne trouve pas mes !", "words": [259, 260, 261, 262, 263, 264, 265]}, {"id": 63, "text": "8.", "words": [266]}, {"id": 64, "text": "- Elles sont dans ton , ma chérie.", "words": [267, 268, 269, 270, 271, 272, 273, 274]}, {"id": 65, "text": "Est-ce que tu as vu mon mobile, par hasard ?", "words": [275, 276, 277, 278, 279, 280, 281, 282, 283, 284]}, {"id": 66, "text": "9.", "words": [285]}, {"id": 67, "text": "— Je crois qu'il est sur la table, avec ton .", "words": [286, 287, 288, 289, 290, 291, 292, 293, 294, 295, 296]}, {"id": 68, "text": "Estelle, est-ce que tu as fini de", "words": [297, 298, 299, 300, 301, 302, 303]}, {"id": 69, "text": "?Ilest 8 heures!", "words": [304, 305, 306]}, {"id": 70, "text": "Tests 99 à 101 +", "words": [307, 308, 309, 310, 311]}, {"id": 71, "text": "soixante-trois 63", "words": [312, 313]}]}