, 24, 25]}, {"id": 10, "text": "la télévision.", "words": [26, 27]}, {"id": 11, "text": "4.", "words": [28]}, {"id": 12, "text": "Tu fais d.", "words": [29, 30, 31]}, {"id": 13, "text": "à la maison.", "words": [32, 33, 34]}, {"id": 14, "text": "5.", "words": [35]}, {"id": 15, "text": "Elle part e.", "words": [36, 37, 38]}, {"id": 16, "text": "la radio.", "words": [39, 40]}, {"id": 17, "text": "6.", "words": [41]}, {"id": 18, "text": "Je rentre f.", "words": [42, 43, 44]}, {"id": 19, "text": "le ménage.", "words": [45, 46]}, {"id": 20, "text": "7.", "words": [47]}, {"id": 21, "text": "Il consulte g.", "words": [48, 49, 50]}, {"id": 22, "text": "le journal.", "words": [51, 52]}, {"id": 23, "text": "Choisissez la bonne réponse.", "words": [53, 54, 55, 56]}, {"id": 24, "text": "1.", "words": [57]}, {"id": 25, "text": "À 8 heures du matin, Léon les enfants à l'école.", "words": [58, 59, 60, 61, 62, 63, 64, 65, 66, 67]}, {"id": 26, "text": "2.", "words": [68]}, {"id": 27, "text": "À quelle heure est-ce que vous de la maison, le matin ?", "words": [69, 70, 71, 72, 73, 74, 75, 76, 77, 78, 79, 80]}, {"id": 28, "text": "3.", "words": [81]}, {"id": 29, "text": "Le soir, nous |dinons | déjeunons | ensemble.", "words": [82, 83, 84, 85, 86, 87, 88, 89]}, {"id": 30, "text": "4.", "words": [90]}, {"id": 31, "text": "Le réveil 5.", "words": [91, 92, 93]}, {"id": 32, "text": "Je suis fatigué, je vais [me lever] me coucher].", "words": [94, 95, 96, 97, 98, 99, 100, 101, 102]}, {"id": 33, "text": "6.", "words": [103]}, {"id": 34, "text": "À quelle heure est-ce que vous | sonnez | le réveil ?", "words": [104, 105, 106, 107, 108, 109, 110, 111, 112, 113, 114, 115]}, {"id": 35, "text": "7.", "words": [116]}, {"id": 36, "text": "Le matin, Angélique |éteint | allume | les lampes avant de partir.", "words": [117, 118, 119, 120, 121, 122, 123, 124, 125, 126, 127, 128]}, {"id": 37, "text": "Choisissez la bonne réponse.", "words": [129, 130, 131, 132]}, {"id": 38, "text": "1.", "words": [133]}, {"id": 39, "text": "Qu'est-ce que vous regardez ?", "words": [134, 135, 136, 137, 138]}, {"id": 40, "text": "4.", "words": [139]}, {"id": 41, "text": "Qu'est-ce que vous allumez ?", "words": [140, 141, 142, 143, 144]}, {"id": 42, "text": "a.", "words": [145]}, {"id": 43, "text": "La télévision.", "words": [146, 147]}, {"id": 44, "text": "Q a.", "words": [148, 149]}, {"id": 45, "text": "Le journal.", "words": [150, 151]}, {"id": 46, "text": "Q b.", "words": [152, 153]}, {"id": 47, "text": "La radio.", "words": [154, 155]}, {"id": 48, "text": "Q b.", "words": [156, 157]}, {"id": 49, "text": "La radio.", "words": [158, 159]}, {"id": 50, "text": "Q 2.", "words": [160, 161]}, {"id": 51, "text": "Vous consultez votre répondeur ?", "words": [162, 163, 164, 165, 166]}, {"id": 52, "text": "5.", "words": [167]}, {"id": 53, "text": "Vous dînez à quelle heure ?", "words": [168, 169, 170, 171, 172, 173]}, {"id": 54, "text": "a.", "words": [174]}, {"id": 55, "text": "Oui, j'écoute mes messages.", "words": [175, 176, 177, 178]}, {"id": 56, "text": "a.", "words": [179]}, {"id": 57, "text": "À 13 heures.", "words": [180, 181, 182]}, {"id": 58, "text": "b.", "words": [183]}, {"id": 59, "text": "Oui, je lis mon courrier.", "words": [184, 185, 186, 187, 188]}, {"id": 60, "text": "Q b.", "words": [189, 190]}, {"id": 61, "text": "À 20 heures.", "words": [191, 192, 193]}, {"id": 62, "text": "Q 3.", "words": [194, 195]}, {"id": 63, "text": "Qu'est-ce que vous faites ?", "words": [196, 197, 198, 199, 200]}, {"id": 64, "text": "6.", "words": [201]}, {"id": 65, "text": "Vous lisez le journal ?", "words": [202, 203, 204, 205, 206]}, {"id": 66, "text": "a.", "words": [207]}, {"id": 67, "text": "Les courses.", "words": [208, 209]}, {"id": 68, "text": "CI a.", "words": [210, 211]}, {"id": 69, "text": "Oui, je regarde la télé.", "words": [212, 213, 214, 215, 216]}, {"id": 70, "text": "QI b.", "words": [217, 218]}, {"id": 71, "text": "Les enfants.", "words": [219, 220]}, {"id": 72, "text": "Q b.", "words": [221, 222]}, {"id": 73, "text": "Non, j'écoute la radio.", "words": [223, 224, 225, 226]}, {"id": 74, "text": "Q", "words": [227]}, {"id": 75, "text": "À vous !", "words": [228, 229, 230]}, {"id": 76, "text": "Répondez librement aux questions.", "words": [231, 232, 233, 234]}, {"id": 77, "text": "1.", "words": [235]}, {"id": 78, "text": "Pouvez-vous raconter une journée normale de votre semaine ?", "words": [236, 237, 238, 239, 240, 241, 242, 243, 244]}, {"id": 79, "text": "2.", "words": [245]}, {"id": 80, "text": "Est-ce que vous faites la même chose le dimanche ?", "words": [246, 247, 248, 249, 250, 251, 252, 253, 254, 255]}, {"id": 81, "text": "3.", "words": [256]}, {"id": 82, "text": "Est-ce que vous passez beaucoup de temps sur l'ordinateur ?", "words": [257, 258, 259, 260, 261, 262, 263, 264, 265, 266]}, {"id": 83, "text": "Tests 93 à 95 k cinquante-neuf e 59", "words": [267, 268, 269, 270, 271, 272, 273, 274]}]}