xt": "| | Le ENT Ü ES", "words": [86, 87, 88, 89, 90, 91]}, {"id": 15, "text": "Jean et Léa se couchent.", "words": [92, 93, 94, 95, 96]}, {"id": 16, "text": "Jean met le réveil à 7 heures.", "words": [97, 98, 99, 100, 101, 102, 103]}, {"id": 17, "text": "Léa éteint la lampe.", "words": [104, 105, 106, 107]}, {"id": 18, "text": "mms LES ACTIVITÉS DANS LA JOURNÉE", "words": [108, 109, 110, 111, 112, 113]}, {"id": 19, "text": "e Est-ce que vous écoutez la radio le matin ?", "words": [114, 115, 116, 117, 118, 119, 120, 121, 122, 123]}, {"id": 20, "text": "Oui, j'allume la radio pour écouter les informations / les nouvelles.", "words": [124, 125, 126, 127, 128, 129, 130, 131, 132, 133, 134]}, {"id": 21, "text": "- Qu'est-ce que vous faites, quand vous rentrez le soir ?", "words": [135, 136, 137, 138, 139, 140, 141, 142, 143, 144, 145]}, {"id": 22, "text": "- D'abord, j'ouvre mon courrier.", "words": [146, 147, 148, 149, 150]}, {"id": 23, "text": "Ensuite, je passe du temps sur", "words": [151, 152, 153, 154, 155, 156]}, {"id": 24, "text": "mon ordinateur !", "words": [157, 158, 159]}, {"id": 25, "text": "Je lis les journaux sur Internet, je regarde/lis mes mails (= courriers électroniques).", "words": [160, 161, 162, 163, 164, 165, 166, 167, 168, 169, 170, 171, 172]}, {"id": 26, "text": "Bien sûr, je consulte mon répondeur", "words": [173, 174, 175, 176, 177, 178]}, {"id": 27, "text": "(= j'écoute les messages), je passe quelques coups de fil* (= je téléphone à des personnes).", "words": [179, 180, 181, 182, 183, 184, 185, 186, 187, 188, 189, 190, 191, 192, 193, 194]}, {"id": 28, "text": "- Quand est-ce que vous faites les courses ?", "words": [195, 196, 197, 198, 199, 200, 201, 202, 203]}, {"id": 29, "text": "(voir chapitre 13)", "words": [204, 205, 206]}, {"id": 30, "text": "- Le samedi, en général.", "words": [207, 208, 209, 210, 211]}, {"id": 31, "text": "Qui fait le ménage à la maison, vous ou Léa ?", "words": [212, 213, 214, 215, 216, 217, 218, 219, 220, 221, 222]}, {"id": 32, "text": "- Euh...", "words": [223, 224]}, {"id": 33, "text": "Nous deux, bien sûr !", "words": [225, 226, 227, 228, 229]}, {"id": 34, "text": "58 cinquante-huit", "words": [230, 231]}]}