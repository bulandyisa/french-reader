, {"id": 14, "text": "il joue à un jeu vidéo.", "words": [84, 85, 86, 87, 88, 89]}, {"id": 15, "text": "Séverine joue avec ses jouets.", "words": [90, 91, 92, 93, 94]}, {"id": 16, "text": "— Qu'est-ce que Séverine a, comme", "words": [95, 96, 97, 98, 99, 100]}, {"id": 17, "text": "jouets ?", "words": [101, 102]}, {"id": 18, "text": "€ - Des poupées, des petites voitures, OMS k R RES", "words": [103, 104, 105, 106, 107, 108, 109, 110, 111, 112, 113]}, {"id": 19, "text": "un train électrique.", "words": [114, 115, 116]}, {"id": 20, "text": "|", "words": [117]}, {"id": 21, "text": "- Elle joue souvent à la poupée ?", "words": [118, 119, 120, 121, 122, 123, 124, 125]}, {"id": 22, "text": "— Oh oui, et elle bien!", "words": [126, 127, 128, 129, 130, 131]}, {"id": 23, "text": ">” <", "words": [132, 133]}, {"id": 24, "text": "+ Est-ce que vous aimez les jeux de société ?", "words": [134, 135, 136, 137, 138, 139, 140, 141, 142, 143]}, {"id": 25, "text": "- Oui, j'aime bien jouer aux cartes et aux échecs.", "words": [144, 145, 146, 147, 148, 149, 150, 151, 152, 153]}, {"id": 26, "text": "Est-ce que vous êtes bonne joueuse ?", "words": [154, 155, 156, 157, 158, 159, 160]}, {"id": 27, "text": "- Oui, ça m'est égal de gagner ou de perdre une partie, mais mon ami est très mauvais joueur : il déteste perdre!", "words": [161, 162, 163, 164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174, 175, 176, 177, 178, 179, 180, 181, 182, 183]}, {"id": 28, "text": "- Et vous, madame, est-ce que vous jouez aux cartes ?", "words": [184, 185, 186, 187, 188, 189, 190, 191, 192, 193, 194]}, {"id": 29, "text": "- Non, moi je préfère jouer au Scrabble® et faire des mots croisés, j'adore ça.", "words": [195, 196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209]}, {"id": 30, "text": "- Et vous, monsieur ?", "words": [210, 211, 212, 213, 214]}, {"id": 31, "text": "- Moi, je joue seulement au Loto, de temps en temps.", "words": [215, 216, 217, 218, 219, 220, 221, 222, 223, 224, 225]}, 