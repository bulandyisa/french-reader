rès sympa.", "words": [210, 211]}, {"id": 63, "text": "7.", "words": [212]}, {"id": 64, "text": "Elle n'aime pas parler, elle est g.", "words": [213, 214, 215, 216, 217, 218, 219]}, {"id": 65, "text": "nerveux.", "words": [220]}, {"id": 66, "text": "2 Replacez les mots suivants dans le dialogue.", "words": [221, 222, 223, 224, 225, 226, 227, 228]}, {"id": 67, "text": "caractère sérieux - optimiste - sympa - adorable - réservé - chouette", "words": [229, 230, 231, 232, 233, 234, 235, 236, 237, 238, 239, 240]}, {"id": 68, "text": "1.", "words": [241]}, {"id": 69, "text": "- Comment est Thierry ?", "words": [242, 243, 244, 245, 246]}, {"id": 70, "text": "2.", "words": [247]}, {"id": 71, "text": "-Ilest plutôt , iln'aime pas beaucoup parler.", "words": [248, 249, 250, 251, 252, 253, 254]}, {"id": 72, "text": "3.", "words": [255]}, {"id": 73, "text": "— Est-ce qu'il est ?", "words": [256, 257, 258, 259, 260]}, {"id": 74, "text": "4, — Oui, il est très , Mais un peu trop , il travaille tout le temps!", "words": [261, 262, 263, 264, 265, 266, 267, 268, 269, 270, 271, 272, 273, 274, 275, 276, 277]}, {"id": 75, "text": "5.", "words": [278]}, {"id": 76, "text": "— Et Barbara ?", "words": [279, 280, 281, 282]}, {"id": 77, "text": "6.", "words": [283]}, {"id": 78, "text": "- Elle est vraiment !", "words": [284, 285, 286, 287, 288]}, {"id": 79, "text": "Elle a très bon et elle voit toujours", "words": [289, 290, 291, 292, 293, 294, 295, 296]}, {"id": 80, "text": "le bon côté des choses.", "words": [297, 298, 299, 300, 301]}, {"id": 81, "text": "C'est quelqu'un d’", "words": [302, 303, 304]}, {"id": 82, "text": "Tests 32 à 35 > vingt-cinq + 25", "words": [305, 306, 307, 308, 309, 310, 311, 312]}]}