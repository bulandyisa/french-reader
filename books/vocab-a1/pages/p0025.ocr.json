4, 5, 6, 7, 8, 9, 10]}, {"id": 2, "text": "LE CARACTÈRE", "words": [11, 12]}, {"id": 3, "text": "12 Choisissez la bonne réponse.", "words": [13, 14, 15, 16, 17]}, {"id": 4, "text": "1.", "words": [18]}, {"id": 5, "text": "Est-ce qu'il est optimiste ?", "words": [19, 20, 21, 22, 23]}, {"id": 6, "text": "4.", "words": [24]}, {"id": 7, "text": "Est-ce qu'il est timide ?", "words": [25, 26, 27, 28, 29]}, {"id": 8, "text": "a.", "words": [30]}, {"id": 9, "text": "Oui, il voit le bon côté des choses.", "words": [31, 32, 33, 34, 35, 36, 37, 38]}, {"id": 10, "text": "a.", "words": [39]}, {"id": 11, "text": "Oui, il n'aime pas parler.", "words": [40, 41, 42, 43, 44]}, {"id": 12, "text": "b.", "words": [45]}, {"id": 13, "text": "Oui, il parle beaucoup.", "words": [46, 47, 48, 49]}, {"id": 14, "text": "b.", "words": [50]}, {"id": 15, "text": "Non, il est sérieux.", "words": [51, 52, 53, 54]}, {"id": 16, "text": "2.", "words": [55]}, {"id": 17, "text": "Est-ce qu'elle est calme ?", "words": [56, 57, 58, 59, 60]}, {"id": 18, "text": "5.", "words": [61]}, {"id": 19, "text": "Est-ce qu'elle est sympa ?", "words": [62, 63, 64, 65, 66]}, {"id": 20, "text": "a.", "words": [67]}, {"id": 21, "text": "Non, c'est quelqu'un de calme.", "words": [68, 69, 70, 71, 72]}, {"id": 22, "text": "a.", "words": [73]}, {"id": 23, "text": "Oui, c'est quelqu'un de sympa.", "words": [74, 75, 76, 77, 78]}, {"id": 24, "text": "b.", "words": [79]}, {"id": 25, "text": "Non, c'est quelqu'un de nerveux.", "words": [80, 81, 82, 83, 84]}, {"id": 26, "text": "b.", "words": [85]}, {"id": 27, "text": "Non, elle est chouette.", "words": [86, 87, 88, 89]}, {"id": 28, "text": "3.", "words": [90]}, {"id": 29, "text": "Est-ce qu'elle parle beaucoup ?", "words": [91, 92, 93, 94, 95]}, {"id": 30, "text": "6.", "words": [96]}, {"id": 31, "text": "Est-ce qu'il a bon caractère ?", "words": [97, 98, 99, 100, 101, 102]}, {"id": 32, "text": "a.", "words": [103]}, {"id": 33, "text": "Oui, elle est très bavarde.", "words": [104,