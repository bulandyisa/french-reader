 [68, 69, 70, 71]}, {"id": 11, "text": "Remarque : On utilise le système officiel de 24 heures à la radio, à la télévision, pour les rendez- vous, les horaires de train, d'avion : Le train part à 14h47.", "words": [72, 73, 74, 75, 76, 77, 78, 79, 80, 81, 82, 83, 84, 85, 86, 87, 88, 89, 90, 91, 92, 93, 94, 95, 96, 97, 98, 99, 100, 101, 102]}, {"id": 12, "text": "Mon avion arrive à 20h25.", "words": [103, 104, 105, 106, 107]}, {"id": 13, "text": "Dans la vie courante, on utilise le système de 12 heures.", "words": [108, 109, 110, 111, 112, 113, 114, 115, 116, 117, 118]}, {"id": 14, "text": "S'il y a un risque de confusion, on ajoute « du matin » ou « du soir»:", "words": [119, 120, 121, 122, 123, 124, 125, 126, 127, 128, 129, 130, 131, 132, 133, 134, 135]}, {"id": 15, "text": "- À quelle heure est-ce que tu pars ?", "words": [136, 137, 138, 139, 140, 141, 142, 143, 144]}, {"id": 16, "text": "- À quelle heure tu t'es couché ?", "words": [145, 146, 147, 148, 149, 150, 151, 152]}, {"id": 17, "text": "- À huit heures du soir.", "words": [153, 154, 155, 156, 157, 158]}, {"id": 18, "text": "- À trois heures du matin!", "words": [159, 160, 161, 162, 163, 164]}, {"id": 19, "text": "LA DURÉE", "words": [165, 166]}, {"id": 20, "text": "J'ai passé.", "words": [167, 168]}, {"id": 21, "text": "un quart d'heure (= 15 minutes).", "words": [169, 170, 171, 172, 173, 174]}, {"id": 22, "text": "une demi-heure (= 30 minutes).", "words": [175, 176, 177, 178, 179]}, {"id": 23, "text": "trois quarts d’heure (= 45 minutes).", "words": [180, 181, 182, 183, 184, 185]}, {"id": 24, "text": "toute la toute la soirée.", "words": [186, 187, 188, 189, 190]}, {"id": 25, "text": "à étudier le français!", "words": [191, 192, 193, 194]}, {"id": 26, "text": "Remarque : Notez l'expression « passer du temps à faire quelque chose »: J'ai passé la journée à lire.", "words": [195, 196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210, 211, 212, 213]}, {"id": 27, "text": "Il a passé deux heures à téléphoner.", "words": [214, 215, 216, 217, 218, 219, 220]}, {"id": 28, "text": "QUELQUES OBJETS", "words": [221, 222]}, {"id": 29, "text": "une montre un agenda un réveil une pendule", "words": [223, 224, 225, 226, 227, 228, 229, 230]}, {"id": 30, "text": "82 e quatre-vingt-deux", "words": [231, 232, 233]}]}