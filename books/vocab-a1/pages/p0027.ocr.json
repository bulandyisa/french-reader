 20, 21]}, {"id": 5, "text": ".", "words": [22]}, {"id": 6, "text": "Est-ce ce qu'elle est intelligente ?", "words": [23, 24, 25, 26, 27, 28]}, {"id": 7, "text": ".", "words": [29]}, {"id": 8, "text": "Est-ce qu'il est méchant ?", "words": [30, 31, 32, 33, 34]}, {"id": 9, "text": ".", "words": [35]}, {"id": 10, "text": "Est-ce qu'elle est chaleureuse ?", "words": [36, 37, 38, 39, 40]}, {"id": 11, "text": ".", "words": [41]}, {"id": 12, "text": "Est-ce qu'il est modeste ?", "words": [42, 43, 44, 45, 46]}, {"id": 13, "text": ".", "words": [47]}, {"id": 14, "text": "Est-ce qu'elle est franche ?", "words": [48, 49, 50, 51, 52]}, {"id": 15, "text": "BB WU N —", "words": [53, 54, 55, 56]}, {"id": 16, "text": ".", "words": [57]}, {"id": 17, "text": "Est-ce qu'elle est paresseuse ?", "words": [58, 59, 60, 61, 62]}, {"id": 18, "text": "22 Choisissez la bonne réponse.", "words": [63, 64, 65, 66, 67]}, {"id": 19, "text": "1.", "words": [68]}, {"id": 20, "text": "Il n'accepte pas les opinions des autres, il est", "words": [69, 70, 71, 72, 73, 74, 75, 76, 77]}, {"id": 21, "text": ".", "words": [78]}, {"id": 22, "text": "Elle dit toujours la vérité, elle est", "words": [79, 80, 81, 82, 83, 84, 85]}, {"id": 23, "text": ".", "words": [86]}, {"id": 24, "text": "Elle fait beaucoup de cadeaux, elle est", "words": [87, 88, 89, 90, 91, 92, 93]}, {"id": 25, "text": "— Non, elle est — Non, — Non, elle est — Non, il est — Non, elle est", "words": [94, 95, 96, 97, 98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 111]}, {"id": 26, "text": "— Non, elle est", "words": [112, 113, 114, 115]}, {"id": 27, "text": "hypocrite | intolérant | froid |.", "words": [116, 117, 118, 119, 120, 121]}, {"id": 28, "text": "sociable", "words": [122]}, {"id": 29, "text": "douce |", "words": [123, 124]}, {"id": 30, "text": "patiente | méchante franche |.", "words": [125, 126, 127, 128, 129]}, {"id": 31, "text": ".", "words": [130]}, {"id": 32, "text": "Ils ne sont pas modestes, ils sont", "words": [131, 132, 133, 134, 135, 136, 137]}, {"id": 33, "text": "impatients | intolérants | prétentieux |.", "words": [138, 139, 140, 141, 142, 143]}, {"id": 34, "text": ".", "words": [144]}, {"id": 35, "text": "Cet animal n'est pas gentil, il est", "words": [145, 146, 147, 148, 149, 150, 151]}, {"id": 36, "text": "BR WW", "words": [152, 153]}, {"id": 37, "text": "bête", "words": [154]}, {"id": 38, "text": "méchant", "words": [155]}, {"id": 39, "text": "paresseux |.", "words": [156, 157]}, {"id": 40, "text": ".", "words": [158]}, {"id": 41, "text": "Elle communique facilement, elle est", "words": [159, 160, 161, 162, 163]}, {"id": 42, "text": "égoiste", "words": [164]}, {"id": 43, "text": "honnête | sociable |.", "words": [165, 166, 167, 168]}, {"id": 44, "text": "Choisissez, parmi les qualités et les défauts suivants, celle ou celui qui correspond le mieux", "words": [169, 170, 171, 172, 173, 174, 175, 176, 177, 178, 179, 180, 181, 182, 183]}, {"id": 45, "text": "à chaque situation.", "words": [184, 185, 186]}, {"id": 46, "text": "franchise — hypocrisie - égoïsme - froideur — culture - bêtise - générosité - modestie impatience - sensibilité — paresse - intelligence", "words": [187, 188, 189, 190, 191, 192, 193, 194, 195, 196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208]}, {"id": 47, "text": "0 BB WW —", "words": [209, 210, 211, 212]}, {"id": 48, "text": ".", "words": [213]}, {"id": 49, "text": "Il a eu le prix Nobel de médecine.", "words": [214, 215, 216, 217, 218, 219, 220, 221]}, {"id": 50, "text": ".", "words": [222]}, {"id": 51, "text": "Elle n'a pas beaucoup d'argent, mais elle a offert un beau cadeau à ses parents.", "words": [223, 224, 225, 226, 227, 228, 229, 230, 231, 232, 233, 234, 235, 236, 237]}, {"id": 52, "text": ".", "words": [238]}, {"id": 53, "text": "Comme sa femme était en retard de deux minutes, il n'a pas attendu.", "words": [239, 240, 241, 242, 243, 244, 245, 246, 247, 248, 249, 250, 251]}, {"id": 54, "text": ".", "words": [252]}, {"id": 55, "text": "Elle connaît très bien la littérature, la musique, l'art.", "words": [253, 254, 255, 256, 257, 258, 259, 260, 261]}, {"id": 56, "text": ".", "words": [262]}, {"id": 57, "text": "Paul n'a rien dit à personne, mais il a réussi son examen brillamment.", "words": [263, 264, 265, 266, 267, 268, 269, 270, 271, 272, 273, 274, 275]}, {"id": 58, "text": ".", "words": [276]}, {"id": 59, "text": "Chloé est toujours gentille, mais elle ne dit jamais la vérité.", "words": [277, 278, 279, 280, 281, 282, 283, 284, 285, 286, 287]}, {"id": 60, "text": ".", "words": [288]}, {"id": 61, "text": "Didier ne veut jamais travailler.", "words": [289, 290, 291, 292, 293]}, {"id": 62, "text": "0 4 2 Vous parlez du caractère d'une personne que vous détestez.", "words": [294, 295, 296, 297, 298, 299, 300, 301, 302, 303, 304, 305]}, {"id": 63, "text": "Quels sont ses défauts ?", "words": [306, 307, 308, 309, 310]}, {"id": 64, "text": "Vous parlez de votre meilleur(e) ami(e).", "words": [311, 312, 313, 314, 315, 316]}, {"id": 65, "text": "Quelles sont ses (grandes !)", "words": [317, 318, 319, 320, 321]}, {"id": 66, "text": "qualités.", "words": [322]}, {"id": 67, "text": "et ses petits défauts ?", "words": [323, 324, 325, 326, 327]}, {"id": 68, "text": "62 Vous parlez de votre caractère, par exemple à un responsable des Ressources humaines.", "words": [328, 329, 330, 331, 332, 333, 334, 335, 336, 337, 338, 339, 340, 341]}, {"id": 69, "text": "Quels sont vos points forts et vos points faibles ?", "words": [342, 343, 344, 345, 346, 347, 348, 349, 350, 351]}, {"id": 70, "text": "Faites le dialogue.", "words": [352, 353, 354]}, {"id": 71, "text": "Tests 36 à 39", "words": [355, 356, 357, 358]}, {"id": 72, "text": "vingt-sept + 27", "words": [359, 360, 361]}]}