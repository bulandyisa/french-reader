t": "113", "x": 1604, "y": 2345, "w": 51, "h": 28, "conf": 96.0, "block": 11, "par": 1, "line": 1, "i": 228}], "sentences": [{"id": 0, "text": "LA GÉOGRAPHIE - LA FRANCOPHONIE", "words": [0, 1, 2, 3, 4]}, {"id": 1, "text": "Vrai ou faux ?", "words": [5, 6, 7, 8]}, {"id": 2, "text": "VRAI FAUX 1.", "words": [9, 10, 11]}, {"id": 3, "text": "La France a une frontière avec l'Autriche.", "words": [12, 13, 14, 15, 16, 17, 18]}, {"id": 4, "text": "2.", "words": [19]}, {"id": 5, "text": "Les Pyrénées sont au sud de la France.", "words": [20, 21, 22, 23, 24, 25, 26, 27]}, {"id": 6, "text": "3.", "words": [28]}, {"id": 7, "text": "La Normandie est un département.", "words": [29, 30, 31, 32, 33]}, {"id": 8, "text": "4.", "words": [34]}, {"id": 9, "text": "Les provinciaux habitent tous en Provence.", "words": [35, 36, 37, 38, 39, 40]}, {"id": 10, "text": "5.", "words": [41]}, {"id": 11, "text": "La Loire est un fleuve.", "words": [42, 43, 44, 45, 46]}, {"id": 12, "text": "6.", "words": [47]}, {"id": 13, "text": "La Corse est une île.", "words": [48, 49, 50, 51, 52]}, {"id": 14, "text": "7.", "words": [53]}, {"id": 15, "text": "Strasbourg se trouve à l'ouest de la France.", "words": [54, 55, 56, 57, 58, 59, 60, 61]}, {"id": 16, "text": "Choisissez la bonne réponse.", "words": [62, 63, 64, 65]}, {"id": 17, "text": "1.", "words": [66]}, {"id": 18, "text": "La Seine est [un fleuve | une île].", "words": [67, 68, 69, 70, 71, 72, 73, 74]}, {"id": 19, "text": "2.", "words": [75]}, {"id": 20, "text": "L'Italie est de l'Europe.", "words": [76, 77, 78, 79]}, {"id": 21, "text": "3.", "words": [80]}, {"id": 22, "text": "Paris est de la France.", "words": [81, 82, 83, 84, 85]}, {"id": 23, "text": "4.", "words": [86]}, {"id": 24, "text": "L'Espagne est d'Europe.", "words": [87, 88, 89]}, {"id": 25, "text": "5.", "words": [90]}, {"id": 26, "text": "Grant est américain, il vient [ du Canada | des États-Unis].", "words": [91, 92, 93, 94, 95, 96, 97, 98, 99, 100, 101]}, {"id": 27, "text": "Compl