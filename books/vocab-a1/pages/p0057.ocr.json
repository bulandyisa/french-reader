: 15, "par": 1, "line": 1, "i": 297}], "sentences": [{"id": 0, "text": "LA MAISON - LE LOGEMENT", "words": [0, 1, 2, 3, 4]}, {"id": 1, "text": "EE Dans quelle(e) pièce(e) de la maison", "words": [5, 6, 7, 8, 9, 10, 11]}, {"id": 2, "text": "1.", "words": [12]}, {"id": 3, "text": "un canapé ?", "words": [13, 14, 15]}, {"id": 4, "text": "6.", "words": [16]}, {"id": 5, "text": "un lit ?", "words": [17, 18, 19]}, {"id": 6, "text": "2.", "words": [20]}, {"id": 7, "text": "un évier ?", "words": [21, 22, 23]}, {"id": 8, "text": "7.", "words": [24]}, {"id": 9, "text": "un oreiller ?", "words": [25, 26, 27]}, {"id": 10, "text": "3.", "words": [28]}, {"id": 11, "text": "un lavabo ?", "words": [29, 30, 31]}, {"id": 12, "text": "8.", "words": [32]}, {"id": 13, "text": "une douche ?", "words": [33, 34, 35]}, {"id": 14, "text": "4.", "words": [36]}, {"id": 15, "text": "un four ?", "words": [37, 38, 39]}, {"id": 16, "text": "9.", "words": [40]}, {"id": 17, "text": "un coussin ?", "words": [41, 42, 43]}, {"id": 18, "text": "5.", "words": [44]}, {"id": 19, "text": "un frigo ?", "words": [45, 46, 47]}, {"id": 20, "text": "10.", "words": [48]}, {"id": 21, "text": "un fauteuil ?", "words": [49, 50, 51]}, {"id": 22, "text": "ED Répondez par le contraire.", "words": [52, 53, 54, 55, 56]}, {"id": 23, "text": "1.", "words": [57]}, {"id": 24, "text": "- Est-ce qu'il ouvre la porte ?", "words": [58, 59, 60, 61, 62, 63, 64]}, {"id": 25, "text": "- Non, il la", "words": [65, 66, 67, 68]}, {"id": 26, "text": "2.", "words": [69]}, {"id": 27, "text": "- Est-ce qu'elle allume la lumière ?", "words": [70, 71, 72, 73, 74, 75, 76]}, {"id": 28, "text": "- Non, elle", "words": [77, 78, 79]}, {"id": 29, "text": "3.", "words": [80]}, {"id": 30, "text": "- Est-ce qu'il est propriétaire de son appartement ?", "words": [81, 82, 83, 84, 85, 86, 87, 88, 89]}, {"id": 31, "text": "- Non, il est 4.", "words": [90, 91, 92, 93, 94]}, {"id": 32, "text": "— Est-ce qu'elle sort, ce soir ?", "words": [95, 96, 97, 98, 99, 100, 101]}, {"id": 33, "text": "- Non, elle", "words": [102, 103, 104]}, {"id": 34, "text": "5.", "words": [105]}, {"id": 35, "text": "- Est-ce que l'ascenseur descend ?- Non, il", "words": [106, 107, 108, 109, 110, 111, 112, 113]}, {"id": 36, "text": "€» Choisissez la meilleure explication.", "words": [114, 115, 116, 117, 118]}, {"id": 37, "text": "1.", "words": [119]}, {"id": 38, "text": "Il'est propriétaire d'une maison.", "words": [120, 121, 122, 123]}, {"id": 39, "text": "Il paye un loyer", "words": [124, 125, 126, 127]}, {"id": 40, "text": "Il a acheté une maison.", "words": [128, 129, 130, 131, 132]}, {"id": 41, "text": "2.", "words": [133]}, {"id": 42, "text": "Elle reste chez elle.", "words": [134, 135, 136, 137]}, {"id": 43, "text": "Elle ne sort pas.", "words": [138, 139, 140, 141]}, {"id": 44, "text": ".", "words": [142]}, {"id": 45, "text": "Elle est fatiguée.", "words": [143, 144, 145]}, {"id": 46, "text": "3.", "words": [146]}, {"id": 47, "text": "Ils vont déménager.", "words": [147, 148, 149]}, {"id": 48, "text": "Ils vont acheter une maison.", "words": [150, 151, 152, 153, 154]}, {"id": 49, "text": ".", "words": [155]}, {"id": 50, "text": "Ils vont changer de maison.", "words": [156, 157, 158, 159, 160]}, {"id": 51, "text": "Elle descend l'escalier.", "words": [161, 162, 163]}, {"id": 52, "text": ".", "words": [164]}, {"id": 53, "text": "Elle ne prend pas l'ascenseur.", "words": [165, 166, 167, 168, 169]}, {"id": 54, "text": "4.", "words": [170]}, {"id": 55, "text": "Elle prend l'escalier.", "words": [171, 172, 173]}, {"id": 56, "text": "5, Il sonne à la porte.", "words": [174, 175, 176, 177, 178, 179]}, {"id": 57, "text": "Il frappe à la porte.", "words": [180, 181, 182, 183, 184]}, {"id": 58, "text": "p œ", "words": [185, 186]}, {"id": 59, "text": "La sonnette marche.", "words": [187, 188, 189]}, {"id": 60, "text": "€» À vous !", "words": [190, 191, 192, 193]}, {"id": 61, "text": "Répondez librement aux questions par des phrases complètes.", "words": [194, 195, 196, 197, 198, 199, 200, 201]}, {"id": 62, "text": "1.", "words": [202]}, {"id": 63, "text": "Est-ce que vous habitez dans une maison ou un appartement ?", "words": [203, 204, 205, 206, 207, 208, 209, 210, 211, 212, 213]}, {"id": 64, "text": "2.", "words": [214]}, {"id": 65, "text": "Est-ce que vous êtes locataire ou propriétaire ?", "words": [215, 216, 217, 218, 219, 220, 221, 222]}, {"id": 66, "text": "3.", "words": [223]}, {"id": 67, "text": "Comment est votre chambre ?", "words": [224, 225, 226, 227, 228]}, {"id": 68, "text": "4, Est-ce que vous préférez vivre dans une habitation ancienne ou moderne ?", "words": [229, 230, 231, 232, 233, 234, 235, 236, 237, 238, 239, 240, 241]}, {"id": 69, "text": "Pourquoi ?", "words": [242, 243]}, {"id": 70, "text": "5.", "words": [244]}, {"id": 71, "text": "Est-ce que vous voulez déménager ?", "words": [245, 246, 247, 248, 249, 250]}, {"id": 72, "text": "Pourquoi ?", "words": [251, 252]}, {"id": 73, "text": "6.", "words": [253]}, {"id": 74, "text": "En général, est-ce que vous recevez souvent des amis à la maison ?", "words": [254, 255, 256, 257, 258, 259, 260, 261, 262, 263, 264, 265, 266]}, {"id": 75, "text": "7.", "words": [267]}, {"id": 76, "text": "Le week-end, vous sortez beaucoup ou vous restez à la maison ?", "words": [268, 269, 270, 271, 272, 273, 274, 275, 276, 277, 278, 279]}, {"id": 77, "text": "Décrivez en détail la maison ou l'appartement de vos rêves !", "words": [280, 281, 282, 283, 284, 285, 286, 287, 288, 289, 290]}, {"id": 78, "text": "Tests 90 à 92 cinquante-sept + 57", "words": [291, 292, 293, 294, 295, 296, 297]}]}