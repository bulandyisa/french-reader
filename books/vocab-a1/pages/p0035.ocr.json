d": 19, "text": "Jules est très fort et très sportif, il a des développés.", "words": [58, 59, 60, 61, 62, 63, 64, 65, 66, 67, 68]}, {"id": 20, "text": "2.", "words": [69]}, {"id": 21, "text": "Michel est pianiste, il a des grandes et souples.", "words": [70, 71, 72, 73, 74, 75, 76, 77, 78]}, {"id": 22, "text": "3.", "words": [79]}, {"id": 23, "text": "Dora travaille dans la parfumerie, son lui permet de sentir les parfums.", "words": [80, 81, 82, 83, 84, 85, 86, 87, 88, 89, 90, 91]}, {"id": 24, "text": "4.", "words": [92]}, {"id": 25, "text": "François goûte les vins, il utilise sa", "words": [93, 94, 95, 96, 97, 98, 99]}, {"id": 26, "text": "5.", "words": [100]}, {"id": 27, "text": "Lætitia est coiffeuse, elle travaille sur les de ses clients.", "words": [101, 102, 103, 104, 105, 106, 107, 108, 109, 110]}, {"id": 28, "text": "6.", "words": [111]}, {"id": 29, "text": "Colombe fait beaucoup de jogging, elle a les très musclées.", "words": [112, 113, 114, 115, 116, 117, 118, 119, 120, 121]}, {"id": 30, "text": "C4 2 Vrai ou faux ?", "words": [122, 123, 124, 125, 126, 127]}, {"id": 31, "text": "VRAI FAUX 1.", "words": [128, 129, 130]}, {"id": 32, "text": "Nous avons deux yeux.", "words": [131, 132, 133, 134]}, {"id": 33, "text": "2.", "words": [135]}, {"id": 34, "text": "Il y a dix doigts à une main.", "words": [136, 137, 138, 139, 140, 141, 142, 143]}, {"id": 35, "text": "3.", "words": [144]}, {"id": 36, "text": "Nous avons deux mains et deux bras.", "words": [145, 146, 147, 148, 149, 150, 151]}, {"id": 37, "text": "4.", "words": [152]}, {"id": 38, "text": "L'estomac est à l'extérieur du corps.", "words": [153, 154, 155, 156, 157, 158]}, {"id": 39, "text": "5.", "words": [159]}, {"id": 40, "text": "Les dents sont dans la bouche.", "words": [160, 161, 162, 163, 164, 165]}, {"id": 41, "text": "6", "words": [166]}, {"id": 42, "text": "R", "words": [167]}, {"id": 43, "text": ".", "words": [168]}, {"id": 44, "text": "Les cheveux sont sur les bras.", "words": [169, 170, 171, 172, 173, 174]}, {"id": 45, "text": "Tests 52 à 54 trente-cinq 35", "words": [175, 176, 177, 178, 179, 180]}]}