d": 1, "text": "EE X", "words": [7, 8]}, {"id": 2, "text": "EP Éliminez l'intrus.", "words": [9, 10, 11]}, {"id": 3, "text": "(1 =) .", "words": [12, 13, 14]}, {"id": 4, "text": "poster / envoyer / recevoir v", "words": [15, 16, 17, 18, 19, 20]}, {"id": 5, "text": ".", "words": [21]}, {"id": 6, "text": "lettre / paquet / colis", "words": [22, 23, 24, 25, 26]}, {"id": 7, "text": ".", "words": [27]}, {"id": 8, "text": "adresse / poste / code postal", "words": [28, 29, 30, 31, 32, 33]}, {"id": 9, "text": ".", "words": [34]}, {"id": 10, "text": "expéditeur / destinataire / facteur .", "words": [35, 36, 37, 38, 39, 40]}, {"id": 11, "text": "annuaire / carnet / Pages jaunes", "words": [41, 42, 43, 44, 45, 46]}, {"id": 12, "text": ".", "words": [47]}, {"id": 13, "text": "colis / tampon / timbre", "words": [48, 49, 50, 51, 52]}, {"id": 14, "text": "NO UE —", "words": [53, 54, 55]}, {"id": 15, "text": ".", "words": [56]}, {"id": 16, "text": "prioritaire / économique / postal", "words": [57, 58, 59, 60, 61]}, {"id": 17, "text": "ED Vrai ou faux?", "words": [62, 63, 64, 65]}, {"id": 18, "text": "VRAI FAUX 1.", "words": [66, 67, 68]}, {"id": 19, "text": "On peut envoyer un paquet en prioritaire.", "words": [69, 70, 71, 72, 73, 74, 75]}, {"id": 20, "text": "2.", "words": [76]}, {"id": 21, "text": "Un carnet de timbres contient cinq timbres.", "words": [77, 78, 79, 80, 81, 82, 83]}, {"id": 22, "text": "3.", "words": [84]}, {"id": 23, "text": "Il a posté le courrier = il a reçu une lettre.", "words": [85, 86, 87, 88, 89, 90, 91, 92, 93, 94, 95]}, {"id": 24, "text": "4.", "words": [96]}, {"id": 25, "text": "On peut ouvrir un compte bancaire à la poste.", "words": [97, 98, 99, 100, 101, 102, 103, 104, 105]}, {"id": 26, "text": "5.", "words": [106]}, {"id": 27, "text": "J'ai du courrier = j'ai reçu du courrier.", "words": [107, 108, 109, 110, 111, 112, 113, 114]}, {"id": 28, "text": "6.", "words": [115]}, {"id": 29, "text": "On met les lettres dans la boîte aux lettres.", "words": [116, 117, 118, 119, 120, 121, 122, 123, 124]}, {"id": 30, "text": "7.", "words": [125]}, {"id": 31, "text": "Le facteur est passé = le courrier est passé.", "words": [126, 127, 128, 129, 130, 131, 132, 133, 134]}, {"id": 32, "text": "Associez, pour constituer de mini-dialogues.", "words": [135, 136, 137, 138, 139]}, {"id": 33, "text": "1.", "words": [140]}, {"id": 34, "text": "Je voudrais envoyer une lettre au Canada, a.", "words": [141, 142, 143, 144, 145, 146, 147, 148]}, {"id": 35, "text": "Tu peux chercher dans l'annuaire.", "words": [149, 150, 151, 152, 153]}, {"id": 36, "text": "2.", "words": [154]}, {"id": 37, "text": "Est-ce que le facteur est passé ?", "words": [155, 156, 157, 158, 159, 160, 161]}, {"id": 38, "text": "b.", "words": [162]}, {"id": 39, "text": "Non, il faut que j'achète un carnet.", "words": [163, 164, 165, 166, 167, 168, 169]}, {"id": 40, "text": "3.", "words": [170]}, {"id": 41, "text": "Tu as reçu du courrier ?", "words": [171, 172, 173, 174, 175, 176]}, {"id": 42, "text": "c.", "words": [177]}, {"id": 43, "text": "En prioritaire ?", "words": [178, 179, 180]}, {"id": 44, "text": "4.", "words": [181]}, {"id": 45, "text": "Je n'ai pas le numéro de téléphone du restaurant.", "words": [182, 183, 184, 185, 186, 187, 188, 189, 190]}, {"id": 46, "text": "d.", "words": [191]}, {"id": 47, "text": "Non, mais je vais le poster aujourd'hui.", "words": [192, 193, 194, 195, 196, 197, 198]}, {"id": 48, "text": "5.", "words": [199]}, {"id": 49, "text": "Tu as envoyé le paquet ?", "words": [200, 201, 202, 203, 204, 205]}, {"id": 50, "text": "e.", "words": [206]}, {"id": 51, "text": "Non, il n'est pas encore passé.", "words": [207, 208, 209, 210, 211, 212]}, {"id": 52, "text": "6.", "words": [213]}, {"id": 53, "text": "Est-ce que tu as des timbres ?", "words": [214, 215, 216, 217, 218, 219, 220]}, {"id": 54, "text": "f.", "words": [221]}, {"id": 55, "text": "Oui, une lettre de Michel.", "words": [222, 223, 224, 225, 226]}, {"id": 56, "text": "ED Complétez par un verbe approprié.", "words": [227, 228, 229, 230, 231, 232]}, {"id": 57, "text": "1.", "words": [233]}, {"id": 58, "text": "J'ai une carte postale à mes amis.", "words": [234, 235, 236, 237, 238, 239, 240]}, {"id": 59, "text": "2.", "words": [241]}, {"id": 60, "text": "En général, le courrier vers 10 heures le matin.", "words": [242, 243, 244, 245, 246, 247, 248, 249, 250]}, {"id": 61, "text": "3.", "words": [251]}, {"id": 62, "text": "Est-ce que vous avez paquet de votre frère?", "words": [252, 253, 254, 255, 256, 257, 258, 259]}, {"id": 63, "text": "4.", "words": [260]}, {"id": 64, "text": "Je dois l'annuaire pour trouver le numéro de téléphone de Luc.", "words": [261, 262, 263, 264, 265, 266, 267, 268, 269, 270, 271]}, {"id": 65, "text": "5.", "words": [272]}, {"id": 66, "text": "Tu dois ta lettre avant 18 heures.", "words": [273, 274, 275, 276, 277, 278, 279]}, {"id": 67, "text": "6.", "words": [280]}, {"id": 68, "text": "voudrait un compte bancaire à la poste.", "words": [281, 282, 283, 284, 285, 286, 287]}, {"id": 69, "text": "Tests 171 à 174", "words": [288, 289, 290, 291]}, {"id": 70, "text": "cent cinq + 105", "words": [292, 293, 294, 295]}]}