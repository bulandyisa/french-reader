67]}, {"id": 13, "text": "- Ah oui !", "words": [68, 69, 70, 71]}, {"id": 14, "text": "Elle est tombée de Guillaume l'année dernière.", "words": [72, 73, 74, 75, 76, 77, 78]}, {"id": 15, "text": "4.", "words": [79]}, {"id": 16, "text": "- Est-ce qu'ils vivent ?", "words": [80, 81, 82, 83, 84]}, {"id": 17, "text": "- Oui, ils ont une maison ensemble.", "words": [85, 86, 87, 88, 89, 90, 91]}, {"id": 18, "text": "Choisissez la bonne réponse.", "words": [92, 93, 94, 95]}, {"id": 19, "text": "1.", "words": [96]}, {"id": 20, "text": "Félix est tombé amoureux | de | avec | Micheline.", "words": [97, 98, 99, 100, 101, 102, 103, 104, 105, 106]}, {"id": 21, "text": ".", "words": [107]}, {"id": 22, "text": "Ils ont une | passion | relation |.", "words": [108, 109, 110, 111, 112, 113, 114, 115]}, {"id": 23, "text": ".", "words": [116]}, {"id": 24, "text": "Ils ne | vivent | se marient | pas encore ensemble.", "words": [117, 118, 119, 120, 121, 122, 123, 124, 125, 126, 127]}, {"id": 25, "text": ".", "words": [128]}, {"id": 26, "text": "Micheline aimerait vivre | ensemble | en couple |.", "words": [129, 130, 131, 132, 133, 134, 135, 136, 137]}, {"id": 27, "text": ".", "words": [138]}, {"id": 28, "text": "Félix ne veut pas | le mariage | se marier |.", "words": [139, 140, 141, 142, 143, 144, 145, 146, 147, 148, 149]}, {"id": 29, "text": ".", "words": [150]}, {"id": 30, "text": "Micheline regarde la robe de | mariage | mariée | de son amie Solange.", "words": [151, 152, 153, 154, 155, 156, 157, 158, 159, 160, 161, 162, 163, 164]}, {"id": 31, "text": "4 BB WW N", "words": [165, 166, 167, 168]}, {"id": 32, "text": ".", "words": [169]}, {"id": 33, "text": "Félix et Micheline vivent | à l'église | une grande passion |.", "words": [170, 171, 172, 173, 174, 175, 176, 177, 178, 179, 180, 181]}, {"id": 34, "text": "Remettez le dialogue suivant dans l'ordre.", "words": [182, 183, 184, 185, 186, 187]}, {"id": 35, "text": "a.", "words": [188]}, {"id": 36, "text": "- Quand est-ce qu'il a quitté Manon ?", "words": [189, 190, 191, 192, 193, 194, 195, 196]}, {"id": 37, "text": "b.", "words": [197]}, {"id": 38, "text": "- Dans un café où j'étais avec des amis.", "words": [198, 199, 200, 201, 202, 203, 204, 205, 206]}, {"id": 39, "text": "c.", "words": [207]}, {"id": 40, "text": "- Et Romain?", "words": [208, 209, 210]}, {"id": 41, "text": "d.", "words": [211]}, {"id": 42, "text": "- Je ne pense pas!", "words": [212, 213, 214, 215, 216]}, {"id": 43, "text": "Je ne suis pas prête pour le mariage!", "words": [217, 218, 219, 220, 221, 222, 223, 224]}, {"id": 44, "text": "e.", "words": [225]}, {"id": 45, "text": "- Où est-ce que tu as rencontré Romain ?", "words": [226, 227, 228, 229, 230, 231, 232, 233, 234]}, {"id": 46, "text": "f.", "words": [235]}, {"id": 47, "text": "- Oui, immédiatement !", "words": [236, 237, 238, 239]}, {"id": 48, "text": "g.", "words": [240]}, {"id": 49, "text": "— Et maintenant, Romain et toi vivez ensemble ?", "words": [241, 242, 243, 244, 245, 246, 247, 248, 249]}, {"id": 50, "text": "h.", "words": [250]}, {"id": 51, "text": "- C'est Manon qui l'a quitté !", "words": [251, 252, 253, 254, 255, 256, 257]}, {"id": 52, "text": "Elle était jalouse de moi!", "words": [258, 259, 260, 261, 262]}, {"id": 53, "text": "i.", "words": [263]}, {"id": 54, "text": "— Vous avez l'intention de vous marier ?", "words": [264, 265, 266, 267, 268, 269, 270, 271]}, {"id": 55, "text": "j.", "words": [272]}, {"id": 56, "text": "Romain était encore amoureux de Manon, à cette époque.", "words": [273, 274, 275, 276, 277, 278, 279, 280, 281]}, {"id": 57, "text": "k.", "words": [282]}, {"id": 58, "text": "— Est-ce que tu es tombée amoureuse tout de suite ?", "words": [283, 284, 285, 286, 287, 288, 289, 290, 291, 292, 293]}, {"id": 59, "text": "1.", "words": [294]}, {"id": 60, "text": "— Oui, nous avons pris un appartement ensemble.", "words": [295, 296, 297, 298, 299, 300, 301, 302]}, {"id": 61, "text": "1.", "words": [303]}, {"id": 62, "text": "_e 2.", "words": [