: 18, "par": 1, "line": 1, "i": 296}, {"text": "+", "x": 1603, "y": 2355, "w": 14, "h": 15, "conf": 68.0, "block": 18, "par": 1, "line": 1, "i": 297}, {"text": "77", "x": 1632, "y": 2348, "w": 35, "h": 28, "conf": 96.0, "block": 18, "par": 1, "line": 1, "i": 298}], "sentences": [{"id": 0, "text": "LA CUISINE - LES REPAS", "words": [0, 1, 2, 3, 4]}, {"id": 1, "text": "a Complétez les mots croisés suivants.", "words": [5, 6, 7, 8, 9, 10]}, {"id": 2, "text": "Horizontalement :", "words": [11, 12]}, {"id": 3, "text": "1.", "words": [13]}, {"id": 4, "text": "C'est rond; on mange dans cet objet.", "words": [14, 15, 16, 17, 18, 19, 20]}, {"id": 5, "text": "2.", "words": [21]}, {"id": 6, "text": "C'est sur la table, c'est blanc ou en couleur.", "words": [22, 23, 24, 25, 26, 27, 28, 29, 30]}, {"id": 7, "text": "3.", "words": [31]}, {"id": 8, "text": "C'est pour mettre le bon vin.", "words": [32, 33, 34, 35, 36, 37]}, {"id": 9, "text": "Verticalement : a.", "words": [38, 39, 40]}, {"id": 10, "text": "C'est posé sur l'assiette,", "words": [41, 42, 43, 44]}, {"id": 11, "text": "c'est de la même couleur que la nappe.", "words": [45, 46, 47, 48, 49, 50, 51, 52]}, {"id": 12, "text": "b.", "words": [53]}, {"id": 13, "text": "C'est pour couper la viande, par exemple.", "words": [54, 55, 56, 57, 58, 59, 60]}, {"id": 14, "text": "c.", "words": [61]}, {"id": 15, "text": "C'est l'objet qu'on utilise pour boire.", "words": [62, 63, 64, 65, 66, 67]}, {"id": 16, "text": "Parmi les objets suivants, identifiez ceux qu'on pose sur la table d'un beau diner.", "words": [68, 69, 70, 71, 72, 73, 74, 75, 76, 77, 78, 79, 80, 81]}, {"id": 17, "text": "une théière - un verre - une casserole - une bouteille de vin - un couteau - une cocotte - une assiette - un bol - une fourchette - une poêle - une passoire à thé", "words": [82, 83, 84, 85, 86, 87, 88, 89, 90, 91, 92, 93, 94, 95, 96, 97, 98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 111, 112, 113, 114, 115, 116, 117]}, {"id": 18, "text": "De quel objet parle-t-on ?", "words": [118, 119, 120, 121, 122]}, {"id": 19, "text": "1.", "words": [123]}, {"id": 20, "text": "Je la pose sur la table, elle est en tissu blanc ou de couleur.", "words": [124, 125, 126, 127, 128, 129, 130, 131, 132, 133, 134, 135, 136, 137]}, {"id": 21, "text": "2.", "words": [138]}, {"id": 22, "text": "me permet d'ouvrir la bouteille de vin.", "words": [139, 140, 141, 142, 143, 144, 145]}, {"id": 23, "text": "3.", "words": [146]}, {"id": 24, "text": "Je la prends pour faire une omelette.", "words": [147, 148, 149, 150, 151, 152, 153]}, {"id": 25, "text": "4.", "words": [154]}, {"id": 26, "text": "Les Français mettent dans cet objet le lait, le café, le chocolat chaud...", "words": [155, 156, 157, 158, 159, 160, 161, 162, 163, 164, 165, 166, 167]}, {"id": 27, "text": "5.", "words": [168]}, {"id": 28, "text": "J'utilise cet objet pour faire une tarte aux pommes, par exemple.", "words": [169, 170, 171, 172, 173, 174, 175, 176, 177, 178, 179]}, {"id": 29, "text": "6.", "words": [180]}, {"id": 30, "text": "Elle est en verre et elle contient de l'eau.", "words": [181, 182, 183, 184, 185, 186, 187, 188, 189]}, {"id": 31, "text": "7.", "words": [190]}, {"id": 32, "text": "Je mets la salade dans cet objet.", "words": [191, 192, 193, 194, 195, 196, 197]}, {"id": 33, "text": "8.", "words": [198]}, {"id": 34, "text": "C'est l'objet destiné au thé.", "words": [199, 200, 201, 202, 203]}, {"id": 35, "text": "2) Associez une personne et l'objet qu'elle cherche.", "words": [204, 205, 206, 207, 208, 209, 210, 211]}, {"id": 36, "text": ".", "words": [212]}, {"id": 37, "text": "Christian prépare la salade.", "words": [213, 214, 215, 216]}, {"id": 38, "text": ".", "words": [217]}, {"id": 39, "text": "un tire-bouchon", "words": [218, 219]}, {"id": 40, "text": "1.", "words": [220]}, {"id": 41, "text": "Claire cherche une bonne recette.", "words": [221, 222, 223, 224, 225]}, {"id": 42, "text": "a.", "words": [226]}, {"id": 43, "text": "un saladier", "words": [227, 228]}, {"id": 44, "text": "2.", "words": [229]}, {"id": 45, "text": "François voudrait boire du lait chaud.", "words": [230, 231, 232, 233, 234, 235]}, {"id": 46, "text": "b.", "words": [236]}, {"id": 47, "text": "une casserole", "words": [237, 238]}, {"id": 48, "text": "3.", "words": [239]}, {"id": 49, "text": "Béatrice boit de l'eau.", "words": [240, 241, 242, 243]}, {"id": 50, "text": "c un moule", "words": [244, 245, 246]}, {"id": 51, "text": "4.", "words": [247]}, {"id": 52, "text": "Michel veut ouvrir une bouteille de vin.", "words": [248, 249, 250, 251, 252, 253, 254]}, {"id": 53, "text": "d.", "words": [255]}, {"id": 54, "text": "un livre de cuisine 5.", "words": [256, 257, 258, 259, 260]}, {"id": 55, "text": "Anne prépare le thé.", "words": [261, 262, 263, 264]}, {"id": 56, "text": "e.", "words": [265]}, {"id": 57, "text": "un bol", "words": [266, 267]}, {"id": 58, "text": "6.", "words": [268]}, {"id": 59, "text": "Lise fait un gâteau au chocolat.", "words": [269, 270, 271, 272, 273, 274]}, {"id": 60, "text": "f.", "words": [275]}, {"id": 61, "text": "une théière", "words": [276, 277]}, {"id": 62, "text": "LL g", "words": [278, 279]}, {"id": 63, "text": "8 h", "words": [280, 281]}, {"id": 64, "text": ".", "words": [282]}, {"id": 65, "text": "Naïma fait cuire des légumes.", "words": [283, 284, 285, 286, 287]}, {"id": 66, "text": ".", "words": [288]}, {"id": 67, "text": "un verre", "words": [289, 290]}, {"id": 68, "text": "Tests 119 à 121 + soixante-dix-sept + 77", "words": [291, 292, 293, 294, 295, 296, 297, 298]}]}