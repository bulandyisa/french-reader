, {"text": "défauts!", "x": 1255, "y": 1761, "w": 124, "h": 29, "conf": 88.0, "block": 19, "par": 1, "line": 1, "i": 314}, {"text": "l'égoïsme,", "x": 1154, "y": 1810, "w": 112, "h": 32, "conf": 66.0, "block": 19, "par": 1, "line": 2, "i": 315}, {"text": "la", "x": 1154, "y": 1904, "w": 18, "h": 23, "conf": 96.0, "block": 19, "par": 2, "line": 1, "i": 316}, {"text": "méchanceté,", "x": 1183, "y": 1902, "w": 150, "h": 28, "conf": 96.0, "block": 19, "par": 2, "line": 1, "i": 317}, {"text": "l'agressivité,", "x": 1154, "y": 1948, "w": 148, "h": 31, "conf": 81.0, "block": 19, "par": 2, "line": 2, "i": 318}, {"text": "l'impatience,", "x": 1154, "y": 1995, "w": 146, "h": 34, "conf": 79.0, "block": 20, "par": 1, "line": 1, "i": 319}, {"text": "la", "x": 1154, "y": 2088, "w": 19, "h": 22, "conf": 96.0, "block": 21, "par": 1, "line": 1, "i": 320}, {"text": "prétention,", "x": 1182, "y": 2085, "w": 132, "h": 35, "conf": 93.0, "block": 21, "par": 1, "line": 1, "i": 321}, {"text": "l'arrogance.", "x": 1325, "y": 2087, "w": 137, "h": 30, "conf": 73.0, "block": 21, "par": 1, "line": 1, "i": 322}, {"text": "26", "x": 247, "y": 2253, "w": 32, "h": 24, "conf": 95.0, "block": 23, "par": 1, "line": 1, "i": 323}, {"text": "vingt-six", "x": 315, "y": 2254, "w": 128, "h": 30, "conf": 96.0, "block": 23, "par": 1, "line": 1, "i": 324}], "sentences": [{"id": 0, "text": "LE CARACTÈRE", "words": [0, 1]}, {"id": 1, "text": "LES QUALITÉS ET LES DÉFAUTS", "words": [2, 3, 4, 5, 6]}, {"id": 2, "text": "+ Que pensez-vous de Bernard Gendron ?", "words": [7, 8, 9, 10, 11, 12, 13]}, {"id": 3, "text": "- C’est un homme intelligent, sérieux et travailleur.", "words": [14, 15, 16, 17, 18, 19, 20, 21]}, {"id": 4, "text": "— Est-ce qu'il communique facilement avec les autres ?", "words": [22, 23, 24, 25, 26, 27, 28, 29, 30]}, {"id": 5, "text": "— Oh oui, il est chaleureux et sociable.", "words": [31, 32, 33, 34, 35, 36, 37, 38]}, {"id": 6, "text": "— Est-ce qu'il accepte les opinions des autres ?", "words": [39, 40, 41, 42, 43, 44, 45, 46, 47]}, {"id": 7, "text": "— Oui, il est très tolérant.", "words": [48, 49, 50, 51, 52, 53]}, {"id": 8, "text": "Il est aussi patient.", "words": [54, 55, 56, 57]}, {"id": 9, "text": "— Vous pensez qu'il est honnête et franc ?", "words": [58, 59, 60, 61, 62, 63, 64, 65, 66]}, {"id": 10, "text": "— Oui, il dit toujours la vérité.", "words": [67, 68, 69, 70, 71, 72, 73]}, {"id": 11, "text": "+ Et que pensez-vous de Raymond Lasalle ?", "words": [74, 75, 76, 77, 78, 79, 80, 81]}, {"id": 12, "text": "- Ah, c'est le contraire de Bernard!", "words": [82, 83, 84, 85, 86, 87, 88]}, {"id": 13, "text": "Je le trouve plutôt bête et paresseux.", "words": [89, 90, 91, 92, 93, 94, 95]}, {"id": 14, "text": "— Comment est-ce qu'il est avec les autres ?", "words": [96, 97, 98, 99, 100, 101, 102, 103, 104]}, {"id": 15, "text": "- Assez froid et intolérant.", "words": [105, 106, 107, 108, 109]}, {"id": 16, "text": "- Vous le trouvez honnête ?", "words": [110, 111, 112, 113, 114, 115]}, {"id": 17, "text": "— Non, à vrai dire, je crois qu'il est assez malhonnête.", "words": [116, 117, 118, 119, 120, 121, 122, 123, 124, 125, 126]}, {"id": 18, "text": "Beaucoup de gens le trouvent aussi hypocrite.", "words": [127, 128, 129, 130, 131, 132, 133]}, {"id": 19, "text": "+ Allez, parle-moi de Fabrice!", "words": [134, 135, 136, 137, 138]}, {"id": 20, "text": "- Oh, il est généreux, tu ne peux pas imaginer!", "words": [139, 140, 141, 142, 143, 144, 145, 146, 147, 148]}, {"id": 21, "text": "Il me fait tout le temps des cadeaux!", "words": [149, 150, 151, 152, 153, 154, 155, 156]}, {"id": 22, "text": "- Alors, il est vraiment gentil ?", "words": [157, 158, 159, 160, 161, 162, 163]}, {"id": 23, "text": "C’est de très sensible, très bon.", "words": [164, 165, 166, 167, 168, 169]}, {"id": 24, "text": "- cultivé, pas ?", "words": [170, 171, 172, 173]}, {"id": 25, "text": "— Oui, mais il reste très modeste sur sa culture.", "words": [174, 175, 176, 177, 178, 179, 180, 181, 182, 183]}, {"id": 26, "text": "Fabrice est bien différent de Thibaut, alors!", "words": [184, 185, 186, 187, 188, 189, 190]}, {"id": 27, "text": "— Oh oui, Thibaut est tellement égoïste !", "words": [191, 192, 193, 194, 195, 196, 197, 198]}, {"id": 28, "text": "Il ne pense qu’à lui.", "words": [199, 200, 201, 202, 203]}, {"id": 29, "text": "- Il n’est pas vraiment méchant ?", "words": [204, 205, 206, 207, 208, 209, 210]}, {"id": 30, "text": "- Non, mais il est agressif.", "words": [211, 212, 213, 214, 215, 216]}, {"id": 31, "text": "Et puis il est trop impatient!", "words": [217, 218, 219, 220, 221, 222]}, {"id": 32, "text": "— Au moins, il est intelligent !", "words": [223, 224, 225, 226, 227, 228, 229]}, {"id": 33, "text": "— Oui, mais il est tellement prétentieux et arrogant!", "words": [230, 231, 232, 233, 234, 235, 236, 237, 238]}, {"id": 34, "text": "Il montre à tout le monde sa supériorité naturelle!", "words": [239, 240, 241, 242, 243, 244, 245, 246, 247]}, {"id": 35, "text": "— Oui, il est adorable, et il est très doux avec les enfants.", "words": [248, 249, 250, 251, 252, 253, 254, 255, 256, 257, 258, 259, 260]}, {"id": 36, "text": "Les qualités de Bernard: l'intelligence, le sérieux", "words": [261, 262, 263, 264, 265, 266, 267]}, {"id": 37, "text": "la chaleur humaine, la sociabilité,", "words": [268, 269, 270, 271, 272]}, {"id": 38, "text": "la tolérance, la patience, l'honnêteté, la franchise.", "words": [273, 274, 275, 276, 277, 278, 279]}, {"id": 39, "text": "Les gros défauts de Raymond: la bêtise, la paresse, la froideur, l'intolérance,", "words": [280, 281, 282, 283, 284, 285, 286, 287, 288, 289, 290, 291]}, {"id": 40, "text": "la malhonnêteté, l'hypocrisie.", "words": [292, 293, 294]}, {"id": 41, "text": "Que de qualités!", "words": [295, 296, 297]}, {"id": 42, "text": "la générosité,", "words": [298, 299]}, {"id": 43, "text": "la gentillesse,", "words": [300, 301]}, {"id": 44, "text": "la douceur,", "words": [302, 303]}, {"id": 45, "text": "la sensibilité, la bonté, la culture,", "words": [304, 305, 306, 307, 308, 309]}, {"id": 46, "text": "la modestie.", "words": [310, 311]}, {"id": 47, "text": "Que de défauts!", "words": [312, 313, 314]}, {"id": 48, "text": "l'égoïsme,", "words": [315]}, {"id": 49, "text": "la méchanceté, l'agressivité,", "words": [316, 317, 318]}, {"id": 50, "text": "l'impatience,", "words": [319]}, {"id": 51, "text": "la prétention, l'arrogance.", "words": [320, 321, 322]}, {"id": 52, "text": "26 vingt-six", "words": [323, 324]}]}