": [49, 50, 51, 52, 53, 54, 55, 56]}, {"id": 17, "text": "5.", "words": [57]}, {"id": 18, "text": "Tu as un problème d'informatique ?", "words": [58, 59, 60, 61, 62, 63]}, {"id": 19, "text": "a.", "words": [64]}, {"id": 20, "text": "Oui, car elle a une adresse électronique.", "words": [65, 66, 67, 68, 69, 70, 71]}, {"id": 21, "text": "Q a.", "words": [72, 73]}, {"id": 22, "text": "Oui, mon écran ne marche pas.", "words": [74, 75, 76, 77, 78, 79]}, {"id": 23, "text": "Q b.", "words": [80, 81]}, {"id": 24, "text": "Oui, car elle a une imprimante.", "words": [82, 83, 84, 85, 86, 87]}, {"id": 25, "text": "Q b.", "words": [88, 89]}, {"id": 26, "text": "Oui, mon mobile ne marche pas.", "words": [90, 91, 92, 93, 94, 95]}, {"id": 27, "text": "Q 3.", "words": [96, 97]}, {"id": 28, "text": "Est-ce que ton mobile est éteint ?", "words": [98, 99, 100, 101, 102, 103, 104]}, {"id": 29, "text": "6.", "words": [105]}, {"id": 30, "text": "Est-ce que tu as reçu mon message ?", "words": [106, 107, 108, 109, 110, 111, 112, 113]}, {"id": 31, "text": "a.", "words": [114]}, {"id": 32, "text": "Oui, il sonne.", "words": [115, 116, 117]}, {"id": 33, "text": "Q a.", "words": [118, 119]}, {"id": 34, "text": "Non, mon répondeur ne marche pas.", "words": [120, 121, 122, 123, 124, 125]}, {"id": 35, "text": "Q b.", "words": [126, 127]}, {"id": 36, "text": "Non, il est allumé.", "words": [128, 129, 130, 131]}, {"id": 37, "text": "Q b.", "words": [132, 133]}, {"id": 38, "text": "Oui, j'ai une messagerie.", "words": [134, 135, 136, 137]}, {"id": 39, "text": "Q", "words": [138]}, {"id": 40, "text": "Quel(s) objet(s) conseillez-vous à ces personnes ?", "words": [139, 140, 141, 142, 143, 144, 145]}, {"id": 41, "text": "1.", "words": [146]}, {"id": 42, "text": "Laure voyage pour ses vacances, mais elle veut être en contact avec sa famille.", "words": [147, 148, 149, 150, 151, 152, 153, 154, 155, 156, 157, 158, 159, 160]}, {"id": 43, "text": "2.", "words": [161]}, {"id": 44, "text": "Bruno doit écrire de